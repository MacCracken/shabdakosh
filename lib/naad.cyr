# naad.cyr -- bundled distribution
# Version: 2.1.1
# Generated by: cyrius distlib
# Do not edit -- rebuild with: cyrius distlib

# --- error.cyr ---

# error.cyr -- naad error codes + shared DSP tolerances and base helpers.
# Usage: included by every build/test entry FIRST; the L0 base module.
# Module files do not `include` each other -- the entry orders them.
#
# Ports rust-old/src/error.rs (NaadError enum + validate_frequency/
# validate_sample_rate) AND the two crate-root helpers from lib.rs that
# the whole crate leans on: flush_denormal + the finite/epsilon tolerances.
# Rust carried a String/f32 payload per error variant; Cyrius uses integer
# codes -- validators return ERR_NONE (0) on success or a negative code on
# failure. Diagnostic strings come from naad_err_name().

# ================================================================
# Error codes (was `enum NaadError`). One per Rust variant.
# ================================================================
var ERR_NONE                = 0;
var ERR_INVALID_FREQUENCY   = (0 - 1);   # frequency out of (0, Nyquist)
var ERR_INVALID_SAMPLE_RATE = (0 - 2);   # sample rate <= 0 or non-finite
var ERR_INVALID_PARAMETER   = (0 - 3);   # a named parameter out of range
var ERR_BUFFER_OVERFLOW     = (0 - 4);   # buffer op exceeded capacity
var ERR_COMPUTATION         = (0 - 5);   # computation produced invalid result

# ================================================================
# Shared f64 tolerances / sentinels (IEEE-754 bit patterns).
# naad's Rust source was f32; the Cyrius port is f64 throughout (hisab's
# HVec3/HComplex are f64-only). NAAD_EPSILON preserves the f32::EPSILON
# (2^-23) guard thresholds the Rust code used, promoted cleanly to f64.
# ================================================================
var NAAD_EPSILON        = 0x3E80000000000000;   # f32::EPSILON = 2^-23 ~ 1.192e-7
var NAAD_POS_INF        = 0x7FF0000000000000;   # +inf
var NAAD_NEG_INF        = 0xFFF0000000000000;   # -inf (naad_amplitude_to_db(<=0))
var NAAD_F32_MIN_POS    = 0x3810000000000000;   # f32::MIN_POSITIVE ~ 1.175e-38

# 1 if `code` is an error (negative), 0 otherwise.
#must_use
fn naad_is_err(code) {
    if (code < 0) { return 1; }
    return 0;
}

# Static name for an error code (for diagnostics / logging).
#must_use
fn naad_err_name(code) {
    if (code == ERR_NONE) { return "none"; }
    if (code == ERR_INVALID_FREQUENCY) { return "invalid frequency"; }
    if (code == ERR_INVALID_SAMPLE_RATE) { return "invalid sample rate"; }
    if (code == ERR_INVALID_PARAMETER) { return "invalid parameter"; }
    if (code == ERR_BUFFER_OVERFLOW) { return "buffer overflow"; }
    if (code == ERR_COMPUTATION) { return "computation error"; }
    return "unknown error";
}

# Finite test: 1 iff x is neither +/-inf nor NaN. abs(x) < +inf holds for
# finite x, fails for infinities (inf < inf is false) and NaN (any NaN
# compare is false). Mirrors Rust `f32::is_finite`.
#must_use
fn naad_is_finite(x) {
    return f64_lt(f64_abs(x), NAAD_POS_INF);
}

# ================================================================
# validate_frequency -- ERR_NONE if in (0, Nyquist) and finite, else
# ERR_INVALID_FREQUENCY. Ports validate_frequency (returns Option<Error>);
# the Rust `warn!` diagnostic is dropped (logging is a separate module).
# ================================================================
#must_use
fn validate_frequency(frequency, sample_rate) {
    var nyquist = f64_mul(sample_rate, F64_HALF);
    if (f64_le(frequency, 0) == 1) { return ERR_INVALID_FREQUENCY; }
    if (f64_ge(frequency, nyquist) == 1) { return ERR_INVALID_FREQUENCY; }
    if (naad_is_finite(frequency) == 0) { return ERR_INVALID_FREQUENCY; }
    return ERR_NONE;
}

# ================================================================
# validate_sample_rate -- ERR_NONE if positive and finite, else
# ERR_INVALID_SAMPLE_RATE. Ports validate_sample_rate.
# ================================================================
#must_use
fn validate_sample_rate(sample_rate) {
    if (f64_le(sample_rate, 0) == 1) { return ERR_INVALID_SAMPLE_RATE; }
    if (naad_is_finite(sample_rate) == 0) { return ERR_INVALID_SAMPLE_RATE; }
    return ERR_NONE;
}

# ================================================================
# flush_denormal -- flush subnormal floats to zero (crate-root helper in
# Rust lib.rs). Denormals cause 10-100x slowdowns on x86; filters and
# feedback paths call this when signals decay to near-zero. Returns +0.0
# if |x| < f32::MIN_POSITIVE, else x unchanged.
# ================================================================
#inline
#must_use
fn flush_denormal(x) {
    if (f64_lt(f64_abs(x), NAAD_F32_MIN_POS) == 1) { return 0; }
    return x;
}

# --- dsp_util.cyr ---

# dsp_util.cyr -- DSP utility free functions: dB conversion, clipping,
# interpolation, windows, PRNG, dB LUT. Shared across synthesis/effects.
#
# Ports rust-old/src/dsp_util.rs. f32 -> f64 throughout. Buffer args that
# were `&[f32]` / `&mut [f32]` become stdlib `vec` handles (f64 per slot).
# The `SmoothingMode` / `SpectralWindow` enums become integer constants.
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_* constants, f64_ln/pow/tanh/sin/cos/sqrt/clamp). No `include` lines.
#
# PENDING (hisab-interop analysis block, tracked in port-audit.md): the
# `synthesis`-gated spectral functions -- fft_magnitudes, power_spectrum,
# stft_magnitudes, chromagram, detect_onsets, detect_pitch_autocorr,
# bspline_eval_1d, fit_polynomial. They wrap hisab num_fft / calc_bspline /
# num_newton / least-squares and land in a dedicated follow-up. The scalar
# core below (which every dependent module actually needs) is complete;
# `eval_polynomial` is pure-f64 and included here.

# ================================================================
# Enums -> integer constants.
# ================================================================
var SMOOTHING_EXPONENTIAL = 0;
var SMOOTHING_LINEAR      = 1;

var WINDOW_RECTANGULAR = 0;
var WINDOW_HANN        = 1;
var WINDOW_HAMMING     = 2;
var WINDOW_BLACKMAN    = 3;

# Extra IEEE-754 literals not in the stdlib.
var DSP_C2_5 = 0x4004000000000000;   # 2.5   (hermite coefficient)
var DSP_C1_5 = 0x3FF8000000000000;   # 1.5   (hermite coefficient)

# ================================================================
# dB <-> linear amplitude.
# ================================================================

# 20 * log10(amplitude); -inf for amplitude <= 0. log10(x) = ln(x)/ln(10).
#inline
#must_use
fn naad_amplitude_to_db(amplitude) {
    if (f64_le(amplitude, 0) == 1) { return NAAD_NEG_INF; }
    var log10 = f64_div(f64_ln(amplitude), F64_LN10);
    return f64_mul(f64_from(20), log10);
}

# 10^(db/20); 0.0 for db == -inf.
#inline
#must_use
fn naad_db_to_amplitude(db) {
    if (db == NAAD_NEG_INF) { return 0; }
    return f64_pow(f64_from(10), f64_div(db, f64_from(20)));
}

# ================================================================
# Buffer ops (operate on a stdlib vec of f64 in place / read-only).
# ================================================================

# Scale a buffer so its peak absolute value is 1.0. No-op if all zeros.
fn normalize(buffer) {
    var n = vec_len(buffer);
    var peak = 0;
    var i = 0;
    while (i < n) {
        var a = f64_abs(vec_get(buffer, i));
        if (f64_gt(a, peak) == 1) { peak = a; }
        i = i + 1;
    }
    if (f64_gt(peak, 0) == 1) {
        var inv = f64_div(F64_ONE, peak);
        i = 0;
        while (i < n) {
            vec_set(buffer, i, f64_mul(vec_get(buffer, i), inv));
            i = i + 1;
        }
    }
    return 0;
}

# Root mean square of a buffer (0.0 if empty).
#inline
#must_use
fn rms(buffer) {
    var n = vec_len(buffer);
    if (n == 0) { return 0; }
    var sum_sq = 0;
    var i = 0;
    while (i < n) {
        var s = vec_get(buffer, i);
        sum_sq = f64_add(sum_sq, f64_mul(s, s));
        i = i + 1;
    }
    return f64_sqrt(f64_div(sum_sq, f64_from(n)));
}

# Peak absolute value of a buffer.
#inline
#must_use
fn peak(buffer) {
    var n = vec_len(buffer);
    var p = 0;
    var i = 0;
    while (i < n) {
        var a = f64_abs(vec_get(buffer, i));
        if (f64_gt(a, p) == 1) { p = a; }
        i = i + 1;
    }
    return p;
}

# ================================================================
# Scalar shaping / interpolation.
# ================================================================

# Hard-limit (clip) a sample to [-limit, +limit].
#inline
#must_use
fn hard_limit(sample, limit) {
    return f64_clamp(sample, f64_neg(limit), limit);
}

# tanh soft-clip; `drive` controls saturation (1.0 mild, higher = more).
#inline
#must_use
fn soft_clip_tanh(sample, drive) {
    return f64_tanh(f64_mul(sample, drive));
}

# Linear interpolation: a + (b - a) * t.
#inline
#must_use
fn lerp(a, b, t) {
    return f64_add(a, f64_mul(f64_sub(b, a), t));
}

# Cubic Hermite interpolation through y0..y3 at fractional t in [0,1]
# between y1 and y2.
#inline
#must_use
fn hermite_interpolate(y0, y1, y2, y3, t) {
    var c0 = y1;
    var c1 = f64_mul(F64_HALF, f64_sub(y2, y0));
    # c2 = y0 - 2.5*y1 + 2*y2 - 0.5*y3
    var c2 = f64_sub(f64_add(f64_sub(y0, f64_mul(DSP_C2_5, y1)), f64_mul(F64_TWO, y2)), f64_mul(F64_HALF, y3));
    # c3 = 0.5*(y3 - y0) + 1.5*(y1 - y2)
    var c3 = f64_add(f64_mul(F64_HALF, f64_sub(y3, y0)), f64_mul(DSP_C1_5, f64_sub(y1, y2)));
    # ((c3*t + c2)*t + c1)*t + c0
    var r = f64_add(f64_mul(c3, t), c2);
    r = f64_add(f64_mul(r, t), c1);
    r = f64_add(f64_mul(r, t), c0);
    return r;
}

# Equal-power crossfade: mix 0.0 = full dry, 1.0 = full wet.
#inline
#must_use
fn crossfade_equal_power(dry, wet, mix) {
    var angle = f64_mul(mix, F64_PI_2);
    return f64_add(f64_mul(dry, f64_cos(angle)), f64_mul(wet, f64_sin(angle)));
}

# ================================================================
# Windows (in place over a vec).
# ================================================================

# Hann window: w(i) = 0.5 * (1 - cos(TAU * i / len)).
fn apply_hann_window(buffer) {
    var len = vec_len(buffer);
    if (len == 0) { return 0; }
    var inv = f64_div(F64_ONE, f64_from(len));
    var i = 0;
    while (i < len) {
        var phase = f64_mul(f64_mul(F64_TAU, f64_from(i)), inv);
        var w = f64_mul(F64_HALF, f64_sub(F64_ONE, f64_cos(phase)));
        vec_set(buffer, i, f64_mul(vec_get(buffer, i), w));
        i = i + 1;
    }
    return 0;
}

# Blackman window: 0.42 - 0.5*cos(TAU*t) + 0.08*cos(2*TAU*t), t = i/len.
fn apply_blackman_window(buffer) {
    var len = vec_len(buffer);
    if (len == 0) { return 0; }
    var inv = f64_div(F64_ONE, f64_from(len));
    var c042 = 0x3FDAE147AE147AE1;   # 0.42
    var c008 = 0x3FB47AE147AE147B;   # 0.08
    var i = 0;
    while (i < len) {
        var t = f64_mul(f64_from(i), inv);
        var tau_t = f64_mul(F64_TAU, t);
        var w = f64_sub(c042, f64_mul(F64_HALF, f64_cos(tau_t)));
        w = f64_add(w, f64_mul(c008, f64_cos(f64_mul(F64_TWO, tau_t))));
        vec_set(buffer, i, f64_mul(vec_get(buffer, i), w));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# eval_polynomial -- Horner evaluation of ascending-degree coeffs (vec of
# f64) at x. Empty coeffs -> 0.0. Pure f64 (no hisab), so ported here; its
# companion fit_polynomial (hisab least-squares) is in the pending block.
# ================================================================
#inline
#must_use
fn eval_polynomial(coeffs, x) {
    var n = vec_len(coeffs);
    if (n == 0) { return 0; }
    var acc = vec_get(coeffs, n - 1);
    var i = n - 1;
    while (i > 0) {
        i = i - 1;
        acc = f64_add(f64_mul(acc, x), vec_get(coeffs, i));
    }
    return acc;
}

# ================================================================
# dB -> linear amplitude via a 256-entry LUT with linear interpolation.
# Rust used a LazyLock<[f32;256]>; here the table is a module-global vec
# built on first access. Range [-80, +20] dB; inputs outside clamp to the
# edges. Avoids powf in per-sample gain stages (compressor/limiter/de-esser).
# ================================================================
var DB_LUT_MIN   = 0xC054000000000000;   # -80.0
var DB_LUT_MAX   = 0x4034000000000000;   #  20.0
var DB_LUT_RANGE = 0x4059000000000000;   # 100.0
var _DB_LUT      = 0;                     # 0 = not yet built

#must_use
fn _db_lut() {
    if (_DB_LUT != 0) { return _DB_LUT; }
    var t = vec_new();
    var i = 0;
    while (i < 256) {
        var frac = f64_div(f64_from(i), f64_from(255));
        var db = f64_add(DB_LUT_MIN, f64_mul(frac, DB_LUT_RANGE));
        vec_push(t, f64_pow(f64_from(10), f64_div(db, f64_from(20))));
        i = i + 1;
    }
    _DB_LUT = t;
    return t;
}

#inline
#must_use
fn db_to_amplitude_lut(db) {
    var table = _db_lut();
    if (f64_le(db, DB_LUT_MIN) == 1) { return vec_get(table, 0); }
    if (f64_ge(db, DB_LUT_MAX) == 1) { return vec_get(table, 255); }
    var normalized = f64_div(f64_sub(db, DB_LUT_MIN), DB_LUT_RANGE);
    var idx = f64_mul(normalized, f64_from(255));
    var i0 = f64_to(idx);
    var i1 = i0 + 1;
    if (i1 > 255) { i1 = 255; }
    var frac = f64_sub(idx, f64_from(i0));
    var lo = f64_mul(vec_get(table, i0), f64_sub(F64_ONE, frac));
    var hi = f64_mul(vec_get(table, i1), frac);
    return f64_add(lo, hi);
}

# ================================================================
# xorshift32 PRNG -- the canonical PRNG for every noise site in the crate
# (white/pink/brown noise, granular spray, drum clicks, physical exciters).
# Rust took `&mut u32`; here `sp` is a POINTER to a 64-bit slot holding the
# u32 state (load64/store64). u32 wrap is emulated with a 0xFFFFFFFF mask
# after each left shift. Zero-state guard: a 0 state is reset to 1 (0 would
# loop forever). Returns the new state (== the raw output).
# ================================================================
var U32_MASK = 0xFFFFFFFF;
var U32_MAXF = 0x41EFFFFFFFE00000;   # not used; kept for reference (u32::MAX as f64)

fn xorshift32(sp) {
    var x = load64(sp) & U32_MASK;
    if (x == 0) { x = 1; }
    x = (x ^ ((x << 13) & U32_MASK)) & U32_MASK;
    x = x ^ (x >> 17);
    x = (x ^ ((x << 5) & U32_MASK)) & U32_MASK;
    store64(sp, x);
    return x;
}

# One step mapped to a signed f32 in [-1.0, 1.0): raw/u32::MAX * 2 - 1.
#must_use
fn xorshift32_signed_f32(sp) {
    var raw = xorshift32(sp);
    var unit = f64_div(f64_from(raw), f64_from(4294967295));
    return f64_sub(f64_mul(unit, F64_TWO), F64_ONE);
}

# One step mapped to an unsigned f32 in [0.0, 1.0): raw/u32::MAX.
#must_use
fn xorshift32_unit_f32(sp) {
    var raw = xorshift32(sp);
    return f64_div(f64_from(raw), f64_from(4294967295));
}

# Single white-noise sample from a state slot (convenience; == signed step).
#must_use
fn white_noise_sample(sp) {
    return xorshift32_signed_f32(sp);
}

# --- dsp_spectral.cyr ---

# dsp_spectral.cyr -- DSP spectral / analysis block (the `synthesis`-gated,
# hisab-interop half of rust-old/src/dsp_util.rs). Kept OUT of dsp_util.cyr
# because these functions need hisab (num_fft / calc_bspline / QR least
# squares) while most dsp_util consumers don't pull hisab. f32 -> f64 as
# usual; buffers are stdlib `vec` handles (one f64 per slot). `SpectralWindow`
# reuses the WINDOW_* constants already defined in dsp_util.cyr.
#
# Requires (from the build/test unit): lib/hisab.cyr (num_fft / calc_bspline /
# hvec3_new / HVec3_x), auto-stdlib math+ganita (F64_* / f64_clamp / ganita_mat_*)
# and src/error.cyr (naad_is_finite, EPSILON tolerances). No `include` lines.
#
# Public API (names match the frozen Rust oracle): fft_magnitudes,
# power_spectrum, stft_magnitudes, chromagram, detect_onsets,
# detect_pitch_autocorr, bspline_eval_1d, fit_polynomial. Internal helpers
# carry a `_dsp_` prefix. `eval_polynomial` already lives in dsp_util.cyr.

# ================================================================
# Extra IEEE-754 literals (non-integers only; integers via f64_from).
# ================================================================
var SPEC_NAN   = 0x7FF8000000000000;   # canonical quiet NaN (bspline None)
var SPEC_C054  = 0x3FE147AE147AE148;   # 0.54  (Hamming a0)
var SPEC_C046  = 0x3FDD70A3D70A3D71;   # 0.46  (Hamming a1)
var SPEC_C042  = 0x3FDAE147AE147AE1;   # 0.42  (Blackman a0)
var SPEC_C008  = 0x3FB47AE147AE147B;   # 0.08  (Blackman a2)
var SPEC_C27_5 = 0x403B800000000000;   # 27.5  (A0, chroma lower bound)
var SPEC_C030  = 0x3FD3333333333333;   # 0.30  (autocorr peak threshold)
var SPEC_C1E6  = 0x3EB0C6F7A0B5ED8D;   # 1e-6  (onset flux floor)
var SPEC_C1E9  = 0x3E112E0BE826D695;   # 1e-9  (Newton convergence tol)
var SPEC_C1E12 = 0x3D719799812DEA11;   # 1e-12 (parabolic denom / deriv guard)

# ================================================================
# _dsp_is_pow2 -- 1 if n is a positive power of two, else 0.
# ================================================================
#must_use
fn _dsp_is_pow2(n) {
    if (n <= 0) { return 0; }
    var m = n & (n - 1);
    if (m == 0) { return 1; }
    return 0;
}

# ================================================================
# _dsp_sort_f64 -- ascending insertion sort of a vec of f64 in place.
# Used for the running-median onset threshold (Rust `sort_by` on partial_cmp).
# ================================================================
fn _dsp_sort_f64(v) {
    var n = vec_len(v);
    var i = 1;
    while (i < n) {
        var key = vec_get(v, i);
        var j = i - 1;
        var go = 1;
        while (go == 1) {
            if (j < 0) { go = 0; }
            if (go == 1) {
                if (f64_gt(vec_get(v, j), key) == 1) {
                    vec_set(v, j + 1, vec_get(v, j));
                    j = j - 1;
                } else {
                    go = 0;
                }
            }
        }
        vec_set(v, j + 1, key);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# _dsp_rem_euclid_12 -- Euclidean remainder x mod 12 in [0, 12). For the
# chromagram MIDI-to-pitch-class fold. Matches Rust f64::rem_euclid(12.0)
# over the positive MIDI range this is called on.
# ================================================================
#must_use
fn _dsp_rem_euclid_12(x) {
    var twelve = f64_from(12);
    var q = f64_floor(f64_div(x, twelve));
    return f64_sub(x, f64_mul(twelve, q));
}

# ================================================================
# fft_magnitudes -- real-valued FFT magnitude spectrum, bins 0..N/2 (DC to
# Nyquist), each scaled by 1/N. Input length must be a power of two. On FFT
# failure returns an empty vec. Ports fft_magnitudes.
# ================================================================
#must_use
fn fft_magnitudes(input) {
    var n = vec_len(input);
    var data = alloc(n * 16);
    var i = 0;
    while (i < n) {
        store64(data + i * 16, vec_get(input, i));
        store64(data + i * 16 + 8, 0);
        i = i + 1;
    }
    var out = vec_new();
    # Empty input: num_fft returns ERR_NONE for n<=1 without validating, so it
    # would fall through to a half=1 read/scale loop over alloc(0) (OOB) with a
    # 1/0=+inf scale. Rust panics on the length-0 slice; we return empty. (n>=1
    # is in-bounds and agrees with the oracle.)
    if (n == 0) { return out; }
    if (num_fft(data, n) != 0) { return out; }
    var half = n / 2 + 1;
    var inv_n = f64_div(F64_ONE, f64_from(n));
    var b = 0;
    while (b < half) {
        var re = load64(data + b * 16);
        var im = load64(data + b * 16 + 8);
        var mag = f64_sqrt(f64_add(f64_mul(re, re), f64_mul(im, im)));
        vec_push(out, f64_mul(mag, inv_n));
        b = b + 1;
    }
    return out;
}

# ================================================================
# power_spectrum -- power (|X|^2) for bins 0..N/2, scaled by 1/N^2. Input
# length must be a power of two. Empty vec on FFT failure. Ports power_spectrum.
# ================================================================
#must_use
fn power_spectrum(input) {
    var n = vec_len(input);
    var data = alloc(n * 16);
    var i = 0;
    while (i < n) {
        store64(data + i * 16, vec_get(input, i));
        store64(data + i * 16 + 8, 0);
        i = i + 1;
    }
    var out = vec_new();
    # Empty input: num_fft returns ERR_NONE for n<=1 without validating, so it
    # would fall through to a half=1 read/scale loop over alloc(0) (OOB) with a
    # 1/0=+inf scale. Rust panics on the length-0 slice; we return empty. (n>=1
    # is in-bounds and agrees with the oracle.)
    if (n == 0) { return out; }
    if (num_fft(data, n) != 0) { return out; }
    var half = n / 2 + 1;
    var inv_n_sq = f64_div(F64_ONE, f64_mul(f64_from(n), f64_from(n)));
    var b = 0;
    while (b < half) {
        var re = load64(data + b * 16);
        var im = load64(data + b * 16 + 8);
        var p = f64_add(f64_mul(re, re), f64_mul(im, im));
        vec_push(out, f64_mul(p, inv_n_sq));
        b = b + 1;
    }
    return out;
}

# ================================================================
# _dsp_apply_spectral_window -- apply a WINDOW_* window to a vec in place.
# Rectangular is a no-op; Hann/Hamming/Blackman use the raised-cosine forms.
# Ports SpectralWindow::apply.
# ================================================================
fn _dsp_apply_spectral_window(buf, window) {
    var len = vec_len(buf);
    if (len == 0) { return 0; }
    if (window == WINDOW_RECTANGULAR) { return 0; }
    var inv = f64_div(F64_ONE, f64_from(len));
    var i = 0;
    while (i < len) {
        # phase = TAU * i / len == TAU * t
        var phase = f64_mul(f64_mul(F64_TAU, f64_from(i)), inv);
        var w = F64_ONE;
        if (window == WINDOW_HANN) {
            w = f64_mul(F64_HALF, f64_sub(F64_ONE, f64_cos(phase)));
        }
        if (window == WINDOW_HAMMING) {
            w = f64_sub(SPEC_C054, f64_mul(SPEC_C046, f64_cos(phase)));
        }
        if (window == WINDOW_BLACKMAN) {
            var c1 = f64_mul(F64_HALF, f64_cos(phase));
            var c2 = f64_mul(SPEC_C008, f64_cos(f64_mul(F64_TWO, phase)));
            w = f64_add(f64_sub(SPEC_C042, c1), c2);
        }
        vec_set(buf, i, f64_mul(vec_get(buf, i), w));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# stft_magnitudes -- windowed-FFT magnitude spectrogram. Slides an FFT of
# length window_size across `signal` by hop_size, windowing each frame. Returns
# a vec of frames, each a vec of window_size/2+1 magnitudes. Empty (vec of
# vecs) if signal shorter than window_size, hop_size == 0, or window_size is
# not a power of two. Ports stft_magnitudes.
# ================================================================
#must_use
fn stft_magnitudes(signal, window_size, hop_size, window) {
    var sig_len = vec_len(signal);
    if (sig_len < window_size) { return vec_new(); }
    if (hop_size == 0) { return vec_new(); }
    if (_dsp_is_pow2(window_size) == 0) { return vec_new(); }
    if (window_size == 0) { return vec_new(); }

    var num_frames = (sig_len - window_size) / hop_size + 1;
    var half = window_size / 2 + 1;
    var frames = vec_new();

    var f = 0;
    while (f < num_frames) {
        var start = f * hop_size;
        var frame = vec_new();
        var k = 0;
        while (k < window_size) {
            vec_push(frame, vec_get(signal, start + k));
            k = k + 1;
        }
        _dsp_apply_spectral_window(frame, window);
        var mag = fft_magnitudes(frame);
        if (vec_len(mag) < half) {
            # FFT failure -- bail out cleanly.
            return vec_new();
        }
        vec_push(frames, mag);
        f = f + 1;
    }
    return frames;
}

# ================================================================
# chromagram -- 12-bin pitch-class profile per STFT frame. Folds each bin's
# centre frequency (piano range 27.5..4186 Hz only) into a chromatic pitch
# class via its fractional MIDI number. Returns a vec of 12-slot vecs (bin 0
# = C .. bin 11 = B). Ports chromagram.
# ================================================================
#must_use
fn chromagram(magnitudes, window_size, sample_rate) {
    var chroma_frames = vec_new();
    if (window_size == 0) { return chroma_frames; }
    if (f64_le(sample_rate, 0) == 1) { return chroma_frames; }
    var bin_hz = f64_div(sample_rate, f64_from(window_size));
    var upper = f64_from(4186);

    var nf = vec_len(magnitudes);
    var fi = 0;
    while (fi < nf) {
        var frame = vec_get(magnitudes, fi);
        var chroma = vec_new();
        var z = 0;
        while (z < 12) {
            vec_push(chroma, 0);
            z = z + 1;
        }
        var flen = vec_len(frame);
        var bin = 1;
        while (bin < flen) {
            var m = vec_get(frame, bin);
            var freq = f64_mul(f64_from(bin), bin_hz);
            if (f64_ge(freq, SPEC_C27_5) == 1 && f64_le(freq, upper) == 1) {
                # MIDI note (fractional): 69 + 12 * log2(freq / 440).
                var ratio = f64_div(freq, f64_from(440));
                var log2 = f64_div(f64_ln(ratio), F64_LN2);
                var midi = f64_add(f64_from(69), f64_mul(f64_from(12), log2));
                var pc = _dsp_rem_euclid_12(midi);
                var pci = f64_to(f64_floor(pc));
                var pc_idx = pci % 12;
                vec_set(chroma, pc_idx, f64_add(vec_get(chroma, pc_idx), m));
            }
            bin = bin + 1;
        }
        vec_push(chroma_frames, chroma);
        fi = fi + 1;
    }
    return chroma_frames;
}

# ================================================================
# detect_onsets -- onset times (seconds) via spectral flux over an STFT
# magnitude spectrogram. Flux = L2 norm of the half-wave-rectified frame-to-
# frame magnitude increase; onsets are local flux maxima above an adaptive
# running-median threshold. Returns a (possibly empty) vec of f64 times.
# Ports detect_onsets.
# ================================================================
#must_use
fn detect_onsets(magnitudes, hop_size, sample_rate, threshold_factor) {
    var nf = vec_len(magnitudes);
    if (nf < 3) { return vec_new(); }
    if (hop_size == 0) { return vec_new(); }
    if (f64_le(sample_rate, 0) == 1) { return vec_new(); }

    # Spectral flux per frame (frame 0 has no flux).
    var flux = vec_new();
    vec_push(flux, 0);
    var i = 1;
    while (i < nf) {
        var prev = vec_get(magnitudes, i - 1);
        var cur = vec_get(magnitudes, i);
        var lc = vec_len(cur);
        var lp = vec_len(prev);
        var len = lc;
        if (lp < len) { len = lp; }
        var sum = 0;
        var k = 0;
        while (k < len) {
            var diff = f64_sub(vec_get(cur, k), vec_get(prev, k));
            if (f64_gt(diff, 0) == 1) {
                sum = f64_add(sum, f64_mul(diff, diff));
            }
            k = k + 1;
        }
        vec_push(flux, f64_sqrt(sum));
        i = i + 1;
    }

    # Running-median threshold over a +/-5-frame window.
    var window = 5;
    var flux_len = vec_len(flux);
    var onsets = vec_new();
    var j = 1;
    while (j < flux_len - 1) {
        var fj = vec_get(flux, j);
        var is_peak = 1;
        if (f64_le(fj, vec_get(flux, j - 1)) == 1) { is_peak = 0; }
        if (f64_le(fj, vec_get(flux, j + 1)) == 1) { is_peak = 0; }
        if (is_peak == 1) {
            var lo = 0;
            if (j >= window) { lo = j - window; }
            var hi = j + window + 1;
            if (hi > flux_len) { hi = flux_len; }
            var local = vec_new();
            var p = lo;
            while (p < hi) {
                vec_push(local, vec_get(flux, p));
                p = p + 1;
            }
            _dsp_sort_f64(local);
            var median = vec_get(local, vec_len(local) / 2);
            if (f64_gt(fj, f64_mul(median, threshold_factor)) == 1 && f64_gt(fj, SPEC_C1E6) == 1) {
                var frame_idx = j * hop_size;
                var time = f64_div(f64_from(frame_idx), sample_rate);
                vec_push(onsets, time);
            }
        }
        j = j + 1;
    }
    return onsets;
}

# ================================================================
# detect_pitch_autocorr -- fundamental pitch (Hz) via autocorrelation with
# Catmull-Rom cubic + Newton-Raphson sub-sample peak refinement. Returns the
# pitch on success or -1.0 (impossible pitch) for the Rust `None`: buffer < 32
# samples, degenerate search range, or a peak below 30% of the zero-lag energy.
# Ports detect_pitch_autocorr; the closure-based newton_raphson is inlined
# (16 iters, tol 1e-9, derivative guard 1e-12).
# ================================================================
#must_use
fn detect_pitch_autocorr(buffer, sample_rate, min_hz, max_hz) {
    var none = f64_neg(F64_ONE);
    var n = vec_len(buffer);
    if (n < 32) { return none; }
    if (f64_le(sample_rate, 0) == 1) { return none; }
    if (f64_le(min_hz, 0) == 1) { return none; }
    if (f64_le(max_hz, min_hz) == 1) { return none; }

    var max_lag = f64_to(f64_div(sample_rate, min_hz));
    if (max_lag > n - 1) { max_lag = n - 1; }
    var min_lag = f64_to(f64_div(sample_rate, max_hz));
    if (min_lag < 2) { min_lag = 2; }
    if (min_lag + 2 >= max_lag) { return none; }

    # Direct autocorrelation, lags 0..max_lag+1.
    var autocorr = vec_new();
    var alen = max_lag + 2;
    var lag = 0;
    while (lag < alen) {
        var sum = 0;
        var upper = n - lag;
        var i = 0;
        while (i < upper) {
            sum = f64_add(sum, f64_mul(vec_get(buffer, i), vec_get(buffer, i + lag)));
            i = i + 1;
        }
        vec_push(autocorr, sum);
        lag = lag + 1;
    }

    var r0 = vec_get(autocorr, 0);
    if (f64_le(r0, 0) == 1) { return none; }

    # Largest peak in [min_lag, max_lag-1].
    var peak_lag = min_lag;
    var peak_val = vec_get(autocorr, min_lag);
    var l = min_lag + 1;
    while (l < max_lag) {
        var al = vec_get(autocorr, l);
        if (f64_gt(al, peak_val) == 1
        && f64_gt(al, vec_get(autocorr, l - 1)) == 1
        && f64_gt(al, vec_get(autocorr, l + 1)) == 1) {
            peak_val = al;
            peak_lag = l;
        }
        l = l + 1;
    }

    # Reject noise-dominated buffers (peak too weak relative to r(0)).
    if (f64_lt(peak_val, f64_mul(SPEC_C030, r0)) == 1) { return none; }

    var y0 = vec_get(autocorr, peak_lag - 1);
    var y1 = vec_get(autocorr, peak_lag);
    var y2 = vec_get(autocorr, peak_lag + 1);
    var y3 = vec_get(autocorr, peak_lag + 2);

    # Cubic through the four samples: P'(t) = 0.5*(3a t^2 + 2b t + c),
    # P''(t) = 0.5*(6a t + 2b).
    var three = f64_from(3);
    var a = f64_add(f64_sub(f64_add(f64_neg(y0), f64_mul(three, y1)), f64_mul(three, y2)), y3);
    var b = f64_sub(f64_add(f64_sub(f64_mul(F64_TWO, y0), f64_mul(f64_from(5), y1)), f64_mul(f64_from(4), y2)), y3);
    var c = f64_add(f64_neg(y0), y2);

    # Parabolic-interpolation initial guess.
    var denom = f64_mul(F64_TWO, f64_add(f64_sub(y0, f64_mul(F64_TWO, y1)), y2));
    var parabolic_t = 0;
    if (f64_lt(f64_abs(denom), SPEC_C1E12) == 0) {
        parabolic_t = f64_clamp(f64_div(f64_sub(y0, y2), denom), f64_neg(F64_ONE), F64_ONE);
    }

    # Newton-Raphson on P'(t) = 0 (inlined; matches num_newton semantics).
    var t = parabolic_t;
    var converged = 0;
    var stop = 0;
    var it = 0;
    while (it < 16) {
        if (stop == 0) {
            var t2 = f64_mul(t, t);
            var fx = f64_mul(F64_HALF,
            f64_add(f64_add(f64_mul(f64_mul(three, a), t2), f64_mul(f64_mul(F64_TWO, b), t)), c));
            if (f64_lt(f64_abs(fx), SPEC_C1E9) == 1) {
                converged = 1;
                stop = 1;
            } else {
                var dfx = f64_mul(F64_HALF, f64_add(f64_mul(f64_mul(f64_from(6), a), t), f64_mul(F64_TWO, b)));
                if (f64_lt(f64_abs(dfx), SPEC_C1E12) == 1) {
                    stop = 1;
                } else {
                    t = f64_sub(t, f64_div(fx, dfx));
                }
            }
        }
        it = it + 1;
    }
    var refined_t = parabolic_t;
    if (converged == 1) { refined_t = t; }
    refined_t = f64_clamp(refined_t, f64_neg(F64_ONE), F64_ONE);

    var refined_lag = f64_add(f64_from(peak_lag), refined_t);
    if (f64_le(refined_lag, 0) == 1) { return none; }
    var pitch = f64_div(sample_rate, refined_lag);
    if (naad_is_finite(pitch) == 0) { return none; }
    if (f64_lt(pitch, f64_mul(min_hz, F64_HALF)) == 1) { return none; }
    if (f64_gt(pitch, f64_mul(max_hz, F64_TWO)) == 1) { return none; }
    return pitch;
}

# ================================================================
# bspline_eval_1d -- evaluate a 1-D clamped open-uniform B-spline of `degree`
# through `control_points` (a vec of f64) at t in [0, 1]. Lifts each scalar
# control point into HVec3.x for hisab's calc_bspline, builds the clamped knot
# vector, and returns the .x component. Returns NaN bits for the Rust `None`:
# degree == 0, control_points.len() <= degree, or t outside [0, 1]. Ports
# bspline_eval_1d.
# ================================================================
#must_use
fn bspline_eval_1d(degree, control_points, t) {
    var n = vec_len(control_points);
    if (degree == 0) { return SPEC_NAN; }
    if (n <= degree) { return SPEC_NAN; }
    if (f64_lt(t, 0) == 1) { return SPEC_NAN; }
    if (f64_gt(t, F64_ONE) == 1) { return SPEC_NAN; }

    # Clamped open-uniform knots: (degree+1) zeros, uniform interior,
    # (degree+1) ones. Total length n + degree + 1.
    var interior_count = n - degree - 1;
    var n_knots = n + degree + 1;
    var knots = alloc(n_knots * 8);
    var idx = 0;
    var z = 0;
    while (z <= degree) {
        store64(knots + idx * 8, 0);
        idx = idx + 1;
        z = z + 1;
    }
    var ii = 1;
    while (ii <= interior_count) {
        var kv = f64_div(f64_from(ii), f64_from(interior_count + 1));
        store64(knots + idx * 8, kv);
        idx = idx + 1;
        ii = ii + 1;
    }
    z = 0;
    while (z <= degree) {
        store64(knots + idx * 8, F64_ONE);
        idx = idx + 1;
        z = z + 1;
    }

    # Lift scalar control points into HVec3.x (as the Rust oracle does).
    var cps = alloc(n * 8);
    var i = 0;
    while (i < n) {
        store64(cps + i * 8, hvec3_new(vec_get(control_points, i), 0, 0));
        i = i + 1;
    }

    var result = calc_bspline(degree, cps, n, knots, n_knots, t);
    if (result == 0) { return SPEC_NAN; }
    return HVec3_x(result);
}

# ================================================================
# fit_polynomial -- least-squares polynomial fit of `degree` to (xs, ys), both
# vecs of f64. Returns the ascending-order coefficients [c0..c_degree] as a
# vec, or an empty vec for the Rust `None`: len(xs) != len(ys) or fewer than
# degree+1 samples. Builds the Vandermonde by incremental multiplication
# (robust for negative/zero xs, unlike exp/ln pow) and solves via ganita's QR
# least squares. Ports fit_polynomial.
# ================================================================
#must_use
fn fit_polynomial(xs, ys, degree) {
    var out = vec_new();
    var nx = vec_len(xs);
    var ny = vec_len(ys);
    if (nx != ny) { return out; }
    if (nx <= degree) { return out; }

    var cols = degree + 1;
    # Vandermonde A: nx x cols, A[i][j] = xs[i]^j (built incrementally).
    var a = ganita_mat_new(nx, cols);
    var i = 0;
    while (i < nx) {
        var xi = vec_get(xs, i);
        var p = F64_ONE;
        var j = 0;
        while (j < cols) {
            ganita_mat_set(a, i, j, p);
            p = f64_mul(p, xi);
            j = j + 1;
        }
        i = i + 1;
    }

    # b = ys as a flat f64 array (length nx); out_x = flat f64 array (length cols).
    var bvec = alloc(nx * 8);
    i = 0;
    while (i < nx) {
        store64(bvec + i * 8, vec_get(ys, i));
        i = i + 1;
    }
    var xarr = alloc(cols * 8);
    ganita_mat_least_squares(a, bvec, xarr);

    # Singular / rank-deficient design (e.g. duplicate x values) makes QR
    # back-substitution divide by a ~0 R diagonal, yielding non-finite coeffs.
    # Rust's least_squares_poly returns Err (mapped to None); mirror that with
    # the empty vec instead of emitting poisoned NaN/inf coefficients.
    var k = 0;
    while (k < cols) {
        if (naad_is_finite(load64(xarr + k * 8)) == 0) { return out; }
        k = k + 1;
    }

    var j = 0;
    while (j < cols) {
        vec_push(out, load64(xarr + j * 8));
        j = j + 1;
    }
    return out;
}

# --- noise.cyr ---

# noise.cyr -- noise generators: white, pink (Voss-McCartney), brown.
#
# Ports rust-old/src/noise.rs. f32 -> f64 throughout. The Rust `NoiseType`
# enum becomes integer constants; the nested `Xorshift32` struct is folded
# into a single pointer-state slot (a `rng` field holding an alloc(8) pointer
# whose 64-bit slot carries the u32 PRNG state, stepped via dsp_util's
# xorshift32_signed_f32). The fixed `[f32; 16]` pink octave array becomes a
# stdlib vec of 16 f64. serde round-trip test dropped.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/TWO,
# f64_add/sub/mul/div/neg/clamp/from) and dsp_util (xorshift32_signed_f32).
# The module file itself has no `include` lines.

# ================================================================
# NoiseType (enum) -> integer constants.
# ================================================================
var NOISE_WHITE = 0;
var NOISE_PINK  = 1;
var NOISE_BROWN = 2;

# Number of octaves for Voss-McCartney pink noise (Rust PINK_OCTAVES).
var NOISE_PINK_OCTAVES = 16;

# u32 wrap mask for the pink counter (matches wrapping_add/wrapping_sub).
var NOISE_U32_MASK = 0xFFFFFFFF;

# Non-integer float literals (IEEE-754 bit patterns).
var NOISE_C0_02  = 0x3F947AE147AE147B;   # 0.02  (brown integration step)
var NOISE_C0_999 = 0x3FEFF7CED916872B;   # 0.999 (brown leaky integrator)

# ================================================================
# NoiseGenerator -- stateful generator for white / pink / brown noise.
#   noise_type       : NOISE_* constant
#   rng              : pointer to an 8-byte slot holding the u32 PRNG state
#   pink_octaves     : vec of 16 f64 (Voss-McCartney octave values)
#   pink_counter     : u32 counter for the octave-update tree
#   pink_running_sum : running sum of the octave values
#   brown_prev       : previous brown-noise sample (leaky integrator state)
# ================================================================
#derive(accessors)
struct NoiseGenerator { noise_type; rng; pink_octaves; pink_counter; pink_running_sum; brown_prev; }

# ================================================================
# noise_new -- create a generator. Mirrors NoiseGenerator::new: seeds the
# PRNG (0 -> 1 to avoid the dead zero state) and, for pink noise only,
# primes the 16 octave values plus their running sum.
# ================================================================
#must_use
fn noise_new(noise_type, seed) {
    var rng = alloc(8);
    var state = seed;
    if (state == 0) { state = 1; }
    store64(rng, state);

    var pink_octaves = vec_new();
    var i = 0;
    while (i < NOISE_PINK_OCTAVES) {
        vec_push(pink_octaves, 0);
        i = i + 1;
    }

    var pink_running_sum = 0;
    if (noise_type == NOISE_PINK) {
        i = 0;
        while (i < NOISE_PINK_OCTAVES) {
            var val = xorshift32_signed_f32(rng);
            vec_set(pink_octaves, i, val);
            pink_running_sum = f64_add(pink_running_sum, val);
            i = i + 1;
        }
    }

    var g = alloc(sizeof(NoiseGenerator));
    NoiseGenerator_set_noise_type(g, noise_type);
    NoiseGenerator_set_rng(g, rng);
    NoiseGenerator_set_pink_octaves(g, pink_octaves);
    NoiseGenerator_set_pink_counter(g, 0);
    NoiseGenerator_set_pink_running_sum(g, pink_running_sum);
    NoiseGenerator_set_brown_prev(g, 0);
    return g;
}

# ================================================================
# noise_next_sample -- dispatch on the noise type (Rust next_sample match).
# ================================================================
#must_use
fn noise_next_sample(self) {
    var nt = NoiseGenerator_noise_type(self);
    if (nt == NOISE_WHITE) { return noise_white(self); }
    if (nt == NOISE_PINK) { return noise_pink(self); }
    return noise_brown(self);
}

# White noise: a single signed PRNG step.
fn noise_white(self) {
    return xorshift32_signed_f32(NoiseGenerator_rng(self));
}

# ================================================================
# noise_pink -- Voss-McCartney pink noise. Each counter increment flips a
# set of trailing bits; every flipped bit i re-rolls octave i. A final white
# component is added and the whole sum is normalized by (octaves + 1).
# ================================================================
fn noise_pink(self) {
    var counter = (NoiseGenerator_pink_counter(self) + 1) & NOISE_U32_MASK;
    NoiseGenerator_set_pink_counter(self, counter);
    var prev = (counter - 1) & NOISE_U32_MASK;
    var changed_bits = counter ^ prev;

    var rng = NoiseGenerator_rng(self);
    var octaves = NoiseGenerator_pink_octaves(self);
    var running_sum = NoiseGenerator_pink_running_sum(self);

    var i = 0;
    while (i < NOISE_PINK_OCTAVES) {
        if ((changed_bits & (1 << i)) != 0) {
            running_sum = f64_sub(running_sum, vec_get(octaves, i));
            var new_val = xorshift32_signed_f32(rng);
            vec_set(octaves, i, new_val);
            running_sum = f64_add(running_sum, new_val);
        }
        i = i + 1;
    }
    NoiseGenerator_set_pink_running_sum(self, running_sum);

    var white = xorshift32_signed_f32(rng);
    return f64_div(f64_add(running_sum, white), f64_from(NOISE_PINK_OCTAVES + 1));
}

# ================================================================
# noise_brown -- integrated white noise with a leaky integrator + clamp.
# ================================================================
fn noise_brown(self) {
    var white = xorshift32_signed_f32(NoiseGenerator_rng(self));
    var prev = NoiseGenerator_brown_prev(self);
    prev = f64_add(prev, f64_mul(white, NOISE_C0_02));
    prev = f64_clamp(prev, f64_neg(F64_ONE), F64_ONE);
    prev = f64_mul(prev, NOISE_C0_999);
    NoiseGenerator_set_brown_prev(self, prev);
    return prev;
}

# ================================================================
# noise_fill_buffer -- fill a vec buffer in place with successive samples.
# ================================================================
fn noise_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, noise_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# noise_white_noise_sample -- stateless convenience: one signed white sample
# from a PRNG state slot (`&mut u32` -> pointer to a 64-bit slot).
# ================================================================
#must_use
fn noise_white_noise_sample(seed) {
    return xorshift32_signed_f32(seed);
}

# --- panning.cyr ---

# panning.cyr -- stereo panning utilities: equal-power / linear pan laws
# and stereo balance for placing signals in the stereo field.
#
# Ports rust-old/src/panning.rs. f32 -> f64 throughout. The `PanLaw` enum
# becomes integer constants (PAN_LAW_*). Rust's serde derives are dropped.
# The `(f32, f32)` tuple returns of `pan_mono` / `stereo_balance` become a
# `PanPair` struct (left, right); `pan_gains` returns a `PanGains` struct.
# Requires (from the build/test unit): stdlib alloc + math (F64_ONE/HALF/
# PI_2, f64_add/sub/mul/clamp/neg, f64_sin/cos, f64_lt). No `include` lines.

# ================================================================
# PanLaw -- panning law used for stereo positioning (was `enum PanLaw`).
#   EQUAL_POWER : constant-power panning via sin/cos (preserves loudness).
#   LINEAR      : linear panning (loudness dips at center).
# ================================================================
var PAN_LAW_EQUAL_POWER = 0;
var PAN_LAW_LINEAR      = 1;

# ================================================================
# PanGains -- stereo panning gains (left/right channel multipliers).
# ================================================================
#derive(accessors)
struct PanGains { left; right; }

# ================================================================
# PanPair -- a (left, right) sample pair; replaces Rust's `(f32, f32)`
# tuple returns from pan_mono / stereo_balance.
# ================================================================
#derive(accessors)
struct PanPair { left; right; }

# ================================================================
# panning_pan_gains -- stereo gains for a pan position. `pan` ranges from
# -1.0 (full left) to +1.0 (full right), 0.0 = center. Ports pan_gains.
# ================================================================
#inline
#must_use
fn panning_pan_gains(pan, law) {
    var p = f64_clamp(pan, f64_neg(F64_ONE), F64_ONE);
    # Map -1..+1 to 0..1.
    var t = f64_mul(f64_add(p, F64_ONE), F64_HALF);
    var g = alloc(sizeof(PanGains));
    if (law == PAN_LAW_EQUAL_POWER) {
        var angle = f64_mul(t, F64_PI_2);
        PanGains_set_left(g, f64_cos(angle));
        PanGains_set_right(g, f64_sin(angle));
    } else {
        PanGains_set_left(g, f64_sub(F64_ONE, t));
        PanGains_set_right(g, t);
    }
    return g;
}

# ================================================================
# panning_pan_mono -- apply panning to a mono sample, returning (left,
# right) as a PanPair. Ports pan_mono.
# ================================================================
#inline
#must_use
fn panning_pan_mono(sample, pan, law) {
    # Gains computed into locals (no intermediate PanGains alloc — this is a
    # per-sample path and Cyrius has no free). Only the PanPair result is
    # allocated. Numerically identical to panning_pan_gains.
    var p = f64_clamp(pan, f64_neg(F64_ONE), F64_ONE);
    var t = f64_mul(f64_add(p, F64_ONE), F64_HALF);
    var gl = 0;
    var gr = 0;
    if (law == PAN_LAW_EQUAL_POWER) {
        var angle = f64_mul(t, F64_PI_2);
        gl = f64_cos(angle);
        gr = f64_sin(angle);
    } else {
        gl = f64_sub(F64_ONE, t);
        gr = t;
    }
    var out = alloc(sizeof(PanPair));
    PanPair_set_left(out, f64_mul(sample, gl));
    PanPair_set_right(out, f64_mul(sample, gr));
    return out;
}

# ================================================================
# panning_stereo_balance -- attenuate one channel to shift the image.
# `balance` ranges from -1.0 (left only) to +1.0 (right only). Returns the
# adjusted (left, right) as a PanPair. Ports stereo_balance.
# ================================================================
#inline
#must_use
fn panning_stereo_balance(left, right, balance) {
    var b = f64_clamp(balance, f64_neg(F64_ONE), F64_ONE);
    var out = alloc(sizeof(PanPair));
    if (f64_lt(b, 0) == 1) {
        # Attenuate right.
        PanPair_set_left(out, left);
        PanPair_set_right(out, f64_mul(right, f64_add(F64_ONE, b)));
    } else {
        # Attenuate left.
        PanPair_set_left(out, f64_mul(left, f64_sub(F64_ONE, b)));
        PanPair_set_right(out, right);
    }
    return out;
}

# --- mod_matrix.cyr ---

# mod_matrix.cyr -- modulation matrix for source-to-destination routing.
#
# Ports rust-old/src/mod_matrix.rs. f32 -> f64 throughout. serde derives
# dropped (no serde). The two `enum`s (ModSource / ModDestination) become
# integer `var` constants whose value IS the array index -- Rust's private
# `index()` maps each variant to 0..7 in declaration order, so the constant
# doubles as the slot index used by set_source / compute / get_destination.
# `Vec<ModRouting>` -> a stdlib `vec` holding ModRouting struct pointers.
# The fixed `[f32; 8]` source/destination arrays -> stdlib `vec`s of 8 f64
# slots. Methods become free `mod_matrix_*` functions on the struct pointer;
# `bool` returns become integer 1/0 (`add_routing` full-check, `enabled`).
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE,
# f64_clamp/neg). No `include` lines in the module itself.

# ================================================================
# Slot counts (was pub const NUM_SOURCES / NUM_DESTINATIONS / MAX_ROUTINGS).
# Prefixed to stay collision-free in the eventual flat bundle.
# ================================================================
var MOD_MATRIX_NUM_SOURCES      = 8;
var MOD_MATRIX_NUM_DESTINATIONS = 8;
var MOD_MATRIX_MAX_ROUTINGS     = 16;

# ================================================================
# ModSource -- modulation source id. Value == array index (see header).
# ================================================================
var MOD_SOURCE_LFO1            = 0;
var MOD_SOURCE_LFO2            = 1;
var MOD_SOURCE_AMP_ENVELOPE    = 2;
var MOD_SOURCE_FILTER_ENVELOPE = 3;
var MOD_SOURCE_VELOCITY        = 4;
var MOD_SOURCE_MOD_WHEEL       = 5;
var MOD_SOURCE_AFTERTOUCH      = 6;
var MOD_SOURCE_PITCH_BEND      = 7;

# ================================================================
# ModDestination -- modulation destination id. Value == array index.
# ================================================================
var MOD_DEST_PITCH            = 0;
var MOD_DEST_FILTER_CUTOFF    = 1;
var MOD_DEST_FILTER_RESONANCE = 2;
var MOD_DEST_AMPLITUDE        = 3;
var MOD_DEST_PAN              = 4;
var MOD_DEST_PULSE_WIDTH      = 5;
var MOD_DEST_FM_INDEX         = 6;
var MOD_DEST_LFO_RATE         = 7;

# ================================================================
# ModRouting -- one source -> destination route with a signed depth.
#   source      : MOD_SOURCE_* index
#   destination : MOD_DEST_* index
#   depth       : f64 modulation depth (clamped to [-1.0, 1.0])
#   enabled     : 1 = active, 0 = bypassed
# ================================================================
#derive(accessors)
struct ModRouting { source; destination; depth; enabled; }

# Create a routing; depth clamped to [-1, 1], enabled by default.
#must_use
fn mod_matrix_routing_new(source, destination, depth) {
    var r = alloc(sizeof(ModRouting));
    ModRouting_set_source(r, source);
    ModRouting_set_destination(r, destination);
    ModRouting_set_depth(r, f64_clamp(depth, f64_neg(F64_ONE), F64_ONE));
    ModRouting_set_enabled(r, 1);
    return r;
}

# ================================================================
# ModMatrix -- up to 16 routing slots plus per-frame source/dest scratch.
#   routings           : vec of ModRouting pointers
#   source_values      : vec of 8 f64 source inputs for the current frame
#   destination_values : vec of 8 f64 accumulated destination amounts
# ================================================================
#derive(accessors)
struct ModMatrix { routings; source_values; destination_values; }

# Create an empty modulation matrix (all source/dest slots zeroed).
#must_use
fn mod_matrix_new() {
    var m = alloc(sizeof(ModMatrix));
    ModMatrix_set_routings(m, vec_new());
    var src = vec_new();
    var dst = vec_new();
    var i = 0;
    while (i < MOD_MATRIX_NUM_SOURCES) {
        vec_push(src, 0);
        i = i + 1;
    }
    i = 0;
    while (i < MOD_MATRIX_NUM_DESTINATIONS) {
        vec_push(dst, 0);
        i = i + 1;
    }
    ModMatrix_set_source_values(m, src);
    ModMatrix_set_destination_values(m, dst);
    return m;
}

# Add a routing. Returns 0 (false) if the matrix is full, else 1 (true).
fn mod_matrix_add_routing(m, routing) {
    var routings = ModMatrix_routings(m);
    if (vec_len(routings) >= MOD_MATRIX_MAX_ROUTINGS) { return 0; }
    vec_push(routings, routing);
    return 1;
}

# Remove a routing by index (no-op if out of range).
fn mod_matrix_remove_routing(m, index) {
    var routings = ModMatrix_routings(m);
    if (index < vec_len(routings)) {
        vec_remove(routings, index);
    }
    return 0;
}

# Clear all routings.
fn mod_matrix_clear(m) {
    vec_truncate(ModMatrix_routings(m), 0);
    return 0;
}

# Set a source value for the current frame.
fn mod_matrix_set_source(m, source, value) {
    vec_set(ModMatrix_source_values(m), source, value);
    return 0;
}

# Compute all destination modulation amounts from the current sources.
# Call once per frame after every set_source. Zeroes the dest scratch,
# then sums src_val * depth into each destination over enabled routings.
fn mod_matrix_compute(m) {
    var dst = ModMatrix_destination_values(m);
    var i = 0;
    while (i < MOD_MATRIX_NUM_DESTINATIONS) {
        vec_set(dst, i, 0);
        i = i + 1;
    }
    var src = ModMatrix_source_values(m);
    var routings = ModMatrix_routings(m);
    var n = vec_len(routings);
    var r = 0;
    while (r < n) {
        var routing = vec_get(routings, r);
        if (ModRouting_enabled(routing) == 1) {
            var s = ModRouting_source(routing);
            var d = ModRouting_destination(routing);
            var src_val = vec_get(src, s);
            var mod_amount = f64_mul(src_val, ModRouting_depth(routing));
            vec_set(dst, d, f64_add(vec_get(dst, d), mod_amount));
        }
        r = r + 1;
    }
    return 0;
}

# Total modulation amount for a destination (0.0 if nothing targets it).
#inline
#must_use
fn mod_matrix_get_destination(m, dest) {
    return vec_get(ModMatrix_destination_values(m), dest);
}

# Number of active routings.
#must_use
fn mod_matrix_num_routings(m) {
    return vec_len(ModMatrix_routings(m));
}

# The vec of all routings (ModRouting pointers).
#must_use
fn mod_matrix_routings(m) {
    return ModMatrix_routings(m);
}

# Pointer to a routing by index, or 0 (None) if out of range.
#must_use
fn mod_matrix_routing_mut(m, index) {
    var routings = ModMatrix_routings(m);
    if (index < 0) { return 0; }
    if (index >= vec_len(routings)) { return 0; }
    return vec_get(routings, index);
}

# --- tuning.cyr ---

# tuning.cyr -- tuning and pitch utilities: equal temperament, MIDI note
# <-> frequency, cents, and custom tuning tables (just intonation,
# Pythagorean, etc.).
#
# Ports rust-old/src/tuning.rs. f32 -> f64 throughout. The `TuningSystem`
# enum becomes integer constants; the `TuningTable` struct's fixed
# `[f32; 12]` ratio array becomes a stdlib `vec` of 12 f64 slots. Rust's
# `Result<T>` constructors return the pointer on success or a negative
# `ERR_*` code on the error path (same validation predicates as Rust).
# Serde round-trip test dropped (no serde). Methods become free
# `tuning_*` functions taking the struct pointer.
#
# Requires (from the build/test unit): stdlib alloc/vec, math/ganita
# (F64_ONE/TWO/LN2, f64_pow/ln/round/clamp/...), string/fmt (strlen,
# memcpy, fmt_int_buf for note_name), and error.cyr (ERR_INVALID_PARAMETER,
# naad_is_finite). The module file itself has no `include` lines.

# ================================================================
# TuningSystem -> integer constants (predefined tuning systems).
# ================================================================
var TUNING_EQUAL_TEMPERAMENT = 0;
var TUNING_JUST_INTONATION   = 1;
var TUNING_PYTHAGOREAN       = 2;

# ================================================================
# TuningTable -- custom tuning table with 12 pitch ratios per octave.
#   name   : cstring name of this tuning
#   ratios : vec of 12 f64 ratios (index 0 = unison, 11 = major seventh)
#   a4_hz  : reference frequency for A4 (f64)
# ================================================================
#derive(accessors)
struct TuningTable { name; ratios; a4_hz; }

# ================================================================
# equal_temperament_freq -- frequency of a note in 12-TET.
# Formula: a4_hz * 2^((note - 69) / 12). Note 69 = A4.
# ================================================================
#inline
#must_use
fn tuning_equal_temperament_freq(note, a4_hz) {
    var exp = f64_div(f64_sub(f64_from(note), f64_from(69)), f64_from(12));
    return f64_mul(a4_hz, f64_pow(F64_TWO, exp));
}

# ================================================================
# midi_to_freq -- MIDI note number to frequency in Hz (A4 = 440 Hz).
# ================================================================
#inline
#must_use
fn tuning_midi_to_freq(note) {
    return tuning_equal_temperament_freq(note, f64_from(440));
}

# ================================================================
# freq_to_midi -- frequency in Hz to nearest MIDI note (0-127).
# note = 69 + 12 * log2(freq / 440); rounded and clamped to [0, 127].
# ================================================================
#inline
#must_use
fn tuning_freq_to_midi(freq) {
    if (f64_le(freq, 0) == 1) { return 0; }
    var ratio = f64_div(freq, f64_from(440));
    var log2 = f64_div(f64_ln(ratio), F64_LN2);
    var note = f64_add(f64_from(69), f64_mul(f64_from(12), log2));
    var clamped = f64_clamp(f64_round(note), 0, f64_from(127));
    return f64_to(clamped);
}

# ================================================================
# cents -- interval in cents between two frequencies.
# cents = 1200 * log2(f2 / f1); 100 cents = 1 semitone in 12-TET.
# ================================================================
#inline
#must_use
fn tuning_cents(f1, f2) {
    if (f64_le(f1, 0) == 1) { return 0; }
    if (f64_le(f2, 0) == 1) { return 0; }
    var log2 = f64_div(f64_ln(f64_div(f2, f1)), F64_LN2);
    return f64_mul(f64_from(1200), log2);
}

# ================================================================
# tuning_table_from_system -- build a table from a predefined system.
# ================================================================
#must_use
fn tuning_table_from_system(system, a4_hz) {
    var ratios = vec_new();
    var name = 0;
    if (system == TUNING_EQUAL_TEMPERAMENT) {
        var i = 0;
        while (i < 12) {
            vec_push(ratios, f64_pow(F64_TWO, f64_div(f64_from(i), f64_from(12))));
            i = i + 1;
        }
        name = "Equal Temperament";
    } elif (system == TUNING_JUST_INTONATION) {
        vec_push(ratios, F64_ONE);
        vec_push(ratios, f64_div(f64_from(16), f64_from(15)));
        vec_push(ratios, f64_div(f64_from(9), f64_from(8)));
        vec_push(ratios, f64_div(f64_from(6), f64_from(5)));
        vec_push(ratios, f64_div(f64_from(5), f64_from(4)));
        vec_push(ratios, f64_div(f64_from(4), f64_from(3)));
        vec_push(ratios, f64_div(f64_from(45), f64_from(32)));
        vec_push(ratios, f64_div(f64_from(3), f64_from(2)));
        vec_push(ratios, f64_div(f64_from(8), f64_from(5)));
        vec_push(ratios, f64_div(f64_from(5), f64_from(3)));
        vec_push(ratios, f64_div(f64_from(9), f64_from(5)));
        vec_push(ratios, f64_div(f64_from(15), f64_from(8)));
        name = "Just Intonation";
    } else {
        vec_push(ratios, F64_ONE);
        vec_push(ratios, f64_div(f64_from(256), f64_from(243)));
        vec_push(ratios, f64_div(f64_from(9), f64_from(8)));
        vec_push(ratios, f64_div(f64_from(32), f64_from(27)));
        vec_push(ratios, f64_div(f64_from(81), f64_from(64)));
        vec_push(ratios, f64_div(f64_from(4), f64_from(3)));
        vec_push(ratios, f64_div(f64_from(729), f64_from(512)));
        vec_push(ratios, f64_div(f64_from(3), f64_from(2)));
        vec_push(ratios, f64_div(f64_from(128), f64_from(81)));
        vec_push(ratios, f64_div(f64_from(27), f64_from(16)));
        vec_push(ratios, f64_div(f64_from(16), f64_from(9)));
        vec_push(ratios, f64_div(f64_from(243), f64_from(128)));
        name = "Pythagorean";
    }
    var t = alloc(sizeof(TuningTable));
    TuningTable_set_name(t, name);
    TuningTable_set_ratios(t, ratios);
    TuningTable_set_a4_hz(t, a4_hz);
    return t;
}

# ================================================================
# tuning_table_custom -- build a custom table with validation.
# Returns ERR_INVALID_PARAMETER if a4_hz <= 0 / non-finite, or if any
# ratio is <= 0 / non-finite; otherwise returns the table pointer.
# ================================================================
#must_use
fn tuning_table_custom(name, ratios, a4_hz) {
    if (f64_le(a4_hz, 0) == 1) { return ERR_INVALID_PARAMETER; }
    if (naad_is_finite(a4_hz) == 0) { return ERR_INVALID_PARAMETER; }
    var n = vec_len(ratios);
    var i = 0;
    while (i < n) {
        var r = vec_get(ratios, i);
        if (f64_le(r, 0) == 1) { return ERR_INVALID_PARAMETER; }
        if (naad_is_finite(r) == 0) { return ERR_INVALID_PARAMETER; }
        i = i + 1;
    }
    var t = alloc(sizeof(TuningTable));
    TuningTable_set_name(t, name);
    TuningTable_set_ratios(t, ratios);
    TuningTable_set_a4_hz(t, a4_hz);
    return t;
}

# ================================================================
# tuning_note_to_freq -- frequency for a MIDI note using this table.
# Note 69 = A4 (degree 9 in the octave). Euclidean division picks the
# octave; the Euclidean remainder selects the ratio. a4_degree.div_euclid
# (12) == 0, so the octave power exponent is simply `octave`.
# ================================================================
#must_use
fn tuning_note_to_freq(self, note) {
    var ratios = TuningTable_ratios(self);
    var a4_hz = TuningTable_a4_hz(self);

    # a4_degree (9) + (note - 69) == note - 60.
    var total_degree = note - 60;
    # rem_euclid(12): normalise to [0, 12); div_euclid(12) matches.
    var degree = ((total_degree % 12) + 12) % 12;
    var octave = (total_degree - degree) / 12;

    var ratio = vec_get(ratios, degree);
    var a4_ratio = vec_get(ratios, 9);
    var pow = f64_pow(F64_TWO, f64_from(octave));
    return f64_mul(f64_mul(a4_hz, f64_div(ratio, a4_ratio)), pow);
}

# ================================================================
# tuning_note_name -- MIDI note number to a name string ("A4", "C#5").
# octave = note / 12 - 1; name index = note % 12. Returns a freshly
# allocated null-terminated cstring.
# ================================================================
#must_use
fn tuning_note_name(note) {
    var name = tuning_note_name_str(note % 12);
    var octave = (note / 12) - 1;
    var buf = alloc(16);
    var nl = strlen(name);
    memcpy(buf, name, nl);
    var tmp = alloc(24);
    var ol = fmt_int_buf(octave, tmp);
    memcpy(buf + nl, tmp, ol);
    store8(buf + nl + ol, 0);
    return buf;
}

# Pitch-class name for a semitone index 0..11 (C, C#, D, ...).
#must_use
fn tuning_note_name_str(idx) {
    if (idx == 0) { return "C"; }
    if (idx == 1) { return "C#"; }
    if (idx == 2) { return "D"; }
    if (idx == 3) { return "D#"; }
    if (idx == 4) { return "E"; }
    if (idx == 5) { return "F"; }
    if (idx == 6) { return "F#"; }
    if (idx == 7) { return "G"; }
    if (idx == 8) { return "G#"; }
    if (idx == 9) { return "A"; }
    if (idx == 10) { return "A#"; }
    return "B";
}

# --- voice.cyr ---

# voice.cyr -- Voice management for polyphonic synthesis.
#
# Ports rust-old/src/voice.rs. Provides voice allocation, stealing, and
# per-voice state tracking for polyphonic instruments. f32 -> f64 for
# velocity/amplitude/pitch_bend/pressure/brightness; bool -> i64 0/1;
# u8 note / u64 age stored directly in i64 slots. The `SmallVec` voice pool
# becomes a stdlib `vec` of `Voice` pointers. Rust's serde derives are
# dropped (no serde in Cyrius). `PolyMode` / `StealMode` enums become integer
# constants. `Option<usize>` returns use -1 as the None sentinel (valid voice
# indices are always >= 0).
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_HALF).
# The module file itself has no `include` lines.

# ================================================================
# Enums -> integer constants.
# ================================================================

# PolyMode: polyphony mode.
var POLY_MODE_POLY   = 0;   # each note gets its own voice
var POLY_MODE_MONO   = 1;   # one note at a time, retrigger on new note
var POLY_MODE_LEGATO = 2;   # monophonic, glide without retriggering

# StealMode: voice stealing strategy when all voices are in use.
var STEAL_MODE_OLDEST   = 0;   # steal the oldest active voice
var STEAL_MODE_QUIETEST = 1;   # steal the quietest active voice
var STEAL_MODE_LOWEST   = 2;   # steal the voice with the lowest note
var STEAL_MODE_NONE     = 3;   # do not steal -- ignore new notes when full

# None sentinel for Option<usize> returns (valid indices are >= 0).
var VOICE_NONE = (0 - 1);

# Default brightness (MIDI 2.0 CC74) = 0.5.
var VOICE_DEFAULT_BRIGHTNESS = 0x3FE0000000000000;   # 0.5

# u64::MAX sentinel for the saturating age counter.
var VOICE_AGE_MAX = (0 - 1);

# ================================================================
# Voice -- state of a single voice.
#   active     : whether the voice is producing sound (0/1)
#   note       : MIDI note number 0-127
#   velocity   : f64 in [0,1]
#   age        : u64 sample counter (incremented while active)
#   amplitude  : f64 current amplitude (quietest-steal heuristic)
#   pitch_bend : f64 per-note pitch bend in semitones (MIDI 2.0)
#   pressure   : f64 per-note aftertouch in [0,1]
#   brightness : f64 per-note brightness in [0,1] (MIDI 2.0 CC74)
# ================================================================
#derive(accessors)
struct Voice { active; note; velocity; age; amplitude; pitch_bend; pressure; brightness; }

# Default voice: inactive, note 0, zeroed dynamics, brightness 0.5.
#must_use
fn voice_default() {
    var v = alloc(sizeof(Voice));
    Voice_set_active(v, 0);
    Voice_set_note(v, 0);
    Voice_set_velocity(v, 0);
    Voice_set_age(v, 0);
    Voice_set_amplitude(v, 0);
    Voice_set_pitch_bend(v, 0);
    Voice_set_pressure(v, 0);
    Voice_set_brightness(v, VOICE_DEFAULT_BRIGHTNESS);
    return v;
}

# Whether this voice is currently active (producing sound).
#inline
#must_use
fn voice_is_active(v) {
    return Voice_active(v);
}

# ================================================================
# VoiceManager -- voice allocation and stealing.
#   voices     : vec of Voice pointers (the pool)
#   max_voices : usize maximum polyphony (clamped 1..128)
#   poly_mode  : PolyMode constant
#   steal_mode : StealMode constant
# ================================================================
#derive(accessors)
struct VoiceManager { voices; max_voices; poly_mode; steal_mode; }

# Create a new voice manager. `max_voices` is clamped to 1..128.
#must_use
fn voice_manager_new(max_voices, poly_mode, steal_mode) {
    var n = max_voices;
    if (n < 1) { n = 1; }
    if (n > 128) { n = 128; }
    var voices = vec_new();
    var i = 0;
    while (i < n) {
        vec_push(voices, voice_default());
        i = i + 1;
    }
    var vm = alloc(sizeof(VoiceManager));
    VoiceManager_set_voices(vm, voices);
    VoiceManager_set_max_voices(vm, n);
    VoiceManager_set_poly_mode(vm, poly_mode);
    VoiceManager_set_steal_mode(vm, steal_mode);
    return vm;
}

# Allocate a voice for a new note. Returns the voice index, or VOICE_NONE.
#
# Poly mode: find a free voice or steal one. Mono/Legato: always voice 0.
#must_use
fn voice_manager_note_on(vm, note, velocity) {
    var mode = VoiceManager_poly_mode(vm);
    var voices = VoiceManager_voices(vm);
    if (mode == POLY_MODE_MONO || mode == POLY_MODE_LEGATO) {
        var v = vec_get(voices, 0);
        Voice_set_active(v, 1);
        Voice_set_note(v, note);
        Voice_set_velocity(v, velocity);
        Voice_set_age(v, 0);
        return 0;
    }

    # Poly: first, find a free voice.
    var n = vec_len(voices);
    var i = 0;
    while (i < n) {
        var vf = vec_get(voices, i);
        if (Voice_active(vf) == 0) {
            Voice_set_active(vf, 1);
            Voice_set_note(vf, note);
            Voice_set_velocity(vf, velocity);
            Voice_set_age(vf, 0);
            return i;
        }
        i = i + 1;
    }

    # All voices busy -- steal.
    var idx = voice_manager_find_steal_target(vm);
    if (idx == VOICE_NONE) { return VOICE_NONE; }
    var vs = vec_get(voices, idx);
    Voice_set_active(vs, 1);
    Voice_set_note(vs, note);
    Voice_set_velocity(vs, velocity);
    Voice_set_age(vs, 0);
    return idx;
}

# Release a voice by note number. Returns the released index, or VOICE_NONE.
fn voice_manager_note_off(vm, note) {
    var voices = VoiceManager_voices(vm);
    var n = vec_len(voices);
    var i = 0;
    while (i < n) {
        var v = vec_get(voices, i);
        if (Voice_active(v) == 1 && Voice_note(v) == note) {
            Voice_set_active(v, 0);
            return i;
        }
        i = i + 1;
    }
    return VOICE_NONE;
}

# Find a voice to steal based on the current steal mode.
# Returns the target index, or VOICE_NONE when no target exists.
#
# Tie-breaking mirrors Rust's iterator adaptors exactly:
#   Oldest   -> max_by_key(age): last element on ties.
#   Quietest -> min_by(amplitude): first element on ties.
#   Lowest   -> min_by_key(note): first element on ties.
#must_use
fn voice_manager_find_steal_target(vm) {
    var mode = VoiceManager_steal_mode(vm);
    var voices = VoiceManager_voices(vm);
    var n = vec_len(voices);

    if (mode == STEAL_MODE_NONE) { return VOICE_NONE; }

    if (mode == STEAL_MODE_OLDEST) {
        var best = VOICE_NONE;
        var best_age = 0;
        var i = 0;
        while (i < n) {
            var v = vec_get(voices, i);
            if (Voice_active(v) == 1) {
                var a = Voice_age(v);
                # >= keeps updating on ties -> last maximum, per max_by_key.
                if (best == VOICE_NONE || a >= best_age) {
                    best = i;
                    best_age = a;
                }
            }
            i = i + 1;
        }
        return best;
    }

    if (mode == STEAL_MODE_QUIETEST) {
        var best = VOICE_NONE;
        var best_amp = 0;
        var i = 0;
        while (i < n) {
            var v = vec_get(voices, i);
            if (Voice_active(v) == 1) {
                var amp = Voice_amplitude(v);
                # strictly-less keeps the first minimum, per min_by.
                if (best == VOICE_NONE || f64_lt(amp, best_amp) == 1) {
                    best = i;
                    best_amp = amp;
                }
            }
            i = i + 1;
        }
        return best;
    }

    # STEAL_MODE_LOWEST: min_by_key(note), first minimum on ties.
    var best = VOICE_NONE;
    var best_note = 0;
    var i = 0;
    while (i < n) {
        var v = vec_get(voices, i);
        if (Voice_active(v) == 1) {
            var note = Voice_note(v);
            if (best == VOICE_NONE || note < best_note) {
                best = i;
                best_note = note;
            }
        }
        i = i + 1;
    }
    return best;
}

# Advance age counters for all active voices (call once per sample/buffer).
# age uses saturating_add(1) at u64::MAX, matching Rust.
fn voice_manager_tick(vm) {
    var voices = VoiceManager_voices(vm);
    var n = vec_len(voices);
    var i = 0;
    while (i < n) {
        var v = vec_get(voices, i);
        if (Voice_active(v) == 1) {
            var a = Voice_age(v);
            if (a != VOICE_AGE_MAX) { Voice_set_age(v, a + 1); }
        }
        i = i + 1;
    }
    return 0;
}

# Number of currently active voices.
#must_use
fn voice_manager_active_count(vm) {
    var voices = VoiceManager_voices(vm);
    var n = vec_len(voices);
    var count = 0;
    var i = 0;
    while (i < n) {
        if (Voice_active(vec_get(voices, i)) == 1) { count = count + 1; }
        i = i + 1;
    }
    return count;
}

# Shared reference to the voice pool (the underlying vec handle).
#inline
#must_use
fn voice_manager_voices(vm) {
    return VoiceManager_voices(vm);
}

# Mutable reference to a voice by index, or 0 (null) if out of bounds.
#inline
fn voice_manager_voice_mut(vm, index) {
    var voices = VoiceManager_voices(vm);
    if (index < 0 || index >= vec_len(voices)) { return 0; }
    return vec_get(voices, index);
}

# Maximum polyphony.
#must_use
fn voice_manager_max_voices(vm) {
    return VoiceManager_max_voices(vm);
}

# Release all voices.
fn voice_manager_all_notes_off(vm) {
    var voices = VoiceManager_voices(vm);
    var n = vec_len(voices);
    var i = 0;
    while (i < n) {
        Voice_set_active(vec_get(voices, i), 0);
        i = i + 1;
    }
    return 0;
}

# --- smoothing.cyr ---

# smoothing.cyr -- parameter smoothing for click-free transitions.
#
# Ports rust-old/src/smoothing.rs. f32 -> f64 throughout; the serde derive is
# dropped (no serde in Cyrius). ParamSmoother is a one-pole exponential
# smoother (EMA) whose coefficient is derived from a time constant and the
# sample rate. Methods become free `smoothing_*` functions taking the struct
# pointer. Non-integer float literals are named IEEE-754 hex constants.
#
# Requires (from the build/test unit): stdlib alloc + math/ganita
# (F64_ONE, f64_max/add/sub/mul/div/neg/exp/abs/gt/lt) and error.cyr
# (flush_denormal, naad_is_finite). The module file has no `include` lines.

# is_settled tolerance: |current - target| < 1e-6.
var SMOOTHING_SETTLE_EPS = 0x3EB0C6F7A0B5ED8D;   # 1e-6

# ================================================================
# ParamSmoother -- one-pole exponential parameter smoother.
#   current      : current smoothed value
#   target       : target value
#   coeff        : smoothing coefficient in (0, 1], higher = faster
#   sample_rate  : sample rate in Hz
#   smooth_time  : smoothing time constant in seconds
# ================================================================
#derive(accessors)
struct ParamSmoother { current; target; coeff; sample_rate; smooth_time; }

# coeff = 1 - exp(-1 / (time * sample_rate)) when time > 0, else 1.0 (instant).
#must_use
fn _smoothing_coeff(time, sample_rate) {
    if (f64_gt(time, 0) == 1) {
        var expo = f64_exp(f64_div(f64_neg(F64_ONE), f64_mul(time, sample_rate)));
        return f64_sub(F64_ONE, expo);
    }
    return F64_ONE;
}

# Create a smoother. `smooth_time` is the time constant in seconds (time to
# reach ~63% of target); `initial_value` is the starting value.
#must_use
fn smoothing_new(smooth_time, sample_rate, initial_value) {
    var time = f64_max(smooth_time, 0);
    var self = alloc(sizeof(ParamSmoother));
    ParamSmoother_set_current(self, initial_value);
    ParamSmoother_set_target(self, initial_value);
    ParamSmoother_set_coeff(self, _smoothing_coeff(time, sample_rate));
    ParamSmoother_set_sample_rate(self, sample_rate);
    ParamSmoother_set_smooth_time(self, time);
    return self;
}

# Set a new target value. Non-finite values are ignored.
fn smoothing_set_target(self, target) {
    if (naad_is_finite(target) == 1) {
        ParamSmoother_set_target(self, target);
    }
    return 0;
}

# Advance one sample and return the new smoothed value.
#inline
#must_use
fn smoothing_next_value(self) {
    var cur = ParamSmoother_current(self);
    var delta = f64_sub(ParamSmoother_target(self), cur);
    cur = f64_add(cur, f64_mul(ParamSmoother_coeff(self), delta));
    cur = flush_denormal(cur);
    ParamSmoother_set_current(self, cur);
    return cur;
}

# 1 if the smoother has reached its target (within 1e-6), else 0.
#inline
#must_use
fn smoothing_is_settled(self) {
    var d = f64_abs(f64_sub(ParamSmoother_current(self), ParamSmoother_target(self)));
    if (f64_lt(d, SMOOTHING_SETTLE_EPS) == 1) { return 1; }
    return 0;
}

# Snap immediately to the target value (skip smoothing).
fn smoothing_snap(self) {
    ParamSmoother_set_current(self, ParamSmoother_target(self));
    return 0;
}

# Set the smoothing time (seconds) and recalculate the coefficient.
fn smoothing_set_smooth_time(self, time) {
    var t = f64_max(time, 0);
    ParamSmoother_set_smooth_time(self, t);
    ParamSmoother_set_coeff(self, _smoothing_coeff(t, ParamSmoother_sample_rate(self)));
    return 0;
}

# Current smoothed value without advancing.
#inline
#must_use
fn smoothing_current(self) {
    return ParamSmoother_current(self);
}

# Target value.
#inline
#must_use
fn smoothing_target(self) {
    return ParamSmoother_target(self);
}

# --- delay.cyr ---

# delay.cyr -- Delay lines, comb filters, and allpass delay networks.
#
# Ports rust-old/src/delay.rs. f32 -> f64 throughout. Rust's serde derive on
# DelayLine/CombFilter/AllpassDelay is dropped (no serde in Cyrius). The
# `Vec<f32>` ring buffer becomes a stdlib `vec` holding an f64 bit pattern per
# slot; usize cursors are plain ints. Methods become free `delay_*`,
# `comb_*`, `allpass_*` functions taking the struct pointer.
#
# Requires (from the build/test unit): stdlib alloc/vec (alloc_init, vec_*),
# math/ganita (F64_ONE, f64_*), and error.cyr (flush_denormal). The module
# file itself has no `include` lines.

# ================================================================
# Float literals (IEEE-754 bit patterns) used by the constructors.
# ================================================================
var DELAY_STABLE_HI = 0x3FEFF7CED916872B;   #  0.999 (feedback/coeff clamp hi)
var DELAY_STABLE_LO = 0xBFEFF7CED916872B;   # -0.999 (feedback/coeff clamp lo)

# ================================================================
# DelayLine -- circular buffer delay line with fractional read.
#   buffer            : vec<f32> ring buffer
#   write_pos         : current write cursor (usize)
#   max_delay_samples : buffer length in samples (usize, >= 1)
# ================================================================
#derive(accessors)
struct DelayLine { buffer; write_pos; max_delay_samples; }

# Create a delay line with the given maximum delay in samples (min 1).
#must_use
fn delay_line_new(max_delay_samples) {
    var size = max_delay_samples;
    if (size < 1) { size = 1; }
    var buffer = vec_new();
    var i = 0;
    while (i < size) {
        vec_push(buffer, 0);
        i = i + 1;
    }
    var dl = alloc(sizeof(DelayLine));
    DelayLine_set_buffer(dl, buffer);
    DelayLine_set_write_pos(dl, 0);
    DelayLine_set_max_delay_samples(dl, size);
    return dl;
}

# Write a sample into the delay line, advancing (and wrapping) the cursor.
#inline
fn delay_line_write(dl, sample) {
    var buffer = DelayLine_buffer(dl);
    var wp = DelayLine_write_pos(dl);
    var max = DelayLine_max_delay_samples(dl);
    vec_set(buffer, wp, sample);
    wp = wp + 1;
    if (wp >= max) { wp = 0; }
    DelayLine_set_write_pos(dl, wp);
    return 0;
}

# Read from the delay line with fractional delay (linear interpolation).
# `delay` is in samples (may be fractional); clamped to the valid range.
#inline
#must_use
fn delay_line_read(dl, delay) {
    var buffer = DelayLine_buffer(dl);
    var wp = DelayLine_write_pos(dl);
    var max = DelayLine_max_delay_samples(dl);

    var delay_clamped = f64_clamp(delay, 0, f64_from(max - 1));
    var delay_floor = f64_floor(delay_clamped);
    var frac = f64_sub(delay_clamped, delay_floor);

    # (write_pos - delay_floor - 1).rem_euclid(max); max >= 1 so emulate with %.
    var idx = wp - f64_to(delay_floor) - 1;
    var read_pos_0 = idx % max;
    if (read_pos_0 < 0) { read_pos_0 = read_pos_0 + max; }
    var read_pos_1 = read_pos_0 - 1;
    if (read_pos_0 == 0) { read_pos_1 = max - 1; }

    var a = f64_mul(vec_get(buffer, read_pos_0), f64_sub(F64_ONE, frac));
    var b = f64_mul(vec_get(buffer, read_pos_1), frac);
    return f64_add(a, b);
}

# Clear the delay line to silence.
fn delay_line_clear(dl) {
    var buffer = DelayLine_buffer(dl);
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, 0);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# CombFilter -- feedback comb: y[n] = x[n] + feedback * y[n - delay].
#   delay_line    : DelayLine pointer
#   feedback      : feedback coefficient, clamped to [-0.999, 0.999]
#   delay_samples : delay time in samples (f32)
# ================================================================
#derive(accessors)
struct CombFilter { delay_line; feedback; delay_samples; }

# Create a comb filter; `feedback` clamped to (-1, 1) for stability.
#must_use
fn comb_filter_new(delay_samples, feedback) {
    var cf = alloc(sizeof(CombFilter));
    CombFilter_set_delay_line(cf, delay_line_new(delay_samples));
    CombFilter_set_feedback(cf, f64_clamp(feedback, DELAY_STABLE_LO, DELAY_STABLE_HI));
    CombFilter_set_delay_samples(cf, f64_from(delay_samples));
    return cf;
}

# Process a single sample through the comb filter.
#inline
#must_use
fn comb_filter_process_sample(cf, input) {
    var dl = CombFilter_delay_line(cf);
    var delayed = delay_line_read(dl, CombFilter_delay_samples(cf));
    var output = f64_add(input, f64_mul(CombFilter_feedback(cf), flush_denormal(delayed)));
    delay_line_write(dl, output);
    return output;
}

# ================================================================
# AllpassDelay -- Schroeder allpass (single-buffer):
#   y[n] = -g * x[n] + x[n - D] + g * y[n - D]
# The buffer stores x[n] + g * y[n], halving memory vs a dual-buffer design.
#   delay_line    : DelayLine pointer
#   coefficient   : allpass coefficient, clamped to [-0.999, 0.999]
#   delay_samples : delay time in samples (f32)
# ================================================================
#derive(accessors)
struct AllpassDelay { delay_line; coefficient; delay_samples; }

# Create an allpass delay; `coefficient` clamped to (-1, 1) for stability.
#must_use
fn allpass_delay_new(delay_samples, coefficient) {
    var ap = alloc(sizeof(AllpassDelay));
    AllpassDelay_set_delay_line(ap, delay_line_new(delay_samples));
    AllpassDelay_set_coefficient(ap, f64_clamp(coefficient, DELAY_STABLE_LO, DELAY_STABLE_HI));
    AllpassDelay_set_delay_samples(ap, f64_from(delay_samples));
    return ap;
}

# Returns the allpass coefficient.
#inline
#must_use
fn allpass_delay_coefficient(ap) {
    return AllpassDelay_coefficient(ap);
}

# Returns the delay time in samples.
#inline
#must_use
fn allpass_delay_delay_samples(ap) {
    return AllpassDelay_delay_samples(ap);
}

# Process a single sample through the Schroeder allpass.
#inline
#must_use
fn allpass_delay_process_sample(ap, input) {
    var dl = AllpassDelay_delay_line(ap);
    var g = AllpassDelay_coefficient(ap);
    var delayed = delay_line_read(dl, AllpassDelay_delay_samples(ap));
    var output = f64_add(f64_mul(f64_neg(g), input), delayed);
    # Store x[n] + g * y[n] in the buffer.
    delay_line_write(dl, f64_add(input, f64_mul(g, output)));
    return output;
}

# --- filter.cyr ---

# filter.cyr -- Biquad and state variable filters.
#
# Ports rust-old/src/filter.rs. f32 -> f64 throughout. Implements the Audio
# EQ Cookbook (Robert Bristow-Johnson) biquad coefficient formulas plus a
# Cytomic/Simper state-variable filter with simultaneous LP/HP/BP/Notch
# outputs. The `FilterType` enum becomes integer constants; serde derives are
# dropped; validators return integer ERR_* codes and constructors return the
# struct pointer on success (or a negative ERR_* on failure). Methods become
# free `filter_*` functions taking the struct pointer.
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_ONE/TWO/HALF/PI/TAU, f64_pow) and error.cyr (validate_frequency/
# validate_sample_rate, flush_denormal, naad_is_finite, ERR_*). No `include`.

# ================================================================
# FilterType -> integer constants (was `enum FilterType`).
# ================================================================
var FILTER_LOWPASS   = 0;
var FILTER_HIGHPASS  = 1;
var FILTER_BANDPASS  = 2;
var FILTER_NOTCH     = 3;
var FILTER_ALLPASS   = 4;
var FILTER_LOWSHELF  = 5;
var FILTER_HIGHSHELF = 6;
var FILTER_PEAK      = 7;

# ================================================================
# BiquadFilter -- Direct Form II Transposed biquad.
#   b0,b1,b2,a1,a2 : coefficients (normalized by a0)
#   z1,z2          : state (delay elements)
#   filter_type    : FILTER_* constant
#   sample_rate    : Hz
#   frequency      : cutoff/center Hz
#   q              : resonance (> 0)
#   gain_db        : shelf/peak gain in dB
# ================================================================
#derive(accessors)
struct BiquadFilter { b0; b1; b2; a1; a2; z1; z2; filter_type; sample_rate; frequency; q; gain_db; }

# ================================================================
# SvfOutput -- the four simultaneous state-variable filter outputs.
# ================================================================
#derive(accessors)
struct SvfOutput { low_pass; high_pass; band_pass; notch; }

# ================================================================
# StateVariableFilter -- Cytomic/Simper SVF; cached coefficients.
#   frequency,q,sample_rate : parameters
#   g,k,a1,a2,a3            : cached coefficients
#   ic1eq,ic2eq             : internal integrator state
# ================================================================
#derive(accessors)
struct StateVariableFilter { frequency; q; sample_rate; g; k; a1; a2; a3; ic1eq; ic2eq; }

# ================================================================
# Biquad constructors.
# ================================================================

# Create a biquad filter with gain (shelf/peak types). Returns the struct
# pointer on success, or a negative ERR_* on invalid sample_rate/frequency/q.
#must_use
fn filter_biquad_with_gain(filter_type, sample_rate, frequency, q, gain_db) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    e = validate_frequency(frequency, sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    if (f64_le(q, 0) == 1) { return ERR_INVALID_PARAMETER; }
    if (naad_is_finite(q) == 0) { return ERR_INVALID_PARAMETER; }

    var self = alloc(sizeof(BiquadFilter));
    BiquadFilter_set_b0(self, F64_ONE);
    BiquadFilter_set_b1(self, 0);
    BiquadFilter_set_b2(self, 0);
    BiquadFilter_set_a1(self, 0);
    BiquadFilter_set_a2(self, 0);
    BiquadFilter_set_z1(self, 0);
    BiquadFilter_set_z2(self, 0);
    BiquadFilter_set_filter_type(self, filter_type);
    BiquadFilter_set_sample_rate(self, sample_rate);
    BiquadFilter_set_frequency(self, frequency);
    BiquadFilter_set_q(self, q);
    BiquadFilter_set_gain_db(self, gain_db);
    filter_biquad_compute_coefficients(self);
    return self;
}

# Create a biquad filter (gain_db = 0.0). Returns pointer or negative ERR_*.
#must_use
fn filter_biquad_new(filter_type, sample_rate, frequency, q) {
    return filter_biquad_with_gain(filter_type, sample_rate, frequency, q, 0);
}

# ================================================================
# filter_biquad_compute_coefficients -- Audio EQ Cookbook coefficients.
# ================================================================
fn filter_biquad_compute_coefficients(self) {
    var frequency = BiquadFilter_frequency(self);
    var sample_rate = BiquadFilter_sample_rate(self);
    var q = BiquadFilter_q(self);
    var gain_db = BiquadFilter_gain_db(self);
    var ft = BiquadFilter_filter_type(self);

    var w0 = f64_div(f64_mul(F64_TAU, frequency), sample_rate);
    var cos_w0 = f64_cos(w0);
    var sin_w0 = f64_sin(w0);
    var alpha = f64_div(sin_w0, f64_mul(F64_TWO, q));
    var neg2 = f64_neg(F64_TWO);

    var b0 = 0;
    var b1 = 0;
    var b2 = 0;
    var a0 = 0;
    var a1 = 0;
    var a2 = 0;

    if (ft == FILTER_LOWPASS) {
        b1 = f64_sub(F64_ONE, cos_w0);
        b0 = f64_div(b1, F64_TWO);
        b2 = b0;
        a0 = f64_add(F64_ONE, alpha);
        a1 = f64_mul(neg2, cos_w0);
        a2 = f64_sub(F64_ONE, alpha);
    } elif (ft == FILTER_HIGHPASS) {
        var onepc = f64_add(F64_ONE, cos_w0);
        b0 = f64_div(onepc, F64_TWO);
        b1 = f64_neg(onepc);
        b2 = b0;
        a0 = f64_add(F64_ONE, alpha);
        a1 = f64_mul(neg2, cos_w0);
        a2 = f64_sub(F64_ONE, alpha);
    } elif (ft == FILTER_BANDPASS) {
        b0 = alpha;
        b1 = 0;
        b2 = f64_neg(alpha);
        a0 = f64_add(F64_ONE, alpha);
        a1 = f64_mul(neg2, cos_w0);
        a2 = f64_sub(F64_ONE, alpha);
    } elif (ft == FILTER_NOTCH) {
        b0 = F64_ONE;
        b1 = f64_mul(neg2, cos_w0);
        b2 = F64_ONE;
        a0 = f64_add(F64_ONE, alpha);
        a1 = f64_mul(neg2, cos_w0);
        a2 = f64_sub(F64_ONE, alpha);
    } elif (ft == FILTER_ALLPASS) {
        b0 = f64_sub(F64_ONE, alpha);
        b1 = f64_mul(neg2, cos_w0);
        b2 = f64_add(F64_ONE, alpha);
        a0 = f64_add(F64_ONE, alpha);
        a1 = f64_mul(neg2, cos_w0);
        a2 = f64_sub(F64_ONE, alpha);
    } elif (ft == FILTER_LOWSHELF) {
        # Distinct names per branch: Cyrius shares one scope across all elif
        # bodies, so a repeated `var` name across branches is a duplicate.
        var ls_a = f64_pow(f64_from(10), f64_div(gain_db, f64_from(40)));
        var ls_ts = f64_mul(f64_mul(F64_TWO, f64_sqrt(ls_a)), alpha);
        var ls_ap1 = f64_add(ls_a, F64_ONE);
        var ls_am1 = f64_sub(ls_a, F64_ONE);
        var ls_am1c = f64_mul(ls_am1, cos_w0);
        var ls_ap1c = f64_mul(ls_ap1, cos_w0);
        b0 = f64_mul(ls_a, f64_add(f64_sub(ls_ap1, ls_am1c), ls_ts));
        b1 = f64_mul(f64_mul(F64_TWO, ls_a), f64_sub(ls_am1, ls_ap1c));
        b2 = f64_mul(ls_a, f64_sub(f64_sub(ls_ap1, ls_am1c), ls_ts));
        a0 = f64_add(f64_add(ls_ap1, ls_am1c), ls_ts);
        a1 = f64_mul(neg2, f64_add(ls_am1, ls_ap1c));
        a2 = f64_sub(f64_add(ls_ap1, ls_am1c), ls_ts);
    } elif (ft == FILTER_HIGHSHELF) {
        var hs_a = f64_pow(f64_from(10), f64_div(gain_db, f64_from(40)));
        var hs_ts = f64_mul(f64_mul(F64_TWO, f64_sqrt(hs_a)), alpha);
        var hs_ap1 = f64_add(hs_a, F64_ONE);
        var hs_am1 = f64_sub(hs_a, F64_ONE);
        var hs_am1c = f64_mul(hs_am1, cos_w0);
        var hs_ap1c = f64_mul(hs_ap1, cos_w0);
        b0 = f64_mul(hs_a, f64_add(f64_add(hs_ap1, hs_am1c), hs_ts));
        b1 = f64_mul(f64_mul(neg2, hs_a), f64_add(hs_am1, hs_ap1c));
        b2 = f64_mul(hs_a, f64_sub(f64_add(hs_ap1, hs_am1c), hs_ts));
        a0 = f64_add(f64_sub(hs_ap1, hs_am1c), hs_ts);
        a1 = f64_mul(F64_TWO, f64_sub(hs_am1, hs_ap1c));
        a2 = f64_sub(f64_sub(hs_ap1, hs_am1c), hs_ts);
    } elif (ft == FILTER_PEAK) {
        var pk_a = f64_pow(f64_from(10), f64_div(gain_db, f64_from(40)));
        var pk_aa = f64_mul(alpha, pk_a);
        var pk_ad = f64_div(alpha, pk_a);
        b0 = f64_add(F64_ONE, pk_aa);
        b1 = f64_mul(neg2, cos_w0);
        b2 = f64_sub(F64_ONE, pk_aa);
        a0 = f64_add(F64_ONE, pk_ad);
        a1 = f64_mul(neg2, cos_w0);
        a2 = f64_sub(F64_ONE, pk_ad);
    }

    var inv_a0 = f64_div(F64_ONE, a0);
    BiquadFilter_set_b0(self, f64_mul(b0, inv_a0));
    BiquadFilter_set_b1(self, f64_mul(b1, inv_a0));
    BiquadFilter_set_b2(self, f64_mul(b2, inv_a0));
    BiquadFilter_set_a1(self, f64_mul(a1, inv_a0));
    BiquadFilter_set_a2(self, f64_mul(a2, inv_a0));
    return 0;
}

# ================================================================
# filter_biquad_process_sample -- Direct Form II Transposed; denormal-flushed.
# ================================================================
#inline
#must_use
fn filter_biquad_process_sample(self, input) {
    var b0 = BiquadFilter_b0(self);
    var b1 = BiquadFilter_b1(self);
    var b2 = BiquadFilter_b2(self);
    var a1 = BiquadFilter_a1(self);
    var a2 = BiquadFilter_a2(self);
    var z1 = BiquadFilter_z1(self);
    var z2 = BiquadFilter_z2(self);

    var output = f64_add(f64_mul(b0, input), z1);
    var new_z1 = flush_denormal(f64_add(f64_sub(f64_mul(b1, input), f64_mul(a1, output)), z2));
    var new_z2 = flush_denormal(f64_sub(f64_mul(b2, input), f64_mul(a2, output)));
    BiquadFilter_set_z1(self, new_z1);
    BiquadFilter_set_z2(self, new_z2);
    return output;
}

# ================================================================
# filter_biquad_set_params -- update parameters + recompute. Returns ERR_NONE
# on success, or a negative ERR_* on invalid frequency/q.
# ================================================================
fn filter_biquad_set_params(self, frequency, q, gain_db) {
    var e = validate_frequency(frequency, BiquadFilter_sample_rate(self));
    if (naad_is_err(e) == 1) { return e; }
    if (f64_le(q, 0) == 1) { return ERR_INVALID_PARAMETER; }
    if (naad_is_finite(q) == 0) { return ERR_INVALID_PARAMETER; }
    BiquadFilter_set_frequency(self, frequency);
    BiquadFilter_set_q(self, q);
    BiquadFilter_set_gain_db(self, gain_db);
    filter_biquad_compute_coefficients(self);
    return ERR_NONE;
}

# ================================================================
# filter_biquad_process_buffer -- process a vec of samples in place.
# ================================================================
#inline
fn filter_biquad_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, filter_biquad_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# filter_biquad_reset -- clear delay line.
# ================================================================
fn filter_biquad_reset(self) {
    BiquadFilter_set_z1(self, 0);
    BiquadFilter_set_z2(self, 0);
    return 0;
}

# ================================================================
# State variable filter.
# ================================================================

# Recompute g/k/a1/a2/a3 from frequency/q/sample_rate.
fn _filter_svf_compute(self) {
    var frequency = StateVariableFilter_frequency(self);
    var sample_rate = StateVariableFilter_sample_rate(self);
    var q = StateVariableFilter_q(self);
    var g = f64_tan(f64_div(f64_mul(F64_PI, frequency), sample_rate));
    var k = f64_div(F64_ONE, q);
    var a1 = f64_div(F64_ONE, f64_add(F64_ONE, f64_mul(g, f64_add(g, k))));
    var a2 = f64_mul(g, a1);
    var a3 = f64_mul(g, a2);
    StateVariableFilter_set_g(self, g);
    StateVariableFilter_set_k(self, k);
    StateVariableFilter_set_a1(self, a1);
    StateVariableFilter_set_a2(self, a2);
    StateVariableFilter_set_a3(self, a3);
    return 0;
}

# Create a state variable filter. Returns the struct pointer on success, or a
# negative ERR_* on invalid sample_rate/frequency/q.
#must_use
fn filter_svf_new(frequency, q, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    e = validate_frequency(frequency, sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    if (f64_le(q, 0) == 1) { return ERR_INVALID_PARAMETER; }
    if (naad_is_finite(q) == 0) { return ERR_INVALID_PARAMETER; }

    var self = alloc(sizeof(StateVariableFilter));
    StateVariableFilter_set_frequency(self, frequency);
    StateVariableFilter_set_q(self, q);
    StateVariableFilter_set_sample_rate(self, sample_rate);
    StateVariableFilter_set_ic1eq(self, 0);
    StateVariableFilter_set_ic2eq(self, 0);
    _filter_svf_compute(self);
    return self;
}

# Current cutoff frequency (Hz).
#inline
#must_use
fn filter_svf_frequency(self) {
    return StateVariableFilter_frequency(self);
}

# Current Q factor.
#inline
#must_use
fn filter_svf_q(self) {
    return StateVariableFilter_q(self);
}

# Sample rate (Hz).
#inline
#must_use
fn filter_svf_sample_rate(self) {
    return StateVariableFilter_sample_rate(self);
}

# ================================================================
# filter_svf_set_params -- update frequency/q + recompute. Returns ERR_NONE
# on success, or a negative ERR_* on invalid frequency/q.
# ================================================================
fn filter_svf_set_params(self, frequency, q) {
    var e = validate_frequency(frequency, StateVariableFilter_sample_rate(self));
    if (naad_is_err(e) == 1) { return e; }
    if (f64_le(q, 0) == 1) { return ERR_INVALID_PARAMETER; }
    if (naad_is_finite(q) == 0) { return ERR_INVALID_PARAMETER; }
    StateVariableFilter_set_frequency(self, frequency);
    StateVariableFilter_set_q(self, q);
    _filter_svf_compute(self);
    return ERR_NONE;
}

# ================================================================
# _filter_svf_compute_lowpass -- value-returning SVF core. Advances the
# integrator state (denormal-flushed) and returns only the low-pass output,
# allocating nothing. Shared by the low-pass sample/buffer hot paths so the
# bump allocator does not grow per sample. Numerics are bit-identical to
# filter_svf_process_sample's low_pass field.
# ================================================================
#inline
fn _filter_svf_compute_lowpass(self, input) {
    var a1 = StateVariableFilter_a1(self);
    var a2 = StateVariableFilter_a2(self);
    var a3 = StateVariableFilter_a3(self);
    var ic1eq = StateVariableFilter_ic1eq(self);
    var ic2eq = StateVariableFilter_ic2eq(self);

    var v3 = f64_sub(input, ic2eq);
    var v1 = f64_add(f64_mul(a1, ic1eq), f64_mul(a2, v3));
    var v2 = f64_add(f64_add(ic2eq, f64_mul(a2, ic1eq)), f64_mul(a3, v3));

    StateVariableFilter_set_ic1eq(self, flush_denormal(f64_sub(f64_mul(F64_TWO, v1), ic1eq)));
    StateVariableFilter_set_ic2eq(self, flush_denormal(f64_sub(f64_mul(F64_TWO, v2), ic2eq)));

    return v2;
}

# ================================================================
# filter_svf_process_sample -- one sample -> all four outputs (SvfOutput
# pointer). Integrator state is denormal-flushed. This is a one-shot API;
# the low-pass hot paths use _filter_svf_compute_lowpass to avoid the alloc.
# ================================================================
#inline
#must_use
fn filter_svf_process_sample(self, input) {
    var a1 = StateVariableFilter_a1(self);
    var a2 = StateVariableFilter_a2(self);
    var a3 = StateVariableFilter_a3(self);
    var k = StateVariableFilter_k(self);
    var ic1eq = StateVariableFilter_ic1eq(self);
    var ic2eq = StateVariableFilter_ic2eq(self);

    var v3 = f64_sub(input, ic2eq);
    var v1 = f64_add(f64_mul(a1, ic1eq), f64_mul(a2, v3));
    var v2 = f64_add(f64_add(ic2eq, f64_mul(a2, ic1eq)), f64_mul(a3, v3));

    StateVariableFilter_set_ic1eq(self, flush_denormal(f64_sub(f64_mul(F64_TWO, v1), ic1eq)));
    StateVariableFilter_set_ic2eq(self, flush_denormal(f64_sub(f64_mul(F64_TWO, v2), ic2eq)));

    var low_pass = v2;
    var band_pass = v1;
    var high_pass = f64_sub(f64_sub(input, f64_mul(k, v1)), v2);
    var notch = f64_add(low_pass, high_pass);

    var out = alloc(sizeof(SvfOutput));
    SvfOutput_set_low_pass(out, low_pass);
    SvfOutput_set_high_pass(out, high_pass);
    SvfOutput_set_band_pass(out, band_pass);
    SvfOutput_set_notch(out, notch);
    return out;
}

# ================================================================
# filter_svf_process_sample_lowpass -- convenience: low-pass output only.
# Routes through the value-returning core; allocates nothing.
# ================================================================
#inline
#must_use
fn filter_svf_process_sample_lowpass(self, input) {
    return _filter_svf_compute_lowpass(self, input);
}

# ================================================================
# filter_svf_process_buffer_lowpass -- write low-pass output in place.
# ================================================================
#inline
fn filter_svf_process_buffer_lowpass(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, filter_svf_process_sample_lowpass(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# filter_svf_reset -- clear integrator state.
# ================================================================
fn filter_svf_reset(self) {
    StateVariableFilter_set_ic1eq(self, 0);
    StateVariableFilter_set_ic2eq(self, 0);
    return 0;
}

# --- granular.cyr ---

# granular.cyr -- Granular synthesis engine.
#
# Ports rust-old/src/synth/granular.rs. f32 -> f64 throughout. The
# `GrainWindow` enum becomes integer constants; the fixed `[Grain; 64]`
# pool becomes a stdlib `vec` of Grain struct pointers; the `&mut u32`
# spray PRNG state becomes a pointer to a 64-bit slot (load64/store64)
# driven by dsp_util's xorshift32. Methods become free `granular_*`
# functions taking the engine pointer. serde derives/tests are dropped.
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_* constants, f64_*), and dsp_util.cyr (hermite_interpolate,
# xorshift32_unit_f32). The module file itself has no `include` lines.

# ================================================================
# GrainWindow enum -> integer constants. Window applied to each grain.
# ================================================================
var GRAIN_WINDOW_HANN        = 0;
var GRAIN_WINDOW_GAUSSIAN    = 1;
var GRAIN_WINDOW_TUKEY       = 2;
var GRAIN_WINDOW_RECTANGULAR = 3;

# Maximum number of simultaneous grains.
var GRAIN_MAX_GRAINS = 64;

# Non-integer float literals (IEEE-754 bit patterns).
var GRAIN_C0_4  = 0x3FD999999999999A;   # 0.4  (Gaussian sigma)
var GRAIN_C0_25 = 0x3FD0000000000000;   # 0.25 (Tukey half_alpha)
var GRAIN_C0_1  = 0x3FB999999999999A;   # 0.1  (grain-rate floor)
var GRAIN_C0_01 = 0x3F847AE147AE147B;   # 0.01 (pitch-shift floor)

# ================================================================
# granular_window_value -- window value at position t (0.0..1.0).
# Ports GrainWindow::value.
# ================================================================
#must_use
fn granular_window_value(win, t) {
    var tc = f64_clamp(t, 0, F64_ONE);
    if (win == GRAIN_WINDOW_HANN) {
        # 0.5 * (1 - cos(TAU * t))
        return f64_mul(F64_HALF, f64_sub(F64_ONE, f64_cos(f64_mul(F64_TAU, tc))));
    }
    if (win == GRAIN_WINDOW_GAUSSIAN) {
        # sigma = 0.4, centred at 0.5; exp(-0.5 * x * x)
        var x = f64_div(f64_sub(tc, F64_HALF), GRAIN_C0_4);
        return f64_exp(f64_mul(f64_neg(F64_HALF), f64_mul(x, x)));
    }
    if (win == GRAIN_WINDOW_TUKEY) {
        # Tukey window, alpha = 0.5 -> half_alpha = 0.25.
        var half_alpha = GRAIN_C0_25;
        if (f64_lt(tc, half_alpha) == 1) {
            # Leading taper: 0 -> 1
            var a = f64_div(f64_mul(F64_PI, tc), half_alpha);
            return f64_mul(F64_HALF, f64_sub(F64_ONE, f64_cos(a)));
        }
        if (f64_gt(tc, f64_sub(F64_ONE, half_alpha)) == 1) {
            # Trailing taper: 1 -> 0
            var b = f64_div(f64_mul(F64_PI, f64_add(f64_sub(tc, F64_ONE), half_alpha)), half_alpha);
            return f64_mul(F64_HALF, f64_add(F64_ONE, f64_cos(b)));
        }
        return F64_ONE;
    }
    # Rectangular.
    return F64_ONE;
}

# ================================================================
# Grain -- one windowed slice of the source buffer.
#   source_position  : f64 fractional sample start in the source
#   playback_rate    : f64 (1.0 = normal, 2.0 = octave up)
#   window           : GRAIN_WINDOW_* constant
#   duration_samples : u32 grain lifetime in samples
#   current_sample   : u32 current sample within the grain
#   amplitude        : f64 amplitude scaling
#   active           : 1 if this slot is active, else 0
# ================================================================
#derive(accessors)
struct Grain {
    source_position;
    playback_rate;
    window;
    duration_samples;
    current_sample;
    amplitude;
    active;
}

# Default grain (Grain::default): inactive, unity rate/amplitude, Hann.
#must_use
fn granular_grain_default() {
    var g = alloc(sizeof(Grain));
    Grain_set_source_position(g, 0);
    Grain_set_playback_rate(g, F64_ONE);
    Grain_set_window(g, GRAIN_WINDOW_HANN);
    Grain_set_duration_samples(g, 0);
    Grain_set_current_sample(g, 0);
    Grain_set_amplitude(g, F64_ONE);
    Grain_set_active(g, 0);
    return g;
}

# ================================================================
# GranularEngine -- reads grains from a source buffer with windowing,
# pitch shift (playback rate), time jitter (spray), and grain density.
#   source            : vec<f64> source audio buffer
#   grains            : vec of Grain pointers (fixed pool, GRAIN_MAX_GRAINS)
#   grain_rate        : f64 grains spawned per second
#   grain_duration_ms : f64 grain duration in milliseconds
#   pitch_shift       : f64 pitch shift via playback rate
#   time_position     : f64 current read position (fractional sample)
#   spray             : f64 time jitter amount (in source samples)
#   window            : GRAIN_WINDOW_* for new grains
#   sample_rate       : f64 Hz
#   spawn_accumulator : f64 accumulator for grain spawning
#   rng_state         : pointer to a 64-bit slot holding the u32 PRNG state
# ================================================================
#derive(accessors)
struct GranularEngine {
    source;
    grains;
    grain_rate;
    grain_duration_ms;
    pitch_shift;
    time_position;
    spray;
    window;
    sample_rate;
    spawn_accumulator;
    rng_state;
}

# ================================================================
# granular_new -- new engine with no source loaded. Ports new().
# ================================================================
#must_use
fn granular_new(sample_rate) {
    var e = alloc(sizeof(GranularEngine));
    GranularEngine_set_source(e, vec_new());

    var grains = vec_new();
    var i = 0;
    while (i < GRAIN_MAX_GRAINS) {
        vec_push(grains, granular_grain_default());
        i = i + 1;
    }
    GranularEngine_set_grains(e, grains);

    GranularEngine_set_grain_rate(e, f64_from(20));
    GranularEngine_set_grain_duration_ms(e, f64_from(50));
    GranularEngine_set_pitch_shift(e, F64_ONE);
    GranularEngine_set_time_position(e, 0);
    GranularEngine_set_spray(e, 0);
    GranularEngine_set_window(e, GRAIN_WINDOW_HANN);
    GranularEngine_set_sample_rate(e, sample_rate);
    GranularEngine_set_spawn_accumulator(e, 0);

    var rng = alloc(8);
    store64(rng, 42);
    GranularEngine_set_rng_state(e, rng);
    return e;
}

# ================================================================
# Parameter setters. Ports set_source/set_grain_rate/.../set_window.
# ================================================================

# Load a source audio buffer (vec<f64>); resets the read position.
fn granular_set_source(e, buffer) {
    GranularEngine_set_source(e, buffer);
    GranularEngine_set_time_position(e, 0);
    return 0;
}

# Grain spawn rate (grains/sec), floored at 0.1.
fn granular_set_grain_rate(e, rate) {
    GranularEngine_set_grain_rate(e, f64_max(rate, GRAIN_C0_1));
    return 0;
}

# Grain duration in milliseconds, floored at 1.0.
fn granular_set_grain_duration(e, ms) {
    GranularEngine_set_grain_duration_ms(e, f64_max(ms, F64_ONE));
    return 0;
}

# Playback pitch shift (1.0 = normal), floored at 0.01.
fn granular_set_pitch_shift(e, shift) {
    GranularEngine_set_pitch_shift(e, f64_max(shift, GRAIN_C0_01));
    return 0;
}

# Read position in the source (0.0..1.0 normalised); no-op if source empty.
fn granular_set_position(e, pos) {
    var src = GranularEngine_source(e);
    var n = vec_len(src);
    if (n != 0) {
        var clamped = f64_clamp(pos, 0, F64_ONE);
        GranularEngine_set_time_position(e, f64_mul(clamped, f64_from(n - 1)));
    }
    return 0;
}

# Time jitter (spray) in milliseconds -> stored as source samples.
fn granular_set_spray(e, ms) {
    var spray = f64_mul(f64_div(ms, f64_from(1000)), GranularEngine_sample_rate(e));
    GranularEngine_set_spray(e, spray);
    return 0;
}

# Window function for new grains.
fn granular_set_window(e, win) {
    GranularEngine_set_window(e, win);
    return 0;
}

# ================================================================
# granular_rem_euclid -- Rust f32::rem_euclid for a positive divisor b.
# r = a - trunc(a/b)*b; if r < 0 then r += |b|. Result in [0, b).
# ================================================================
#must_use
fn granular_rem_euclid(a, b) {
    var q = f64_div(a, b);
    var tq = 0;
    if (f64_lt(q, 0) == 1) {
        tq = f64_ceil(q);
    } else {
        tq = f64_floor(q);
    }
    var r = f64_sub(a, f64_mul(tq, b));
    if (f64_lt(r, 0) == 1) {
        r = f64_add(r, f64_abs(b));
    }
    return r;
}

# ================================================================
# granular_next_rng_f32 -- random f64 in [0,1) from the spray PRNG.
# Ports next_rng_f32.
# ================================================================
#must_use
fn granular_next_rng_f32(e) {
    return xorshift32_unit_f32(GranularEngine_rng_state(e));
}

# ================================================================
# granular_spawn_grain -- spawn a new grain in the next free slot.
# Ports spawn_grain. Drops the grain if the pool is full.
# ================================================================
fn granular_spawn_grain(e) {
    var dur_f = f64_mul(f64_div(GranularEngine_grain_duration_ms(e), f64_from(1000)), GranularEngine_sample_rate(e));
    var duration_samples = f64_to(dur_f);

    var grains = GranularEngine_grains(e);
    var ng = vec_len(grains);
    var slot_idx = 0 - 1;
    var i = 0;
    while (i < ng) {
        if (Grain_active(vec_get(grains, i)) == 0) {
            slot_idx = i;
            i = ng;
        } else {
            i = i + 1;
        }
    }
    if (slot_idx < 0) {
        return 0;
    }

    var spray = GranularEngine_spray(e);
    var jitter = 0;
    if (f64_gt(spray, 0) == 1) {
        var r = granular_next_rng_f32(e);
        jitter = f64_mul(f64_mul(f64_sub(r, F64_HALF), F64_TWO), spray);
    }

    var src = GranularEngine_source(e);
    var src_len = f64_from(vec_len(src));
    var pos = granular_rem_euclid(f64_add(GranularEngine_time_position(e), jitter), src_len);

    var g = vec_get(grains, slot_idx);
    Grain_set_source_position(g, pos);
    Grain_set_playback_rate(g, GranularEngine_pitch_shift(e));
    Grain_set_window(g, GranularEngine_window(e));
    Grain_set_duration_samples(g, duration_samples);
    Grain_set_current_sample(g, 0);
    Grain_set_amplitude(g, F64_ONE);
    Grain_set_active(g, 1);
    return 0;
}

# ================================================================
# granular_next_sample -- generate the next output sample.
# Ports next_sample. Spawns grains at the configured rate, then sums
# all active grains (windowed, hermite-interpolated from the source).
# ================================================================
#must_use
fn granular_next_sample(e) {
    var src = GranularEngine_source(e);
    var src_len = vec_len(src);
    if (src_len == 0) {
        return 0;
    }

    # Spawn new grains at the configured rate.
    var acc = GranularEngine_spawn_accumulator(e);
    acc = f64_add(acc, f64_div(GranularEngine_grain_rate(e), GranularEngine_sample_rate(e)));
    while (f64_ge(acc, F64_ONE) == 1) {
        acc = f64_sub(acc, F64_ONE);
        granular_spawn_grain(e);
    }
    GranularEngine_set_spawn_accumulator(e, acc);

    # Sum active grains.
    var sum = 0;
    var src_len_f = f64_from(src_len);
    var grains = GranularEngine_grains(e);
    var ng = vec_len(grains);
    var i = 0;
    while (i < ng) {
        var grain = vec_get(grains, i);
        if (Grain_active(grain) == 1) {
            var dur = Grain_duration_samples(grain);
            var cur = Grain_current_sample(grain);

            # Window position (0..1).
            var t = 0;
            if (dur > 0) {
                t = f64_div(f64_from(cur), f64_from(dur));
            }
            var window_val = granular_window_value(Grain_window(grain), t);

            # Read from source with cubic hermite interpolation.
            var read_pos = f64_add(Grain_source_position(grain), f64_mul(f64_from(cur), Grain_playback_rate(grain)));
            read_pos = granular_rem_euclid(read_pos, src_len_f);
            var floor_pos = f64_floor(read_pos);
            var floor_i = f64_to(floor_pos);
            var idx1 = floor_i % src_len;
            var idx0 = 0;
            if (idx1 == 0) {
                idx0 = src_len - 1;
            } else {
                idx0 = idx1 - 1;
            }
            var idx2 = (idx1 + 1) % src_len;
            var idx3 = (idx1 + 2) % src_len;
            var frac = f64_sub(read_pos, floor_pos);
            var s0 = vec_get(src, idx0);
            var s1 = vec_get(src, idx1);
            var s2 = vec_get(src, idx2);
            var s3 = vec_get(src, idx3);
            var sample = hermite_interpolate(s0, s1, s2, s3, frac);

            sum = f64_add(sum, f64_mul(f64_mul(sample, window_val), Grain_amplitude(grain)));

            cur = cur + 1;
            Grain_set_current_sample(grain, cur);
            if (cur >= dur) {
                Grain_set_active(grain, 0);
            }
        }
        i = i + 1;
    }
    return sum;
}

# ================================================================
# granular_fill_buffer -- fill a vec<f64> with successive samples.
# Ports fill_buffer.
# ================================================================
fn granular_fill_buffer(e, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, granular_next_sample(e));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# granular_is_active -- 1 if the source is loaded AND any grain is
# active, else 0. Ports is_active.
# ================================================================
#must_use
fn granular_is_active(e) {
    var src = GranularEngine_source(e);
    if (vec_len(src) == 0) {
        return 0;
    }
    var grains = GranularEngine_grains(e);
    var n = vec_len(grains);
    var i = 0;
    while (i < n) {
        if (Grain_active(vec_get(grains, i)) == 1) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# --- wavetable.cyr ---

# wavetable.cyr -- Wavetable synthesis with morphing support.
#
# Ports rust-old/src/wavetable.rs. f32 -> f64 throughout. A `Wavetable`
# holds one cycle of a waveform in a stdlib `vec` of f64 samples. The
# `WavetableOscillator` phase-accumulates and reads with linear
# interpolation; `MorphWavetable` linearly blends between a `vec` of
# equal-length wavetables. serde derives/tests are dropped; constructors
# return the struct pointer on success or a negative ERR_* on failure;
# methods become free `wavetable_*` functions taking the struct pointer.
#
# MorphWavetable::next_sample_smooth is the cubic B-spline morph; it wraps
# bspline_eval_1d (in dsp_spectral.cyr, hisab-backed), so ITS test unit adds
# lib/hisab.cyr + src/dsp_spectral.cyr ahead of this module. Every other
# wavetable method is hisab-free (only this one references dsp_spectral).
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_ONE/TWO/HALF/TAU, f64_clamp, f64_sin/floor) and error.cyr
# (validate_frequency/validate_sample_rate, naad_is_err/naad_is_finite,
# ERR_*). The module file itself has no `include` lines.

# ================================================================
# Wavetable -- one cycle of a waveform.
#   samples : vec<f64> waveform samples (one cycle)
# ================================================================
#derive(accessors)
struct Wavetable {
    samples;
}

# ================================================================
# wavetable_from_samples -- build a wavetable from a vec of raw samples.
# Returns the struct pointer, or ERR_INVALID_PARAMETER if `samples` is
# empty. Ports Wavetable::from_samples.
# ================================================================
#must_use
fn wavetable_from_samples(samples) {
    if (vec_len(samples) == 0) {
        return ERR_INVALID_PARAMETER;
    }
    var self = alloc(sizeof(Wavetable));
    Wavetable_set_samples(self, samples);
    return self;
}

# ================================================================
# wavetable_from_harmonics -- build a `size`-sample wavetable by summing
# sine waves at integer multiples of the fundamental, weighted by
# `amplitudes` (a vec of f64). Only the first min(num_harmonics,
# amplitudes.len) harmonics are generated. The result is normalised so its
# peak magnitude is 1.0. Returns the pointer, or ERR_INVALID_PARAMETER if
# num_harmonics == 0, amplitudes is empty, or size == 0.
# Ports Wavetable::from_harmonics.
# ================================================================
#must_use
fn wavetable_from_harmonics(num_harmonics, amplitudes, size) {
    if (num_harmonics == 0) {
        return ERR_INVALID_PARAMETER;
    }
    if (vec_len(amplitudes) == 0) {
        return ERR_INVALID_PARAMETER;
    }
    if (size == 0) {
        return ERR_INVALID_PARAMETER;
    }

    var samples = vec_new();
    var z = 0;
    while (z < size) {
        vec_push(samples, 0);
        z = z + 1;
    }

    var harmonics_to_generate = num_harmonics;
    var alen = vec_len(amplitudes);
    if (alen < harmonics_to_generate) {
        harmonics_to_generate = alen;
    }

    var size_f = f64_from(size);
    var h = 0;
    while (h < harmonics_to_generate) {
        var amp = vec_get(amplitudes, h);
        var harmonic_num = f64_from(h + 1);
        var i = 0;
        while (i < size) {
            var phase = f64_mul(f64_mul(f64_div(f64_from(i), size_f), F64_TAU), harmonic_num);
            var cur = vec_get(samples, i);
            vec_set(samples, i, f64_add(cur, f64_mul(amp, f64_sin(phase))));
            i = i + 1;
        }
        h = h + 1;
    }

    # Normalize to -1..1 (peak magnitude -> 1.0).
    var max_abs = 0;
    var j = 0;
    while (j < size) {
        var a = f64_abs(vec_get(samples, j));
        if (f64_gt(a, max_abs) == 1) {
            max_abs = a;
        }
        j = j + 1;
    }
    if (f64_gt(max_abs, 0) == 1) {
        var k = 0;
        while (k < size) {
            vec_set(samples, k, f64_div(vec_get(samples, k), max_abs));
            k = k + 1;
        }
    }

    var self = alloc(sizeof(Wavetable));
    Wavetable_set_samples(self, samples);
    return self;
}

# ================================================================
# wavetable_samples -- shared reference to the waveform samples (the vec).
# Ports Wavetable::samples.
# ================================================================
#inline
#must_use
fn wavetable_samples(self) {
    return Wavetable_samples(self);
}

# ================================================================
# wavetable_len -- number of samples in the wavetable. Ports Wavetable::len.
# ================================================================
#inline
#must_use
fn wavetable_len(self) {
    return vec_len(Wavetable_samples(self));
}

# ================================================================
# wavetable_is_empty -- 1 if the wavetable has no samples, else 0.
# Ports Wavetable::is_empty.
# ================================================================
#inline
#must_use
fn wavetable_is_empty(self) {
    if (vec_len(Wavetable_samples(self)) == 0) {
        return 1;
    }
    return 0;
}

# ================================================================
# wavetable_read_interpolated -- read a sample at fractional `phase`
# (0.0..1.0) with linear interpolation and wraparound.
# Ports Wavetable::read_interpolated.
# ================================================================
#inline
#must_use
fn wavetable_read_interpolated(self, phase) {
    var samples = Wavetable_samples(self);
    var n = vec_len(samples);
    var len = f64_from(n);
    var index = f64_mul(phase, len);
    var index_floor = f64_floor(index);
    var frac = f64_sub(index, index_floor);

    var floor_i = f64_to(index_floor);
    var i0 = floor_i % n;
    var i1 = (i0 + 1) % n;

    var s0 = vec_get(samples, i0);
    var s1 = vec_get(samples, i1);
    return f64_add(f64_mul(s0, f64_sub(F64_ONE, frac)), f64_mul(s1, frac));
}

# ================================================================
# WavetableOscillator -- reads from a single wavetable via phase accum.
#   table       : Wavetable pointer
#   phase       : f64 current phase (0.0..1.0)
#   sample_rate : f64 Hz
#   frequency   : f64 playback frequency (Hz)
# ================================================================
#derive(accessors)
struct WavetableOscillator {
    table;
    phase;
    sample_rate;
    frequency;
}

# ================================================================
# wavetable_osc_new -- new oscillator over `table`. Returns the pointer,
# or a negative ERR_* on invalid sample_rate/frequency.
# Ports WavetableOscillator::new.
# ================================================================
#must_use
fn wavetable_osc_new(table, frequency, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) {
        return e;
    }
    e = validate_frequency(frequency, sample_rate);
    if (naad_is_err(e) == 1) {
        return e;
    }
    var self = alloc(sizeof(WavetableOscillator));
    WavetableOscillator_set_table(self, table);
    WavetableOscillator_set_phase(self, 0);
    WavetableOscillator_set_sample_rate(self, sample_rate);
    WavetableOscillator_set_frequency(self, frequency);
    return self;
}

# Shared reference to the wavetable. Ports WavetableOscillator::table.
#inline
#must_use
fn wavetable_osc_table(self) {
    return WavetableOscillator_table(self);
}

# Current phase (0.0..1.0). Ports WavetableOscillator::phase.
#inline
#must_use
fn wavetable_osc_phase(self) {
    return WavetableOscillator_phase(self);
}

# Sample rate (Hz). Ports WavetableOscillator::sample_rate.
#inline
#must_use
fn wavetable_osc_sample_rate(self) {
    return WavetableOscillator_sample_rate(self);
}

# Playback frequency (Hz). Ports WavetableOscillator::frequency.
#inline
#must_use
fn wavetable_osc_frequency(self) {
    return WavetableOscillator_frequency(self);
}

# ================================================================
# wavetable_osc_set_frequency -- update playback frequency. Returns
# ERR_NONE on success or a negative ERR_* if invalid for the sample rate.
# Ports WavetableOscillator::set_frequency.
# ================================================================
fn wavetable_osc_set_frequency(self, freq) {
    var e = validate_frequency(freq, WavetableOscillator_sample_rate(self));
    if (naad_is_err(e) == 1) {
        return e;
    }
    WavetableOscillator_set_frequency(self, freq);
    return ERR_NONE;
}

# ================================================================
# wavetable_osc_next_sample -- next sample with linear interpolation,
# advancing the phase accumulator. Ports WavetableOscillator::next_sample.
# ================================================================
#inline
#must_use
fn wavetable_osc_next_sample(self) {
    var sample = wavetable_read_interpolated(WavetableOscillator_table(self), WavetableOscillator_phase(self));

    var phase = f64_add(WavetableOscillator_phase(self),
    f64_div(WavetableOscillator_frequency(self), WavetableOscillator_sample_rate(self)));
    if (f64_ge(phase, F64_ONE) == 1) {
        phase = f64_sub(phase, F64_ONE);
    }
    WavetableOscillator_set_phase(self, phase);
    return sample;
}

# ================================================================
# wavetable_osc_fill_buffer -- fill a vec<f64> with successive samples.
# Ports WavetableOscillator::fill_buffer.
# ================================================================
#inline
fn wavetable_osc_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, wavetable_osc_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# MorphWavetable -- a vec of equal-length wavetables blended by position.
#   tables      : vec of Wavetable pointers
#   position    : f64 morph position (0.0..1.0)
#   phase       : f64 current phase (0.0..1.0)
#   sample_rate : f64 Hz
#   frequency   : f64 playback frequency (Hz)
# ================================================================
#derive(accessors)
struct MorphWavetable {
    tables;
    position;
    phase;
    sample_rate;
    frequency;
}

# ================================================================
# wavetable_morph_new -- new morph wavetable over `tables`. Returns the
# pointer, or a negative ERR_* if tables is empty, the wavetables differ
# in length, or sample_rate/frequency is invalid. Ports MorphWavetable::new.
# ================================================================
#must_use
fn wavetable_morph_new(tables, frequency, sample_rate) {
    var nt = vec_len(tables);
    if (nt == 0) {
        return ERR_INVALID_PARAMETER;
    }
    # All tables must share a length for correct morphing.
    var first_len = wavetable_len(vec_get(tables, 0));
    var i = 0;
    while (i < nt) {
        if (wavetable_len(vec_get(tables, i)) != first_len) {
            return ERR_INVALID_PARAMETER;
        }
        i = i + 1;
    }
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) {
        return e;
    }
    e = validate_frequency(frequency, sample_rate);
    if (naad_is_err(e) == 1) {
        return e;
    }
    var self = alloc(sizeof(MorphWavetable));
    MorphWavetable_set_tables(self, tables);
    MorphWavetable_set_position(self, 0);
    MorphWavetable_set_phase(self, 0);
    MorphWavetable_set_sample_rate(self, sample_rate);
    MorphWavetable_set_frequency(self, frequency);
    return self;
}

# Shared reference to the wavetables (the vec). Ports MorphWavetable::tables.
#inline
#must_use
fn wavetable_morph_tables(self) {
    return MorphWavetable_tables(self);
}

# Current morph position (0.0..1.0). Ports MorphWavetable::position.
#inline
#must_use
fn wavetable_morph_position(self) {
    return MorphWavetable_position(self);
}

# Current phase (0.0..1.0). Ports MorphWavetable::phase.
#inline
#must_use
fn wavetable_morph_phase(self) {
    return MorphWavetable_phase(self);
}

# Sample rate (Hz). Ports MorphWavetable::sample_rate.
#inline
#must_use
fn wavetable_morph_sample_rate(self) {
    return MorphWavetable_sample_rate(self);
}

# Playback frequency (Hz). Ports MorphWavetable::frequency.
#inline
#must_use
fn wavetable_morph_frequency(self) {
    return MorphWavetable_frequency(self);
}

# ================================================================
# wavetable_morph_set_morph -- set the morph position (clamped to 0..1).
# Ports MorphWavetable::set_morph.
# ================================================================
fn wavetable_morph_set_morph(self, position) {
    MorphWavetable_set_position(self, f64_clamp(position, 0, F64_ONE));
    return 0;
}

# ================================================================
# wavetable_morph_next_sample -- next sample, linearly blending the two
# adjacent tables at the current morph position, then advancing the phase.
# Ports MorphWavetable::next_sample.
# ================================================================
#inline
#must_use
fn wavetable_morph_next_sample(self) {
    var tables = MorphWavetable_tables(self);
    var num_tables = vec_len(tables);
    var phase = MorphWavetable_phase(self);

    var sample = 0;
    if (num_tables == 1) {
        sample = wavetable_read_interpolated(vec_get(tables, 0), phase);
    } else {
        var scaled = f64_mul(MorphWavetable_position(self), f64_from(num_tables - 1));
        var idx_low = f64_to(f64_floor(scaled));
        if (idx_low > num_tables - 2) {
            idx_low = num_tables - 2;
        }
        var idx_high = idx_low + 1;
        var frac = f64_sub(scaled, f64_from(idx_low));

        var s_low = wavetable_read_interpolated(vec_get(tables, idx_low), phase);
        var s_high = wavetable_read_interpolated(vec_get(tables, idx_high), phase);
        sample = f64_add(f64_mul(s_low, f64_sub(F64_ONE, frac)), f64_mul(s_high, frac));
    }

    var new_phase = f64_add(phase, f64_div(MorphWavetable_frequency(self), MorphWavetable_sample_rate(self)));
    if (f64_ge(new_phase, F64_ONE) == 1) {
        new_phase = f64_sub(new_phase, F64_ONE);
    }
    MorphWavetable_set_phase(self, new_phase);
    return sample;
}

# wavetable_morph_next_sample_smooth -- cubic B-spline morph across tables.
# Ports MorphWavetable::next_sample_smooth. With < 4 tables, falls back to the
# linear wavetable_morph_next_sample. Otherwise samples every table at the
# current phase and evaluates a degree-3 B-spline across those control points
# at `position`, with a linear blend fallback if bspline_eval_1d returns None
# (NaN sentinel). Requires bspline_eval_1d (dsp_spectral.cyr) + hisab.
#must_use
fn wavetable_morph_next_sample_smooth(self) {
    var tables = MorphWavetable_tables(self);
    var num_tables = vec_len(tables);
    if (num_tables < 4) { return wavetable_morph_next_sample(self); }

    var phase = MorphWavetable_phase(self);
    var position = MorphWavetable_position(self);

    # Control points: each table read at the current phase.
    var cps = vec_new();
    var i = 0;
    while (i < num_tables) {
        vec_push(cps, wavetable_read_interpolated(vec_get(tables, i), phase));
        i = i + 1;
    }

    var sample = bspline_eval_1d(3, cps, position);
    if (naad_is_finite(sample) == 0) {
        # Defensive linear fallback (mirrors next_sample's two-table blend).
        var scaled = f64_mul(position, f64_from(num_tables - 1));
        var idx_low = f64_to(f64_floor(scaled));
        if (idx_low > num_tables - 2) { idx_low = num_tables - 2; }
        var frac = f64_sub(scaled, f64_from(idx_low));
        var s_low = vec_get(cps, idx_low);
        var s_high = vec_get(cps, idx_low + 1);
        sample = f64_add(f64_mul(s_low, f64_sub(F64_ONE, frac)), f64_mul(s_high, frac));
    }

    var new_phase = f64_add(phase, f64_div(MorphWavetable_frequency(self), MorphWavetable_sample_rate(self)));
    if (f64_ge(new_phase, F64_ONE) == 1) { new_phase = f64_sub(new_phase, F64_ONE); }
    MorphWavetable_set_phase(self, new_phase);
    return sample;
}

# --- envelope.cyr ---

# envelope.cyr -- ADSR, multi-stage, and Catmull-Rom envelope generators.
#
# Ports rust-old/src/envelope.rs. f32 -> f64 throughout. serde/Display derives
# dropped. The `EnvelopeState` enum becomes integer `var` constants; validators
# and `Result` constructors return the struct pointer on success or a negative
# ERR_* code on failure (see error.cyr). Methods become free `envelope_*`
# functions on the struct pointer. `Vec<EnvelopeSegment>` / `Vec<EnvelopePoint>`
# -> stdlib `vec`s holding struct pointers.
#
# The Catmull-Rom envelope stays on the canonical hisab implementation: each
# scalar control value is lifted into HVec3.x, run through calc_catmull_rom,
# then HVec3_x taken back -- exactly as the Rust oracle lifts into Vec3::new.
#
# Requires (from the build/test unit): lib/hisab.cyr (hvec3_new / HVec3_x /
# calc_catmull_rom), stdlib alloc/vec + math (F64_ONE, f64_min/clamp), and
# error.cyr (validate_sample_rate, naad_is_err, ERR_*). No `include` lines.

# ================================================================
# EnvelopeState -> integer constants (was `enum EnvelopeState`).
# ================================================================
var ENV_STATE_IDLE    = 0;
var ENV_STATE_ATTACK  = 1;
var ENV_STATE_DECAY   = 2;
var ENV_STATE_SUSTAIN = 3;
var ENV_STATE_RELEASE = 4;

# Default sample rate shared by the `new` constructors (44100 Hz).
var ENV_DEFAULT_SAMPLE_RATE = 44100;

# ================================================================
# Adsr -- Attack/Decay/Sustain/Release generator with linear segments.
#   attack_time,decay_time,release_time : seconds
#   sustain_level                       : 0.0..1.0
#   sample_rate                         : Hz
#   state                               : ENV_STATE_* constant
#   current_value                       : latest output (0.0..1.0)
#   release_start_value                 : value captured at gate_off
#   stage_samples                       : samples spent in the current stage
# ================================================================
#derive(accessors)
struct Adsr {
    attack_time;
    decay_time;
    sustain_level;
    release_time;
    sample_rate;
    state;
    current_value;
    release_start_value;
    stage_samples;
}

# Create an ADSR envelope at an explicit sample rate. Returns the struct
# pointer on success, or a negative ERR_* on invalid parameters/sample rate.
#must_use
fn envelope_adsr_with_sample_rate(attack, decay, sustain, release, sample_rate) {
    if (f64_lt(attack, 0) == 1) { return ERR_INVALID_PARAMETER; }
    if (f64_lt(decay, 0) == 1) { return ERR_INVALID_PARAMETER; }
    # Mirrors Rust `!(0.0..=1.0).contains(&sustain)`: error unless
    # 0 <= sustain <= 1 (so NaN, which fails both bounds, is also rejected).
    var sustain_in_range = 0;
    if (f64_ge(sustain, 0) == 1) {
        if (f64_le(sustain, F64_ONE) == 1) { sustain_in_range = 1; }
    }
    if (sustain_in_range == 0) { return ERR_INVALID_PARAMETER; }
    if (f64_lt(release, 0) == 1) { return ERR_INVALID_PARAMETER; }
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var self = alloc(sizeof(Adsr));
    Adsr_set_attack_time(self, attack);
    Adsr_set_decay_time(self, decay);
    Adsr_set_sustain_level(self, sustain);
    Adsr_set_release_time(self, release);
    Adsr_set_sample_rate(self, sample_rate);
    Adsr_set_state(self, ENV_STATE_IDLE);
    Adsr_set_current_value(self, 0);
    Adsr_set_release_start_value(self, 0);
    Adsr_set_stage_samples(self, 0);
    return self;
}

# Create an ADSR envelope at the default 44100 Hz sample rate.
#must_use
fn envelope_adsr_new(attack, decay, sustain, release) {
    return envelope_adsr_with_sample_rate(attack, decay, sustain, release,
    f64_from(ENV_DEFAULT_SAMPLE_RATE));
}

# Current envelope state (ENV_STATE_* constant).
#inline
#must_use
fn envelope_adsr_state(self) {
    return Adsr_state(self);
}

# Trigger the envelope (note on).
fn envelope_adsr_gate_on(self) {
    Adsr_set_state(self, ENV_STATE_ATTACK);
    Adsr_set_stage_samples(self, 0);
    return 0;
}

# Release the envelope (note off). No-op when idle.
fn envelope_adsr_gate_off(self) {
    if (Adsr_state(self) != ENV_STATE_IDLE) {
        Adsr_set_release_start_value(self, Adsr_current_value(self));
        Adsr_set_state(self, ENV_STATE_RELEASE);
        Adsr_set_stage_samples(self, 0);
    }
    return 0;
}

# Generate the next envelope value (0.0..1.0).
#inline
#must_use
fn envelope_adsr_next_value(self) {
    var sr = Adsr_sample_rate(self);
    var state = Adsr_state(self);
    if (state == ENV_STATE_IDLE) {
        Adsr_set_current_value(self, 0);
    } elif (state == ENV_STATE_ATTACK) {
        var attack_samples = f64_mul(Adsr_attack_time(self), sr);
        if (f64_le(attack_samples, 0) == 1) {
            Adsr_set_current_value(self, F64_ONE);
            Adsr_set_state(self, ENV_STATE_DECAY);
            Adsr_set_stage_samples(self, 0);
        } else {
            var cv = f64_div(Adsr_stage_samples(self), attack_samples);
            Adsr_set_current_value(self, cv);
            Adsr_set_stage_samples(self, f64_add(Adsr_stage_samples(self), F64_ONE));
            if (f64_ge(cv, F64_ONE) == 1) {
                Adsr_set_current_value(self, F64_ONE);
                Adsr_set_state(self, ENV_STATE_DECAY);
                Adsr_set_stage_samples(self, 0);
            }
        }
    } elif (state == ENV_STATE_DECAY) {
        var decay_samples = f64_mul(Adsr_decay_time(self), sr);
        if (f64_le(decay_samples, 0) == 1) {
            Adsr_set_current_value(self, Adsr_sustain_level(self));
            Adsr_set_state(self, ENV_STATE_SUSTAIN);
        } else {
            var progress = f64_div(Adsr_stage_samples(self), decay_samples);
            var cv = f64_add(F64_ONE, f64_mul(f64_sub(Adsr_sustain_level(self), F64_ONE), progress));
            Adsr_set_current_value(self, cv);
            Adsr_set_stage_samples(self, f64_add(Adsr_stage_samples(self), F64_ONE));
            if (f64_le(cv, Adsr_sustain_level(self)) == 1) {
                Adsr_set_current_value(self, Adsr_sustain_level(self));
                Adsr_set_state(self, ENV_STATE_SUSTAIN);
            }
        }
    } elif (state == ENV_STATE_SUSTAIN) {
        Adsr_set_current_value(self, Adsr_sustain_level(self));
    } elif (state == ENV_STATE_RELEASE) {
        var release_samples = f64_mul(Adsr_release_time(self), sr);
        if (f64_le(release_samples, 0) == 1) {
            Adsr_set_current_value(self, 0);
            Adsr_set_state(self, ENV_STATE_IDLE);
        } else {
            var progress = f64_div(Adsr_stage_samples(self), release_samples);
            var cv = f64_mul(Adsr_release_start_value(self), f64_sub(F64_ONE, progress));
            Adsr_set_current_value(self, cv);
            Adsr_set_stage_samples(self, f64_add(Adsr_stage_samples(self), F64_ONE));
            if (f64_le(cv, 0) == 1) {
                Adsr_set_current_value(self, 0);
                Adsr_set_state(self, ENV_STATE_IDLE);
            }
        }
    }
    return Adsr_current_value(self);
}

# Whether the envelope is active (not idle). Returns 1/0.
#must_use
fn envelope_adsr_is_active(self) {
    if (Adsr_state(self) != ENV_STATE_IDLE) { return 1; }
    return 0;
}

# ================================================================
# EnvelopeSegment -- one target/duration segment of a multi-stage envelope.
#   target   : target level (0.0..1.0)
#   duration : seconds
# ================================================================
#derive(accessors)
struct EnvelopeSegment {
    target;
    duration;
}

# Create an envelope segment.
#must_use
fn envelope_segment_new(target, duration) {
    var s = alloc(sizeof(EnvelopeSegment));
    EnvelopeSegment_set_target(s, target);
    EnvelopeSegment_set_duration(s, duration);
    return s;
}

# ================================================================
# MultiStageEnvelope -- arbitrary linear segments.
#   segments            : vec of EnvelopeSegment pointers
#   sample_rate         : Hz
#   current_segment     : index of the active segment
#   current_value       : latest output
#   segment_start_value : value at the start of the current segment
#   stage_samples       : samples spent in the current segment
#   active              : 1 = running, 0 = stopped
# ================================================================
#derive(accessors)
struct MultiStageEnvelope {
    segments;
    sample_rate;
    current_segment;
    current_value;
    segment_start_value;
    stage_samples;
    active;
}

# Create a multi-stage envelope at an explicit sample rate. Returns the struct
# pointer on success, or a negative ERR_* on empty segments / invalid rate.
#must_use
fn envelope_multistage_with_sample_rate(segments, sample_rate) {
    if (vec_len(segments) == 0) { return ERR_INVALID_PARAMETER; }
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var self = alloc(sizeof(MultiStageEnvelope));
    MultiStageEnvelope_set_segments(self, segments);
    MultiStageEnvelope_set_sample_rate(self, sample_rate);
    MultiStageEnvelope_set_current_segment(self, 0);
    MultiStageEnvelope_set_current_value(self, 0);
    MultiStageEnvelope_set_segment_start_value(self, 0);
    MultiStageEnvelope_set_stage_samples(self, 0);
    MultiStageEnvelope_set_active(self, 0);
    return self;
}

# Create a multi-stage envelope at the default 44100 Hz sample rate.
#must_use
fn envelope_multistage_new(segments) {
    return envelope_multistage_with_sample_rate(segments, f64_from(ENV_DEFAULT_SAMPLE_RATE));
}

# Start the envelope from the first segment.
fn envelope_multistage_trigger(self) {
    MultiStageEnvelope_set_current_segment(self, 0);
    MultiStageEnvelope_set_current_value(self, 0);
    MultiStageEnvelope_set_segment_start_value(self, 0);
    MultiStageEnvelope_set_stage_samples(self, 0);
    MultiStageEnvelope_set_active(self, 1);
    return 0;
}

# Generate the next envelope value.
#inline
#must_use
fn envelope_multistage_next_value(self) {
    if (MultiStageEnvelope_active(self) == 0) { return 0; }
    var segments = MultiStageEnvelope_segments(self);
    var cur = MultiStageEnvelope_current_segment(self);
    if (cur >= vec_len(segments)) {
        MultiStageEnvelope_set_active(self, 0);
        return 0;
    }
    var seg = vec_get(segments, cur);
    var seg_samples = f64_mul(EnvelopeSegment_duration(seg), MultiStageEnvelope_sample_rate(self));
    if (f64_le(seg_samples, 0) == 1) {
        MultiStageEnvelope_set_current_value(self, EnvelopeSegment_target(seg));
        MultiStageEnvelope_set_segment_start_value(self, MultiStageEnvelope_current_value(self));
        MultiStageEnvelope_set_current_segment(self, cur + 1);
        MultiStageEnvelope_set_stage_samples(self, 0);
    } else {
        var stage = MultiStageEnvelope_stage_samples(self);
        var progress = f64_min(f64_div(stage, seg_samples), F64_ONE);
        var ssv = MultiStageEnvelope_segment_start_value(self);
        var cv = f64_add(ssv, f64_mul(f64_sub(EnvelopeSegment_target(seg), ssv), progress));
        MultiStageEnvelope_set_current_value(self, cv);
        var newstage = f64_add(stage, F64_ONE);
        MultiStageEnvelope_set_stage_samples(self, newstage);
        if (f64_ge(newstage, seg_samples) == 1) {
            MultiStageEnvelope_set_current_value(self, EnvelopeSegment_target(seg));
            MultiStageEnvelope_set_segment_start_value(self, MultiStageEnvelope_current_value(self));
            MultiStageEnvelope_set_current_segment(self, cur + 1);
            MultiStageEnvelope_set_stage_samples(self, 0);
        }
    }
    return MultiStageEnvelope_current_value(self);
}

# Whether the multi-stage envelope is active. Returns 1/0.
#must_use
fn envelope_multistage_is_active(self) {
    return MultiStageEnvelope_active(self);
}

# ================================================================
# EnvelopePoint -- one time/value control point of a Catmull-Rom envelope.
#   time  : seconds from trigger
#   value : target value at this time
# ================================================================
#derive(accessors)
struct EnvelopePoint {
    time;
    value;
}

# Create an envelope control point.
#must_use
fn envelope_point_new(time, value) {
    var p = alloc(sizeof(EnvelopePoint));
    EnvelopePoint_set_time(p, time);
    EnvelopePoint_set_value(p, value);
    return p;
}

# ================================================================
# CatmullRomEnvelope -- smooth C1-continuous curve through control points.
#   points          : vec of EnvelopePoint pointers, ordered by time
#   sample_rate     : Hz
#   elapsed_samples : samples since trigger
#   active          : 1 = producing values, 0 = stopped
# ================================================================
#derive(accessors)
struct CatmullRomEnvelope {
    points;
    sample_rate;
    elapsed_samples;
    active;
}

# Build a Catmull-Rom envelope from control points (>= 2, strictly increasing
# times). Returns the struct pointer on success, or a negative ERR_* on
# invalid points / non-monotone times / invalid sample rate.
#must_use
fn envelope_catmull_rom_new(points, sample_rate) {
    if (vec_len(points) < 2) { return ERR_INVALID_PARAMETER; }
    var w = 0;
    while (w < vec_len(points) - 1) {
        var a = vec_get(points, w);
        var b = vec_get(points, w + 1);
        if (f64_le(EnvelopePoint_time(b), EnvelopePoint_time(a)) == 1) {
            return ERR_INVALID_PARAMETER;
        }
        w = w + 1;
    }
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var self = alloc(sizeof(CatmullRomEnvelope));
    CatmullRomEnvelope_set_points(self, points);
    CatmullRomEnvelope_set_sample_rate(self, sample_rate);
    CatmullRomEnvelope_set_elapsed_samples(self, 0);
    CatmullRomEnvelope_set_active(self, 0);
    return self;
}

# Start the envelope from t = 0.
fn envelope_catmull_rom_trigger(self) {
    CatmullRomEnvelope_set_elapsed_samples(self, 0);
    CatmullRomEnvelope_set_active(self, 1);
    return 0;
}

# Stop and reset the envelope (next value returns 0).
fn envelope_catmull_rom_release(self) {
    CatmullRomEnvelope_set_active(self, 0);
    return 0;
}

# Generate the next envelope sample (spline value at the current elapsed time).
#inline
#must_use
fn envelope_catmull_rom_next_value(self) {
    if (CatmullRomEnvelope_active(self) == 0) { return 0; }

    var t = f64_div(CatmullRomEnvelope_elapsed_samples(self), CatmullRomEnvelope_sample_rate(self));
    CatmullRomEnvelope_set_elapsed_samples(self,
    f64_add(CatmullRomEnvelope_elapsed_samples(self), F64_ONE));

    var points = CatmullRomEnvelope_points(self);
    var n = vec_len(points);
    var last = vec_get(points, n - 1);
    var last_time = EnvelopePoint_time(last);

    if (f64_ge(t, last_time) == 1) {
        CatmullRomEnvelope_set_active(self, 0);
        return EnvelopePoint_value(last);
    }
    var first = vec_get(points, 0);
    if (f64_le(t, EnvelopePoint_time(first)) == 1) {
        return EnvelopePoint_value(first);
    }

    # Locate the segment [i, i+1] containing t (first k with t < points[k+1].time).
    var i = 0;
    var found = 0;
    var k = 0;
    while (k < n - 1) {
        if (found == 0) {
            var nxt = vec_get(points, k + 1);
            if (f64_lt(t, EnvelopePoint_time(nxt)) == 1) {
                i = k;
                found = 1;
            }
        }
        k = k + 1;
    }

    var p1 = vec_get(points, i);
    var p2 = vec_get(points, i + 1);
    # Phantom endpoints clamp the curve at the boundaries.
    var p0 = p1;
    if (i != 0) { p0 = vec_get(points, i - 1); }
    var p3 = p2;
    if (i + 2 < n) { p3 = vec_get(points, i + 2); }

    var t1 = EnvelopePoint_time(p1);
    var t2 = EnvelopePoint_time(p2);
    var u = f64_clamp(f64_div(f64_sub(t, t1), f64_sub(t2, t1)), 0, F64_ONE);

    # Lift each scalar value into HVec3.x, run hisab's catmull_rom, take .x back.
    var v0 = hvec3_new(EnvelopePoint_value(p0), 0, 0);
    var v1 = hvec3_new(EnvelopePoint_value(p1), 0, 0);
    var v2 = hvec3_new(EnvelopePoint_value(p2), 0, 0);
    var v3 = hvec3_new(EnvelopePoint_value(p3), 0, 0);
    var lifted = calc_catmull_rom(v0, v1, v2, v3, u);
    return HVec3_x(lifted);
}

# Whether the envelope is currently producing values. Returns 1/0.
#must_use
fn envelope_catmull_rom_is_active(self) {
    return CatmullRomEnvelope_active(self);
}

# Number of control points.
#must_use
fn envelope_catmull_rom_num_points(self) {
    return vec_len(CatmullRomEnvelope_points(self));
}

# --- additive.cyr ---

# additive.cyr -- additive synthesis with per-partial control.
#
# Ports rust-old/src/synth/additive.rs. f32 -> f64 throughout. Builds complex
# timbres by summing individually controllable sine partials; the default
# constructor creates a harmonic series with 1/n amplitude rolloff. The DCT
# amplitude-compression pair (compress/restore) wraps hisab num_dct/num_idct
# (in-place, raw f64 buffers). serde/Display derives are dropped; validators
# and constructors return integer ERR_* codes (or the struct pointer / a vec
# handle on success). Methods become free `additive_*` functions.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/TWO/
# HALF/TAU, f64_clamp), hisab (num_dct/num_idct), and error.cyr (naad_is_finite,
# ERR_*). No `include` lines here -- the test entry orders the deps.

# Maximum number of partials supported.
var ADDITIVE_MAX_PARTIALS = 64;

# ================================================================
# Partial -- one sine partial in an AdditiveSynth bank.
#   frequency_ratio : frequency multiplier relative to the fundamental
#   amplitude       : 0.0 .. 1.0
#   phase           : initial phase offset in turns (0..1)
# A partial is amplitude * sin(TAU * (fundamental * frequency_ratio) * t + phase).
# ================================================================
#derive(accessors)
struct Partial { frequency_ratio; amplitude; phase; }

# Build a partial from its three fields.
#must_use
fn additive_partial_new(frequency_ratio, amplitude, phase) {
    var p = alloc(sizeof(Partial));
    Partial_set_frequency_ratio(p, frequency_ratio);
    Partial_set_amplitude(p, amplitude);
    Partial_set_phase(p, phase);
    return p;
}

# ================================================================
# AdditiveSynth -- sums up to 64 sine partials at independent frequency
# ratios relative to the fundamental.
#   fundamental : fundamental frequency in Hz
#   partials    : vec of Partial pointers
#   phases      : vec of running phases (0..1), one per partial
#   sample_rate : Hz
# ================================================================
#derive(accessors)
struct AdditiveSynth { fundamental; partials; phases; sample_rate; }

# ================================================================
# additive_new -- harmonic-series constructor.
#
# Generates `num_partials` harmonics at 1x, 2x, 3x ... with amplitudes of
# 1/1, 1/2, 1/3 ... Partials whose frequency would reach/exceed Nyquist are
# zeroed. `num_partials` is clamped to [1, 64]. Returns the struct pointer on
# success, or a negative ERR_* for an invalid sample rate / fundamental.
# ================================================================
#must_use
fn additive_new(fundamental, num_partials, sample_rate) {
    if (f64_le(sample_rate, 0) == 1) { return ERR_INVALID_SAMPLE_RATE; }
    if (naad_is_finite(sample_rate) == 0) { return ERR_INVALID_SAMPLE_RATE; }
    if (f64_le(fundamental, 0) == 1) { return ERR_INVALID_FREQUENCY; }
    if (naad_is_finite(fundamental) == 0) { return ERR_INVALID_FREQUENCY; }

    var count = num_partials;
    if (count < 1) { count = 1; }
    if (count > ADDITIVE_MAX_PARTIALS) { count = ADDITIVE_MAX_PARTIALS; }
    var nyquist = f64_mul(sample_rate, F64_HALF);

    var partials = vec_new();
    var phases = vec_new();
    var i = 0;
    while (i < count) {
        var ratio = f64_from(i + 1);
        var amp = 0;
        if (f64_lt(f64_mul(fundamental, ratio), nyquist) == 1) {
            amp = f64_div(F64_ONE, ratio);
        }
        vec_push(partials, additive_partial_new(ratio, amp, 0));
        vec_push(phases, 0);
        i = i + 1;
    }

    var self = alloc(sizeof(AdditiveSynth));
    AdditiveSynth_set_fundamental(self, fundamental);
    AdditiveSynth_set_partials(self, partials);
    AdditiveSynth_set_phases(self, phases);
    AdditiveSynth_set_sample_rate(self, sample_rate);
    return self;
}

# ================================================================
# additive_set_fundamental -- set the fundamental frequency.
#
# Returns ERR_INVALID_FREQUENCY if `freq` is <= 0 or non-finite, else
# ERR_NONE. Re-checks Nyquist: zeros any partial whose frequency now
# reaches/exceeds Nyquist.
# ================================================================
fn additive_set_fundamental(self, freq) {
    if (f64_le(freq, 0) == 1) { return ERR_INVALID_FREQUENCY; }
    if (naad_is_finite(freq) == 0) { return ERR_INVALID_FREQUENCY; }
    AdditiveSynth_set_fundamental(self, freq);
    var nyquist = f64_mul(AdditiveSynth_sample_rate(self), F64_HALF);
    var partials = AdditiveSynth_partials(self);
    var n = vec_len(partials);
    var i = 0;
    while (i < n) {
        var p = vec_get(partials, i);
        if (f64_ge(f64_mul(freq, Partial_frequency_ratio(p)), nyquist) == 1) {
            Partial_set_amplitude(p, 0);
        }
        i = i + 1;
    }
    return ERR_NONE;
}

# ================================================================
# additive_set_partial -- configure an individual partial by index.
#
# Amplitude is clamped to 0.0 if the partial frequency reaches/exceeds
# Nyquist, else clamped to [0.0, 1.0]. Does nothing if `index` is out of
# range. Returns ERR_NONE.
# ================================================================
fn additive_set_partial(self, index, freq_ratio, amplitude) {
    var partials = AdditiveSynth_partials(self);
    if (index < 0 || index >= vec_len(partials)) { return ERR_NONE; }
    var p = vec_get(partials, index);
    Partial_set_frequency_ratio(p, freq_ratio);
    var nyquist = f64_mul(AdditiveSynth_sample_rate(self), F64_HALF);
    if (f64_ge(f64_mul(AdditiveSynth_fundamental(self), freq_ratio), nyquist) == 1) {
        Partial_set_amplitude(p, 0);
    } else {
        Partial_set_amplitude(p, f64_clamp(amplitude, 0, F64_ONE));
    }
    return ERR_NONE;
}

# Number of partials.
#must_use
fn additive_num_partials(self) {
    return vec_len(AdditiveSynth_partials(self));
}

# Fundamental frequency in Hz.
#must_use
fn additive_fundamental(self) {
    return AdditiveSynth_fundamental(self);
}

# ================================================================
# additive_next_sample -- generate the next output sample.
# ================================================================
#inline
#must_use
fn additive_next_sample(self) {
    var partials = AdditiveSynth_partials(self);
    var phases = AdditiveSynth_phases(self);
    var fundamental = AdditiveSynth_fundamental(self);
    var sample_rate = AdditiveSynth_sample_rate(self);
    var n = vec_len(partials);
    var sum = 0;
    var i = 0;
    while (i < n) {
        var p = vec_get(partials, i);
        var amp = Partial_amplitude(p);
        if (f64_le(amp, 0) == 0) {
            var phase = vec_get(phases, i);
            sum = f64_add(sum, f64_mul(f64_sin(f64_mul(phase, F64_TAU)), amp));

            var freq = f64_mul(fundamental, Partial_frequency_ratio(p));
            var inc = f64_div(freq, sample_rate);
            var new_phase = f64_add(phase, inc);
            vec_set(phases, i, f64_sub(new_phase, f64_floor(new_phase)));
        }
        i = i + 1;
    }
    return sum;
}

# ================================================================
# additive_fill_buffer -- fill `buffer` (a vec) with samples. Returns ERR_NONE.
# ================================================================
#inline
fn additive_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, additive_next_sample(self));
        i = i + 1;
    }
    return ERR_NONE;
}

# ================================================================
# additive_is_active -- 1 if any partial has non-zero amplitude, else 0.
# ================================================================
#must_use
fn additive_is_active(self) {
    var partials = AdditiveSynth_partials(self);
    var n = vec_len(partials);
    var i = 0;
    while (i < n) {
        if (f64_gt(Partial_amplitude(vec_get(partials, i)), 0) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# additive_compress_amplitudes_dct -- DCT-II compress the amplitude bank,
# keeping the first `num_coeffs` coefficients.
#
# Returns a vec of the kept coefficients on success, or ERR_COMPUTATION if
# the underlying hisab DCT fails. `num_coeffs` is clamped to [1, num_partials].
# ================================================================
fn additive_compress_amplitudes_dct(self, num_coeffs) {
    var partials = AdditiveSynth_partials(self);
    var n = vec_len(partials);
    var buf = alloc(n * 8);
    var i = 0;
    while (i < n) {
        store64(buf + i * 8, Partial_amplitude(vec_get(partials, i)));
        i = i + 1;
    }

    if (num_dct(buf, n) != ERR_NONE) { return ERR_COMPUTATION; }

    var keep = num_coeffs;
    if (keep < 1) { keep = 1; }
    if (keep > n) { keep = n; }

    var coeffs = vec_new();
    var k = 0;
    while (k < keep) {
        vec_push(coeffs, load64(buf + k * 8));
        k = k + 1;
    }
    return coeffs;
}

# ================================================================
# additive_restore_amplitudes_dct -- inverse of compress; zero-pads `coeffs`
# to the partial count, runs the inverse DCT, and writes the result back into
# the partial bank (clamped to [0.0, 1.0] and re-Nyquist-filtered).
#
# Returns ERR_INVALID_PARAMETER if `coeffs` is empty or longer than the
# partial count, ERR_COMPUTATION if the hisab IDCT fails, else ERR_NONE.
# ================================================================
fn additive_restore_amplitudes_dct(self, coeffs) {
    var partials = AdditiveSynth_partials(self);
    var n = vec_len(partials);
    var clen = vec_len(coeffs);
    if (clen == 0 || clen > n) { return ERR_INVALID_PARAMETER; }

    var padded = alloc(n * 8);
    var i = 0;
    while (i < n) {
        store64(padded + i * 8, 0);
        i = i + 1;
    }
    var j = 0;
    while (j < clen) {
        store64(padded + j * 8, vec_get(coeffs, j));
        j = j + 1;
    }

    if (num_idct(padded, n) != ERR_NONE) { return ERR_COMPUTATION; }

    var nyquist = f64_mul(AdditiveSynth_sample_rate(self), F64_HALF);
    var fundamental = AdditiveSynth_fundamental(self);
    var k = 0;
    while (k < n) {
        var p = vec_get(partials, k);
        var amp = load64(padded + k * 8);
        if (f64_ge(f64_mul(fundamental, Partial_frequency_ratio(p)), nyquist) == 1) {
            Partial_set_amplitude(p, 0);
        } else {
            Partial_set_amplitude(p, f64_clamp(amp, 0, F64_ONE));
        }
        k = k + 1;
    }
    return ERR_NONE;
}

# --- reverb.cyr ---

# reverb.cyr -- Algorithmic reverb based on the Schroeder topology.
#
# Ports rust-old/src/reverb.rs. f32 -> f64 throughout. Classic reverb with 4
# parallel damped comb filters feeding 2 series allpass filters, plus
# pre-delay, decay/feedback, high-frequency damping, wet/dry mix and stereo
# width. Rust's serde derives are dropped. The `(f32, f32)` tuple return of
# process_sample becomes a `ReverbStereo` struct (left, right). The fixed
# `[DampedComb; 4]` / `[ReverbAllpass; 2]` inline arrays become stdlib vecs of
# struct pointers. Constructor returns the struct pointer on success or a
# negative ERR_* on invalid sample_rate.
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_ONE/HALF, f64_add/sub/mul/div/neg/clamp/max/floor/from/to) and the L0
# modules error.cyr (validate_sample_rate, flush_denormal, naad_is_finite,
# ERR_*) and delay.cyr (delay_line_*). The module file has no `include` lines.

# ================================================================
# Float literals (IEEE-754 bit patterns).
# ================================================================
var REVERB_FEEDBACK_HI = 0x3fefae147ae147ae;   # 0.99  (decay/feedback clamp hi)
var REVERB_COMB_NORM   = 0x3fd0000000000000;   # 0.25  (normalize by comb count)

# ================================================================
# Prime delay lengths (samples at 44100 Hz) for minimal modal clustering.
# All values are prime and mutually coprime for optimal diffusion.
# ================================================================
var REVERB_COMB_0        = 1117;
var REVERB_COMB_1        = 1187;
var REVERB_COMB_2        = 1277;
var REVERB_COMB_3        = 1361;
var REVERB_ALLPASS_0     = 557;
var REVERB_ALLPASS_1     = 443;
# Stereo offset (samples added to right channel for decorrelation).
var REVERB_STEREO_OFFSET = 23;

# ================================================================
# DampedComb -- comb filter + one-pole lowpass in the feedback path.
#   delay         : DelayLine pointer
#   delay_samples : delay time in samples (f32-widened)
#   feedback      : feedback coefficient
#   damp1         : lowpass state weight (== damping)
#   damp2         : lowpass input weight (== 1 - damping)
#   filter_state  : one-pole lowpass state
# ================================================================
#derive(accessors)
struct DampedComb { delay; delay_samples; feedback; damp1; damp2; filter_state; }

# Create a damped comb over `delay_samples` (int) with `feedback`/`damping`.
#must_use
fn reverb_damped_comb_new(delay_samples, feedback, damping) {
    var self = alloc(sizeof(DampedComb));
    DampedComb_set_delay(self, delay_line_new(delay_samples));
    DampedComb_set_delay_samples(self, f64_from(delay_samples));
    DampedComb_set_feedback(self, feedback);
    DampedComb_set_damp1(self, damping);
    DampedComb_set_damp2(self, f64_sub(F64_ONE, damping));
    DampedComb_set_filter_state(self, 0);
    return self;
}

# Process one sample: read delayed, lowpass-damp the feedback, write back.
#inline
#must_use
fn reverb_damped_comb_process(self, input) {
    var dl = DampedComb_delay(self);
    var delayed = delay_line_read(dl, DampedComb_delay_samples(self));
    # One-pole lowpass damping in feedback path.
    var state = flush_denormal(f64_add(f64_mul(delayed, DampedComb_damp2(self)),
    f64_mul(DampedComb_filter_state(self), DampedComb_damp1(self))));
    DampedComb_set_filter_state(self, state);
    delay_line_write(dl, f64_add(input, f64_mul(state, DampedComb_feedback(self))));
    return delayed;
}

# ================================================================
# ReverbAllpass -- simple Schroeder allpass for diffusion.
#   delay         : DelayLine pointer
#   delay_samples : delay time in samples (f32-widened)
#   feedback      : allpass feedback coefficient
# ================================================================
#derive(accessors)
struct ReverbAllpass { delay; delay_samples; feedback; }

# Create an allpass over `delay_samples` (int) with `feedback`.
#must_use
fn reverb_allpass_new(delay_samples, feedback) {
    var self = alloc(sizeof(ReverbAllpass));
    ReverbAllpass_set_delay(self, delay_line_new(delay_samples));
    ReverbAllpass_set_delay_samples(self, f64_from(delay_samples));
    ReverbAllpass_set_feedback(self, feedback);
    return self;
}

# Process one sample through the allpass.
#inline
#must_use
fn reverb_allpass_process(self, input) {
    var dl = ReverbAllpass_delay(self);
    var fb = ReverbAllpass_feedback(self);
    var delayed = delay_line_read(dl, ReverbAllpass_delay_samples(self));
    var output = f64_add(f64_mul(f64_neg(fb), input), delayed);
    delay_line_write(dl, f64_add(input, f64_mul(fb, flush_denormal(output))));
    return output;
}

# ================================================================
# ReverbStereo -- a (left, right) sample pair; replaces Rust's `(f32, f32)`
# tuple return from process_sample.
# ================================================================
#derive(accessors)
struct ReverbStereo { left; right; }

# ================================================================
# Reverb -- Schroeder algorithmic reverb.
#   pre_delay         : pre-delay DelayLine pointer
#   pre_delay_samples : pre-delay time in samples (f32-widened)
#   combs_l/combs_r   : vecs of 4 DampedComb pointers (right offset for stereo)
#   allpasses_l/_r    : vecs of 2 ReverbAllpass pointers
#   mix               : wet/dry mix (0 = dry, 1 = wet)
#   width             : stereo width (0 = mono, 1 = full stereo)
#   sample_rate       : Hz
# ================================================================
#derive(accessors)
struct Reverb {
    pre_delay;
    pre_delay_samples;
    combs_l;
    combs_r;
    allpasses_l;
    allpasses_r;
    mix;
    width;
    sample_rate;
}

# Build a damped comb sized `(base + offset) * scale` samples (min 1).
#must_use
fn reverb_make_comb(base, offset, scale, feedback, damp) {
    var len = f64_to(f64_floor(f64_mul(f64_from(base + offset), scale)));
    if (len < 1) { len = 1; }
    return reverb_damped_comb_new(len, feedback, damp);
}

# Build an allpass sized `(base + offset) * scale` samples (min 1), fb 0.5.
#must_use
fn reverb_make_ap(base, offset, scale) {
    var len = f64_to(f64_floor(f64_mul(f64_from(base + offset), scale)));
    if (len < 1) { len = 1; }
    return reverb_allpass_new(len, F64_HALF);
}

# ================================================================
# reverb_new -- create a reverb. `decay` (0..1) controls feedback, `damping`
# (0..1) high-frequency damping, `pre_delay_ms` pre-delay, `mix` (0..1)
# wet/dry, `sample_rate` in Hz. Returns the struct pointer on success or a
# negative ERR_* on invalid sample_rate. Ports Reverb::new.
# ================================================================
#must_use
fn reverb_new(decay, damping, pre_delay_ms, mix, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var scale = f64_div(sample_rate, f64_from(44100));
    var feedback = f64_clamp(decay, 0, REVERB_FEEDBACK_HI);
    var damp = f64_clamp(damping, 0, F64_ONE);
    var pre_samples = f64_max(f64_div(f64_mul(pre_delay_ms, sample_rate), f64_from(1000)), 0);

    var pre_len = f64_to(f64_floor(pre_samples));
    if (pre_len < 1) { pre_len = 1; }

    var combs_l = vec_new();
    vec_push(combs_l, reverb_make_comb(REVERB_COMB_0, 0, scale, feedback, damp));
    vec_push(combs_l, reverb_make_comb(REVERB_COMB_1, 0, scale, feedback, damp));
    vec_push(combs_l, reverb_make_comb(REVERB_COMB_2, 0, scale, feedback, damp));
    vec_push(combs_l, reverb_make_comb(REVERB_COMB_3, 0, scale, feedback, damp));

    var combs_r = vec_new();
    vec_push(combs_r, reverb_make_comb(REVERB_COMB_0, REVERB_STEREO_OFFSET, scale, feedback, damp));
    vec_push(combs_r, reverb_make_comb(REVERB_COMB_1, REVERB_STEREO_OFFSET, scale, feedback, damp));
    vec_push(combs_r, reverb_make_comb(REVERB_COMB_2, REVERB_STEREO_OFFSET, scale, feedback, damp));
    vec_push(combs_r, reverb_make_comb(REVERB_COMB_3, REVERB_STEREO_OFFSET, scale, feedback, damp));

    var allpasses_l = vec_new();
    vec_push(allpasses_l, reverb_make_ap(REVERB_ALLPASS_0, 0, scale));
    vec_push(allpasses_l, reverb_make_ap(REVERB_ALLPASS_1, 0, scale));

    var allpasses_r = vec_new();
    vec_push(allpasses_r, reverb_make_ap(REVERB_ALLPASS_0, REVERB_STEREO_OFFSET, scale));
    vec_push(allpasses_r, reverb_make_ap(REVERB_ALLPASS_1, REVERB_STEREO_OFFSET, scale));

    var self = alloc(sizeof(Reverb));
    Reverb_set_pre_delay(self, delay_line_new(pre_len));
    Reverb_set_pre_delay_samples(self, pre_samples);
    Reverb_set_combs_l(self, combs_l);
    Reverb_set_combs_r(self, combs_r);
    Reverb_set_allpasses_l(self, allpasses_l);
    Reverb_set_allpasses_r(self, allpasses_r);
    Reverb_set_mix(self, f64_clamp(mix, 0, F64_ONE));
    Reverb_set_width(self, F64_ONE);
    Reverb_set_sample_rate(self, sample_rate);
    return self;
}

# ================================================================
# reverb_process_core -- compute one stereo sample and write it into the
# caller-provided `res` (an existing ReverbStereo). Allocation-free so the
# buffer loop can reuse a single scratch struct instead of allocating per
# sample. All comb/allpass/predelay/stereo-width/wet-dry math and every delay-
# line state update are identical to the struct-returning wrapper below.
# ================================================================
#inline
fn reverb_process_core(self, input, res) {
    # Pre-delay.
    var pre = Reverb_pre_delay(self);
    delay_line_write(pre, input);
    var delayed = delay_line_read(pre, Reverb_pre_delay_samples(self));

    # Parallel comb filters.
    var wet_l = 0;
    var wet_r = 0;
    var combs_l = Reverb_combs_l(self);
    var combs_r = Reverb_combs_r(self);
    var i = 0;
    while (i < 4) {
        wet_l = f64_add(wet_l, reverb_damped_comb_process(vec_get(combs_l, i), delayed));
        i = i + 1;
    }
    i = 0;
    while (i < 4) {
        wet_r = f64_add(wet_r, reverb_damped_comb_process(vec_get(combs_r, i), delayed));
        i = i + 1;
    }
    wet_l = f64_mul(wet_l, REVERB_COMB_NORM);
    wet_r = f64_mul(wet_r, REVERB_COMB_NORM);

    # Series allpass filters.
    var allpasses_l = Reverb_allpasses_l(self);
    var allpasses_r = Reverb_allpasses_r(self);
    i = 0;
    while (i < 2) {
        wet_l = reverb_allpass_process(vec_get(allpasses_l, i), wet_l);
        i = i + 1;
    }
    i = 0;
    while (i < 2) {
        wet_r = reverb_allpass_process(vec_get(allpasses_r, i), wet_r);
        i = i + 1;
    }

    # Stereo width: blend left/right.
    var w = Reverb_width(self);
    var half_plus = f64_add(F64_HALF, f64_mul(F64_HALF, w));
    var half_minus = f64_sub(F64_HALF, f64_mul(F64_HALF, w));
    var out_l = f64_add(f64_mul(wet_l, half_plus), f64_mul(wet_r, half_minus));
    var out_r = f64_add(f64_mul(wet_r, half_plus), f64_mul(wet_l, half_minus));

    # Wet/dry mix.
    var mix = Reverb_mix(self);
    var dry = f64_sub(F64_ONE, mix);
    ReverbStereo_set_left(res, f64_add(f64_mul(input, dry), f64_mul(out_l, mix)));
    ReverbStereo_set_right(res, f64_add(f64_mul(input, dry), f64_mul(out_r, mix)));
    return 0;
}

# ================================================================
# reverb_process_sample -- process a mono input, returning stereo (left,
# right) as a ReverbStereo. Ports Reverb::process_sample.
# ================================================================
#inline
#must_use
fn reverb_process_sample(self, input) {
    var res = alloc(sizeof(ReverbStereo));
    reverb_process_core(self, input, res);
    return res;
}

# ================================================================
# reverb_process_buffer -- process a mono `input` vec into stereo `left`/
# `right` vecs (writing only where the output vec is long enough). Ports
# Reverb::process_buffer. Reuses a single scratch ReverbStereo across all
# samples so the hot loop performs no per-sample allocation.
# ================================================================
fn reverb_process_buffer(self, input, left, right) {
    var n = vec_len(input);
    var ll = vec_len(left);
    var rl = vec_len(right);
    var res = alloc(sizeof(ReverbStereo));
    var i = 0;
    while (i < n) {
        reverb_process_core(self, vec_get(input, i), res);
        if (i < ll) { vec_set(left, i, ReverbStereo_left(res)); }
        if (i < rl) { vec_set(right, i, ReverbStereo_right(res)); }
        i = i + 1;
    }
    return 0;
}

# --- eq.cyr ---

# eq.cyr -- Parametric and graphic equalizers.
#
# Ports rust-old/src/eq.rs. f32 -> f64 throughout. Wraps BiquadFilter
# (filter.cyr) into multi-band EQ configurations: an N-band ParametricEq,
# a 10-band GraphicEq with ISO center frequencies, and a sidechain DeEsser.
# The SmallVec<[EqBand; 16]> band storage becomes a stdlib vec of EqBand
# pointers; `Vec<f32>` active frequencies become a vec of f64. serde derives
# are dropped; constructors return the struct pointer on success or a negative
# ERR_* on failure; band mutators return ERR_NONE / negative ERR_*. Methods
# become free `eq_*` functions taking the struct pointer.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/TWO/
# HALF), builtins (f64_abs/exp/from/sub/mul/div/neg/lt/gt), error.cyr
# (naad_is_err/flush_denormal/ERR_*), dsp_util.cyr (naad_amplitude_to_db/
# naad_db_to_amplitude) and filter.cyr (filter_biquad_* + FILTER_* constants).
# No `include` lines.

# ================================================================
# Float literals not in the stdlib (IEEE-754 hex bit patterns).
# ================================================================
var EQ_C1_4    = 0x3ff6666666666666;   # 1.4    (~1 octave bandwidth Q)
var EQ_C31_25  = 0x403f400000000000;   # 31.25  (graphic band 0)
var EQ_C62_5   = 0x404f400000000000;   # 62.5   (graphic band 1)
var EQ_C0_002  = 0x3f60624dd2f1a9fc;   # 0.002  (~2ms envelope smoothing)

# ================================================================
# EqBand -- one band of a ParametricEq.
#   filter  : BiquadFilter pointer (type/freq/Q/gain set at add-band time)
#   enabled : 1 if active, 0 if bypassed (state preserved, no filtering)
# ================================================================
#derive(accessors)
struct EqBand { filter; enabled; }

# ================================================================
# ParametricEq -- N-band parametric equalizer.
#   bands       : vec of EqBand pointers, processed in series
#   sample_rate : Hz
# ================================================================
#derive(accessors)
struct ParametricEq { bands; sample_rate; }

# ================================================================
# GraphicEq -- 10-band graphic equalizer (ISO center frequencies).
#   eq                 : internal ParametricEq pointer
#   active_frequencies : vec of f64 (fewer than 10 at low sample rates)
# ================================================================
#derive(accessors)
struct GraphicEq { eq; active_frequencies; }

# ================================================================
# DeEsser -- reduces sibilance in the 4-8 kHz range via a bandpass sidechain.
#   detector_filter : BiquadFilter pointer (sidechain bandpass)
#   envelope        : envelope-follower state
#   threshold_db    : dB threshold above which reduction applies
#   max_reduction_db: maximum reduction in dB (negative)
#   smooth_coeff    : envelope smoothing coefficient
# ================================================================
#derive(accessors)
struct DeEsser { detector_filter; envelope; threshold_db; max_reduction_db; smooth_coeff; }

# ================================================================
# ParametricEq.
# ================================================================

# Create a new parametric EQ with no bands. Ports new(); infallible.
#must_use
fn eq_parametric_new(sample_rate) {
    var self = alloc(sizeof(ParametricEq));
    ParametricEq_set_bands(self, vec_new());
    ParametricEq_set_sample_rate(self, sample_rate);
    return self;
}

# Add a band to the EQ. Returns ERR_NONE on success, or a negative ERR_* if
# the filter parameters are invalid. Ports add_band().
fn eq_add_band(self, filter_type, frequency, q, gain_db) {
    var sr = ParametricEq_sample_rate(self);
    var filter = filter_biquad_with_gain(filter_type, sr, frequency, q, gain_db);
    if (naad_is_err(filter) == 1) { return filter; }
    var band = alloc(sizeof(EqBand));
    EqBand_set_filter(band, filter);
    EqBand_set_enabled(band, 1);
    vec_push(ParametricEq_bands(self), band);
    return ERR_NONE;
}

# Number of bands. Ports num_bands().
#must_use
fn eq_num_bands(self) {
    return vec_len(ParametricEq_bands(self));
}

# Get the band pointer at `index` for parameter changes, or 0 (null) if out of
# range. Ports band_mut() (Option<&mut EqBand> -> pointer / null sentinel).
fn eq_band_mut(self, index) {
    var bands = ParametricEq_bands(self);
    if (index < 0) { return 0; }
    if (index >= vec_len(bands)) { return 0; }
    return vec_get(bands, index);
}

# Process a single sample through all enabled bands in series.
# Ports process_sample().
#inline
#must_use
fn eq_process_sample(self, input) {
    var bands = ParametricEq_bands(self);
    var n = vec_len(bands);
    var out = input;
    var i = 0;
    while (i < n) {
        var band = vec_get(bands, i);
        if (EqBand_enabled(band) == 1) {
            out = filter_biquad_process_sample(EqBand_filter(band), out);
        }
        i = i + 1;
    }
    return out;
}

# Process a buffer (vec of f64) in place. Ports process_buffer().
#inline
fn eq_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, eq_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# Reset all band filter states. Ports reset().
fn eq_reset(self) {
    var bands = ParametricEq_bands(self);
    var n = vec_len(bands);
    var i = 0;
    while (i < n) {
        filter_biquad_reset(EqBand_filter(vec_get(bands, i)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# GraphicEq -- 10-band graphic equalizer with ISO center frequencies:
# 31.25, 62.5, 125, 250, 500, 1k, 2k, 4k, 8k, 16k Hz. Bands above Nyquist
# are excluded. Each band is a peak filter (Q = 1.4, ~1 octave).
# ================================================================

# Create a new 10-band graphic EQ with all bands at 0 dB. Returns the struct
# pointer on success, or a negative ERR_* if a band's parameters are invalid.
# Ports new().
fn eq_graphic_new(sample_rate) {
    var eq = eq_parametric_new(sample_rate);
    var active = vec_new();

    var freqs = vec_new();
    vec_push(freqs, EQ_C31_25);
    vec_push(freqs, EQ_C62_5);
    vec_push(freqs, f64_from(125));
    vec_push(freqs, f64_from(250));
    vec_push(freqs, f64_from(500));
    vec_push(freqs, f64_from(1000));
    vec_push(freqs, f64_from(2000));
    vec_push(freqs, f64_from(4000));
    vec_push(freqs, f64_from(8000));
    vec_push(freqs, f64_from(16000));

    var nyquist = f64_mul(sample_rate, F64_HALF);
    var i = 0;
    while (i < 10) {
        var freq = vec_get(freqs, i);
        if (f64_lt(freq, nyquist) == 1) {
            var e = eq_add_band(eq, FILTER_PEAK, freq, EQ_C1_4, 0);
            if (naad_is_err(e) == 1) { return e; }
            vec_push(active, freq);
        }
        i = i + 1;
    }

    var self = alloc(sizeof(GraphicEq));
    GraphicEq_set_eq(self, eq);
    GraphicEq_set_active_frequencies(self, active);
    return self;
}

# Set the gain for a band (0..num_bands) in dB. Returns ERR_NONE on success,
# or a negative ERR_* if `index` is out of range or the gain is invalid.
# Ports set_band_gain().
fn eq_graphic_set_band_gain(self, index, gain_db) {
    var active = GraphicEq_active_frequencies(self);
    if (index < 0) { return ERR_INVALID_PARAMETER; }
    if (index >= vec_len(active)) { return ERR_INVALID_PARAMETER; }
    var freq = vec_get(active, index);
    var band = eq_band_mut(GraphicEq_eq(self), index);
    if (band == 0) { return ERR_INVALID_PARAMETER; }
    return filter_biquad_set_params(EqBand_filter(band), freq, EQ_C1_4, gain_db);
}

# Process a single sample. Ports process_sample().
#inline
#must_use
fn eq_graphic_process_sample(self, input) {
    return eq_process_sample(GraphicEq_eq(self), input);
}

# Process a buffer (vec of f64) in place. Ports process_buffer().
#inline
fn eq_graphic_process_buffer(self, buffer) {
    return eq_process_buffer(GraphicEq_eq(self), buffer);
}

# Number of active bands. Ports num_bands().
#must_use
fn eq_graphic_num_bands(self) {
    return eq_num_bands(GraphicEq_eq(self));
}

# ================================================================
# DeEsser.
# ================================================================

# Create a new de-esser. `center_freq` is the sibilance detection center
# (typically 6000-8000 Hz), `threshold_db` the reduction threshold. Returns the
# struct pointer on success, or a negative ERR_* on invalid parameters.
# Ports new().
fn eq_deesser_new(center_freq, threshold_db, sample_rate) {
    var detector_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, center_freq, F64_TWO);
    if (naad_is_err(detector_filter) == 1) { return detector_filter; }
    # smooth_coeff = 1.0 - (-1.0 / (0.002 * sample_rate)).exp()  -- ~2ms
    var tau = f64_mul(EQ_C0_002, sample_rate);
    var smooth_coeff = f64_sub(F64_ONE, f64_exp(f64_div(f64_neg(F64_ONE), tau)));

    var self = alloc(sizeof(DeEsser));
    DeEsser_set_detector_filter(self, detector_filter);
    DeEsser_set_envelope(self, 0);
    DeEsser_set_threshold_db(self, threshold_db);
    DeEsser_set_max_reduction_db(self, f64_neg(f64_from(12)));
    DeEsser_set_smooth_coeff(self, smooth_coeff);
    return self;
}

# Process a single sample. Ports process_sample().
#inline
#must_use
fn eq_deesser_process_sample(self, input) {
    # Sidechain: bandpass the input to detect sibilance.
    var detected = filter_biquad_process_sample(DeEsser_detector_filter(self), input);
    var level = f64_abs(detected);

    # Envelope follower.
    var env = DeEsser_envelope(self);
    env = f64_add(env, f64_mul(DeEsser_smooth_coeff(self), f64_sub(level, env)));
    env = flush_denormal(env);
    DeEsser_set_envelope(self, env);

    var env_db = naad_amplitude_to_db(env);
    var threshold = DeEsser_threshold_db(self);
    if (f64_gt(env_db, threshold) == 1) {
        var overshoot = f64_sub(env_db, threshold);
        var reduction_db = f64_max(f64_neg(overshoot), DeEsser_max_reduction_db(self));
        return f64_mul(input, naad_db_to_amplitude(reduction_db));
    }
    return input;
}

# Process a buffer (vec of f64) in place. Ports process_buffer().
#inline
fn eq_deesser_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, eq_deesser_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# --- formant.cyr ---

# formant.cyr -- Formant synthesis for vowel sounds.
#
# Ports rust-old/src/synth/formant.rs. f32 -> f64 throughout. Models the human
# vocal tract as a parallel bank of 3 bandpass resonators (F1/F2/F3). Each
# vowel is characterised by three formant frequencies with bandwidths and
# amplitudes; supports smooth morphing between vowel shapes.
#
# The `Vowel` enum becomes integer constants; serde derives are dropped;
# constructors return the struct pointer on success (or a negative ERR_* on
# failure); `Result<()>` operations return ERR_NONE or a negative ERR_*. The
# fixed `[(f32,f32,f32); 3]` formant table maps to a vec of `FormantBand`
# structs. Reuses filter.cyr's BiquadFilter (bandpass). Requires (from the
# build/test unit): stdlib alloc/vec + math/ganita, error.cyr, filter.cyr.
# No `include`.

# ================================================================
# Vowel -> integer constants (was `enum Vowel`).
# ================================================================
var VOWEL_A = 0;
var VOWEL_E = 1;
var VOWEL_I = 2;
var VOWEL_O = 3;
var VOWEL_U = 4;

# Number of formant bands.
var FORMANT_NUM = 3;

# ================================================================
# Formant amplitude bit patterns (IEEE-754 f64).
# ================================================================
var FORMANT_C0_5  = 0x3fe0000000000000;   # 0.5
var FORMANT_C0_25 = 0x3fd0000000000000;   # 0.25
var FORMANT_C0_4  = 0x3fd999999999999a;   # 0.4
var FORMANT_C0_2  = 0x3fc999999999999a;   # 0.2
var FORMANT_C0_3  = 0x3fd3333333333333;   # 0.3
var FORMANT_C0_15 = 0x3fc3333333333333;   # 0.15
var FORMANT_C0_35 = 0x3fd6666666666666;   # 0.35

# ================================================================
# FormantBand -- one formant tuple (frequency Hz, bandwidth Hz, amplitude).
# ================================================================
#derive(accessors)
struct FormantBand { freq; bw; amp; }

# Construct a formant band.
#must_use
fn formant_band_new(freq, bw, amp) {
    var b = alloc(sizeof(FormantBand));
    FormantBand_set_freq(b, freq);
    FormantBand_set_bw(b, bw);
    FormantBand_set_amp(b, amp);
    return b;
}

# ================================================================
# formant_vowel_formants -- the first three formant parameters (freq, bw, amp)
# for a vowel. Values are standard approximations for an adult male voice.
# Returns a fresh vec of 3 FormantBand pointers. Ports Vowel::formants().
# ================================================================
#must_use
fn formant_vowel_formants(vowel) {
    var v = vec_new();
    if (vowel == VOWEL_A) {
        vec_push(v, formant_band_new(f64_from(730), f64_from(90), F64_ONE));
        vec_push(v, formant_band_new(f64_from(1090), f64_from(110), FORMANT_C0_5));
        vec_push(v, formant_band_new(f64_from(2440), f64_from(170), FORMANT_C0_25));
    } elif (vowel == VOWEL_E) {
        vec_push(v, formant_band_new(f64_from(530), f64_from(60), F64_ONE));
        vec_push(v, formant_band_new(f64_from(1840), f64_from(100), FORMANT_C0_4));
        vec_push(v, formant_band_new(f64_from(2480), f64_from(120), FORMANT_C0_2));
    } elif (vowel == VOWEL_I) {
        vec_push(v, formant_band_new(f64_from(270), f64_from(60), F64_ONE));
        vec_push(v, formant_band_new(f64_from(2290), f64_from(90), FORMANT_C0_3));
        vec_push(v, formant_band_new(f64_from(3010), f64_from(100), FORMANT_C0_15));
    } elif (vowel == VOWEL_O) {
        vec_push(v, formant_band_new(f64_from(570), f64_from(80), F64_ONE));
        vec_push(v, formant_band_new(f64_from(840), f64_from(100), FORMANT_C0_5));
        vec_push(v, formant_band_new(f64_from(2410), f64_from(120), FORMANT_C0_2));
    } else {
        vec_push(v, formant_band_new(f64_from(300), f64_from(70), F64_ONE));
        vec_push(v, formant_band_new(f64_from(870), f64_from(100), FORMANT_C0_35));
        vec_push(v, formant_band_new(f64_from(2240), f64_from(120), FORMANT_C0_15));
    }
    return v;
}

# ================================================================
# formant_q -- resonance for a band: freq/bw if bw > 0, else 1.0. Ports the
# `q` closure in FormantFilter::new / FormantSynth::apply_params.
# ================================================================
#must_use
fn formant_q(freq, bw) {
    if (f64_gt(bw, 0) == 1) { return f64_div(freq, bw); }
    return F64_ONE;
}

# ================================================================
# formant_lerp -- a + (b - a) * t. Ports the inline morph interpolation.
# ================================================================
#must_use
fn formant_lerp(a, b, t) {
    return f64_add(a, f64_mul(f64_sub(b, a), t));
}

# ================================================================
# FormantFilter -- a parallel bank of 3 bandpass resonators.
#   filters    : vec of 3 BiquadFilter pointers (one per formant)
#   amplitudes : vec of 3 per-formant amplitudes
# ================================================================
#derive(accessors)
struct FormantFilter { filters; amplitudes; }

# Create a formant filter from explicit parameters (vec of FormantBand).
# Returns the struct pointer on success, ERR_INVALID_PARAMETER if the band
# count is not exactly 3, or a negative ERR_* if any filter params are invalid.
#must_use
fn formant_filter_new(formants, sample_rate) {
    if (vec_len(formants) != FORMANT_NUM) { return ERR_INVALID_PARAMETER; }

    var filters = vec_new();
    var amplitudes = vec_new();
    var i = 0;
    while (i < FORMANT_NUM) {
        var band = vec_get(formants, i);
        var freq = FormantBand_freq(band);
        var bw = FormantBand_bw(band);
        var f = filter_biquad_new(FILTER_BANDPASS, sample_rate, freq, formant_q(freq, bw));
        if (naad_is_err(f) == 1) { return f; }
        vec_push(filters, f);
        vec_push(amplitudes, FormantBand_amp(band));
        i = i + 1;
    }

    var self = alloc(sizeof(FormantFilter));
    FormantFilter_set_filters(self, filters);
    FormantFilter_set_amplitudes(self, amplitudes);
    return self;
}

# Process one input sample through all parallel formant bands.
#inline
#must_use
fn formant_filter_process_sample(self, input) {
    var filters = FormantFilter_filters(self);
    var amplitudes = FormantFilter_amplitudes(self);
    var sum = 0;
    var i = 0;
    while (i < FORMANT_NUM) {
        var s = filter_biquad_process_sample(vec_get(filters, i), input);
        sum = f64_add(sum, f64_mul(s, vec_get(amplitudes, i)));
        i = i + 1;
    }
    return sum;
}

# ================================================================
# FormantSynth -- formant synthesis engine with vowel morphing.
#   filters        : vec of 3 BiquadFilter pointers
#   amplitudes     : vec of 3 current formant amplitudes
#   target_params  : vec of 3 FormantBand (current target parameters)
#   current_vowel  : VOWEL_* constant
#   sample_rate    : Hz
# ================================================================
#derive(accessors)
struct FormantSynth { filters; amplitudes; target_params; current_vowel; sample_rate; }

# Create a new formant synth initialised to the given vowel. Returns the struct
# pointer on success, or a negative ERR_* if filter parameters are invalid.
# Matches Rust new(): q uses raw freq/bw (no bw > 0 guard).
#must_use
fn formant_synth_new(vowel, sample_rate) {
    var params = formant_vowel_formants(vowel);
    var filters = vec_new();
    var amplitudes = vec_new();
    var i = 0;
    while (i < FORMANT_NUM) {
        var band = vec_get(params, i);
        var freq = FormantBand_freq(band);
        var bw = FormantBand_bw(band);
        var f = filter_biquad_new(FILTER_BANDPASS, sample_rate, freq, f64_div(freq, bw));
        if (naad_is_err(f) == 1) { return f; }
        vec_push(filters, f);
        vec_push(amplitudes, FormantBand_amp(band));
        i = i + 1;
    }

    var self = alloc(sizeof(FormantSynth));
    FormantSynth_set_filters(self, filters);
    FormantSynth_set_amplitudes(self, amplitudes);
    FormantSynth_set_target_params(self, params);
    FormantSynth_set_current_vowel(self, vowel);
    FormantSynth_set_sample_rate(self, sample_rate);
    return self;
}

# Apply formant parameters (vec of FormantBand) to the filters. Returns
# ERR_NONE on success or a negative ERR_* if the filter params are invalid.
# Ports apply_params(); q uses the bw > 0 guard.
fn formant_synth_apply_params(self, params) {
    FormantSynth_set_target_params(self, params);
    var filters = FormantSynth_filters(self);
    var amplitudes = FormantSynth_amplitudes(self);
    var i = 0;
    while (i < FORMANT_NUM) {
        var band = vec_get(params, i);
        var freq = FormantBand_freq(band);
        var bw = FormantBand_bw(band);
        var amp = FormantBand_amp(band);
        var e = filter_biquad_set_params(vec_get(filters, i), freq, formant_q(freq, bw), 0);
        if (naad_is_err(e) == 1) { return e; }
        vec_set(amplitudes, i, amp);
        i = i + 1;
    }
    return ERR_NONE;
}

# Set the target vowel, updating filter parameters. Returns ERR_NONE or a
# negative ERR_*. Ports set_vowel().
fn formant_synth_set_vowel(self, vowel) {
    FormantSynth_set_current_vowel(self, vowel);
    var params = formant_vowel_formants(vowel);
    return formant_synth_apply_params(self, params);
}

# Morph between two vowels at position t (0.0 = vowel_a, 1.0 = vowel_b).
# Returns ERR_NONE or a negative ERR_*. Ports morph().
fn formant_synth_morph(self, vowel_a, vowel_b, t) {
    var tc = f64_clamp(t, 0, F64_ONE);
    var a = formant_vowel_formants(vowel_a);
    var b = formant_vowel_formants(vowel_b);

    var params = vec_new();
    var i = 0;
    while (i < FORMANT_NUM) {
        var ba = vec_get(a, i);
        var bb = vec_get(b, i);
        var freq = formant_lerp(FormantBand_freq(ba), FormantBand_freq(bb), tc);
        var bw = formant_lerp(FormantBand_bw(ba), FormantBand_bw(bb), tc);
        var amp = formant_lerp(FormantBand_amp(ba), FormantBand_amp(bb), tc);
        vec_push(params, formant_band_new(freq, bw, amp));
        i = i + 1;
    }
    return formant_synth_apply_params(self, params);
}

# Process one input sample through the parallel formant bank.
#inline
#must_use
fn formant_synth_process_sample(self, input) {
    var filters = FormantSynth_filters(self);
    var amplitudes = FormantSynth_amplitudes(self);
    var sum = 0;
    var i = 0;
    while (i < FORMANT_NUM) {
        var s = filter_biquad_process_sample(vec_get(filters, i), input);
        sum = f64_add(sum, f64_mul(s, vec_get(amplitudes, i)));
        i = i + 1;
    }
    return sum;
}

# Fill a buffer by processing each input sample in place. Ports process_buffer().
#inline
fn formant_synth_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, formant_synth_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# Returns the current vowel. Ports current_vowel().
#must_use
fn formant_synth_current_vowel(self) {
    return FormantSynth_current_vowel(self);
}

# --- vocoder.cyr ---

# vocoder.cyr -- Channel vocoder.
#
# Ports rust-old/src/synth/vocoder.rs. f32 -> f64 throughout. Splits both a
# modulator (voice) and carrier (synth) into log-spaced frequency bands with
# bandpass filters, extracts each modulator band's envelope, and applies it
# to the corresponding carrier band -- the classic "talking synth" effect.
#
# The `SmallVec<[VocoderBand; 16]>` band store becomes a stdlib `vec` of
# VocoderBand struct pointers. Each band owns two BiquadFilter pointers
# (analysis/synthesis) from filter.cyr. Methods become free `vocoder_*`
# functions; serde derives/tests are dropped. Constructors return the struct
# pointer on success, or a negative ERR_* on invalid parameters.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/TWO/
# HALF, f64_min/clamp), error.cyr (flush_denormal, naad_is_finite, ERR_*),
# and filter.cyr (filter_biquad_new, filter_biquad_process_sample, FILTER_*).
# The module file itself has no `include` lines.

# ================================================================
# Non-integer float literals (IEEE-754 bit patterns).
# ================================================================
var VOCODER_C0_005 = 0x3F747AE147AE147B;   # 0.005 (~5ms attack time constant)
var VOCODER_C0_02  = 0x3F947AE147AE147B;   # 0.020 (~20ms release time constant)
var VOCODER_C0_49  = 0x3FDF5C28F5C28F5C;   # 0.49  (Nyquist safety fraction)

# ================================================================
# VocoderBand -- one frequency band.
#   analysis_filter   : BiquadFilter pointer (bandpass, modulator path)
#   synthesis_filter  : BiquadFilter pointer (bandpass, carrier path)
#   envelope_follower : f64 envelope follower state
#   attack_coeff      : f64 smoothing coeff for a rising envelope
#   release_coeff     : f64 smoothing coeff for a falling envelope
# ================================================================
#derive(accessors)
struct VocoderBand {
    analysis_filter;
    synthesis_filter;
    envelope_follower;
    attack_coeff;
    release_coeff;
}

# ================================================================
# Vocoder -- channel vocoder with a configurable number of bands.
#   bands       : vec of VocoderBand pointers
#   sample_rate : f64 Hz
# ================================================================
#derive(accessors)
struct Vocoder {
    bands;
    sample_rate;
}

# ================================================================
# vocoder_band_process -- process one sample through a band. Returns the
# carrier bandpassed and amplitude-modulated by the modulator's envelope.
# Ports VocoderBand::process.
# ================================================================
#inline
#must_use
fn vocoder_band_process(self, modulator, carrier) {
    # Bandpass the modulator and extract its envelope.
    var mod_filtered = filter_biquad_process_sample(VocoderBand_analysis_filter(self), modulator);
    var mod_level = f64_abs(mod_filtered);

    # Envelope follower with separate attack/release.
    var env = VocoderBand_envelope_follower(self);
    var coeff = VocoderBand_release_coeff(self);
    if (f64_gt(mod_level, env) == 1) {
        coeff = VocoderBand_attack_coeff(self);
    }
    var new_env = flush_denormal(f64_add(env, f64_mul(coeff, f64_sub(mod_level, env))));
    VocoderBand_set_envelope_follower(self, new_env);

    # Bandpass the carrier and apply the modulator envelope.
    var car_filtered = filter_biquad_process_sample(VocoderBand_synthesis_filter(self), carrier);
    return f64_mul(car_filtered, new_env);
}

# ================================================================
# vocoder_new -- create a vocoder with logarithmically-spaced bands.
# Returns the struct pointer on success, or a negative ERR_* on invalid
# sample_rate / num_bands / frequency range (or a propagated filter error).
# Ports Vocoder::new.
# ================================================================
#must_use
fn vocoder_new(num_bands, low_freq, high_freq, sample_rate) {
    if (f64_le(sample_rate, 0) == 1) { return ERR_INVALID_SAMPLE_RATE; }
    if (naad_is_finite(sample_rate) == 0) { return ERR_INVALID_SAMPLE_RATE; }
    if (num_bands == 0) { return ERR_INVALID_PARAMETER; }
    if (f64_le(low_freq, 0) == 1) { return ERR_INVALID_PARAMETER; }
    if (f64_le(high_freq, low_freq) == 1) { return ERR_INVALID_PARAMETER; }

    var log_low = f64_ln(low_freq);
    var log_high = f64_ln(high_freq);
    var step = 0;
    if (num_bands > 1) {
        step = f64_div(f64_sub(log_high, log_low), f64_from(num_bands - 1));
    }

    # Envelope follower coefficients: ~5ms attack, ~20ms release.
    var attack_coeff = f64_sub(F64_ONE, f64_exp(f64_div(f64_neg(F64_ONE), f64_mul(VOCODER_C0_005, sample_rate))));
    var release_coeff = f64_sub(F64_ONE, f64_exp(f64_div(f64_neg(F64_ONE), f64_mul(VOCODER_C0_02, sample_rate))));

    var nyq_safe = f64_mul(sample_rate, VOCODER_C0_49);
    var bands = vec_new();
    var i = 0;
    while (i < num_bands) {
        var center = f64_exp(f64_add(log_low, f64_mul(step, f64_from(i))));
        # Clamp to Nyquist safety.
        center = f64_min(center, nyq_safe);
        # Q scales with band spacing: Q ~ 1/(exp(step)-1) so adjacent bands
        # overlap at their -3dB points; single-band fallback Q = 4.0.
        var q = f64_from(4);
        if (f64_gt(step, 0) == 1) {
            q = f64_clamp(f64_div(F64_ONE, f64_sub(f64_exp(step), F64_ONE)), F64_ONE, f64_from(20));
        }

        var analysis_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, center, q);
        if (naad_is_err(analysis_filter) == 1) { return analysis_filter; }
        var synthesis_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, center, q);
        if (naad_is_err(synthesis_filter) == 1) { return synthesis_filter; }

        var band = alloc(sizeof(VocoderBand));
        VocoderBand_set_analysis_filter(band, analysis_filter);
        VocoderBand_set_synthesis_filter(band, synthesis_filter);
        VocoderBand_set_envelope_follower(band, 0);
        VocoderBand_set_attack_coeff(band, attack_coeff);
        VocoderBand_set_release_coeff(band, release_coeff);
        vec_push(bands, band);
        i = i + 1;
    }

    var self = alloc(sizeof(Vocoder));
    Vocoder_set_bands(self, bands);
    Vocoder_set_sample_rate(self, sample_rate);
    return self;
}

# ================================================================
# vocoder_process_sample -- process one (modulator, carrier) pair through
# all bands. Returns the sum of all band outputs. Ports Vocoder::process_sample.
# ================================================================
#inline
#must_use
fn vocoder_process_sample(self, modulator, carrier) {
    var bands = Vocoder_bands(self);
    var n = vec_len(bands);
    var sum = 0;
    var i = 0;
    while (i < n) {
        sum = f64_add(sum, vocoder_band_process(vec_get(bands, i), modulator, carrier));
        i = i + 1;
    }
    return sum;
}

# ================================================================
# vocoder_process_buffer -- process a buffer of modulator/carrier pairs into
# `output`. Iterates over min(len(modulator), len(carrier), len(output)).
# Ports Vocoder::process_buffer.
# ================================================================
fn vocoder_process_buffer(self, modulator, carrier, output) {
    var len = vec_len(modulator);
    var lc = vec_len(carrier);
    var lo = vec_len(output);
    if (lc < len) { len = lc; }
    if (lo < len) { len = lo; }
    var i = 0;
    while (i < len) {
        vec_set(output, i, vocoder_process_sample(self, vec_get(modulator, i), vec_get(carrier, i)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# vocoder_num_bands -- number of bands. Ports Vocoder::num_bands.
# ================================================================
#must_use
fn vocoder_num_bands(self) {
    return vec_len(Vocoder_bands(self));
}

# --- drum.cyr ---

# drum.cyr -- analog drum synthesis models: kick, snare, hi-hat.
#
# Ports rust-old/src/synth/drum.rs. f32 -> f64 throughout. Pitch-swept
# sine bodies, noise bursts, and decay envelopes -- all generated from
# primitives, no samples. The `noise_state: u32` PRNG field becomes an
# alloc(8) pointer-state slot (load64/store64) stepped via dsp_util's
# xorshift32_signed_f32 (matching the noise.cyr idiom). The BiquadFilter
# fields hold filter struct pointers; the fixed `[f32; 6]` phase/frequency
# arrays become stdlib vecs. Constructors return the struct pointer on
# success or a negative ERR_* (was Result<Self>). serde/Display tests dropped.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/TWO/
# HALF/TAU, f64_add/sub/mul/div/neg/clamp/from/sin/floor), error.cyr
# (validate_sample_rate, flush_denormal, naad_is_err, ERR_*), and filter.cyr
# (filter_biquad_new, filter_biquad_process_sample, FILTER_*). No `include`.

# ================================================================
# Non-integer float literals (IEEE-754 bit patterns).
# ================================================================
var DRUM_NEG_6_9 = 0xC01B99999999999A;   # -6.9  (decay: e^(-6.9) ~ 0.1% over N samples)
var DRUM_C0_005  = 0x3F747AE147AE147B;   # 0.005 (click decay window, 5ms)
var DRUM_C0_03   = 0x3F9EB851EB851EB8;   # 0.03  (pitch envelope window, 30ms)
var DRUM_C1E_6   = 0x3EB0C6F7A0B5ED8D;   # 1e-6  (deactivation threshold)
var DRUM_C0_1    = 0x3FB999999999999A;   # 0.1   (snare tone decay window, 100ms)
var DRUM_C0_15   = 0x3FC3333333333333;   # 0.15  (snare noise decay window, 150ms)
var DRUM_C1_5    = 0x3FF8000000000000;   # 1.5   (snare bandpass Q)
var DRUM_C0_8    = 0x3FE999999999999A;   # 0.8   (snare noise level)
var DRUM_C0_707  = 0x3FE69FBE76C8B439;   # 0.707 (hi-hat highpass Q)

# Hi-hat inharmonic metallic frequencies (classic 808 ratios).
var DRUM_F205_3 = 0x4069A9999999999A;   # 205.3
var DRUM_F304_4 = 0x4073066666666666;   # 304.4
var DRUM_F369_6 = 0x407719999999999A;   # 369.6
var DRUM_F522_7 = 0x408055999999999A;   # 522.7
var DRUM_F540_5 = 0x4080E40000000000;   # 540.5
var DRUM_F800_6 = 0x408904CCCCCCCCCD;   # 800.6

# ================================================================
# _drum_decay_coeff -- e^(-6.9 / samples), or 0.0 if samples <= 0.
# Shared decay-coefficient helper (Rust inlined this per field).
# ================================================================
#must_use
fn _drum_decay_coeff(samples) {
    if (f64_gt(samples, 0) == 1) {
        return f64_exp(f64_div(DRUM_NEG_6_9, samples));
    }
    return 0;
}

# ================================================================
# KickDrum -- pitch-swept sine body + noise click transient.
#   start_freq, end_freq : body pitch sweep endpoints (Hz)
#   phase                : body oscillator phase (0..1)
#   pitch_env            : pitch envelope (0..1), decays toward 0
#   body_amp, click_amp  : amplitude envelopes (0..1)
#   body_decay, click_decay, pitch_decay : per-sample decay coefficients
#   click_level          : click noise level (clamped 0..1)
#   rng                  : pointer to an 8-byte slot holding the u32 PRNG state
#   sample_rate          : Hz
#   active               : 1 if currently producing output, else 0
# ================================================================
#derive(accessors)
struct KickDrum {
    start_freq;
    end_freq;
    phase;
    pitch_env;
    body_amp;
    click_amp;
    body_decay;
    click_decay;
    click_level;
    pitch_decay;
    rng;
    sample_rate;
    active;
}

# ================================================================
# drum_kick_new -- create a kick drum. Mirrors KickDrum::new. Returns the
# struct pointer on success, or ERR_INVALID_SAMPLE_RATE on invalid sample_rate.
# ================================================================
#must_use
fn drum_kick_new(start_freq, end_freq, body_decay_ms, click_level, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var body_decay_samples = f64_mul(f64_div(body_decay_ms, f64_from(1000)), sample_rate);
    var body_decay = _drum_decay_coeff(body_decay_samples);

    # Click decays much faster than body (5ms).
    var click_decay_samples = f64_mul(DRUM_C0_005, sample_rate);
    var click_decay = _drum_decay_coeff(click_decay_samples);

    # Pitch envelope decays over ~30ms.
    var pitch_decay_samples = f64_mul(DRUM_C0_03, sample_rate);
    var pitch_decay = _drum_decay_coeff(pitch_decay_samples);

    var rng = alloc(8);
    store64(rng, 12345);

    var self = alloc(sizeof(KickDrum));
    KickDrum_set_start_freq(self, start_freq);
    KickDrum_set_end_freq(self, end_freq);
    KickDrum_set_phase(self, 0);
    KickDrum_set_pitch_env(self, 0);
    KickDrum_set_body_amp(self, 0);
    KickDrum_set_click_amp(self, 0);
    KickDrum_set_body_decay(self, body_decay);
    KickDrum_set_click_decay(self, click_decay);
    KickDrum_set_click_level(self, f64_clamp(click_level, 0, F64_ONE));
    KickDrum_set_pitch_decay(self, pitch_decay);
    KickDrum_set_rng(self, rng);
    KickDrum_set_sample_rate(self, sample_rate);
    KickDrum_set_active(self, 0);
    return self;
}

# Trigger the kick drum: reset phase and envelopes, mark active.
fn drum_kick_trigger(self) {
    KickDrum_set_phase(self, 0);
    KickDrum_set_pitch_env(self, F64_ONE);
    KickDrum_set_body_amp(self, F64_ONE);
    KickDrum_set_click_amp(self, F64_ONE);
    KickDrum_set_active(self, 1);
    return 0;
}

# ================================================================
# drum_kick_next_sample -- one sample of body + click, advancing all state.
# ================================================================
#inline
#must_use
fn drum_kick_next_sample(self) {
    if (KickDrum_active(self) == 0) { return 0; }

    var start_freq = KickDrum_start_freq(self);
    var end_freq = KickDrum_end_freq(self);
    var sample_rate = KickDrum_sample_rate(self);

    # Pitch sweep: interpolate from start_freq to end_freq.
    var pitch_env = KickDrum_pitch_env(self);
    var freq = f64_add(end_freq, f64_mul(f64_sub(start_freq, end_freq), pitch_env));
    pitch_env = flush_denormal(f64_mul(pitch_env, KickDrum_pitch_decay(self)));
    KickDrum_set_pitch_env(self, pitch_env);

    # Body: sine oscillator.
    var phase = KickDrum_phase(self);
    var body_amp = KickDrum_body_amp(self);
    var body = f64_mul(f64_sin(f64_mul(phase, F64_TAU)), body_amp);
    phase = f64_add(phase, f64_div(freq, sample_rate));
    phase = f64_sub(phase, f64_floor(phase));
    KickDrum_set_phase(self, phase);
    body_amp = flush_denormal(f64_mul(body_amp, KickDrum_body_decay(self)));
    KickDrum_set_body_amp(self, body_amp);

    # Click: noise burst.
    var noise = xorshift32_signed_f32(KickDrum_rng(self));
    var click_amp = KickDrum_click_amp(self);
    var click = f64_mul(f64_mul(noise, click_amp), KickDrum_click_level(self));
    click_amp = flush_denormal(f64_mul(click_amp, KickDrum_click_decay(self)));
    KickDrum_set_click_amp(self, click_amp);

    # Deactivate when both envelopes are negligible.
    if (f64_lt(body_amp, DRUM_C1E_6) == 1 && f64_lt(click_amp, DRUM_C1E_6) == 1) {
        KickDrum_set_active(self, 0);
    }

    return f64_add(body, click);
}

# Fill a vec buffer in place with successive kick samples.
#inline
fn drum_kick_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, drum_kick_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# 1 if the kick is currently producing output, else 0.
#must_use
fn drum_kick_is_active(self) {
    return KickDrum_active(self);
}

# ================================================================
# SnareDrum -- sine tone body + bandpass-filtered noise.
#   phase        : tone oscillator phase
#   tone_freq    : tone frequency (Hz)
#   tone_amp, noise_amp : amplitude envelopes
#   tone_decay, noise_decay : per-sample decay coefficients
#   noise_level  : noise level relative to tone
#   noise_filter : BiquadFilter pointer (bandpass over the noise)
#   rng          : pointer to an 8-byte slot holding the u32 PRNG state
#   sample_rate  : Hz
#   active       : 1 if currently producing output, else 0
# ================================================================
#derive(accessors)
struct SnareDrum {
    phase;
    tone_freq;
    tone_amp;
    tone_decay;
    noise_amp;
    noise_decay;
    noise_level;
    noise_filter;
    rng;
    sample_rate;
    active;
}

# ================================================================
# drum_snare_new -- create a snare drum. Mirrors SnareDrum::new. Returns the
# struct pointer on success, or a negative ERR_* on invalid sample_rate or an
# invalid bandpass filter (propagated from filter_biquad_new).
# ================================================================
#must_use
fn drum_snare_new(sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var tone_decay = _drum_decay_coeff(f64_mul(DRUM_C0_1, sample_rate));     # 100ms
    var noise_decay = _drum_decay_coeff(f64_mul(DRUM_C0_15, sample_rate));   # 150ms

    var noise_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_from(1500), DRUM_C1_5);
    if (naad_is_err(noise_filter) == 1) { return noise_filter; }

    var rng = alloc(8);
    store64(rng, 67890);

    var self = alloc(sizeof(SnareDrum));
    SnareDrum_set_phase(self, 0);
    SnareDrum_set_tone_freq(self, f64_from(200));
    SnareDrum_set_tone_amp(self, 0);
    SnareDrum_set_tone_decay(self, tone_decay);
    SnareDrum_set_noise_amp(self, 0);
    SnareDrum_set_noise_decay(self, noise_decay);
    SnareDrum_set_noise_level(self, DRUM_C0_8);
    SnareDrum_set_noise_filter(self, noise_filter);
    SnareDrum_set_rng(self, rng);
    SnareDrum_set_sample_rate(self, sample_rate);
    SnareDrum_set_active(self, 0);
    return self;
}

# Trigger the snare drum: reset phase and envelopes, mark active.
fn drum_snare_trigger(self) {
    SnareDrum_set_phase(self, 0);
    SnareDrum_set_tone_amp(self, F64_ONE);
    SnareDrum_set_noise_amp(self, F64_ONE);
    SnareDrum_set_active(self, 1);
    return 0;
}

# ================================================================
# drum_snare_next_sample -- one sample of tone + bandpassed noise.
# ================================================================
#inline
#must_use
fn drum_snare_next_sample(self) {
    if (SnareDrum_active(self) == 0) { return 0; }

    # Tone component: sine at ~200 Hz.
    var phase = SnareDrum_phase(self);
    var tone_amp = SnareDrum_tone_amp(self);
    var tone = f64_mul(f64_sin(f64_mul(phase, F64_TAU)), tone_amp);
    phase = f64_add(phase, f64_div(SnareDrum_tone_freq(self), SnareDrum_sample_rate(self)));
    phase = f64_sub(phase, f64_floor(phase));
    SnareDrum_set_phase(self, phase);
    tone_amp = flush_denormal(f64_mul(tone_amp, SnareDrum_tone_decay(self)));
    SnareDrum_set_tone_amp(self, tone_amp);

    # Noise component: bandpass-filtered white noise.
    var noise_raw = xorshift32_signed_f32(SnareDrum_rng(self));
    var noise_filtered = filter_biquad_process_sample(SnareDrum_noise_filter(self), noise_raw);
    var noise_amp = SnareDrum_noise_amp(self);
    var noise = f64_mul(f64_mul(noise_filtered, noise_amp), SnareDrum_noise_level(self));
    noise_amp = flush_denormal(f64_mul(noise_amp, SnareDrum_noise_decay(self)));
    SnareDrum_set_noise_amp(self, noise_amp);

    if (f64_lt(tone_amp, DRUM_C1E_6) == 1 && f64_lt(noise_amp, DRUM_C1E_6) == 1) {
        SnareDrum_set_active(self, 0);
    }

    return f64_add(tone, noise);
}

# Fill a vec buffer in place with successive snare samples.
#inline
fn drum_snare_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, drum_snare_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# 1 if the snare is currently producing output, else 0.
#must_use
fn drum_snare_is_active(self) {
    return SnareDrum_active(self);
}

# ================================================================
# HiHat -- detuned square oscillators through highpass + bandpass.
#   phases       : vec of 6 metallic oscillator phases
#   frequencies  : vec of 6 detuned inharmonic frequencies (Hz)
#   amp          : amplitude envelope
#   decay        : per-sample decay coefficient
#   highpass, bandpass : BiquadFilter pointers (filter chain)
#   sample_rate  : Hz
#   active       : 1 if currently producing output, else 0
# ================================================================
#derive(accessors)
struct HiHat {
    phases;
    frequencies;
    amp;
    decay;
    highpass;
    bandpass;
    sample_rate;
    active;
}

# Number of metallic oscillators.
var DRUM_HIHAT_OSCILLATORS = 6;

# ================================================================
# drum_hihat_new -- create a hi-hat. Mirrors HiHat::new. `open` (1/0) selects
# a longer decay. Returns the struct pointer on success, or a negative ERR_*
# on invalid sample_rate or an invalid filter (propagated from the biquads).
# ================================================================
#must_use
fn drum_hihat_new(open, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var decay_ms = f64_from(30);
    if (open == 1) { decay_ms = f64_from(200); }
    var decay_samples = f64_mul(f64_div(decay_ms, f64_from(1000)), sample_rate);
    var decay = f64_exp(f64_div(DRUM_NEG_6_9, decay_samples));

    # Inharmonic metallic frequencies (classic 808 ratios).
    var frequencies = vec_new();
    vec_push(frequencies, DRUM_F205_3);
    vec_push(frequencies, DRUM_F304_4);
    vec_push(frequencies, DRUM_F369_6);
    vec_push(frequencies, DRUM_F522_7);
    vec_push(frequencies, DRUM_F540_5);
    vec_push(frequencies, DRUM_F800_6);

    var phases = vec_new();
    var i = 0;
    while (i < DRUM_HIHAT_OSCILLATORS) {
        vec_push(phases, 0);
        i = i + 1;
    }

    var highpass = filter_biquad_new(FILTER_HIGHPASS, sample_rate, f64_from(6000), DRUM_C0_707);
    if (naad_is_err(highpass) == 1) { return highpass; }
    var bandpass = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_from(10000), F64_ONE);
    if (naad_is_err(bandpass) == 1) { return bandpass; }

    var self = alloc(sizeof(HiHat));
    HiHat_set_phases(self, phases);
    HiHat_set_frequencies(self, frequencies);
    HiHat_set_amp(self, 0);
    HiHat_set_decay(self, decay);
    HiHat_set_highpass(self, highpass);
    HiHat_set_bandpass(self, bandpass);
    HiHat_set_sample_rate(self, sample_rate);
    HiHat_set_active(self, 0);
    return self;
}

# Trigger the hi-hat: reset all phases and amplitude, mark active.
fn drum_hihat_trigger(self) {
    var phases = HiHat_phases(self);
    var i = 0;
    while (i < DRUM_HIHAT_OSCILLATORS) {
        vec_set(phases, i, 0);
        i = i + 1;
    }
    HiHat_set_amp(self, F64_ONE);
    HiHat_set_active(self, 1);
    return 0;
}

# ================================================================
# drum_hihat_next_sample -- summed detuned squares through highpass -> bandpass.
# ================================================================
#inline
#must_use
fn drum_hihat_next_sample(self) {
    if (HiHat_active(self) == 0) { return 0; }

    var phases = HiHat_phases(self);
    var frequencies = HiHat_frequencies(self);
    var sample_rate = HiHat_sample_rate(self);

    # Sum of detuned square oscillators for metallic tone.
    var metallic = 0;
    var i = 0;
    while (i < DRUM_HIHAT_OSCILLATORS) {
        var ph = vec_get(phases, i);
        var sq = F64_ONE;
        if (f64_lt(ph, F64_HALF) == 0) { sq = f64_neg(F64_ONE); }
        metallic = f64_add(metallic, sq);
        ph = f64_add(ph, f64_div(vec_get(frequencies, i), sample_rate));
        ph = f64_sub(ph, f64_floor(ph));
        vec_set(phases, i, ph);
        i = i + 1;
    }
    metallic = f64_div(metallic, f64_from(DRUM_HIHAT_OSCILLATORS));

    # Filter chain: highpass -> bandpass.
    var hp = filter_biquad_process_sample(HiHat_highpass(self), metallic);
    var bp = filter_biquad_process_sample(HiHat_bandpass(self), hp);
    var amp = HiHat_amp(self);
    var out = f64_mul(bp, amp);

    amp = flush_denormal(f64_mul(amp, HiHat_decay(self)));
    HiHat_set_amp(self, amp);

    if (f64_lt(amp, DRUM_C1E_6) == 1) {
        HiHat_set_active(self, 0);
    }

    return out;
}

# Fill a vec buffer in place with successive hi-hat samples.
#inline
fn drum_hihat_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, drum_hihat_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# 1 if the hi-hat is currently producing output, else 0.
#must_use
fn drum_hihat_is_active(self) {
    return HiHat_active(self);
}

# --- dynamics.cyr ---

# dynamics.cyr -- Dynamics processors: compressor, limiter, and noise gate.
#
# Ports rust-old/src/dynamics.rs. f32 -> f64 throughout. serde/Display derives
# dropped and the `debug!` construction log dropped (logging is a separate
# module). All processors operate sample-by-sample for real-time use.
#
# The detector-mode split is a soft/hard-knee dispatch inside the compressor
# (no free-standing enum in the oracle); knee <= 0.0 selects the hard path.
# Structs compose by pointer: a Compressor owns a LevelDetector; a Limiter
# owns a Compressor. `&mut [f32]` buffers -> stdlib `vec` (mutated in place).
# Methods become free `dynamics_*` functions on the struct pointer.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/TWO/
# HALF, f64_max, f64_clamp), builtins (f64_exp/abs), dsp_util.cyr
# (naad_amplitude_to_db, db_to_amplitude_lut) and error.cyr (flush_denormal,
# naad_is_finite). No `include` lines -- the entry orders the modules.

# ================================================================
# Detector-knee dispatch tags (documentation constants; the compressor
# selects between them by inspecting knee_db each sample, exactly as the
# oracle branches on `self.knee_db <= 0.0`).
# ================================================================
var DETECTOR_HARD_KNEE = 0;
var DETECTOR_SOFT_KNEE = 1;

# Non-integer IEEE-754 literals used by the constructors.
var DYN_C0_001  = 0x3f50624dd2f1a9fc;   # 0.001  (noise-gate min attack)
var DYN_C0_0001 = 0x3f1a36e2eb1c432d;   # 0.0001 (limiter attack time)
var DYN_F32_MAX = 0x47efffffe0000000;   # f32::MAX = 3.4028235e38 (limiter ratio)

# ================================================================
# LevelDetector -- smoothed abs-value envelope with split attack/release
# time constants (was `EnvelopeDetector`, renamed in 1.1.0).
#   current       : current envelope value (linear)
#   attack_coeff  : attack smoothing coefficient
#   release_coeff : release smoothing coefficient
# ================================================================
#derive(accessors)
struct LevelDetector {
    current;
    attack_coeff;
    release_coeff;
}

# Convert an attack/release time (seconds) to a one-pole coefficient.
# time <= 0.0 collapses to an instantaneous (coeff = 1.0) response.
#must_use
fn dynamics_time_to_coeff(time, sample_rate) {
    if (f64_le(time, 0) == 1) { return F64_ONE; }
    var e = f64_exp(f64_div(f64_neg(F64_ONE), f64_mul(time, sample_rate)));
    return f64_sub(F64_ONE, e);
}

# Create a level detector. `attack`/`release` are times in seconds.
#must_use
fn dynamics_level_detector_new(attack, release, sample_rate) {
    var self = alloc(sizeof(LevelDetector));
    LevelDetector_set_current(self, 0);
    LevelDetector_set_attack_coeff(self, dynamics_time_to_coeff(attack, sample_rate));
    LevelDetector_set_release_coeff(self, dynamics_time_to_coeff(release, sample_rate));
    return self;
}

# Process a sample and return the envelope level. Non-finite input -> level 0.
#inline
#must_use
fn dynamics_level_detector_process(self, input) {
    var level = 0;
    if (naad_is_finite(input) == 1) { level = f64_abs(input); }
    var cur = LevelDetector_current(self);
    var coeff = LevelDetector_release_coeff(self);
    if (f64_gt(level, cur) == 1) { coeff = LevelDetector_attack_coeff(self); }
    var newcur = f64_add(cur, f64_mul(coeff, f64_sub(level, cur)));
    newcur = flush_denormal(newcur);
    LevelDetector_set_current(self, newcur);
    return newcur;
}

# ================================================================
# Compressor -- soft-knee dynamics compressor.
#   threshold_db : threshold in dB (direct-read; no validation)
#   ratio        : compression ratio, clamped >= 1.0 (private invariant)
#   knee_db      : knee width in dB (0.0 = hard knee)
#   makeup_db    : makeup gain in dB
#   detector     : LevelDetector pointer
# ================================================================
#derive(accessors)
struct Compressor {
    threshold_db;
    ratio;
    knee_db;
    makeup_db;
    detector;
}

# Create a compressor. `ratio` clamped to >= 1.0; knee/makeup default 0.0.
#must_use
fn dynamics_compressor_new(threshold_db, ratio, attack, release, sample_rate) {
    var self = alloc(sizeof(Compressor));
    Compressor_set_threshold_db(self, threshold_db);
    Compressor_set_ratio(self, f64_max(ratio, F64_ONE));
    Compressor_set_knee_db(self, 0);
    Compressor_set_makeup_db(self, 0);
    Compressor_set_detector(self, dynamics_level_detector_new(attack, release, sample_rate));
    return self;
}

# Current compression ratio.
#must_use
fn dynamics_compressor_ratio(self) {
    return Compressor_ratio(self);
}

# Set the compression ratio. Clamped to >= 1.0.
fn dynamics_compressor_set_ratio(self, ratio) {
    Compressor_set_ratio(self, f64_max(ratio, F64_ONE));
    return 0;
}

# Hard-knee gain reduction (dB) -- `knee_db == 0.0` fast path.
#inline
fn dynamics_compressor_compute_gain_db_hard(self, input_db) {
    var t = Compressor_threshold_db(self);
    if (f64_le(input_db, t) == 1) { return 0; }
    var r = Compressor_ratio(self);
    # (t + (input_db - t) / r) - input_db
    return f64_sub(f64_add(t, f64_div(f64_sub(input_db, t), r)), input_db);
}

# Soft-knee gain reduction (dB) -- `knee_db > 0.0`.
#inline
fn dynamics_compressor_compute_gain_db_soft(self, input_db) {
    var t = Compressor_threshold_db(self);
    var r = Compressor_ratio(self);
    var k = Compressor_knee_db(self);
    var half_k = f64_mul(k, F64_HALF);
    if (f64_gt(f64_abs(f64_sub(input_db, t)), half_k) == 1) {
        # Outside the soft-knee window -- full hard-knee math.
        if (f64_le(input_db, t) == 1) { return 0; }
        return f64_sub(f64_add(t, f64_div(f64_sub(input_db, t), r)), input_db);
    }
    # Inside the soft-knee window -- quadratic interpolation.
    # x = input_db - t + k * 0.5 ; (1/r - 1) * x * x / (2 * k)
    var x = f64_add(f64_sub(input_db, t), half_k);
    var coeff = f64_sub(f64_div(F64_ONE, r), F64_ONE);
    var num = f64_mul(f64_mul(coeff, x), x);
    return f64_div(num, f64_mul(F64_TWO, k));
}

# Compute gain reduction (dB) for an input level in dB -- dispatch entry.
#inline
#must_use
fn dynamics_compressor_compute_gain_db(self, input_db) {
    if (f64_le(Compressor_knee_db(self), 0) == 1) {
        return dynamics_compressor_compute_gain_db_hard(self, input_db);
    }
    return dynamics_compressor_compute_gain_db_soft(self, input_db);
}

# Process a single sample. dB->linear via db_to_amplitude_lut (no powf).
#inline
#must_use
fn dynamics_compressor_process_sample(self, input) {
    var env = dynamics_level_detector_process(Compressor_detector(self), input);
    var env_db = naad_amplitude_to_db(env);
    var gain_db = 0;
    if (f64_le(Compressor_knee_db(self), 0) == 1) {
        gain_db = dynamics_compressor_compute_gain_db_hard(self, env_db);
    } else {
        gain_db = dynamics_compressor_compute_gain_db_soft(self, env_db);
    }
    gain_db = f64_add(gain_db, Compressor_makeup_db(self));
    return f64_mul(input, db_to_amplitude_lut(gain_db));
}

# Process a buffer (vec of f64) in place.
#inline
fn dynamics_compressor_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, dynamics_compressor_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Limiter -- brick-wall limiter (fast attack, infinite ratio).
#   ceiling_db : ceiling in dB (private; shadows the compressor threshold)
#   release    : release time in seconds (private)
#   compressor : Compressor pointer (infinity ratio)
# ================================================================
#derive(accessors)
struct Limiter {
    ceiling_db;
    release;
    compressor;
}

# Create a limiter. `ceiling_db` is the max output level, `release` in seconds.
#must_use
fn dynamics_limiter_new(ceiling_db, release, sample_rate) {
    var comp = dynamics_compressor_new(ceiling_db, DYN_F32_MAX, DYN_C0_0001, release, sample_rate);
    Compressor_set_knee_db(comp, 0);
    var self = alloc(sizeof(Limiter));
    Limiter_set_ceiling_db(self, ceiling_db);
    Limiter_set_release(self, release);
    Limiter_set_compressor(self, comp);
    return self;
}

# Current ceiling in dB.
#must_use
fn dynamics_limiter_ceiling_db(self) {
    return Limiter_ceiling_db(self);
}

# Set the ceiling in dB. Propagates to the internal gain stage.
fn dynamics_limiter_set_ceiling_db(self, ceiling_db) {
    Limiter_set_ceiling_db(self, ceiling_db);
    Compressor_set_threshold_db(Limiter_compressor(self), ceiling_db);
    return 0;
}

# Current release time in seconds.
#must_use
fn dynamics_limiter_release(self) {
    return Limiter_release(self);
}

# Process a single sample.
#inline
#must_use
fn dynamics_limiter_process_sample(self, input) {
    return dynamics_compressor_process_sample(Limiter_compressor(self), input);
}

# Process a buffer (vec of f64) in place.
#inline
fn dynamics_limiter_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, dynamics_limiter_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# NoiseGate -- silences signal below a threshold with attack/hold/release.
#   threshold_db  : threshold in dB (direct-read each sample)
#   detector      : LevelDetector pointer
#   gate_gain     : current gate gain (0.0 closed, 1.0 open)
#   hold_counter  : samples remaining before release (u32 -> i64 slot)
#   hold_samples  : hold time in samples (u32 -> i64 slot)
#   attack_coeff  : gate-opening smoothing coefficient (fast)
#   release_coeff : gate-closing smoothing coefficient (matches release)
# ================================================================
#derive(accessors)
struct NoiseGate {
    threshold_db;
    detector;
    gate_gain;
    hold_counter;
    hold_samples;
    attack_coeff;
    release_coeff;
}

# Create a noise gate. Times (attack/hold/release) in seconds; attack floored
# at 1ms to avoid clicks. release <= 0.0 gives an instantaneous close.
#must_use
fn dynamics_noise_gate_new(threshold_db, attack, hold, release, sample_rate) {
    var attack_time = f64_max(attack, DYN_C0_001);
    var self = alloc(sizeof(NoiseGate));
    NoiseGate_set_threshold_db(self, threshold_db);
    NoiseGate_set_detector(self, dynamics_level_detector_new(attack, release, sample_rate));
    NoiseGate_set_gate_gain(self, 0);
    NoiseGate_set_hold_counter(self, 0);
    NoiseGate_set_hold_samples(self, f64_to(f64_mul(hold, sample_rate)));
    NoiseGate_set_attack_coeff(self,
    f64_sub(F64_ONE, f64_exp(f64_div(f64_neg(F64_ONE), f64_mul(attack_time, sample_rate)))));
    var rc = F64_ONE;
    if (f64_gt(release, 0) == 1) {
        rc = f64_sub(F64_ONE, f64_exp(f64_div(f64_neg(F64_ONE), f64_mul(release, sample_rate))));
    }
    NoiseGate_set_release_coeff(self, rc);
    return self;
}

# Process a single sample.
#inline
#must_use
fn dynamics_noise_gate_process_sample(self, input) {
    var env = dynamics_level_detector_process(NoiseGate_detector(self), input);
    var env_db = naad_amplitude_to_db(env);

    var target = 0;
    if (f64_ge(env_db, NoiseGate_threshold_db(self)) == 1) {
        NoiseGate_set_hold_counter(self, NoiseGate_hold_samples(self));
        target = F64_ONE;
    } elif (NoiseGate_hold_counter(self) > 0) {
        NoiseGate_set_hold_counter(self, NoiseGate_hold_counter(self) - 1);
        target = F64_ONE;
    } else {
        target = 0;
    }

    # Smooth the gate gain: fast attack, slow release.
    var gg = NoiseGate_gate_gain(self);
    var coeff = NoiseGate_release_coeff(self);
    if (f64_gt(target, gg) == 1) { coeff = NoiseGate_attack_coeff(self); }
    var newgg = f64_add(gg, f64_mul(coeff, f64_sub(target, gg)));
    newgg = flush_denormal(newgg);
    NoiseGate_set_gate_gain(self, newgg);
    return f64_mul(input, newgg);
}

# Process a buffer (vec of f64) in place.
#inline
fn dynamics_noise_gate_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, dynamics_noise_gate_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# --- fm.cyr ---

# fm.cyr -- Multi-operator FM (Frequency Modulation) synthesis.
#
# Ports rust-old/src/synth/fm.rs. f32 -> f64 throughout. Classic FM synthesis
# with up to 6 operators routed through configurable algorithms. Each operator
# is a sine oscillator with its own ADSR envelope (reused from envelope.cyr),
# output level, and optional self-feedback.
#
# The `FmAlgorithm` enum becomes integer FM_ALGO_* constants. The
# `SmallVec<[FmOperator; 6]>` operator storage becomes a stdlib vec of
# FmOperator pointers. serde/Display derives + tests are dropped. Constructors
# return the struct pointer on success or a negative ERR_* on failure (was
# Result<Self>). `Option<()>` setters return 1 (Some) / 0 (None) for out-of-
# range indices; `Option<&FmOperator>` accessors return the pointer or 0 (null).
# Methods become free `fm_*` functions taking the struct pointer.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/HALF/
# TAU, f64_clamp), builtins (f64_add/sub/mul/div/sin/floor/from/lt/gt),
# error.cyr (validate_sample_rate, flush_denormal, naad_is_err, ERR_*), and
# envelope.cyr (envelope_adsr_with_sample_rate/next_value/gate_on/gate_off/
# is_active). No `include` lines.

# ================================================================
# Maximum number of FM operators supported (was const MAX_OPERATORS).
# ================================================================
var FM_MAX_OPERATORS = 6;

# ================================================================
# FmAlgorithm -> integer constants (was `enum FmAlgorithm`).
#   SERIAL2   : op0 modulates op1, op1 is carrier.
#   PARALLEL2 : op0 and op1 both output (additive).
#   SERIAL4   : op0 -> op1 -> op2 -> op3 (carrier).
#   STACK4    : (op0+op1) modulates (op2+op3), latter pair is carrier.
#   CUSTOM    : caller manages modulation externally (parallel, no mod).
# ================================================================
var FM_ALGO_SERIAL2   = 0;
var FM_ALGO_PARALLEL2 = 1;
var FM_ALGO_SERIAL4   = 2;
var FM_ALGO_STACK4    = 3;
var FM_ALGO_CUSTOM    = 4;

# ================================================================
# Default ADSR parameters for a new operator (IEEE-754 bit patterns).
# ================================================================
var FM_C0_01 = 0x3f847ae147ae147b;   # 0.01 (attack seconds)
var FM_C0_1  = 0x3fb999999999999a;   # 0.1  (decay seconds)
var FM_C0_8  = 0x3fe999999999999a;   # 0.8  (sustain level)
var FM_C0_3  = 0x3fd3333333333333;   # 0.3  (release seconds)

# Default operator frequency (440 Hz) as an integer literal.
var FM_DEFAULT_FREQ = 440;

# ================================================================
# FmOperator -- a single FM operator: sine oscillator + envelope + level +
# feedback.
#   frequency      : frequency in Hz
#   phase          : current oscillator phase (0..1)
#   envelope       : Adsr pointer for this operator
#   output_level   : output level (0.0..1.0)
#   feedback       : self-feedback amount (0.0..1.0)
#   feedback_state : previous output for the feedback path
#   sample_rate    : sample rate in Hz
# ================================================================
#derive(accessors)
struct FmOperator {
    frequency;
    phase;
    envelope;
    output_level;
    feedback;
    feedback_state;
    sample_rate;
}

# Create a new FM operator at the given frequency. Returns the struct pointer
# on success, or a negative ERR_* if the envelope/sample_rate is invalid.
#must_use
fn fm_operator_new(frequency, sample_rate) {
    var envelope = envelope_adsr_with_sample_rate(FM_C0_01, FM_C0_1, FM_C0_8, FM_C0_3, sample_rate);
    if (naad_is_err(envelope) == 1) { return envelope; }

    var self = alloc(sizeof(FmOperator));
    FmOperator_set_frequency(self, frequency);
    FmOperator_set_phase(self, 0);
    FmOperator_set_envelope(self, envelope);
    FmOperator_set_output_level(self, F64_ONE);
    FmOperator_set_feedback(self, 0);
    FmOperator_set_feedback_state(self, 0);
    FmOperator_set_sample_rate(self, sample_rate);
    return self;
}

# Set the operator frequency.
fn fm_operator_set_frequency(self, freq) {
    FmOperator_set_frequency(self, freq);
    return 0;
}

# Set the output level (clamped to 0.0..1.0).
fn fm_operator_set_level(self, level) {
    FmOperator_set_output_level(self, f64_clamp(level, 0, F64_ONE));
    return 0;
}

# Set the self-feedback amount (clamped to 0.0..1.0).
fn fm_operator_set_feedback(self, amount) {
    FmOperator_set_feedback(self, f64_clamp(amount, 0, F64_ONE));
    return 0;
}

# Trigger the operator envelope.
fn fm_operator_gate_on(self) {
    envelope_adsr_gate_on(FmOperator_envelope(self));
    return 0;
}

# Release the operator envelope.
fn fm_operator_gate_off(self) {
    envelope_adsr_gate_off(FmOperator_envelope(self));
    return 0;
}

# Generate the next sample with external phase modulation input.
# `phase_mod` is added to the operator's phase before computing sine.
#inline
#must_use
fn fm_operator_next_sample(self, phase_mod) {
    var fb = f64_mul(FmOperator_feedback(self), FmOperator_feedback_state(self));
    var mod_phase = f64_add(f64_add(FmOperator_phase(self), phase_mod), fb);
    var out = f64_sin(f64_mul(mod_phase, F64_TAU));
    var env = envelope_adsr_next_value(FmOperator_envelope(self));
    var result = f64_mul(f64_mul(out, env), FmOperator_output_level(self));

    FmOperator_set_feedback_state(self, flush_denormal(result));

    # Advance phase and wrap into [0, 1).
    var phase_inc = f64_div(FmOperator_frequency(self), FmOperator_sample_rate(self));
    var new_phase = f64_add(FmOperator_phase(self), phase_inc);
    FmOperator_set_phase(self, f64_sub(new_phase, f64_floor(new_phase)));

    return result;
}

# Returns the operator's envelope pointer (mutable view).
fn fm_operator_envelope_mut(self) {
    return FmOperator_envelope(self);
}

# Returns the operator's envelope pointer (shared view).
#must_use
fn fm_operator_envelope(self) {
    return FmOperator_envelope(self);
}

# ================================================================
# FmSynthEngine -- multi-operator FM synthesis engine.
#   operators   : vec of FmOperator pointers (up to 6)
#   algorithm   : FM_ALGO_* routing constant
#   sample_rate : sample rate in Hz
# ================================================================
#derive(accessors)
struct FmSynthEngine {
    operators;
    algorithm;
    sample_rate;
}

# Create a new FM synth engine with `num_operators` 440 Hz sine operators.
# Returns the struct pointer on success, or a negative ERR_* if num_operators
# is 0 or > 6, or sample_rate is invalid.
#must_use
fn fm_engine_new(num_operators, sample_rate) {
    if (num_operators == 0) { return ERR_INVALID_PARAMETER; }
    if (num_operators > FM_MAX_OPERATORS) { return ERR_INVALID_PARAMETER; }
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var operators = vec_new();
    var i = 0;
    while (i < num_operators) {
        var op = fm_operator_new(f64_from(FM_DEFAULT_FREQ), sample_rate);
        if (naad_is_err(op) == 1) { return op; }
        vec_push(operators, op);
        i = i + 1;
    }

    var self = alloc(sizeof(FmSynthEngine));
    FmSynthEngine_set_operators(self, operators);
    FmSynthEngine_set_algorithm(self, FM_ALGO_SERIAL2);
    FmSynthEngine_set_sample_rate(self, sample_rate);
    return self;
}

# Set the routing algorithm.
fn fm_engine_set_algorithm(self, algorithm) {
    FmSynthEngine_set_algorithm(self, algorithm);
    return 0;
}

# Set the frequency of an operator by index. Returns 1 (Some) on success or
# 0 (None) if `index` is out of range.
fn fm_engine_set_operator_freq(self, index, freq) {
    var operators = FmSynthEngine_operators(self);
    if (index < 0) { return 0; }
    if (index >= vec_len(operators)) { return 0; }
    fm_operator_set_frequency(vec_get(operators, index), freq);
    return 1;
}

# Set the output level of an operator by index. Returns 1 (Some) on success or
# 0 (None) if `index` is out of range.
fn fm_engine_set_operator_level(self, index, level) {
    var operators = FmSynthEngine_operators(self);
    if (index < 0) { return 0; }
    if (index >= vec_len(operators)) { return 0; }
    fm_operator_set_level(vec_get(operators, index), level);
    return 1;
}

# Trigger all operator envelopes (note on).
fn fm_engine_note_on(self) {
    var operators = FmSynthEngine_operators(self);
    var n = vec_len(operators);
    var i = 0;
    while (i < n) {
        fm_operator_gate_on(vec_get(operators, i));
        i = i + 1;
    }
    return 0;
}

# Release all operator envelopes (note off).
fn fm_engine_note_off(self) {
    var operators = FmSynthEngine_operators(self);
    var n = vec_len(operators);
    var i = 0;
    while (i < n) {
        fm_operator_gate_off(vec_get(operators, i));
        i = i + 1;
    }
    return 0;
}

# Returns the operator pointer at `index` (mutable view), or 0 (null) if out
# of range.
fn fm_engine_operator_mut(self, index) {
    var operators = FmSynthEngine_operators(self);
    if (index < 0) { return 0; }
    if (index >= vec_len(operators)) { return 0; }
    return vec_get(operators, index);
}

# Returns the operator pointer at `index` (shared view), or 0 (null) if out
# of range.
#must_use
fn fm_engine_operator(self, index) {
    var operators = FmSynthEngine_operators(self);
    if (index < 0) { return 0; }
    if (index >= vec_len(operators)) { return 0; }
    return vec_get(operators, index);
}

# Serial2: op[0] -> op[1] -> out (uses first 2 operators).
#inline
fn fm_engine_process_serial2(self, n) {
    var operators = FmSynthEngine_operators(self);
    if (n < 2) {
        return fm_operator_next_sample(vec_get(operators, 0), 0);
    }
    var mod_out = fm_operator_next_sample(vec_get(operators, 0), 0);
    return fm_operator_next_sample(vec_get(operators, 1), mod_out);
}

# Parallel2: (op[0] + op[1]) / 2 -> out.
#inline
fn fm_engine_process_parallel2(self, n) {
    var operators = FmSynthEngine_operators(self);
    if (n < 2) {
        return fm_operator_next_sample(vec_get(operators, 0), 0);
    }
    var a = fm_operator_next_sample(vec_get(operators, 0), 0);
    var b = fm_operator_next_sample(vec_get(operators, 1), 0);
    return f64_mul(f64_add(a, b), F64_HALF);
}

# Serial4: op[0] -> op[1] -> op[2] -> op[3] -> out.
#inline
fn fm_engine_process_serial4(self, n) {
    var operators = FmSynthEngine_operators(self);
    var mod_signal = 0;
    var count = n;
    if (count > 4) { count = 4; }
    var i = 0;
    while (i < count) {
        mod_signal = fm_operator_next_sample(vec_get(operators, i), mod_signal);
        i = i + 1;
    }
    return mod_signal;
}

# Stack4: (op[0]+op[1]) modulates (op[2]+op[3]).
#inline
fn fm_engine_process_stack4(self, n) {
    if (n < 4) {
        return fm_engine_process_serial4(self, n);
    }
    var operators = FmSynthEngine_operators(self);
    var mod_a = fm_operator_next_sample(vec_get(operators, 0), 0);
    var mod_b = fm_operator_next_sample(vec_get(operators, 1), 0);
    var mod_sum = f64_mul(f64_add(mod_a, mod_b), F64_HALF);
    var car_a = fm_operator_next_sample(vec_get(operators, 2), mod_sum);
    var car_b = fm_operator_next_sample(vec_get(operators, 3), mod_sum);
    return f64_mul(f64_add(car_a, car_b), F64_HALF);
}

# Generate the next output sample by routing operators through the current
# algorithm.
#inline
#must_use
fn fm_engine_next_sample(self) {
    var operators = FmSynthEngine_operators(self);
    var n = vec_len(operators);
    var algo = FmSynthEngine_algorithm(self);
    if (algo == FM_ALGO_SERIAL2) {
        return fm_engine_process_serial2(self, n);
    } elif (algo == FM_ALGO_PARALLEL2) {
        return fm_engine_process_parallel2(self, n);
    } elif (algo == FM_ALGO_SERIAL4) {
        return fm_engine_process_serial4(self, n);
    } elif (algo == FM_ALGO_STACK4) {
        return fm_engine_process_stack4(self, n);
    }
    # Custom: all operators output in parallel (no modulation).
    var sum = 0;
    var i = 0;
    while (i < n) {
        sum = f64_add(sum, fm_operator_next_sample(vec_get(operators, i), 0));
        i = i + 1;
    }
    var divisor = n;
    if (divisor < 1) { divisor = 1; }
    return f64_div(sum, f64_from(divisor));
}

# Fill a buffer (vec of f64 slots) with samples.
#inline
fn fm_engine_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, fm_engine_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# Check if any operator envelope is still active. Returns 1/0.
#must_use
fn fm_engine_is_active(self) {
    var operators = FmSynthEngine_operators(self);
    var n = vec_len(operators);
    var i = 0;
    while (i < n) {
        var op = vec_get(operators, i);
        if (envelope_adsr_is_active(FmOperator_envelope(op)) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# --- physical.cyr ---

# physical.cyr -- Physical modeling synthesis (Karplus-Strong / waveguide /
# RK4 Moog ladder). Ports rust-old/src/synth/physical.rs. f32 -> f64 throughout.
#
# Serde derives + Display are dropped. Constructors return the struct pointer on
# success or a negative ERR_* on invalid frequency/sample_rate (mirroring the
# Rust `Result` error paths). Methods become free `physical_*` functions taking
# the struct pointer. `&mut u32` PRNG state -> a pointer to an 8-byte slot
# stepped via dsp_util's xorshift32_signed_f32. `&mut [f32]` buffers -> vec.
#
# DIVERGENCE (noted, not silent): the Rust MoogLadder integrates a coupled
# 4-state ODE with `hisab::num::rk4(derivative, 0.0, &state, dt, 1)` -- a VECTOR
# RK4. The ported hisab exposes only a SCALAR `num_rk4(f, t, y, dt)` (single
# f64 state via fncall2), which cannot integrate a coupled system correctly.
# We therefore hand-roll the identical classic 4th-order Runge-Kutta step over
# the 4-vector (same k1..k4 / (1,2,2,1)/6 weights hisab's Rust rk4 uses),
# calling physical_moog_deriv for the derivative — a faithful reimplementation,
# not an approximation. One deliberate, port-wide difference: the oracle stores
# each ladder state as `flush_denormal(new_state[i] as f32) as f64` (re-quantized
# to f32 every sample, a Rust-native artifact); consistent with naad's f32->f64
# widening policy this port keeps the state at f64 (a precision refinement, not
# a divergence in intent). Both flush denormals.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/TWO/
# HALF/PI/TAU, f64_clamp), ganita (f64_tanh), error.cyr (validate_frequency/
# validate_sample_rate, flush_denormal, naad_is_err, ERR_*), dsp_util
# (xorshift32_signed_f32), delay.cyr (delay_line_*). The module has no includes.

# ================================================================
# Float literals (IEEE-754 bit patterns).
# ================================================================
var PHYS_KS_FB_BASE    = 0x3feccccccccccccd;   # 0.9   feedback base
var PHYS_KS_FB_SCALE   = 0x3fb95810624dd2f2;   # 0.099 feedback decay scale
var PHYS_ACTIVE_THRESH = 0x3eb0c6f7a0b5ed8d;   # 1e-6  is_active threshold
var PHYS_WG_JUNCTION   = 0x3fefae147ae147ae;   # 0.99  default junction coeff

# ================================================================
# KarplusStrong -- plucked string. A noise burst excites a delay line whose
# length sets the pitch; each loop pass applies a one-pole lowpass (damping)
# and feedback attenuation for a naturally decaying, pitched tone.
#   delay_line    : DelayLine pointer (period = sample_rate / frequency)
#   feedback      : feedback coefficient (decay control)
#   damping_prev  : one-pole lowpass state
#   brightness    : damping coefficient in [0,1] (higher = brighter)
#   delay_samples : fractional delay in samples (tuning)
#   sample_rate   : Hz
#   frequency     : fundamental Hz
#   rng           : pointer to an 8-byte slot holding the u32 PRNG state
# ================================================================
#derive(accessors)
struct KarplusStrong { delay_line; feedback; damping_prev; brightness; delay_samples;
    sample_rate; frequency; rng; }

# Create a Karplus-Strong string model. Returns the struct pointer on success,
# or a negative ERR_* on invalid sample_rate/frequency.
#must_use
fn physical_ks_new(frequency, decay, brightness, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    e = validate_frequency(frequency, sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var delay_samples = f64_div(sample_rate, frequency);
    var max_delay = f64_to(f64_ceil(delay_samples)) + 2;
    var dl = delay_line_new(max_delay);

    # Feedback derived from decay: higher decay = closer to 1.0 (~0.9..0.999).
    var feedback = f64_add(PHYS_KS_FB_BASE, f64_mul(f64_clamp(decay, 0, F64_ONE), PHYS_KS_FB_SCALE));

    var rng = alloc(8);
    store64(rng, 54321);

    var self = alloc(sizeof(KarplusStrong));
    KarplusStrong_set_delay_line(self, dl);
    KarplusStrong_set_feedback(self, feedback);
    KarplusStrong_set_damping_prev(self, 0);
    KarplusStrong_set_brightness(self, f64_clamp(brightness, 0, F64_ONE));
    KarplusStrong_set_delay_samples(self, delay_samples);
    KarplusStrong_set_sample_rate(self, sample_rate);
    KarplusStrong_set_frequency(self, frequency);
    KarplusStrong_set_rng(self, rng);
    return self;
}

# Signed noise sample for the exciter (xorshift32 pointer-state step).
#inline
fn physical_ks_next_noise(self) {
    return xorshift32_signed_f32(KarplusStrong_rng(self));
}

# Excite the string with a noise burst (pluck).
fn physical_ks_pluck(self) {
    delay_line_clear(KarplusStrong_delay_line(self));
    KarplusStrong_set_damping_prev(self, 0);
    var n = f64_to(f64_ceil(KarplusStrong_delay_samples(self)));
    var i = 0;
    while (i < n) {
        var noise = physical_ks_next_noise(self);
        delay_line_write(KarplusStrong_delay_line(self), noise);
        i = i + 1;
    }
    return 0;
}

# Set the fundamental frequency. Returns ERR_NONE on success, negative ERR_* if
# the frequency is out of (0, Nyquist) or non-finite.
fn physical_ks_set_frequency(self, frequency) {
    var e = validate_frequency(frequency, KarplusStrong_sample_rate(self));
    if (naad_is_err(e) == 1) { return e; }
    KarplusStrong_set_frequency(self, frequency);
    KarplusStrong_set_delay_samples(self, f64_div(KarplusStrong_sample_rate(self), frequency));
    return ERR_NONE;
}

# Generate the next sample.
#inline
#must_use
fn physical_ks_next_sample(self) {
    var dl = KarplusStrong_delay_line(self);
    var delayed = delay_line_read(dl, KarplusStrong_delay_samples(self));

    # One-pole lowpass for damping:
    # y[n] = brightness * x[n] + (1 - brightness) * y[n-1]
    var brightness = KarplusStrong_brightness(self);
    var damping_prev = KarplusStrong_damping_prev(self);
    var filtered = f64_add(f64_mul(brightness, delayed),
    f64_mul(f64_sub(F64_ONE, brightness), damping_prev));
    KarplusStrong_set_damping_prev(self, flush_denormal(filtered));

    # Write back with feedback.
    var feedback_sample = f64_mul(filtered, KarplusStrong_feedback(self));
    delay_line_write(dl, flush_denormal(feedback_sample));
    return delayed;
}

# Fill a vec buffer with samples (in place).
#inline
fn physical_ks_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, physical_ks_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# 1 if the string is still vibrating (|damping_prev| > 1e-6), else 0.
#must_use
fn physical_ks_is_active(self) {
    if (f64_gt(f64_abs(KarplusStrong_damping_prev(self)), PHYS_ACTIVE_THRESH) == 1) { return 1; }
    return 0;
}

# Returns the fundamental frequency.
#must_use
fn physical_ks_frequency(self) {
    return KarplusStrong_frequency(self);
}

# ================================================================
# Waveguide -- simple bidirectional tube/string model. Two delay lines carry
# waves in opposite directions with boundary reflection (sign inversion) and
# damping.
#   forward_delay   : forward-travelling DelayLine pointer
#   backward_delay  : backward-travelling DelayLine pointer
#   delay_samples   : delay length in samples (half the period)
#   damping         : energy loss per round trip in [0,1]
#   junction_coeff  : junction reflection coefficient
#   sample_rate     : Hz
# ================================================================
#derive(accessors)
struct Waveguide { forward_delay; backward_delay; delay_samples; damping; junction_coeff;
    sample_rate; }

# Create a bidirectional waveguide. Returns the struct pointer on success, or a
# negative ERR_* on invalid sample_rate/frequency.
#must_use
fn physical_wg_new(frequency, damping, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    e = validate_frequency(frequency, sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    # Each delay line is half the period (wave travels in both directions).
    var half_period = f64_div(f64_div(sample_rate, frequency), F64_TWO);
    var max_delay = f64_to(f64_ceil(half_period)) + 2;

    var self = alloc(sizeof(Waveguide));
    Waveguide_set_forward_delay(self, delay_line_new(max_delay));
    Waveguide_set_backward_delay(self, delay_line_new(max_delay));
    Waveguide_set_delay_samples(self, half_period);
    Waveguide_set_damping(self, f64_clamp(damping, 0, F64_ONE));
    Waveguide_set_junction_coeff(self, PHYS_WG_JUNCTION);
    Waveguide_set_sample_rate(self, sample_rate);
    return self;
}

# Inject energy into the waveguide (excitation): split equally into both dirs.
fn physical_wg_excite(self, sample) {
    var half = f64_mul(sample, F64_HALF);
    delay_line_write(Waveguide_forward_delay(self), half);
    delay_line_write(Waveguide_backward_delay(self), half);
    return 0;
}

# Generate the next sample (advance both lines with boundary reflection).
#inline
#must_use
fn physical_wg_next_sample(self) {
    var fwd_dl = Waveguide_forward_delay(self);
    var bwd_dl = Waveguide_backward_delay(self);
    var ds = Waveguide_delay_samples(self);

    var fwd = delay_line_read(fwd_dl, ds);
    var bwd = delay_line_read(bwd_dl, ds);

    # Reflection at boundaries: invert and apply damping + junction.
    var attenuation = f64_sub(F64_ONE, Waveguide_damping(self));
    var jc = Waveguide_junction_coeff(self);
    var fwd_reflected = f64_mul(f64_mul(f64_neg(bwd), attenuation), jc);
    var bwd_reflected = f64_mul(f64_mul(f64_neg(fwd), attenuation), jc);

    delay_line_write(fwd_dl, flush_denormal(fwd_reflected));
    delay_line_write(bwd_dl, flush_denormal(bwd_reflected));

    # Output is the sum at the observation point.
    return f64_add(fwd, bwd);
}

# Fill a vec buffer with samples (in place).
#inline
fn physical_wg_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, physical_wg_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# Set the junction reflection coefficient (clamped to [0,1]).
fn physical_wg_set_junction_coeff(self, coeff) {
    Waveguide_set_junction_coeff(self, f64_clamp(coeff, 0, F64_ONE));
    return 0;
}

# 1 if the waveguide still has energy above threshold, else 0.
#must_use
fn physical_wg_is_active(self) {
    var ds = Waveguide_delay_samples(self);
    var fwd = delay_line_read(Waveguide_forward_delay(self), ds);
    var bwd = delay_line_read(Waveguide_backward_delay(self), ds);
    if (f64_gt(f64_abs(f64_add(fwd, bwd)), PHYS_ACTIVE_THRESH) == 1) { return 1; }
    return 0;
}

# ================================================================
# MoogLadder -- 4-pole lowpass integrated via classic RK4 (see DIVERGENCE note
# at the top of this file). Four cascaded one-pole stages with global feedback
# `k` for resonance and a tanh saturator per stage. State equations:
#   dy[0]/dt = omega * (tanh(input - k*y[3]) - tanh(y[0]))
#   dy[1]/dt = omega * (tanh(y[0]) - tanh(y[1]))
#   dy[2]/dt = omega * (tanh(y[1]) - tanh(y[2]))
#   dy[3]/dt = omega * (tanh(y[2]) - tanh(y[3]))
# where omega = 2*pi*cutoff_hz and k in [0, 4] (k ~ 4 -> self-oscillation).
#   cutoff_hz   : cutoff frequency Hz
#   resonance   : feedback amount, clamped to [0, 4]
#   sample_rate : Hz
#   state       : vec of 4 f64 ladder-stage states
#   scratch     : 128-byte scratch (4 x 32B RK4 stage buffers k1..k4)
# ================================================================
#derive(accessors)
struct MoogLadder { cutoff_hz; resonance; sample_rate; state; scratch; }

# Create a Moog-ladder filter. Returns the struct pointer on success, or a
# negative ERR_* on invalid sample_rate/cutoff.
#must_use
fn physical_moog_new(cutoff_hz, resonance, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    e = validate_frequency(cutoff_hz, sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var state = vec_new();
    vec_push(state, 0);
    vec_push(state, 0);
    vec_push(state, 0);
    vec_push(state, 0);

    var self = alloc(sizeof(MoogLadder));
    MoogLadder_set_cutoff_hz(self, cutoff_hz);
    MoogLadder_set_resonance(self, f64_clamp(resonance, 0, f64_from(4)));
    MoogLadder_set_sample_rate(self, sample_rate);
    MoogLadder_set_state(self, state);
    MoogLadder_set_scratch(self, alloc(128));
    return self;
}

# Set the cutoff frequency. Returns ERR_NONE on success, negative ERR_* if out
# of the valid (0, Nyquist) range.
fn physical_moog_set_cutoff(self, cutoff_hz) {
    var e = validate_frequency(cutoff_hz, MoogLadder_sample_rate(self));
    if (naad_is_err(e) == 1) { return e; }
    MoogLadder_set_cutoff_hz(self, cutoff_hz);
    return ERR_NONE;
}

# Set the resonance amount (clamped to [0, 4]).
fn physical_moog_set_resonance(self, resonance) {
    MoogLadder_set_resonance(self, f64_clamp(resonance, 0, f64_from(4)));
    return 0;
}

# Returns the current cutoff in Hz.
#inline
#must_use
fn physical_moog_cutoff_hz(self) {
    return MoogLadder_cutoff_hz(self);
}

# Returns the current resonance amount.
#inline
#must_use
fn physical_moog_resonance(self) {
    return MoogLadder_resonance(self);
}

# Reset internal state to zero.
fn physical_moog_reset(self) {
    var state = MoogLadder_state(self);
    vec_set(state, 0, 0);
    vec_set(state, 1, 0);
    vec_set(state, 2, 0);
    vec_set(state, 3, 0);
    return 0;
}

# Evaluate the 4-state Moog derivative at (y0..y3) into the 4-slot buffer `out`
# (32 bytes: components at offsets 0/8/16/24).
fn physical_moog_deriv(omega, k, input, y0, y1, y2, y3, out) {
    var stage_in = f64_tanh(f64_sub(input, f64_mul(k, y3)));
    var t0 = f64_tanh(y0);
    var t1 = f64_tanh(y1);
    var t2 = f64_tanh(y2);
    var t3 = f64_tanh(y3);
    store64(out, f64_mul(omega, f64_sub(stage_in, t0)));
    store64(out + 8, f64_mul(omega, f64_sub(t0, t1)));
    store64(out + 16, f64_mul(omega, f64_sub(t1, t2)));
    store64(out + 24, f64_mul(omega, f64_sub(t2, t3)));
    return 0;
}

# One classic RK4 step of the 4-state Moog system over `dt`, updating `state`
# (vec of 4 f64) in place. `scratch` is 128 bytes: k1..k4 at 0/32/64/96.
fn physical_moog_rk4_step(omega, k, input, state, dt, scratch) {
    var h2 = f64_mul(dt, F64_HALF);
    var k1 = scratch;
    var k2 = scratch + 32;
    var k3 = scratch + 64;
    var k4 = scratch + 96;

    var y0 = vec_get(state, 0);
    var y1 = vec_get(state, 1);
    var y2 = vec_get(state, 2);
    var y3 = vec_get(state, 3);

    physical_moog_deriv(omega, k, input, y0, y1, y2, y3, k1);
    physical_moog_deriv(omega, k, input,
    f64_add(y0, f64_mul(h2, load64(k1))),
    f64_add(y1, f64_mul(h2, load64(k1 + 8))),
    f64_add(y2, f64_mul(h2, load64(k1 + 16))),
    f64_add(y3, f64_mul(h2, load64(k1 + 24))), k2);
    physical_moog_deriv(omega, k, input,
    f64_add(y0, f64_mul(h2, load64(k2))),
    f64_add(y1, f64_mul(h2, load64(k2 + 8))),
    f64_add(y2, f64_mul(h2, load64(k2 + 16))),
    f64_add(y3, f64_mul(h2, load64(k2 + 24))), k3);
    physical_moog_deriv(omega, k, input,
    f64_add(y0, f64_mul(dt, load64(k3))),
    f64_add(y1, f64_mul(dt, load64(k3 + 8))),
    f64_add(y2, f64_mul(dt, load64(k3 + 16))),
    f64_add(y3, f64_mul(dt, load64(k3 + 24))), k4);

    # y_new = y + (dt/6) * (k1 + 2*k2 + 2*k3 + k4), per component.
    var over6 = f64_div(dt, f64_from(6));
    var i = 0;
    while (i < 4) {
        var off = i * 8;
        var sum = f64_add(load64(k1 + off),
        f64_add(f64_mul(F64_TWO, load64(k2 + off)),
        f64_add(f64_mul(F64_TWO, load64(k3 + off)), load64(k4 + off))));
        vec_set(state, i, f64_add(vec_get(state, i), f64_mul(over6, sum)));
        i = i + 1;
    }
    return 0;
}

# Process a single sample through the Moog ladder (one RK4 step over
# 1/sample_rate seconds), returning the lowpass-most stage y[3] clamped to
# [-2, 2] as a divergence guard.
#inline
#must_use
fn physical_moog_process_sample(self, input) {
    var omega = f64_mul(F64_TAU, MoogLadder_cutoff_hz(self));
    var k = MoogLadder_resonance(self);
    var dt = f64_div(F64_ONE, MoogLadder_sample_rate(self));
    var state = MoogLadder_state(self);

    physical_moog_rk4_step(omega, k, input, state, dt, MoogLadder_scratch(self));

    # Denormal-flush each stage (matches Rust's per-component flush).
    var i = 0;
    while (i < 4) {
        vec_set(state, i, flush_denormal(vec_get(state, i)));
        i = i + 1;
    }
    return f64_clamp(vec_get(state, 3), f64_neg(F64_TWO), F64_TWO);
}

# Process a vec buffer through the Moog ladder in place.
#inline
fn physical_moog_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, physical_moog_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# --- osc_core.cyr ---

# osc_core.cyr -- core oscillator: Waveform, polyblep kernel, Oscillator.
#
# Ports rust-old/src/oscillator/core.rs. f32 -> f64 throughout. The
# `Waveform` enum becomes integer constants; serde/Display derives are
# dropped; the constructor returns the struct pointer on success (or a
# negative ERR_* on invalid sample_rate/frequency). Methods become free
# `osc_*` functions taking the struct pointer.
#
# Noise waveforms: like the oracle's `Option<noise::NoiseGenerator>`, the
# Oscillator owns a NoiseGenerator (noise.cyr) constructed with the matching
# NOISE_WHITE/PINK/BROWN type + seed 42, so PinkNoise is Voss-McCartney and
# BrownNoise is integrated brown (full parity, not a white-noise stand-in).
# The field is 0 (null) for non-noise waveforms.
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_ONE/TWO/HALF/TAU, f64_clamp/fract/sin/cos), error.cyr
# (validate_frequency/validate_sample_rate, naad_is_err, ERR_*), and
# noise.cyr (noise_new, noise_next_sample, NOISE_*). No `include` lines.

# ================================================================
# Waveform (enum) -> integer constants. Exact oracle variant order.
# ================================================================
var WAVEFORM_SINE        = 0;
var WAVEFORM_SAW         = 1;
var WAVEFORM_SQUARE      = 2;
var WAVEFORM_TRIANGLE    = 3;
var WAVEFORM_PULSE       = 4;
var WAVEFORM_WHITE_NOISE = 5;
var WAVEFORM_PINK_NOISE  = 6;
var WAVEFORM_BROWN_NOISE = 7;

# Non-integer float literals (IEEE-754 bit patterns).
var OSC_C0_999 = 0x3FEFF7CED916872B;   # 0.999 (triangle leaky integrator)
var OSC_C0_01  = 0x3F847AE147AE147B;   # 0.01  (pulse-width lower clamp)
var OSC_C0_99  = 0x3FEFAE147AE147AE;   # 0.99  (pulse-width upper clamp)
var OSC_C0_25  = 0x3FD0000000000000;   # 0.25  (stateless triangle knee)
var OSC_C0_75  = 0x3FE8000000000000;   # 0.75  (stateless triangle knee)

# PRNG seed for noise waveforms (matches Rust NoiseGenerator::new(_, 42)).
var OSC_NOISE_SEED = 42;

# ================================================================
# polyblep -- 4-point PolyBLEP correction for anti-aliased discontinuities.
# `t` is the phase (0..1), `dt` the phase increment per sample. Branch-local
# `var`s are uniquely named (Cyrius shares one scope across elif bodies).
# ================================================================
#inline
#must_use
fn osc_polyblep(t, dt) {
    if (f64_le(dt, 0) == 1) { return 0; }
    var dt2 = f64_mul(F64_TWO, dt);
    if (f64_lt(t, dt) == 1) {
        # First sample after discontinuity.
        var na = f64_div(t, dt);
        var na2 = f64_mul(na, na);
        var blepa = f64_sub(f64_sub(f64_mul(F64_TWO, na), na2), F64_ONE);
        var cubica = f64_mul(f64_mul(na2, f64_sub(na, F64_ONE)), F64_HALF);
        return f64_add(blepa, cubica);
    } elif (f64_lt(t, dt2) == 1) {
        # Second sample after discontinuity (cubic tail).
        var nb = f64_sub(f64_div(t, dt), F64_ONE);
        var nb2 = f64_mul(nb, nb);
        return f64_mul(f64_mul(f64_neg(nb2), f64_sub(F64_ONE, nb)), F64_HALF);
    } elif (f64_gt(t, f64_sub(F64_ONE, dt)) == 1) {
        # First sample before discontinuity.
        var nc = f64_div(f64_sub(t, F64_ONE), dt);
        var nc2 = f64_mul(nc, nc);
        var blepc = f64_add(f64_add(nc2, f64_mul(F64_TWO, nc)), F64_ONE);
        var cubicc = f64_mul(f64_mul(f64_neg(nc2), f64_add(nc, F64_ONE)), F64_HALF);
        return f64_add(blepc, cubicc);
    } elif (f64_gt(t, f64_sub(F64_ONE, dt2)) == 1) {
        # Second sample before discontinuity (cubic tail).
        var nd = f64_add(f64_div(f64_sub(t, F64_ONE), dt), F64_ONE);
        var nd2 = f64_mul(nd, nd);
        return f64_mul(f64_mul(nd2, f64_add(F64_ONE, nd)), F64_HALF);
    }
    return 0;
}

# ================================================================
# Oscillator -- band-limited waveform generator.
#   waveform     : WAVEFORM_* constant
#   frequency    : Hz
#   phase        : 0..1
#   sample_rate  : Hz
#   pulse_width  : 0..1 (pulse duty cycle)
#   noise_gen    : NoiseGenerator pointer for noise waveforms (0 otherwise)
#   triangle_sum : leaky-integrator state for the triangle waveform
# ================================================================
#derive(accessors)
struct Oscillator { waveform; frequency; phase; sample_rate; pulse_width; noise_gen; triangle_sum; }

# ================================================================
# osc_new -- construct. Returns the struct pointer on success, or a negative
# ERR_* on invalid sample_rate/frequency (frequency is not validated for the
# noise waveforms, matching the oracle).
# ================================================================
#must_use
fn osc_new(waveform, frequency, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var is_noise = 0;
    if (waveform == WAVEFORM_WHITE_NOISE) { is_noise = 1; }
    if (waveform == WAVEFORM_PINK_NOISE) { is_noise = 1; }
    if (waveform == WAVEFORM_BROWN_NOISE) { is_noise = 1; }

    if (is_noise == 0) {
        e = validate_frequency(frequency, sample_rate);
        if (naad_is_err(e) == 1) { return e; }
    }

    # Noise waveforms own a NoiseGenerator (White/Pink/Brown), matching the
    # oracle's Option<NoiseGenerator>; non-noise waveforms leave it null (0).
    var noise_gen = 0;
    if (waveform == WAVEFORM_WHITE_NOISE) { noise_gen = noise_new(NOISE_WHITE, OSC_NOISE_SEED); }
    if (waveform == WAVEFORM_PINK_NOISE) { noise_gen = noise_new(NOISE_PINK, OSC_NOISE_SEED); }
    if (waveform == WAVEFORM_BROWN_NOISE) { noise_gen = noise_new(NOISE_BROWN, OSC_NOISE_SEED); }

    var self = alloc(sizeof(Oscillator));
    Oscillator_set_waveform(self, waveform);
    Oscillator_set_frequency(self, frequency);
    Oscillator_set_phase(self, 0);
    Oscillator_set_sample_rate(self, sample_rate);
    Oscillator_set_pulse_width(self, F64_HALF);
    Oscillator_set_noise_gen(self, noise_gen);
    Oscillator_set_triangle_sum(self, 0);
    return self;
}

# ================================================================
# osc_phase_increment -- phase advance per sample (frequency / sample_rate).
# ================================================================
#inline
#must_use
fn osc_phase_increment(self) {
    return f64_div(Oscillator_frequency(self), Oscillator_sample_rate(self));
}

# ================================================================
# osc_next_sample -- generate the next sample and advance phase.
# ================================================================
#inline
#must_use
fn osc_next_sample(self) {
    var dt = osc_phase_increment(self);
    var t = Oscillator_phase(self);
    var wf = Oscillator_waveform(self);

    var sample = 0;
    if (wf == WAVEFORM_SINE) {
        sample = f64_sin(f64_mul(t, F64_TAU));
    } elif (wf == WAVEFORM_SAW) {
        var saw_naive = f64_sub(f64_mul(F64_TWO, t), F64_ONE);
        sample = f64_sub(saw_naive, osc_polyblep(t, dt));
    } elif (wf == WAVEFORM_SQUARE) {
        var sq_naive = f64_neg(F64_ONE);
        if (f64_lt(t, F64_HALF) == 1) { sq_naive = F64_ONE; }
        var sq_t2 = f64_fract(f64_add(t, F64_HALF));
        sample = f64_sub(f64_add(sq_naive, osc_polyblep(t, dt)), osc_polyblep(sq_t2, dt));
    } elif (wf == WAVEFORM_TRIANGLE) {
        var tr_square = f64_neg(F64_ONE);
        if (f64_lt(t, F64_HALF) == 1) { tr_square = F64_ONE; }
        var tr_t2 = f64_fract(f64_add(t, F64_HALF));
        var tr_blep = f64_sub(f64_add(tr_square, osc_polyblep(t, dt)), osc_polyblep(tr_t2, dt));
        # leaky integrator: triangle_sum = 0.999*triangle_sum + square_blep*dt*4
        var tr_decay = f64_mul(OSC_C0_999, Oscillator_triangle_sum(self));
        var ts = f64_add(tr_decay, f64_mul(f64_mul(tr_blep, dt), f64_from(4)));
        Oscillator_set_triangle_sum(self, ts);
        sample = f64_clamp(ts, f64_neg(F64_ONE), F64_ONE);
    } elif (wf == WAVEFORM_PULSE) {
        var pw = f64_clamp(Oscillator_pulse_width(self), OSC_C0_01, OSC_C0_99);
        var pl_naive = f64_neg(F64_ONE);
        if (f64_lt(t, pw) == 1) { pl_naive = F64_ONE; }
        var pl_t2 = f64_fract(f64_add(t, f64_sub(F64_ONE, pw)));
        sample = f64_sub(f64_add(pl_naive, osc_polyblep(t, dt)), osc_polyblep(pl_t2, dt));
    } else {
        # Noise waveforms -- delegate to the owned NoiseGenerator (White =
        # xorshift, Pink = Voss-McCartney, Brown = integrated), matching oracle.
        sample = noise_next_sample(Oscillator_noise_gen(self));
    }

    var ph = f64_add(t, dt);
    if (f64_ge(ph, F64_ONE) == 1) { ph = f64_sub(ph, F64_ONE); }
    Oscillator_set_phase(self, ph);
    return sample;
}

# ================================================================
# osc_fill_buffer -- fill a vec buffer in place.
# ================================================================
#inline
fn osc_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, osc_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Accessors (read-only getters mirroring the Rust methods).
# ================================================================
#inline
#must_use
fn osc_waveform(self) {
    return Oscillator_waveform(self);
}

#inline
#must_use
fn osc_frequency(self) {
    return Oscillator_frequency(self);
}

#inline
#must_use
fn osc_phase(self) {
    return Oscillator_phase(self);
}

#inline
#must_use
fn osc_sample_rate(self) {
    return Oscillator_sample_rate(self);
}

#inline
#must_use
fn osc_pulse_width(self) {
    return Oscillator_pulse_width(self);
}

# ================================================================
# osc_set_frequency -- validate then set. Returns ERR_NONE or negative ERR_*.
# ================================================================
fn osc_set_frequency(self, freq) {
    var e = validate_frequency(freq, Oscillator_sample_rate(self));
    if (naad_is_err(e) == 1) { return e; }
    Oscillator_set_frequency(self, freq);
    return ERR_NONE;
}

# ================================================================
# osc_set_pulse_width -- clamp to [0.01, 0.99].
# ================================================================
fn osc_set_pulse_width(self, pw) {
    Oscillator_set_pulse_width(self, f64_clamp(pw, OSC_C0_01, OSC_C0_99));
    return 0;
}

# ================================================================
# osc_set_phase -- set phase, wrapped to [0, 1) (rem_euclid(1.0) == fract).
# ================================================================
fn osc_set_phase(self, phase) {
    Oscillator_set_phase(self, f64_fract(phase));
    return 0;
}

# ================================================================
# osc_reset_phase -- clear phase and triangle integrator.
# ================================================================
fn osc_reset_phase(self) {
    Oscillator_set_phase(self, 0);
    Oscillator_set_triangle_sum(self, 0);
    return 0;
}

# ================================================================
# osc_advance_phase_sine -- FM helper: return sin(phase) then advance by dt.
# ================================================================
#inline
fn osc_advance_phase_sine(self, dt) {
    var sample = f64_sin(f64_mul(Oscillator_phase(self), F64_TAU));
    var ph = f64_add(Oscillator_phase(self), dt);
    if (f64_ge(ph, F64_ONE) == 1) { ph = f64_sub(ph, F64_ONE); }
    Oscillator_set_phase(self, ph);
    return sample;
}

# ================================================================
# osc_stateless_waveform_sample -- stateless waveform value from (t, dt).
# Ports core::stateless_waveform_sample (used by UnisonOscillator). No noise,
# no triangle integration: triangle is the naive piecewise ramp; noise -> 0.
# ================================================================
#inline
#must_use
fn osc_stateless_waveform_sample(waveform, t, dt) {
    if (waveform == WAVEFORM_SINE) {
        return f64_sin(f64_mul(t, F64_TAU));
    } elif (waveform == WAVEFORM_SAW) {
        var sw_naive = f64_sub(f64_mul(F64_TWO, t), F64_ONE);
        return f64_sub(sw_naive, osc_polyblep(t, dt));
    } elif (waveform == WAVEFORM_SQUARE) {
        var sq_naive = f64_neg(F64_ONE);
        if (f64_lt(t, F64_HALF) == 1) { sq_naive = F64_ONE; }
        var sq_t2 = f64_fract(f64_add(t, F64_HALF));
        return f64_sub(f64_add(sq_naive, osc_polyblep(t, dt)), osc_polyblep(sq_t2, dt));
    } elif (waveform == WAVEFORM_TRIANGLE) {
        if (f64_lt(t, OSC_C0_25) == 1) {
            return f64_mul(f64_from(4), t);
        } elif (f64_lt(t, OSC_C0_75) == 1) {
            return f64_sub(F64_TWO, f64_mul(f64_from(4), t));
        }
        return f64_sub(f64_mul(f64_from(4), t), f64_from(4));
    } elif (waveform == WAVEFORM_PULSE) {
        var pl_naive = f64_neg(F64_ONE);
        if (f64_lt(t, F64_HALF) == 1) { pl_naive = F64_ONE; }
        var pl_t2 = f64_fract(f64_add(t, F64_HALF));
        return f64_sub(f64_add(pl_naive, osc_polyblep(t, dt)), osc_polyblep(pl_t2, dt));
    }
    # Noise waveforms make no sense for unison detuning -> silence.
    return 0;
}

# --- osc_unison.cyr ---

# osc_unison.cyr -- unison oscillator: N detuned voices mixed together.
#
# Ports rust-old/src/oscillator/unison.rs. f32 -> f64 throughout. The fixed
# `[f32; 8]` phase and detune-ratio arrays become stdlib vecs of 8 f64; the
# `bool ratios_dirty` becomes an i64 flag (1/0). The `(f32, f32)` stereo
# tuple return becomes a `UnisonStereo` pair struct. serde derives/tests are
# dropped; the constructor returns the struct pointer or a negative ERR_*.
# Per-voice waveform generation reuses osc_stateless_waveform_sample from
# osc_core.cyr, matching the oracle.
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_ONE/TWO/HALF/PI_2/FRAC_1_SQRT2, f64_pow/sin/cos/clamp/max) and
# error.cyr (validate_*, naad_is_err, ERR_*), dsp_util.cyr
# (xorshift32_unit_f32), osc_core.cyr (osc_stateless_waveform_sample,
# WAVEFORM_*). No `include` lines.

# ================================================================
# UnisonStereo -- (left, right) sample pair (was a Rust tuple return).
# ================================================================
#derive(accessors)
struct UnisonStereo { left; right; }

# ================================================================
# UnisonOscillator -- N detuned copies of a waveform mixed together.
#   waveform      : WAVEFORM_* constant (shared by all voices)
#   frequency     : base Hz
#   sample_rate   : Hz
#   num_voices    : 1..8
#   detune_cents  : total detune spread in cents (>= 0)
#   stereo_spread : 0 (mono) .. 1 (full width)
#   phases        : vec of 8 f64 per-voice phases
#   detune_ratios : vec of 8 f64 precomputed frequency ratios
#   ratios_dirty  : 1 if ratios need recomputing, else 0
# ================================================================
#derive(accessors)
struct UnisonOscillator { waveform; frequency; sample_rate; num_voices; detune_cents;
    stereo_spread; phases; detune_ratios; ratios_dirty; }

# ================================================================
# unison_new -- construct. Clamps num_voices to 1..8, randomizes initial
# phases (xorshift32 seeded 12345), primes detune ratios. Returns the struct
# pointer on success, or a negative ERR_* on invalid sample_rate/frequency.
# ================================================================
#must_use
fn unison_new(waveform, frequency, num_voices, detune_cents, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    e = validate_frequency(frequency, sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var nv = num_voices;
    if (nv < 1) { nv = 1; }
    if (nv > 8) { nv = 8; }

    var phases = vec_new();
    var i = 0;
    while (i < 8) {
        vec_push(phases, 0);
        i = i + 1;
    }
    var seed = alloc(8);
    store64(seed, 12345);
    i = 0;
    while (i < nv) {
        vec_set(phases, i, xorshift32_unit_f32(seed));
        i = i + 1;
    }

    var detune_ratios = vec_new();
    i = 0;
    while (i < 8) {
        vec_push(detune_ratios, F64_ONE);
        i = i + 1;
    }

    var self = alloc(sizeof(UnisonOscillator));
    UnisonOscillator_set_waveform(self, waveform);
    UnisonOscillator_set_frequency(self, frequency);
    UnisonOscillator_set_sample_rate(self, sample_rate);
    UnisonOscillator_set_num_voices(self, nv);
    UnisonOscillator_set_detune_cents(self, f64_max(detune_cents, 0));
    UnisonOscillator_set_stereo_spread(self, F64_HALF);
    UnisonOscillator_set_phases(self, phases);
    UnisonOscillator_set_detune_ratios(self, detune_ratios);
    UnisonOscillator_set_ratios_dirty(self, 1);
    unison_recompute_ratios(self);
    return self;
}

# ================================================================
# unison_recompute_ratios -- rebuild detune ratios from the cents spread.
# Voices are spread symmetrically over [-cents/2, +cents/2]; each ratio is
# 2^(cents_offset/1200).
# ================================================================
fn unison_recompute_ratios(self) {
    var nv = UnisonOscillator_num_voices(self);
    var ratios = UnisonOscillator_detune_ratios(self);
    var dc = UnisonOscillator_detune_cents(self);
    if (nv <= 1) {
        vec_set(ratios, 0, F64_ONE);
    } else {
        var denom = f64_from(nv - 1);
        var i = 0;
        while (i < nv) {
            var t = f64_div(f64_from(i), denom);
            var cents_offset = f64_mul(f64_sub(t, F64_HALF), dc);
            var expo = f64_div(cents_offset, f64_from(1200));
            vec_set(ratios, i, f64_pow(F64_TWO, expo));
            i = i + 1;
        }
    }
    UnisonOscillator_set_ratios_dirty(self, 0);
    return 0;
}

# ================================================================
# unison_next_sample -- next mono sample (all voices averaged).
# ================================================================
#inline
#must_use
fn unison_next_sample(self) {
    if (UnisonOscillator_ratios_dirty(self) == 1) {
        unison_recompute_ratios(self);
    }
    var wf = UnisonOscillator_waveform(self);
    var freq_base = UnisonOscillator_frequency(self);
    var sr = UnisonOscillator_sample_rate(self);
    var ratios = UnisonOscillator_detune_ratios(self);
    var phases = UnisonOscillator_phases(self);
    var nv = UnisonOscillator_num_voices(self);

    var sum = 0;
    var i = 0;
    while (i < nv) {
        var freq = f64_mul(freq_base, vec_get(ratios, i));
        var dt = f64_div(freq, sr);
        var t = vec_get(phases, i);
        sum = f64_add(sum, osc_stateless_waveform_sample(wf, t, dt));
        var ph = f64_add(t, dt);
        if (f64_ge(ph, F64_ONE) == 1) { ph = f64_sub(ph, F64_ONE); }
        vec_set(phases, i, ph);
        i = i + 1;
    }
    return f64_div(sum, f64_from(nv));
}

# ================================================================
# unison_advance_stereo -- value-returning core: advance one stereo sample and
# write the (left, right) pair into out_left/out_right at index idx. Allocates
# nothing, so the buffer loop can call it per sample without leaking. Voices are
# equal-power panned across the field per stereo_spread.
# ================================================================
#inline
fn unison_advance_stereo(self, out_left, out_right, idx) {
    if (UnisonOscillator_ratios_dirty(self) == 1) {
        unison_recompute_ratios(self);
    }
    var wf = UnisonOscillator_waveform(self);
    var freq_base = UnisonOscillator_frequency(self);
    var sr = UnisonOscillator_sample_rate(self);
    var ratios = UnisonOscillator_detune_ratios(self);
    var phases = UnisonOscillator_phases(self);
    var nv = UnisonOscillator_num_voices(self);
    var spread = UnisonOscillator_stereo_spread(self);

    var left = 0;
    var right = 0;
    var i = 0;
    while (i < nv) {
        var freq = f64_mul(freq_base, vec_get(ratios, i));
        var dt = f64_div(freq, sr);
        var t = vec_get(phases, i);
        var sample = osc_stateless_waveform_sample(wf, t, dt);
        if (nv > 1) {
            var pan = f64_div(f64_from(i), f64_from(nv - 1));
            var w = f64_mul(spread, F64_HALF);
            var pan_scaled = f64_add(F64_HALF, f64_mul(f64_mul(f64_sub(pan, F64_HALF), w), F64_TWO));
            var angle = f64_mul(pan_scaled, F64_PI_2);
            left = f64_add(left, f64_mul(sample, f64_cos(angle)));
            right = f64_add(right, f64_mul(sample, f64_sin(angle)));
        } else {
            left = f64_add(left, f64_mul(sample, F64_FRAC_1_SQRT2));
            right = f64_add(right, f64_mul(sample, F64_FRAC_1_SQRT2));
        }
        var ph = f64_add(t, dt);
        if (f64_ge(ph, F64_ONE) == 1) { ph = f64_sub(ph, F64_ONE); }
        vec_set(phases, i, ph);
        i = i + 1;
    }
    var inv = f64_div(F64_ONE, f64_from(nv));
    vec_set(out_left, idx, f64_mul(left, inv));
    vec_set(out_right, idx, f64_mul(right, inv));
    return 0;
}

# ================================================================
# unison_next_sample_stereo -- next stereo pair. Voices are equal-power
# panned across the field per stereo_spread. Returns a UnisonStereo pointer.
# One-shot API; delegates to unison_advance_stereo for the identical math.
# ================================================================
#must_use
fn unison_next_sample_stereo(self) {
    var scratch_l = vec_new();
    vec_push(scratch_l, 0);
    var scratch_r = vec_new();
    vec_push(scratch_r, 0);
    unison_advance_stereo(self, scratch_l, scratch_r, 0);
    var out = alloc(sizeof(UnisonStereo));
    UnisonStereo_set_left(out, vec_get(scratch_l, 0));
    UnisonStereo_set_right(out, vec_get(scratch_r, 0));
    return out;
}

# ================================================================
# unison_fill_buffer -- fill a mono vec buffer in place.
# ================================================================
#inline
fn unison_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, unison_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# unison_fill_buffer_stereo -- fill left/right vecs (over the shorter length).
# ================================================================
#inline
fn unison_fill_buffer_stereo(self, left, right) {
    var n = vec_len(left);
    var nr = vec_len(right);
    if (nr < n) { n = nr; }
    var i = 0;
    while (i < n) {
        unison_advance_stereo(self, left, right, i);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Setters.
# ================================================================
fn unison_set_num_voices(self, n) {
    var nv = n;
    if (nv < 1) { nv = 1; }
    if (nv > 8) { nv = 8; }
    UnisonOscillator_set_num_voices(self, nv);
    UnisonOscillator_set_ratios_dirty(self, 1);
    return 0;
}

fn unison_set_detune_cents(self, cents) {
    UnisonOscillator_set_detune_cents(self, f64_max(cents, 0));
    UnisonOscillator_set_ratios_dirty(self, 1);
    return 0;
}

fn unison_set_stereo_spread(self, spread) {
    UnisonOscillator_set_stereo_spread(self, f64_clamp(spread, 0, F64_ONE));
    return 0;
}

fn unison_set_frequency(self, freq) {
    var e = validate_frequency(freq, UnisonOscillator_sample_rate(self));
    if (naad_is_err(e) == 1) { return e; }
    UnisonOscillator_set_frequency(self, freq);
    return ERR_NONE;
}

# ================================================================
# Accessors.
# ================================================================
#inline
#must_use
fn unison_num_voices(self) {
    return UnisonOscillator_num_voices(self);
}

#inline
#must_use
fn unison_frequency(self) {
    return UnisonOscillator_frequency(self);
}

#inline
#must_use
fn unison_detune_cents(self) {
    return UnisonOscillator_detune_cents(self);
}

# --- osc_sub.cyr ---

# osc_sub.cyr -- sub-oscillator: plays 1 or 2 octaves below a frequency.
#
# Ports rust-old/src/oscillator/sub.rs. f32 -> f64 throughout. The
# `SubOctave` enum becomes integer constants; serde derives/tests are
# dropped; the constructor returns the struct pointer or a negative ERR_*.
# The sub embeds an Oscillator pointer (built via osc_new from osc_core.cyr).
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/TWO,
# f64_div/mul/max/from) and error.cyr (naad_is_err, ERR_NONE) and
# osc_core.cyr (osc_new/osc_next_sample/osc_set_frequency, WAVEFORM_*).
# No `include` lines.

# ================================================================
# SubOctave (enum) -> integer constants.
# ================================================================
var SUBOCT_DOWN1 = 0;   # one octave below (half frequency)
var SUBOCT_DOWN2 = 1;   # two octaves below (quarter frequency)

# Minimum sub frequency floor (Rust `.max(0.1)`).
var SUBOSC_C0_1 = 0x3FB999999999999A;   # 0.1

# ================================================================
# SubOscillator -- octave-down oscillator with an independent waveform.
#   osc            : embedded Oscillator pointer
#   octave         : SUBOCT_* constant
#   base_frequency : base Hz (before octave division)
#   level          : mix level (0..1); pub field in Rust
# ================================================================
#derive(accessors)
struct SubOscillator { osc; octave; base_frequency; level; }

# ================================================================
# subosc_new -- construct. Divides base_frequency by 2 (Down1) or 4 (Down2),
# floored at 0.1 Hz. Returns the struct pointer, or a negative ERR_* if the
# underlying Oscillator failed to build.
# ================================================================
#must_use
fn subosc_new(waveform, base_frequency, octave, sample_rate) {
    var divisor = F64_TWO;
    if (octave == SUBOCT_DOWN2) { divisor = f64_from(4); }
    var sub_freq = f64_div(base_frequency, divisor);
    var osc = osc_new(waveform, f64_max(sub_freq, SUBOSC_C0_1), sample_rate);
    if (naad_is_err(osc) == 1) { return osc; }

    var self = alloc(sizeof(SubOscillator));
    SubOscillator_set_osc(self, osc);
    SubOscillator_set_octave(self, octave);
    SubOscillator_set_base_frequency(self, base_frequency);
    SubOscillator_set_level(self, F64_ONE);
    return self;
}

# ================================================================
# subosc_next_sample -- next sample scaled by level.
# ================================================================
#inline
#must_use
fn subosc_next_sample(self) {
    return f64_mul(osc_next_sample(SubOscillator_osc(self)), SubOscillator_level(self));
}

# ================================================================
# subosc_set_base_frequency -- update base frequency (sub freq derived).
# Validates before mutating. Returns ERR_NONE or a negative ERR_*.
# ================================================================
fn subosc_set_base_frequency(self, freq) {
    var divisor = F64_TWO;
    if (SubOscillator_octave(self) == SUBOCT_DOWN2) { divisor = f64_from(4); }
    var e = osc_set_frequency(SubOscillator_osc(self), f64_max(f64_div(freq, divisor), SUBOSC_C0_1));
    if (naad_is_err(e) == 1) { return e; }
    SubOscillator_set_base_frequency(self, freq);
    return ERR_NONE;
}

# ================================================================
# subosc_set_octave -- change octave division. Returns ERR_NONE or ERR_*.
# ================================================================
fn subosc_set_octave(self, octave) {
    var divisor = F64_TWO;
    if (octave == SUBOCT_DOWN2) { divisor = f64_from(4); }
    var base = SubOscillator_base_frequency(self);
    var e = osc_set_frequency(SubOscillator_osc(self), f64_max(f64_div(base, divisor), SUBOSC_C0_1));
    if (naad_is_err(e) == 1) { return e; }
    SubOscillator_set_octave(self, octave);
    return ERR_NONE;
}

# ================================================================
# Accessors.
# ================================================================
#inline
#must_use
fn subosc_octave(self) {
    return SubOscillator_octave(self);
}

#inline
#must_use
fn subosc_base_frequency(self) {
    return SubOscillator_base_frequency(self);
}

# ================================================================
# subosc_fill_buffer -- fill a vec buffer in place.
# ================================================================
#inline
fn subosc_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, subosc_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# --- osc_sync.cyr ---

# osc_sync.cyr -- hard sync: slave phase resets on master cycle wrap.
#
# Ports rust-old/src/oscillator/sync.rs. f32 -> f64 throughout. serde
# derives/tests are dropped; the constructor returns the struct pointer or a
# negative ERR_*. HardSync embeds two Oscillator pointers (master always a
# Saw, slave the caller-chosen waveform), both built via osc_new.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (f64_lt) and
# error.cyr (naad_is_err) and osc_core.cyr (osc_new/osc_next_sample/
# osc_phase/osc_reset_phase/osc_set_frequency, WAVEFORM_SAW). No `include`.

# ================================================================
# HardSync -- master (reset timing) + slave (audio output) oscillators.
# ================================================================
#derive(accessors)
struct HardSync { master; slave; }

# ================================================================
# hardsync_new -- construct a master (Saw) / slave pair. Returns the struct
# pointer on success, or a negative ERR_* if either oscillator failed.
# ================================================================
#must_use
fn hardsync_new(master_freq, slave_freq, slave_waveform, sample_rate) {
    var master = osc_new(WAVEFORM_SAW, master_freq, sample_rate);
    if (naad_is_err(master) == 1) { return master; }
    var slave = osc_new(slave_waveform, slave_freq, sample_rate);
    if (naad_is_err(slave) == 1) { return slave; }

    var self = alloc(sizeof(HardSync));
    HardSync_set_master(self, master);
    HardSync_set_slave(self, slave);
    return self;
}

# ================================================================
# hardsync_next_sample -- advance master; reset slave when master wraps
# (phase decreased past 1.0); return the slave's sample.
# ================================================================
#inline
#must_use
fn hardsync_next_sample(self) {
    var master = HardSync_master(self);
    var slave = HardSync_slave(self);

    var before = osc_phase(master);
    var advanced = osc_next_sample(master);
    var after = osc_phase(master);

    # Detect master cycle wrap (phase decreased = wrapped past 1.0).
    if (f64_lt(after, before) == 1) { osc_reset_phase(slave); }

    # `advanced` is the master's sample; discarded, only its side effect
    # (phase advance) matters -- mirrors Rust `let _ = master.next_sample()`.
    advanced = advanced;
    return osc_next_sample(slave);
}

# ================================================================
# hardsync_fill_buffer -- fill a vec buffer in place.
# ================================================================
#inline
fn hardsync_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, hardsync_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Accessors -- inner master/slave oscillator pointers.
# ================================================================
#must_use
fn hardsync_master(self) {
    return HardSync_master(self);
}

#must_use
fn hardsync_slave(self) {
    return HardSync_slave(self);
}

# ================================================================
# hardsync_set_master_freq / hardsync_set_slave_freq -- delegate to the inner
# oscillators. Return ERR_NONE or a negative ERR_*.
# ================================================================
fn hardsync_set_master_freq(self, freq) {
    return osc_set_frequency(HardSync_master(self), freq);
}

fn hardsync_set_slave_freq(self, freq) {
    return osc_set_frequency(HardSync_slave(self), freq);
}

# --- modulation.cyr ---

# modulation.cyr -- modulation sources: LFO, 2-op FM, and ring modulation.
#
# Ports rust-old/src/modulation.rs. f32 -> f64 throughout. The `LfoShape`
# and `LfoMode` enums become integer constants; serde/Display derives and
# their round-trip test are dropped. Constructors return the struct pointer
# on success or a negative ERR_* on invalid frequency/sample_rate.
#
# The `ModulationSource` trait collapses to a free function
# (modulation_lfo_next_modulation_value) that just calls next_value.
#
# The LFO's private xorshift32 state (Rust `rng_state: u32`) is folded into a
# `rng` field holding an alloc(8) pointer whose 64-bit slot carries the u32
# PRNG state, stepped via dsp_util's xorshift32_signed_f32. This matches the
# oracle bit-for-bit: seed 42 -> one step for the initial S&H value, one step
# per cycle wrap thereafter (xorshift never yields 0 from a nonzero seed, so
# dsp_util's zero-state guard never fires -> identical output).
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE/TWO/
# HALF/TAU, f64_add/sub/mul/div/neg/abs/clamp/sin/lt/gt/ge/le/from), error.cyr
# (validate_sample_rate, naad_is_err, naad_is_finite, ERR_*), dsp_util.cyr
# (xorshift32_signed_f32), and osc_core.cyr (osc_new/osc_next_sample/
# osc_frequency/osc_sample_rate/osc_advance_phase_sine, WAVEFORM_*). No
# `include` lines -- the entry orders the deps.

# ================================================================
# LfoShape (enum) -> integer constants. Exact oracle variant order.
# ================================================================
var MODULATION_LFO_SINE            = 0;
var MODULATION_LFO_TRIANGLE        = 1;
var MODULATION_LFO_SQUARE          = 2;
var MODULATION_LFO_SAW_UP          = 3;
var MODULATION_LFO_SAW_DOWN        = 4;
var MODULATION_LFO_SAMPLE_AND_HOLD = 5;

# ================================================================
# LfoMode (enum) -> integer constants.
# ================================================================
var MODULATION_LFO_BIPOLAR  = 0;
var MODULATION_LFO_UNIPOLAR = 1;

# ================================================================
# Non-integer float literals (IEEE-754 bit patterns).
# ================================================================
var MODULATION_C0_25 = 0x3FD0000000000000;   # 0.25 (triangle lower knee)
var MODULATION_C0_75 = 0x3FE8000000000000;   # 0.75 (triangle upper knee)
var MODULATION_C0_1  = 0x3FB999999999999A;   # 0.1  (FM instantaneous-freq floor)

# PRNG seed for the LFO sample-and-hold (matches Rust `let mut rng = 42u32`).
var MODULATION_SH_SEED = 42;

# ================================================================
# Lfo -- low-frequency oscillator for modulation.
#   shape       : MODULATION_LFO_* shape constant
#   frequency   : Hz
#   sample_rate : Hz
#   phase       : 0..1 accumulator
#   mode        : MODULATION_LFO_BIPOLAR / _UNIPOLAR
#   depth       : amplitude scaling (0..1); Rust `pub depth`
#   sh_value    : current sample-and-hold value
#   rng         : pointer to an 8-byte slot holding the u32 PRNG state
# ================================================================
#derive(accessors)
struct Lfo { shape; frequency; sample_rate; phase; mode; depth; sh_value; rng; }

# ================================================================
# modulation_lfo_new -- construct. Returns the struct pointer on success, or a
# negative ERR_* (ERR_INVALID_SAMPLE_RATE / ERR_INVALID_PARAMETER) on failure.
# The oracle seeds rng=42, advances it once, and derives the initial S&H value
# from that first step so the first cycle isn't silent.
# ================================================================
#must_use
fn modulation_lfo_new(shape, frequency, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    if (f64_lt(frequency, 0) == 1) { return ERR_INVALID_PARAMETER; }
    if (naad_is_finite(frequency) == 0) { return ERR_INVALID_PARAMETER; }

    # Seed the PRNG and take the first step for the initial S&H value.
    var rng = alloc(8);
    store64(rng, MODULATION_SH_SEED);
    var initial_sh = xorshift32_signed_f32(rng);

    var self = alloc(sizeof(Lfo));
    Lfo_set_shape(self, shape);
    Lfo_set_frequency(self, frequency);
    Lfo_set_sample_rate(self, sample_rate);
    Lfo_set_phase(self, 0);
    Lfo_set_mode(self, MODULATION_LFO_BIPOLAR);
    Lfo_set_depth(self, F64_ONE);
    Lfo_set_sh_value(self, initial_sh);
    Lfo_set_rng(self, rng);
    return self;
}

# ================================================================
# modulation_lfo_from_waveform -- build an LFO from a legacy Waveform const.
# Maps Sine->Sine, Triangle->Triangle, Square->Square, Saw->SawDown, else Sine.
# ================================================================
#must_use
fn modulation_lfo_from_waveform(waveform, frequency, sample_rate) {
    var shape = MODULATION_LFO_SINE;
    if (waveform == WAVEFORM_TRIANGLE) { shape = MODULATION_LFO_TRIANGLE; }
    if (waveform == WAVEFORM_SQUARE) { shape = MODULATION_LFO_SQUARE; }
    if (waveform == WAVEFORM_SAW) { shape = MODULATION_LFO_SAW_DOWN; }
    return modulation_lfo_new(shape, frequency, sample_rate);
}

# ================================================================
# modulation_lfo_raw_sample -- raw bipolar sample for the current phase.
# ================================================================
#inline
#must_use
fn modulation_lfo_raw_sample(self) {
    var t = Lfo_phase(self);
    var shape = Lfo_shape(self);
    if (shape == MODULATION_LFO_SINE) {
        return f64_sin(f64_mul(t, F64_TAU));
    } elif (shape == MODULATION_LFO_TRIANGLE) {
        if (f64_lt(t, MODULATION_C0_25) == 1) {
            return f64_mul(f64_from(4), t);
        } elif (f64_lt(t, MODULATION_C0_75) == 1) {
            return f64_sub(F64_TWO, f64_mul(f64_from(4), t));
        }
        return f64_sub(f64_mul(f64_from(4), t), f64_from(4));
    } elif (shape == MODULATION_LFO_SQUARE) {
        if (f64_lt(t, F64_HALF) == 1) { return F64_ONE; }
        return f64_neg(F64_ONE);
    } elif (shape == MODULATION_LFO_SAW_UP) {
        return f64_sub(f64_mul(F64_TWO, t), F64_ONE);
    } elif (shape == MODULATION_LFO_SAW_DOWN) {
        return f64_sub(F64_ONE, f64_mul(F64_TWO, t));
    }
    # MODULATION_LFO_SAMPLE_AND_HOLD.
    return Lfo_sh_value(self);
}

# ================================================================
# modulation_lfo_next_value -- next modulation value (scaled by depth).
# Advances phase, re-rolls the S&H value on a cycle wrap, then applies the
# bipolar/unipolar mode and the depth scaling.
# ================================================================
#inline
#must_use
fn modulation_lfo_next_value(self) {
    var raw = modulation_lfo_raw_sample(self);

    # Advance phase.
    var dt = f64_div(Lfo_frequency(self), Lfo_sample_rate(self));
    var prev_phase = Lfo_phase(self);
    var phase = f64_add(prev_phase, dt);
    if (f64_ge(phase, F64_ONE) == 1) { phase = f64_sub(phase, F64_ONE); }
    Lfo_set_phase(self, phase);

    # Update S&H on cycle wrap.
    if (Lfo_shape(self) == MODULATION_LFO_SAMPLE_AND_HOLD) {
        if (f64_lt(phase, prev_phase) == 1) {
            Lfo_set_sh_value(self, xorshift32_signed_f32(Lfo_rng(self)));
        }
    }

    var output = raw;
    if (Lfo_mode(self) == MODULATION_LFO_UNIPOLAR) {
        output = f64_mul(f64_add(raw, F64_ONE), F64_HALF);
    }

    return f64_mul(output, Lfo_depth(self));
}

# ================================================================
# modulation_lfo_next_modulation_value -- ModulationSource trait impl; just
# forwards to next_value.
# ================================================================
#inline
#must_use
fn modulation_lfo_next_modulation_value(self) {
    return modulation_lfo_next_value(self);
}

# ================================================================
# modulation_lfo_set_frequency -- validate then set. Rust's predicate is
# `freq < 0.0 || !freq.is_finite()`. Returns ERR_NONE or ERR_INVALID_PARAMETER.
# ================================================================
fn modulation_lfo_set_frequency(self, freq) {
    if (f64_lt(freq, 0) == 1) { return ERR_INVALID_PARAMETER; }
    if (naad_is_finite(freq) == 0) { return ERR_INVALID_PARAMETER; }
    Lfo_set_frequency(self, freq);
    return ERR_NONE;
}

# ================================================================
# modulation_lfo_set_shape / _set_mode -- setters.
# ================================================================
fn modulation_lfo_set_shape(self, shape) {
    Lfo_set_shape(self, shape);
    return 0;
}

fn modulation_lfo_set_mode(self, mode) {
    Lfo_set_mode(self, mode);
    return 0;
}

# ================================================================
# modulation_lfo_shape / _mode -- read-only getters.
# ================================================================
#inline
#must_use
fn modulation_lfo_shape(self) {
    return Lfo_shape(self);
}

#inline
#must_use
fn modulation_lfo_mode(self) {
    return Lfo_mode(self);
}

# ================================================================
# FmModulator -- two-operator FM (frequency modulation) primitive.
#   carrier          : carrier Oscillator (always sine output)
#   modulator        : modulator Oscillator
#   mod_index        : modulation index (Rust `pub mod_index`)
#   carrier_base_freq: base carrier frequency for the FM calculation
# ================================================================
#derive(accessors)
struct FmModulator { carrier; modulator; mod_index; carrier_base_freq; }

# ================================================================
# modulation_fm_new -- construct. Both operators are sine oscillators. Returns
# the struct pointer on success or a negative ERR_* on invalid sr/frequency.
# ================================================================
#must_use
fn modulation_fm_new(carrier_freq, mod_freq, mod_index, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }
    var carrier = osc_new(WAVEFORM_SINE, carrier_freq, sample_rate);
    if (naad_is_err(carrier) == 1) { return carrier; }
    var modulator = osc_new(WAVEFORM_SINE, mod_freq, sample_rate);
    if (naad_is_err(modulator) == 1) { return modulator; }

    var self = alloc(sizeof(FmModulator));
    FmModulator_set_carrier(self, carrier);
    FmModulator_set_modulator(self, modulator);
    FmModulator_set_mod_index(self, mod_index);
    FmModulator_set_carrier_base_freq(self, carrier_freq);
    return self;
}

# ================================================================
# modulation_fm_carrier / _modulator -- inner oscillator pointers.
# ================================================================
#inline
#must_use
fn modulation_fm_carrier(self) {
    return FmModulator_carrier(self);
}

#inline
#must_use
fn modulation_fm_modulator(self) {
    return FmModulator_modulator(self);
}

# ================================================================
# modulation_fm_next_sample -- next FM synthesis sample. The carrier frequency
# is modulated by the modulator output scaled by mod_index * mod_frequency,
# clamped to [0.1, nyquist-1], and the carrier is phase-modulated directly as
# a sine regardless of its waveform setting.
# ================================================================
#inline
#must_use
fn modulation_fm_next_sample(self) {
    var modulator = FmModulator_modulator(self);
    var carrier = FmModulator_carrier(self);

    var mod_out = osc_next_sample(modulator);

    # Instantaneous carrier frequency.
    var freq_deviation = f64_mul(f64_mul(mod_out, FmModulator_mod_index(self)), osc_frequency(modulator));
    var inst_freq = f64_add(FmModulator_carrier_base_freq(self), freq_deviation);

    # Clamp to a valid range.
    var nyquist = f64_div(osc_sample_rate(carrier), F64_TWO);
    var clamped_freq = f64_clamp(inst_freq, MODULATION_C0_1, f64_sub(nyquist, F64_ONE));

    # Phase-modulate the carrier directly (always sine).
    var dt = f64_div(clamped_freq, osc_sample_rate(carrier));
    return osc_advance_phase_sine(carrier, dt);
}

# ================================================================
# modulation_fm_fill_buffer -- fill a vec buffer in place with FM samples.
# ================================================================
#inline
fn modulation_fm_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, modulation_fm_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# RingModulator -- multiplies an input signal by a modulator oscillator.
#   modulator : the modulator Oscillator
# ================================================================
#derive(accessors)
struct RingModulator { modulator; }

# ================================================================
# modulation_ring_new -- construct. Returns the struct pointer on success or a
# negative ERR_* on invalid frequency/sample_rate.
# ================================================================
#must_use
fn modulation_ring_new(waveform, mod_freq, sample_rate) {
    var modulator = osc_new(waveform, mod_freq, sample_rate);
    if (naad_is_err(modulator) == 1) { return modulator; }

    var self = alloc(sizeof(RingModulator));
    RingModulator_set_modulator(self, modulator);
    return self;
}

# ================================================================
# modulation_ring_modulator -- inner modulator oscillator pointer.
# ================================================================
#inline
#must_use
fn modulation_ring_modulator(self) {
    return RingModulator_modulator(self);
}

# ================================================================
# modulation_ring_process_sample -- input * modulator output.
# ================================================================
#inline
#must_use
fn modulation_ring_process_sample(self, input) {
    return f64_mul(input, osc_next_sample(RingModulator_modulator(self)));
}

# ================================================================
# modulation_ring_process_buffer -- process a vec buffer in place.
# ================================================================
#inline
fn modulation_ring_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, modulation_ring_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# --- effects.cyr ---

# effects.cyr -- Audio effects: chorus, flanger, phaser, and distortion.
#
# Ports rust-old/src/effects.rs. f32 -> f64 throughout. serde derives are
# dropped (no serde in Cyrius). The `DistortionType` enum becomes integer
# constants. Constructors return the struct pointer on success or a negative
# ERR_* on invalid sample_rate / LFO rate (propagated from osc_new). Methods
# become free `effects_*` functions taking the struct pointer.
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_ONE/TWO/HALF/PI, f64_clamp/min/max/pow/tanh, f64_floor), error.cyr
# (validate_sample_rate, naad_is_err, naad_is_finite, flush_denormal),
# delay.cyr (delay_line_*), and osc_core.cyr (osc_new, osc_next_sample,
# osc_set_phase, WAVEFORM_SINE). The module file has no `include` lines.

# ================================================================
# DistortionType (enum) -> integer constants. Exact oracle variant order.
# ================================================================
var DISTORTION_SOFT_CLIP = 0;   # tanh saturation
var DISTORTION_HARD_CLIP = 1;   # clamp to [-1, 1]
var DISTORTION_WAVE_FOLD = 2;   # triangle wave folding

# ================================================================
# Non-integer float literals (IEEE-754 bit patterns).
# ================================================================
var EFFECTS_C0_01     = 0x3F847AE147AE147B;   #  0.01 (LFO rate floor / w clamp)
var EFFECTS_C0_99     = 0x3FEFAE147AE147AE;   #  0.99 (feedback / w clamp hi)
var EFFECTS_CNEG0_99  = 0xBFEFAE147AE147AE;   # -0.99 (feedback clamp lo)

# ================================================================
# Chorus -- multi-tap modulated delay.
#   delay_lines : vec of DelayLine pointers (one per voice)
#   lfos        : vec of Oscillator pointers (one per voice)
#   base_delay  : base delay in samples
#   depth       : modulation depth in samples
#   mix         : wet/dry mix (0..1)
#   num_voices  : number of chorus voices
# ================================================================
#derive(accessors)
struct Chorus { delay_lines; lfos; base_delay; depth; mix; num_voices; }

# Create a new chorus. Returns the struct pointer, or a negative ERR_* if
# sample_rate is invalid or the LFO oscillator fails to construct.
#must_use
fn effects_chorus_new(num_voices, base_delay_ms, depth_ms, rate, mix, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var voices = num_voices;
    if (voices < 1) { voices = 1; }

    var base_delay = f64_div(f64_mul(base_delay_ms, sample_rate), f64_from(1000));
    var depth = f64_div(f64_mul(depth_ms, sample_rate), f64_from(1000));
    var max_delay = f64_to(f64_add(f64_add(base_delay, depth), F64_ONE));

    var delay_lines = vec_new();
    var lfos = vec_new();

    var i = 0;
    while (i < voices) {
        vec_push(delay_lines, delay_line_new(max_delay));
        # Spread LFO phases across voices.
        var lfo = osc_new(WAVEFORM_SINE, f64_max(rate, EFFECTS_C0_01), sample_rate);
        if (naad_is_err(lfo) == 1) { return lfo; }
        osc_set_phase(lfo, f64_div(f64_from(i), f64_from(voices)));
        vec_push(lfos, lfo);
        i = i + 1;
    }

    var self = alloc(sizeof(Chorus));
    Chorus_set_delay_lines(self, delay_lines);
    Chorus_set_lfos(self, lfos);
    Chorus_set_base_delay(self, base_delay);
    Chorus_set_depth(self, depth);
    Chorus_set_mix(self, f64_clamp(mix, 0, F64_ONE));
    Chorus_set_num_voices(self, voices);
    return self;
}

# Process a single sample through the chorus.
#inline
#must_use
fn effects_chorus_process_sample(self, input) {
    var wet = 0;
    var base_delay = Chorus_base_delay(self);
    var depth = Chorus_depth(self);
    var delay_lines = Chorus_delay_lines(self);
    var lfos = Chorus_lfos(self);
    var n = Chorus_num_voices(self);

    var i = 0;
    while (i < n) {
        var lfo_val = osc_next_sample(vec_get(lfos, i));
        var mod_amt = f64_add(f64_mul(lfo_val, F64_HALF), F64_HALF);
        var delay = f64_add(base_delay, f64_mul(depth, mod_amt));

        var dl = vec_get(delay_lines, i);
        delay_line_write(dl, input);
        wet = f64_add(wet, delay_line_read(dl, delay));
        i = i + 1;
    }

    wet = f64_div(wet, f64_from(n));
    var mix = Chorus_mix(self);
    var dry = f64_mul(input, f64_sub(F64_ONE, mix));
    return f64_add(dry, f64_mul(wet, mix));
}

# ================================================================
# Flanger -- short feedback delay with LFO modulation.
#   delay_line  : DelayLine pointer
#   lfo         : Oscillator pointer
#   base_delay  : base delay in samples
#   depth       : modulation depth in samples
#   feedback    : feedback coefficient, clamped to [-0.99, 0.99]
#   mix         : wet/dry mix (0..1)
#   prev_output : previous output for feedback
# ================================================================
#derive(accessors)
struct Flanger { delay_line; lfo; base_delay; depth; feedback; mix; prev_output; }

# Create a new flanger. Returns the struct pointer, or a negative ERR_* if
# sample_rate is invalid or the LFO oscillator fails to construct.
#must_use
fn effects_flanger_new(base_delay_ms, depth_ms, rate, feedback, mix, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    var base_delay = f64_div(f64_mul(base_delay_ms, sample_rate), f64_from(1000));
    var depth = f64_div(f64_mul(depth_ms, sample_rate), f64_from(1000));
    var max_delay = f64_to(f64_add(f64_add(base_delay, depth), F64_ONE));

    var lfo = osc_new(WAVEFORM_SINE, f64_max(rate, EFFECTS_C0_01), sample_rate);
    if (naad_is_err(lfo) == 1) { return lfo; }

    var self = alloc(sizeof(Flanger));
    Flanger_set_delay_line(self, delay_line_new(max_delay));
    Flanger_set_lfo(self, lfo);
    Flanger_set_base_delay(self, base_delay);
    Flanger_set_depth(self, depth);
    Flanger_set_feedback(self, f64_clamp(feedback, EFFECTS_CNEG0_99, EFFECTS_C0_99));
    Flanger_set_mix(self, f64_clamp(mix, 0, F64_ONE));
    Flanger_set_prev_output(self, 0);
    return self;
}

# Process a single sample through the flanger.
#inline
#must_use
fn effects_flanger_process_sample(self, input) {
    var lfo_val = osc_next_sample(Flanger_lfo(self));
    var mod_amt = f64_add(f64_mul(lfo_val, F64_HALF), F64_HALF);
    var delay = f64_add(Flanger_base_delay(self), f64_mul(Flanger_depth(self), mod_amt));

    var input_with_fb = f64_add(input, f64_mul(Flanger_feedback(self), Flanger_prev_output(self)));
    var dl = Flanger_delay_line(self);
    delay_line_write(dl, input_with_fb);

    var delayed = delay_line_read(dl, delay);
    Flanger_set_prev_output(self, delayed);

    var mix = Flanger_mix(self);
    var dry = f64_mul(input, f64_sub(F64_ONE, mix));
    return f64_add(dry, f64_mul(delayed, mix));
}

# ================================================================
# Phaser -- cascade of allpass filters with LFO modulation.
#   allpass_states : vec<f64> of z-1 states (one per stage)
#   lfo            : Oscillator pointer
#   num_stages     : number of allpass stages
#   min_freq       : minimum sweep frequency in Hz
#   max_freq       : maximum sweep frequency in Hz
#   feedback       : feedback coefficient, clamped to [-0.99, 0.99]
#   mix            : wet/dry mix (0..1)
#   sample_rate    : Hz
#   prev_output    : previous output for feedback
# ================================================================
#derive(accessors)
struct Phaser {
    allpass_states;
    lfo;
    num_stages;
    min_freq;
    max_freq;
    feedback;
    mix;
    sample_rate;
    prev_output;
}

# Create a new phaser. Returns the struct pointer, or a negative ERR_* if
# sample_rate is invalid or the LFO oscillator fails to construct.
#must_use
fn effects_phaser_new(num_stages, rate, min_freq, max_freq, feedback, mix, sample_rate) {
    var e = validate_sample_rate(sample_rate);
    if (naad_is_err(e) == 1) { return e; }

    # Validate frequency range: positive and below Nyquist.
    var nyquist = f64_mul(sample_rate, F64_HALF);
    var min_f = f64_min(f64_max(min_freq, f64_from(20)), nyquist);
    var max_f = f64_min(f64_max(max_freq, min_f), nyquist);

    var stages = num_stages;
    if (stages < 2) { stages = 2; }

    var lfo = osc_new(WAVEFORM_SINE, f64_max(rate, EFFECTS_C0_01), sample_rate);
    if (naad_is_err(lfo) == 1) { return lfo; }

    var states = vec_new();
    var i = 0;
    while (i < stages) {
        vec_push(states, 0);
        i = i + 1;
    }

    var self = alloc(sizeof(Phaser));
    Phaser_set_allpass_states(self, states);
    Phaser_set_lfo(self, lfo);
    Phaser_set_num_stages(self, stages);
    Phaser_set_min_freq(self, min_f);
    Phaser_set_max_freq(self, max_f);
    Phaser_set_feedback(self, f64_clamp(feedback, EFFECTS_CNEG0_99, EFFECTS_C0_99));
    Phaser_set_mix(self, f64_clamp(mix, 0, F64_ONE));
    Phaser_set_sample_rate(self, sample_rate);
    Phaser_set_prev_output(self, 0);
    return self;
}

# Process a single sample through the phaser.
#inline
#must_use
fn effects_phaser_process_sample(self, input) {
    var lfo_val = osc_next_sample(Phaser_lfo(self));
    # Map LFO to frequency range (logarithmic).
    var t = f64_mul(f64_add(lfo_val, F64_ONE), F64_HALF);
    var min_freq = Phaser_min_freq(self);
    var ratio = f64_div(Phaser_max_freq(self), min_freq);
    var freq = f64_mul(min_freq, f64_pow(ratio, t));

    # Compute allpass coefficient from frequency (bilinear transform).
    var w = f64_min(f64_div(f64_mul(F64_PI, freq), Phaser_sample_rate(self)), EFFECTS_C0_99);
    var coeff = f64_div(f64_sub(F64_ONE, w), f64_add(F64_ONE, w));

    var states = Phaser_allpass_states(self);
    var n = vec_len(states);
    var output = f64_add(input, f64_mul(Phaser_feedback(self), Phaser_prev_output(self)));
    var i = 0;
    while (i < n) {
        var state = vec_get(states, i);
        var x = output;
        output = f64_sub(state, f64_mul(coeff, x));
        vec_set(states, i, f64_add(f64_mul(coeff, output), x));
        i = i + 1;
    }

    Phaser_set_prev_output(self, output);

    var mix = Phaser_mix(self);
    var dry = f64_mul(input, f64_sub(F64_ONE, mix));
    var wet = f64_mul(f64_mul(f64_add(input, output), F64_HALF), mix);
    return f64_add(dry, wet);
}

# ================================================================
# Distortion -- multiple distortion types.
#   distortion_type : DISTORTION_* constant
#   drive           : drive/gain amount (1.0 = unity), >= 0
#   mix             : wet/dry mix (0..1)
# ================================================================
#derive(accessors)
struct Distortion { distortion_type; drive; mix; }

# Create a new distortion effect.
#must_use
fn effects_distortion_new(distortion_type, drive, mix) {
    var self = alloc(sizeof(Distortion));
    Distortion_set_distortion_type(self, distortion_type);
    Distortion_set_drive(self, f64_max(drive, 0));
    Distortion_set_mix(self, f64_clamp(mix, 0, F64_ONE));
    return self;
}

# Process a single sample through the distortion.
#inline
#must_use
fn effects_distortion_process_sample(self, input) {
    var driven = f64_mul(input, Distortion_drive(self));
    var dtype = Distortion_distortion_type(self);

    var distorted = 0;
    if (dtype == DISTORTION_SOFT_CLIP) {
        distorted = f64_tanh(driven);
    } elif (dtype == DISTORTION_HARD_CLIP) {
        distorted = f64_clamp(driven, f64_neg(F64_ONE), F64_ONE);
    } else {
        # WaveFold: analytical triangle-wave folding into [-1, 1] by
        # reflecting at the boundaries. Non-finite input folds to 0.
        if (naad_is_finite(driven) == 0) {
            distorted = 0;
        } else {
            # Shift so -1 maps to 0, then triangle-fold with period 4.
            var x = f64_add(driven, F64_ONE);
            var period = f64_from(4);
            # rem_euclid(x, 4): x - 4 * floor(x / 4) is always in [0, 4).
            var q = f64_floor(f64_div(x, period));
            var tf = f64_sub(x, f64_mul(period, q));
            if (f64_lt(tf, F64_TWO) == 1) {
                distorted = f64_sub(tf, F64_ONE);   # rising: 0->-1, 1->0, 2->1
            } else {
                distorted = f64_sub(f64_from(3), tf);   # falling: 2->1, 3->0, 4->-1
            }
        }
    }

    var mix = Distortion_mix(self);
    var dry = f64_mul(input, f64_sub(F64_ONE, mix));
    return f64_add(dry, f64_mul(distorted, mix));
}

# --- subtractive.cyr ---

# subtractive.cyr -- single-voice subtractive synthesis signal chain.
#
# Ports rust-old/src/synth/subtractive.rs. f32 -> f64 throughout. serde
# derives dropped. Signal flow: oscillator(s) -> state-variable filter ->
# amplitude envelope -> output, with an optional second oscillator and a
# filter envelope modulating cutoff (in octaves). The consumer (dhvani)
# handles voice allocation and polyphony; this module is one voice.
#
# Reuses the already-ported dep symbols: Oscillator (osc_*), the
# StateVariableFilter (filter_svf_*), and Adsr (envelope_adsr_*). The
# `Result<T>` / `Option<T>` returns become pointer-or-negative-ERR_* / null
# (0) sentinels, exactly mirroring the oracle's fallible constructors.
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_ONE/TWO/HALF, f64_clamp/max/pow), error.cyr (naad_is_err, ERR_NONE),
# osc_core.cyr (osc_new/osc_next_sample/osc_set_frequency, WAVEFORM_*),
# filter.cyr (filter_svf_new/filter_svf_set_params/filter_svf_q/
# filter_svf_process_sample_lowpass), and envelope.cyr
# (envelope_adsr_with_sample_rate/gate_on/gate_off/next_value/is_active).
# No `include` lines -- the test entry orders the deps.

# ================================================================
# Non-integer float literals (IEEE-754 bit patterns).
# ================================================================
var SUB_C0_1   = 0x3FB999999999999A;   # 0.1  (min resonance / amp decay)
var SUB_C0_7   = 0x3FE6666666666666;   # 0.7  (amp sustain)
var SUB_C0_3   = 0x3FD3333333333333;   # 0.3  (amp release)
var SUB_C0_01  = 0x3F847AE147AE147B;   # 0.01 (attack for both envelopes)
var SUB_C0_2   = 0x3FC999999999999A;   # 0.2  (filter-env decay)
var SUB_C0_49  = 0x3FDF5C28F5C28F5C;   # 0.49 (Nyquist headroom factor)

# ================================================================
# SubtractiveSynth -- one subtractive voice.
#   osc1                 : primary Oscillator pointer
#   osc2                 : optional second Oscillator pointer (0 = None)
#   osc2_mix             : osc2 blend level (0.0..1.0)
#   filter               : StateVariableFilter pointer
#   amp_env              : amplitude Adsr pointer
#   filter_env           : filter-cutoff Adsr pointer
#   filter_env_depth     : filter-env depth in octaves (-4.0..+4.0)
#   base_cutoff          : base filter cutoff (Hz)
#   sample_rate          : Hz
#   prev_modulated_cutoff: last applied cutoff (skips redundant recompute)
# ================================================================
#derive(accessors)
struct SubtractiveSynth {
    osc1;
    osc2;
    osc2_mix;
    filter;
    amp_env;
    filter_env;
    filter_env_depth;
    base_cutoff;
    sample_rate;
    prev_modulated_cutoff;
}

# ================================================================
# subtractive_new -- construct a voice. Returns the struct pointer on
# success, or the first negative ERR_* encountered while building the
# oscillator / filter / envelopes (mirrors the oracle's `?` propagation).
# resonance is floored at 0.1 (resonance.max(0.1)); the two envelopes use
# the oracle's fixed ADSR presets.
# ================================================================
#must_use
fn subtractive_new(waveform, frequency, cutoff, resonance, sample_rate) {
    var osc1 = osc_new(waveform, frequency, sample_rate);
    if (naad_is_err(osc1) == 1) { return osc1; }
    var res = f64_max(resonance, SUB_C0_1);
    var filter = filter_svf_new(cutoff, res, sample_rate);
    if (naad_is_err(filter) == 1) { return filter; }
    var amp_env = envelope_adsr_with_sample_rate(SUB_C0_01, SUB_C0_1, SUB_C0_7, SUB_C0_3, sample_rate);
    if (naad_is_err(amp_env) == 1) { return amp_env; }
    var filter_env = envelope_adsr_with_sample_rate(SUB_C0_01, SUB_C0_2, F64_HALF, F64_HALF, sample_rate);
    if (naad_is_err(filter_env) == 1) { return filter_env; }

    var self = alloc(sizeof(SubtractiveSynth));
    SubtractiveSynth_set_osc1(self, osc1);
    SubtractiveSynth_set_osc2(self, 0);
    SubtractiveSynth_set_osc2_mix(self, F64_HALF);
    SubtractiveSynth_set_filter(self, filter);
    SubtractiveSynth_set_amp_env(self, amp_env);
    SubtractiveSynth_set_filter_env(self, filter_env);
    SubtractiveSynth_set_filter_env_depth(self, F64_TWO);
    SubtractiveSynth_set_base_cutoff(self, cutoff);
    SubtractiveSynth_set_sample_rate(self, sample_rate);
    SubtractiveSynth_set_prev_modulated_cutoff(self, cutoff);
    return self;
}

# ================================================================
# subtractive_set_osc2 -- enable the second oscillator. Returns ERR_NONE on
# success, or a negative ERR_* if the oscillator parameters are invalid.
# The mix level is clamped to [0.0, 1.0].
# ================================================================
fn subtractive_set_osc2(self, waveform, frequency, mix) {
    var osc2 = osc_new(waveform, frequency, SubtractiveSynth_sample_rate(self));
    if (naad_is_err(osc2) == 1) { return osc2; }
    SubtractiveSynth_set_osc2(self, osc2);
    SubtractiveSynth_set_osc2_mix(self, f64_clamp(mix, 0, F64_ONE));
    return ERR_NONE;
}

# ================================================================
# subtractive_clear_osc2 -- disable the second oscillator (osc2 -> None).
# ================================================================
fn subtractive_clear_osc2(self) {
    SubtractiveSynth_set_osc2(self, 0);
    return 0;
}

# ================================================================
# subtractive_note_on -- trigger the voice (gate on both envelopes).
# ================================================================
fn subtractive_note_on(self) {
    envelope_adsr_gate_on(SubtractiveSynth_amp_env(self));
    envelope_adsr_gate_on(SubtractiveSynth_filter_env(self));
    return 0;
}

# ================================================================
# subtractive_note_off -- release the voice (gate off both envelopes).
# ================================================================
fn subtractive_note_off(self) {
    envelope_adsr_gate_off(SubtractiveSynth_amp_env(self));
    envelope_adsr_gate_off(SubtractiveSynth_filter_env(self));
    return 0;
}

# ================================================================
# subtractive_set_frequency -- retune both oscillators. Returns ERR_NONE on
# success or a negative ERR_* if osc1's frequency is invalid; osc2's retune
# result is ignored (mirrors the oracle's `let _ = osc2.set_frequency(..)`).
# ================================================================
fn subtractive_set_frequency(self, freq) {
    var e = osc_set_frequency(SubtractiveSynth_osc1(self), freq);
    if (naad_is_err(e) == 1) { return e; }
    var osc2 = SubtractiveSynth_osc2(self);
    if (osc2 != 0) {
        osc_set_frequency(osc2, freq);
    }
    return ERR_NONE;
}

# ================================================================
# subtractive_set_filter_env_depth -- set filter-env depth in octaves,
# clamped to [-4.0, +4.0].
# ================================================================
fn subtractive_set_filter_env_depth(self, octaves) {
    SubtractiveSynth_set_filter_env_depth(self, f64_clamp(octaves, f64_neg(f64_from(4)), f64_from(4)));
    return 0;
}

# ================================================================
# subtractive_set_cutoff -- set the base filter cutoff and reapply it to the
# filter (preserving its current Q). Returns ERR_NONE or a negative ERR_*.
# ================================================================
fn subtractive_set_cutoff(self, cutoff) {
    SubtractiveSynth_set_base_cutoff(self, cutoff);
    var filter = SubtractiveSynth_filter(self);
    return filter_svf_set_params(filter, cutoff, filter_svf_q(filter));
}

# ================================================================
# subtractive_next_sample -- oscillator mix -> envelope-modulated filter ->
# amplitude envelope. Filter coefficients are only recomputed when the
# modulated cutoff moves more than 0.5 Hz (matching the oracle's guard).
# ================================================================
#inline
#must_use
fn subtractive_next_sample(self) {
    # Oscillator mix.
    var osc_out = osc_next_sample(SubtractiveSynth_osc1(self));
    var osc2 = SubtractiveSynth_osc2(self);
    if (osc2 != 0) {
        var o2 = osc_next_sample(osc2);
        var mix = SubtractiveSynth_osc2_mix(self);
        osc_out = f64_add(f64_mul(osc_out, f64_sub(F64_ONE, mix)), f64_mul(o2, mix));
    }

    # Filter with envelope modulation (depth in octaves -> 2^mod).
    var filter_mod = f64_mul(envelope_adsr_next_value(SubtractiveSynth_filter_env(self)),
    SubtractiveSynth_filter_env_depth(self));
    var modulated_cutoff = f64_mul(SubtractiveSynth_base_cutoff(self), f64_pow(F64_TWO, filter_mod));
    var nyq = f64_mul(SubtractiveSynth_sample_rate(self), SUB_C0_49);
    var clamped = f64_clamp(modulated_cutoff, f64_from(20), nyq);
    var diff = f64_abs(f64_sub(clamped, SubtractiveSynth_prev_modulated_cutoff(self)));
    if (f64_gt(diff, F64_HALF) == 1) {
        var filter = SubtractiveSynth_filter(self);
        filter_svf_set_params(filter, clamped, filter_svf_q(filter));
        SubtractiveSynth_set_prev_modulated_cutoff(self, clamped);
    }
    var filtered = filter_svf_process_sample_lowpass(SubtractiveSynth_filter(self), osc_out);

    # Amplitude envelope.
    var amp = envelope_adsr_next_value(SubtractiveSynth_amp_env(self));
    return f64_mul(filtered, amp);
}

# ================================================================
# subtractive_fill_buffer -- fill a vec buffer in place.
# ================================================================
#inline
fn subtractive_fill_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, subtractive_next_sample(self));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# subtractive_is_active -- 1 while the amplitude envelope is not idle.
# ================================================================
#must_use
fn subtractive_is_active(self) {
    return envelope_adsr_is_active(SubtractiveSynth_amp_env(self));
}

# ================================================================
# subtractive_amp_env / subtractive_amp_env_mut -- the amplitude envelope
# pointer (Rust returned &Adsr / &mut Adsr; here both hand back the pointer).
# ================================================================
#must_use
fn subtractive_amp_env(self) {
    return SubtractiveSynth_amp_env(self);
}

fn subtractive_amp_env_mut(self) {
    return SubtractiveSynth_amp_env(self);
}

# ================================================================
# subtractive_filter_env_mut -- the filter envelope pointer (Rust: &mut Adsr).
# ================================================================
fn subtractive_filter_env_mut(self) {
    return SubtractiveSynth_filter_env(self);
}

# --- acoustics.cyr ---

# acoustics.cyr -- naad acoustics base layer.
#
# Ports the shared helper from rust-old/src/acoustics/mod.rs: material_by_name,
# used by the room / convolution / coupled / analysis wrappers. naad's acoustics
# modules are thin wrappers over the goonj acoustics engine; this file holds the
# one cross-cutting helper. Requires goonj (acoustic_material_* constructors) and
# stdlib string (streq). No `include` lines.

# Look up a built-in goonj AcousticMaterial by name. Returns the material
# pointer, or 0 (Rust None) for an unknown name. Mirrors material_by_name's
# exact 7-name set: concrete, carpet, glass, wood, curtain, drywall, tile.
#must_use
fn naad_acoustics_material_by_name(name) {
    if (streq(name, "concrete") == 1) { return acoustic_material_concrete(); }
    if (streq(name, "carpet") == 1) { return acoustic_material_carpet(); }
    if (streq(name, "glass") == 1) { return acoustic_material_glass(); }
    if (streq(name, "wood") == 1) { return acoustic_material_wood(); }
    if (streq(name, "curtain") == 1) { return acoustic_material_curtain(); }
    if (streq(name, "drywall") == 1) { return acoustic_material_drywall(); }
    if (streq(name, "tile") == 1) { return acoustic_material_tile(); }
    return 0;
}

# --- acoustics_room.cyr ---

# acoustics_room.cyr -- naad room simulation reverb (thin goonj wrapper).
#
# Ports rust-old/src/acoustics/room.rs. Builds a shoebox room in goonj,
# generates a broadband impulse response via image-source + diffuse rain,
# and applies it as a sample-by-sample convolution reverb. f32 -> f64
# throughout. Rust's serde derives and the `debug!` log are dropped.
#
# Cross-crate goonj mapping (discovered from lib/goonj.cyr + goonj src/tests):
#   goonj::room::AcousticRoom::shoebox   -> acoustic_room_shoebox(l, w, h, mat)
#   goonj::impulse::IrConfig{..}         -> ir_config_new(rate, order, rays,
#                                                          bounces, secs, seed)
#   goonj::impulse::generate_ir          -> generate_ir(src, lis, room, cfg)
#   MultibandIr::to_broadband            -> multiband_ir_to_broadband(mi)
#   ImpulseResponse.samples              -> ImpulseResponse_samples(ir)
#   hisab::Vec3::new                     -> hvec3_new(x, y, z)
# The wall material name resolves through naad_acoustics_material_by_name
# (src/acoustics.cyr). Result<Self> -> struct pointer on success or a
# negative ERR_COMPUTATION on unknown material / non-positive dimensions.
#
# Requires (from the build/test unit): stdlib alloc/vec + math (F64_ONE,
# f64_add/mul/le, f64_abs/lt), hisab (hvec3_new), the goonj bundle
# (acoustic_room_shoebox, ir_config_new, generate_ir,
# multiband_ir_to_broadband, ImpulseResponse_samples), and the naad L0
# modules error.cyr (ERR_COMPUTATION, naad_is_err) + acoustics.cyr
# (naad_acoustics_material_by_name). This file has no `include` lines.

# ================================================================
# RoomReverbConfig -- configuration for a room simulation reverb.
#   length            : room length in metres (X axis)
#   width             : room width  in metres (Z axis)
#   height            : room height in metres (Y axis)
#   wall_material_name: goonj material name ("concrete", "carpet", ...)
#   source_position   : source HVec3 [x, y, z] in metres
#   listener_position : listener HVec3 [x, y, z] in metres
#   sample_rate       : sample rate in Hz
# The Rust `[f32; 3]` source/listener arrays map to hisab HVec3 points.
# ================================================================
#derive(accessors)
struct RoomReverbConfig {
    length;
    width;
    height;
    wall_material_name;
    source_position;
    listener_position;
    sample_rate;
}

# Build a RoomReverbConfig. `source_position` / `listener_position` are
# HVec3 pointers (hvec3_new). Ports the Rust struct literal.
#must_use
fn naad_room_reverb_config_new(length, width, height, wall_material_name,
source_position, listener_position, sample_rate) {
    var c = alloc(sizeof(RoomReverbConfig));
    RoomReverbConfig_set_length(c, length);
    RoomReverbConfig_set_width(c, width);
    RoomReverbConfig_set_height(c, height);
    RoomReverbConfig_set_wall_material_name(c, wall_material_name);
    RoomReverbConfig_set_source_position(c, source_position);
    RoomReverbConfig_set_listener_position(c, listener_position);
    RoomReverbConfig_set_sample_rate(c, sample_rate);
    return c;
}

# ================================================================
# RoomReverb -- room simulation reverb backed by a goonj impulse response.
#   config          : the RoomReverbConfig used to build this reverb
#   impulse_response: pre-computed broadband IR (vec of f64, may be empty)
#   input_buffer    : ring-buffer of recent inputs (len == max(ir_len, 1))
#   current_position: current write position in the ring buffer
# ================================================================
#derive(accessors)
struct RoomReverb {
    config;
    impulse_response;
    input_buffer;
    current_position;
}

# ================================================================
# naad_room_reverb_new -- create a room reverb from a config. Builds a
# shoebox room in goonj, generates a broadband impulse response via
# image-source + diffuse-rain, and stores it for sample-by-sample
# convolution. Returns the struct pointer on success, or a negative
# ERR_COMPUTATION if the wall material name is unknown or the room
# dimensions are not positive. Ports RoomReverb::new.
# ================================================================
#must_use
fn naad_room_reverb_new(config) {
    var material = naad_acoustics_material_by_name(RoomReverbConfig_wall_material_name(config));
    if (material == 0) { return ERR_COMPUTATION; }

    if (f64_le(RoomReverbConfig_length(config), 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(RoomReverbConfig_width(config), 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(RoomReverbConfig_height(config), 0) == 1) { return ERR_COMPUTATION; }

    var room = acoustic_room_shoebox(RoomReverbConfig_length(config),
    RoomReverbConfig_width(config), RoomReverbConfig_height(config), material);

    var source = RoomReverbConfig_source_position(config);
    var listener = RoomReverbConfig_listener_position(config);

    # Fixed generation parameters (mirrors the Rust IrConfig literal):
    # order 3, 2000 diffuse rays, 30 bounces, 1.0 s, seed 42.
    var ir_config = ir_config_new(RoomReverbConfig_sample_rate(config), 3, 2000, 30, F64_ONE, 42);

    var multiband = generate_ir(source, listener, room, ir_config);
    var broadband = multiband_ir_to_broadband(multiband);
    var ir = ImpulseResponse_samples(broadband);

    var ir_len = vec_len(ir);
    var buf_len = ir_len;
    if (buf_len < 1) { buf_len = 1; }

    var input_buffer = vec_new();
    var i = 0;
    while (i < buf_len) {
        vec_push(input_buffer, 0);
        i = i + 1;
    }

    var self = alloc(sizeof(RoomReverb));
    RoomReverb_set_config(self, config);
    RoomReverb_set_impulse_response(self, ir);
    RoomReverb_set_input_buffer(self, input_buffer);
    RoomReverb_set_current_position(self, 0);
    return self;
}

# ================================================================
# naad_room_reverb_process_sample -- process a single audio sample via
# direct convolution with the stored impulse response. An empty IR passes
# the input through unchanged. Ports RoomReverb::process_sample.
# ================================================================
#inline
#must_use
fn naad_room_reverb_process_sample(self, input) {
    var ir = RoomReverb_impulse_response(self);
    var ir_len = vec_len(ir);
    if (ir_len == 0) { return input; }

    var buf = RoomReverb_input_buffer(self);
    var pos = RoomReverb_current_position(self);
    # Write input into the ring buffer.
    vec_set(buf, pos, input);

    # Direct convolution: output = sum(input_buffer[pos - k] * ir[k]).
    var output = 0;
    var k = 0;
    while (k < ir_len) {
        var idx_raw = pos + ir_len - k;
        var idx = idx_raw % ir_len;
        output = f64_add(output, f64_mul(vec_get(buf, idx), vec_get(ir, k)));
        k = k + 1;
    }

    var nextp = pos + 1;
    var np = nextp % ir_len;
    RoomReverb_set_current_position(self, np);
    return output;
}

# --- acoustics_directivity.cyr ---

# acoustics_directivity.cyr -- source directivity patterns for monitor
# placement and spatial synthesis.
#
# Ports rust-old/src/acoustics/directivity.rs. Thin wrapper over goonj's
# analytical directivity patterns (omni / cardioid family / figure-8). Given
# a source's front-axis vector and the direction toward a receiver,
# naad_directivity_gain returns the linear attenuation factor to apply before
# further propagation. Tabulated balloon data (CLF/CF2 measured directivity)
# is intentionally excluded -- load that via goonj directly; this module
# exposes only the closed-form analytical patterns that map cleanly onto
# naad's no-IO contract.
#
# Rust `SourceDirectivity` (a #[non_exhaustive] enum) becomes an integer
# `kind` tag; the naad_directivity_* helpers dispatch on it. Directions are
# hisab HVec3 pointers (Rust `Vec3`). f32 -> f64 throughout. serde round-trip
# test dropped (no serde in Cyrius).
#
# Requires (from the build/test unit): stdlib math (F64_ONE/F64_HALF/F64_PI,
# f64_clamp/f64_max/f64_cos/f64_abs), hisab (hvec3_dot via goonj), and goonj
# (directivity_* constructors + directivity_gain). No `include` lines.

# ================================================================
# SourceDirectivity variants (was `enum SourceDirectivity`).
# ================================================================
var NAAD_DIR_OMNIDIRECTIONAL = 0;   # equal radiation in all directions
var NAAD_DIR_CARDIOID        = 1;   # 0.5·(1 + cos θ); front-firing, null behind
var NAAD_DIR_SUBCARDIOID     = 2;   # 0.75 + 0.25·cos θ; mostly omni, forward bias
var NAAD_DIR_SUPERCARDIOID   = 3;   # 0.37 + 0.63·cos θ; tighter, small rear lobe
var NAAD_DIR_FIGURE8         = 4;   # |cos θ|; equal front + back, side nulls

# ================================================================
# Analytical pattern coefficients (IEEE-754 bit patterns; decimals noted).
# ================================================================
var NAAD_DIR_NEG_ONE = 0xbff0000000000000;   # -1.0  (clamp lower bound)
var NAAD_DIR_0_75    = 0x3fe8000000000000;   # 0.75  subcardioid DC term
var NAAD_DIR_0_25    = 0x3fd0000000000000;   # 0.25  subcardioid cos coeff
var NAAD_DIR_0_37    = 0x3fd7ae147ae147ae;   # 0.37  supercardioid DC term
var NAAD_DIR_0_63    = 0x3fe428f5c28f5c29;   # 0.63  supercardioid cos coeff

# ================================================================
# to_goonj -- map a SourceDirectivity kind to a freshly built goonj
# DirectivityPattern pointer. Mirrors SourceDirectivity::to_goonj; the
# Omnidirectional (and any future) variant is the default.
# ================================================================
#must_use
fn naad_directivity_to_goonj(kind) {
    if (kind == NAAD_DIR_CARDIOID) { return directivity_cardioid(); }
    if (kind == NAAD_DIR_SUBCARDIOID) { return directivity_subcardioid(); }
    if (kind == NAAD_DIR_SUPERCARDIOID) { return directivity_supercardioid(); }
    if (kind == NAAD_DIR_FIGURE8) { return directivity_figure8(); }
    return directivity_omnidirectional();
}

# ================================================================
# gain -- linear directivity gain for a direction relative to the source's
# front axis. `direction` and `front` are HVec3 pointers (unit vectors);
# 1.0 is the on-axis reference. Ports SourceDirectivity::gain, delegating to
# goonj's directivity_gain.
# ================================================================
#inline
#must_use
fn naad_directivity_gain(kind, direction, front) {
    return directivity_gain(naad_directivity_to_goonj(kind), direction, front);
}

# ================================================================
# gain_polar -- evaluate the directivity gain for a polar angle `theta`
# (radians from the front axis; 0 = on-axis, π = directly behind). Convenience
# for the 2D case with no full 3D vectors handy. Ports SourceDirectivity::
# gain_polar's closed forms exactly.
# ================================================================
#inline
#must_use
fn naad_directivity_gain_polar(kind, theta) {
    var cos_theta = f64_clamp(f64_cos(theta), NAAD_DIR_NEG_ONE, F64_ONE);
    if (kind == NAAD_DIR_OMNIDIRECTIONAL) { return F64_ONE; }
    if (kind == NAAD_DIR_CARDIOID) {
        return f64_max(f64_mul(F64_HALF, f64_add(F64_ONE, cos_theta)), 0);
    }
    if (kind == NAAD_DIR_SUBCARDIOID) {
        return f64_add(NAAD_DIR_0_75, f64_mul(NAAD_DIR_0_25, cos_theta));
    }
    if (kind == NAAD_DIR_SUPERCARDIOID) {
        return f64_max(f64_add(NAAD_DIR_0_37, f64_mul(NAAD_DIR_0_63, cos_theta)), 0);
    }
    if (kind == NAAD_DIR_FIGURE8) {
        return f64_abs(cos_theta);
    }
    return F64_ONE;
}

# --- acoustics_ambisonics.cyr ---

# acoustics_ambisonics.cyr -- Ambisonics B-format encoding (naad wrapper).
#
# Ports rust-old/src/acoustics/ambisonics.rs. Encodes a mono audio sample
# into first-order Ambisonics (B-format: W, X, Y, Z) from a source
# direction (azimuth, elevation) using SN3D/ACN direction cosines --
# the same normalization goonj's `encode_bformat` applies to a unit
# direction vector. NOTE: the Rust source is self-contained pure math; it
# references goonj only in a doc comment and makes NO goonj:: / hisab::
# call, so this port has no cross-crate symbols to bind.
#
# f32 -> f64 throughout. serde is dropped (no serde in Cyrius): the
# deserialization-recovery branch in Rust's encode_sample (taken only when
# the trig cache was zeroed by a deserializer) is unreachable here because
# the cache is always populated by _new / set_position, so encode_sample
# uses the cached values directly -- behaviorally identical for every
# constructible encoder. Requires math (F64_*, f64_mul) + builtins
# (f64_sin/cos). alloc_init() must have run.

# ================================================================
# A single B-format encoded sample: W (omni pressure), X (front/back),
# Y (left/right), Z (up/down).
# ================================================================
#derive(accessors)
struct BFormatSample { w; x; y; z; }

# Ambisonics B-format encoder: source direction (azimuth/elevation, both
# radians) plus a cached sin/cos of each for hot-path encoding.
#derive(accessors)
struct AmbisonicsEncoder { azimuth; elevation; cos_el; sin_el; cos_az; sin_az; }

# Recompute the trig cache from the current azimuth / elevation.
fn naad_ambisonics_update_cache(enc) {
    AmbisonicsEncoder_set_cos_el(enc, f64_cos(AmbisonicsEncoder_elevation(enc)));
    AmbisonicsEncoder_set_sin_el(enc, f64_sin(AmbisonicsEncoder_elevation(enc)));
    AmbisonicsEncoder_set_cos_az(enc, f64_cos(AmbisonicsEncoder_azimuth(enc)));
    AmbisonicsEncoder_set_sin_az(enc, f64_sin(AmbisonicsEncoder_azimuth(enc)));
    return 0;
}

# Create a new encoder for the given source direction (radians).
#must_use
fn naad_ambisonics_encoder_new(azimuth, elevation) {
    var enc = alloc(sizeof(AmbisonicsEncoder));
    AmbisonicsEncoder_set_azimuth(enc, azimuth);
    AmbisonicsEncoder_set_elevation(enc, elevation);
    AmbisonicsEncoder_set_cos_el(enc, 0);
    AmbisonicsEncoder_set_sin_el(enc, 0);
    AmbisonicsEncoder_set_cos_az(enc, 0);
    AmbisonicsEncoder_set_sin_az(enc, 0);
    naad_ambisonics_update_cache(enc);
    return enc;
}

# Update the source direction (radians) and refresh the trig cache.
fn naad_ambisonics_set_position(enc, azimuth, elevation) {
    AmbisonicsEncoder_set_azimuth(enc, azimuth);
    AmbisonicsEncoder_set_elevation(enc, elevation);
    naad_ambisonics_update_cache(enc);
    return 0;
}

# Encode one mono input sample into a fresh B-format sample:
#   W = input
#   X = input * cos(az) * cos(el)
#   Y = input * sin(az) * cos(el)
#   Z = input * sin(el)
#inline
#must_use
fn naad_ambisonics_encode_sample(enc, input) {
    var cos_el = AmbisonicsEncoder_cos_el(enc);
    var sin_el = AmbisonicsEncoder_sin_el(enc);
    var cos_az = AmbisonicsEncoder_cos_az(enc);
    var sin_az = AmbisonicsEncoder_sin_az(enc);
    var s = alloc(sizeof(BFormatSample));
    BFormatSample_set_w(s, input);
    BFormatSample_set_x(s, f64_mul(f64_mul(input, cos_az), cos_el));
    BFormatSample_set_y(s, f64_mul(f64_mul(input, sin_az), cos_el));
    BFormatSample_set_z(s, f64_mul(input, sin_el));
    return s;
}

# Current azimuth in radians.
#must_use
fn naad_ambisonics_azimuth(enc) {
    return AmbisonicsEncoder_azimuth(enc);
}

# Current elevation in radians.
#must_use
fn naad_ambisonics_elevation(enc) {
    return AmbisonicsEncoder_elevation(enc);
}

# --- acoustics_fdn.cyr ---

# acoustics_fdn.cyr -- Feedback Delay Network reverbs (naad acoustics wrapper).
#
# Ports rust-old/src/acoustics/fdn_reverb.rs. f32 -> f64 throughout. Two
# reverberators:
#   * FdnReverb -- thin wet/dry wrapper over goonj's room-derived FDN
#     (goonj fdn_config_for_room / fdn_new / fdn_process_sample / fdn_reset).
#   * MatrixFdn -- naad-owned color-free 8x8 Sylvester-Hadamard FDN, built
#     from scratch (per-line ring buffers + one-pole damping + Hadamard mix).
#
# Rust's serde derives (and the lazy Fdn/buffer reconstruction they require)
# are dropped -- with no serde the inner FDN / delay buffers are always live,
# so the `Option<Fdn>` and `ensure_buffers` deser paths collapse away.
# Constructors return the struct pointer on success or a negative ERR_* on
# invalid parameters (Rust's ComputationError -> ERR_COMPUTATION). Fixed
# `[T; 8]` inline arrays become stdlib vecs; `Vec<f32>` ring buffers become
# vecs of vecs.
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita
# (F64_ONE/HALF, f64_add/sub/mul/div/neg/abs/max/clamp/pow/sqrt/from/to/gt/le)
# and the L0 modules error.cyr (flush_denormal, naad_is_finite, ERR_*) and the
# goonj fdn engine (fdn_config_for_room / fdn_new / fdn_process_sample /
# fdn_reset). The module file has no `include` lines.

# ================================================================
# Float literals (IEEE-754 bit patterns).
# ================================================================
var FDN_MS_SCALE = 0x3f50624dd2f1a9fc;   # 0.001  (milliseconds -> seconds)

# MatrixFdn delay lengths in milliseconds -- mutually-coprime primes spanning
# ~30-80 ms, chosen to maximise modal density and avoid metallic resonances.
var FDN_MS_0 = 0x403db33333333333;   # 29.7
var FDN_MS_1 = 0x40428ccccccccccd;   # 37.1
var FDN_MS_2 = 0x4044a66666666666;   # 41.3
var FDN_MS_3 = 0x4045d9999999999a;   # 43.7
var FDN_MS_4 = 0x404af33333333333;   # 53.9
var FDN_MS_5 = 0x404d8ccccccccccd;   # 59.1
var FDN_MS_6 = 0x4050d33333333333;   # 67.3
var FDN_MS_7 = 0x40526ccccccccccd;   # 73.7

# Number of delay lines in MatrixFdn (Hadamard requires a power of 2; 8 is a
# sweet spot).
var MATRIX_FDN_N = 8;

# ================================================================
# FdnReverb -- goonj-backed FDN reverb with a wet/dry mix.
#   fdn          : inner goonj Fdn pointer
#   room_length  : room length in meters (drives delay-line lengths)
#   room_width   : room width in meters
#   room_height  : room height in meters
#   target_rt60  : target RT60 in seconds
#   sample_rate  : Hz
#   mix          : wet/dry mix (0 = dry, 1 = wet)
# ================================================================
#derive(accessors)
struct FdnReverb {
    fdn;
    room_length;
    room_width;
    room_height;
    target_rt60;
    sample_rate;
    mix;
}

# ================================================================
# naad_fdn_reverb_new -- create a goonj-backed FDN reverb. Room dimensions
# drive the delay-line lengths (larger room = longer delays = spacier tail);
# `target_rt60` sets decay time. Returns the struct pointer on success, or
# ERR_COMPUTATION if any parameter is out of range. Ports FdnReverb::new.
# ================================================================
#must_use
fn naad_fdn_reverb_new(room_length, room_width, room_height, target_rt60, sample_rate, mix) {
    if (f64_le(room_length, 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(room_width, 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(room_height, 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(target_rt60, 0) == 1) { return ERR_COMPUTATION; }
    if (naad_is_finite(target_rt60) == 0) { return ERR_COMPUTATION; }
    if (sample_rate == 0) { return ERR_COMPUTATION; }

    var config = fdn_config_for_room(room_length, room_width, room_height, target_rt60, sample_rate);
    var fdn = fdn_new(config);

    var self = alloc(sizeof(FdnReverb));
    FdnReverb_set_fdn(self, fdn);
    FdnReverb_set_room_length(self, room_length);
    FdnReverb_set_room_width(self, room_width);
    FdnReverb_set_room_height(self, room_height);
    FdnReverb_set_target_rt60(self, target_rt60);
    FdnReverb_set_sample_rate(self, sample_rate);
    FdnReverb_set_mix(self, f64_clamp(mix, 0, F64_ONE));
    return self;
}

# ================================================================
# naad_fdn_reverb_process_sample -- process one sample, applying the wet/dry
# mix to the goonj FDN output. Ports FdnReverb::process_sample.
# ================================================================
#inline
#must_use
fn naad_fdn_reverb_process_sample(self, input) {
    var wet = fdn_process_sample(FdnReverb_fdn(self), input);
    var mix = FdnReverb_mix(self);
    var dry = f64_sub(F64_ONE, mix);
    return f64_add(f64_mul(input, dry), f64_mul(wet, mix));
}

# ================================================================
# naad_fdn_reverb_reset -- reset the inner FDN to silence. Ports
# FdnReverb::reset.
# ================================================================
fn naad_fdn_reverb_reset(self) {
    fdn_reset(FdnReverb_fdn(self));
    return 0;
}

# ================================================================
# naad_fdn_hadamard8 -- apply the 8x8 Sylvester-Hadamard matrix to a vec of 8
# (without the 1/sqrt(8) scaling; the caller applies that separately to keep
# the transform orthogonal / energy-preserving). Entries are +/-1, so the
# matmul is fully unrolled. Ports the private `hadamard8`.
#   Row 0: + + + + + + + +      Row 4: + + + + - - - -
#   Row 1: + - + - + - + -      Row 5: + - + - - + - +
#   Row 2: + + - - + + - -      Row 6: + + - - - - + +
#   Row 3: + - - + + - - +      Row 7: + - - + - + + -
# ================================================================
# _naad_fdn_hadamard8_into -- Hadamard core that writes the 8 results into a
# caller-owned 8-slot scratch vec (via vec_set, no allocation). The hot buffer
# loop calls this against struct-owned scratch to avoid a per-sample alloc; the
# public one-shot wrapper below allocates a fresh vec once and delegates here.
# Numerics are bit-identical to the original (same op order, vec_set only
# replaces vec_push).
#inline
fn _naad_fdn_hadamard8_into(x, out) {
    var x0 = vec_get(x, 0);
    var x1 = vec_get(x, 1);
    var x2 = vec_get(x, 2);
    var x3 = vec_get(x, 3);
    var x4 = vec_get(x, 4);
    var x5 = vec_get(x, 5);
    var x6 = vec_get(x, 6);
    var x7 = vec_get(x, 7);

    # Four sign patterns over the low half, mirrored onto the high half; each
    # row is the sum (rows 0-3) or difference (rows 4-7) of the two halves.
    var a = f64_add(f64_add(f64_add(x0, x1), x2), x3);
    var b = f64_sub(f64_add(f64_sub(x0, x1), x2), x3);
    var c = f64_sub(f64_sub(f64_add(x0, x1), x2), x3);
    var d = f64_add(f64_sub(f64_sub(x0, x1), x2), x3);
    var a2 = f64_add(f64_add(f64_add(x4, x5), x6), x7);
    var b2 = f64_sub(f64_add(f64_sub(x4, x5), x6), x7);
    var c2 = f64_sub(f64_sub(f64_add(x4, x5), x6), x7);
    var d2 = f64_add(f64_sub(f64_sub(x4, x5), x6), x7);

    vec_set(out, 0, f64_add(a, a2));
    vec_set(out, 1, f64_add(b, b2));
    vec_set(out, 2, f64_add(c, c2));
    vec_set(out, 3, f64_add(d, d2));
    vec_set(out, 4, f64_sub(a, a2));
    vec_set(out, 5, f64_sub(b, b2));
    vec_set(out, 6, f64_sub(c, c2));
    vec_set(out, 7, f64_sub(d, d2));
    return 0;
}

#inline
#must_use
fn naad_fdn_hadamard8(x) {
    var out = vec_new();
    var i = 0;
    while (i < MATRIX_FDN_N) {
        vec_push(out, 0);
        i = i + 1;
    }
    _naad_fdn_hadamard8_into(x, out);
    return out;
}

# ================================================================
# MatrixFdn -- color-free Hadamard FDN reverb owning its matrix end-to-end.
#   buffers        : vec of 8 ring-buffer vecs (per-line delay lines)
#   positions      : vec<usize> per-line write cursor
#   delay_lengths  : vec<usize> per-line length in samples
#   damping_state  : vec<f32> per-line one-pole lowpass state (mirror)
#   damping_gain   : vec<f32> per-line damping coefficient
#   target_rt60    : target RT60 in seconds
#   sample_rate    : Hz
#   mix            : wet/dry mix (0 = dry, 1 = wet)
#   scratch_delay  : owned 8-slot scratch for per-line damped reads (no alloc)
#   scratch_had    : owned 8-slot scratch for the Hadamard mix output (no alloc)
# ================================================================
#derive(accessors)
struct MatrixFdn {
    buffers;
    positions;
    delay_lengths;
    damping_state;
    damping_gain;
    target_rt60;
    sample_rate;
    mix;
    scratch_delay;
    scratch_had;
}

# The eight delay lengths in milliseconds, in order.
#must_use
fn _matrix_fdn_ms(i) {
    if (i == 0) { return FDN_MS_0; }
    if (i == 1) { return FDN_MS_1; }
    if (i == 2) { return FDN_MS_2; }
    if (i == 3) { return FDN_MS_3; }
    if (i == 4) { return FDN_MS_4; }
    if (i == 5) { return FDN_MS_5; }
    if (i == 6) { return FDN_MS_6; }
    return FDN_MS_7;
}

# ================================================================
# naad_fdn_matrix_new -- create a color-free Hadamard-FDN reverb. `target_rt60`
# sets decay time; delay lengths are primes around 30-80 ms scaled to the
# sample rate; per-line damping gains give a 60 dB drop per RT60. Returns the
# struct pointer, or ERR_COMPUTATION on bad parameters. Ports MatrixFdn::new.
# ================================================================
#must_use
fn naad_fdn_matrix_new(target_rt60, sample_rate, mix) {
    if (f64_le(target_rt60, 0) == 1) { return ERR_COMPUTATION; }
    if (naad_is_finite(target_rt60) == 0) { return ERR_COMPUTATION; }
    if (sample_rate == 0) { return ERR_COMPUTATION; }

    var sr = f64_from(sample_rate);

    # Delay lengths (samples) = (ms * 0.001 * sample_rate).max(1) as usize.
    var delay_lengths = vec_new();
    var i = 0;
    while (i < MATRIX_FDN_N) {
        var secs = f64_mul(_matrix_fdn_ms(i), FDN_MS_SCALE);
        var samples = f64_max(f64_mul(secs, sr), F64_ONE);
        vec_push(delay_lengths, f64_to(samples));
        i = i + 1;
    }

    # Damping gains: g_i = 10^(-3 * D_i / (RT60 * SR)) -> 60 dB per RT60.
    var damping_gain = vec_new();
    var rt_sr = f64_mul(target_rt60, sr);
    i = 0;
    while (i < MATRIX_FDN_N) {
        var d = f64_from(vec_get(delay_lengths, i));
        var expo = f64_div(f64_mul(f64_neg(f64_from(3)), d), rt_sr);
        vec_push(damping_gain, f64_pow(f64_from(10), expo));
        i = i + 1;
    }

    # Allocate ring buffers, cursors, and damping state.
    var buffers = vec_new();
    var positions = vec_new();
    var damping_state = vec_new();
    i = 0;
    while (i < MATRIX_FDN_N) {
        var len = vec_get(delay_lengths, i);
        var line = vec_new();
        var j = 0;
        while (j < len) {
            vec_push(line, 0);
            j = j + 1;
        }
        vec_push(buffers, line);
        vec_push(positions, 0);
        vec_push(damping_state, 0);
        i = i + 1;
    }

    # Per-instance scratch vecs (8 slots each), allocated ONCE here so the hot
    # process_sample path can overwrite them in place instead of allocating a
    # fresh result vec per sample (Cyrius bump allocator never frees).
    var scratch_delay = vec_new();
    var scratch_had = vec_new();
    i = 0;
    while (i < MATRIX_FDN_N) {
        vec_push(scratch_delay, 0);
        vec_push(scratch_had, 0);
        i = i + 1;
    }

    var self = alloc(sizeof(MatrixFdn));
    MatrixFdn_set_buffers(self, buffers);
    MatrixFdn_set_positions(self, positions);
    MatrixFdn_set_delay_lengths(self, delay_lengths);
    MatrixFdn_set_damping_state(self, damping_state);
    MatrixFdn_set_damping_gain(self, damping_gain);
    MatrixFdn_set_target_rt60(self, target_rt60);
    MatrixFdn_set_sample_rate(self, sample_rate);
    MatrixFdn_set_mix(self, f64_clamp(mix, 0, F64_ONE));
    MatrixFdn_set_scratch_delay(self, scratch_delay);
    MatrixFdn_set_scratch_had(self, scratch_had);
    return self;
}

# ================================================================
# naad_fdn_matrix_process_sample -- process one sample through the Hadamard
# FDN: read + damp every delay line, mix the damped vector by the normalised
# 8x8 Hadamard matrix, then write `input + feedback` back into each line.
# Output is the dry/wet mix of the input and the sum of damped outputs. Ports
# MatrixFdn::process_sample.
# ================================================================
#inline
#must_use
fn naad_fdn_matrix_process_sample(self, input) {
    var buffers = MatrixFdn_buffers(self);
    var positions = MatrixFdn_positions(self);
    var damping_gain = MatrixFdn_damping_gain(self);
    var damping_state = MatrixFdn_damping_state(self);

    var norm = f64_sqrt(f64_from(MATRIX_FDN_N));

    # Read delay-line outputs, apply per-line damping, accumulate the sum.
    # Reuse the struct-owned scratch (overwrite via vec_set) -- no per-sample
    # allocation.
    var delayed = MatrixFdn_scratch_delay(self);
    var wet_sum = 0;
    var i = 0;
    while (i < MATRIX_FDN_N) {
        var line = vec_get(buffers, i);
        var len = vec_len(line);
        var read_pos = (vec_get(positions, i) + 1) % len;
        var damped = f64_mul(vec_get(line, read_pos), vec_get(damping_gain, i));
        var slot = flush_denormal(damped);
        vec_set(delayed, i, slot);
        vec_set(damping_state, i, slot);
        wet_sum = f64_add(wet_sum, slot);
        i = i + 1;
    }

    # Output sum before writing feedback: sum / sqrt(N).
    var wet = f64_div(wet_sum, norm);

    # Apply the normalised Hadamard mix: y = (1/sqrt(N)) * H * x. Write into the
    # struct-owned Hadamard scratch instead of allocating a result vec.
    var h = MatrixFdn_scratch_had(self);
    _naad_fdn_hadamard8_into(delayed, h);
    var scale = f64_div(F64_ONE, norm);

    # Write input + scaled feedback into each line.
    i = 0;
    while (i < MATRIX_FDN_N) {
        var line = vec_get(buffers, i);
        var len = vec_len(line);
        var v = f64_add(input, f64_mul(vec_get(h, i), scale));
        var wp = (vec_get(positions, i) + 1) % len;
        vec_set(positions, i, wp);
        vec_set(line, wp, flush_denormal(v));
        i = i + 1;
    }

    var mix = MatrixFdn_mix(self);
    var dry = f64_sub(F64_ONE, mix);
    return f64_add(f64_mul(input, dry), f64_mul(wet, mix));
}

# ================================================================
# naad_fdn_matrix_process_buffer -- process a vec of samples in place. Ports
# MatrixFdn::process_buffer.
# ================================================================
fn naad_fdn_matrix_process_buffer(self, buffer) {
    var n = vec_len(buffer);
    var i = 0;
    while (i < n) {
        vec_set(buffer, i, naad_fdn_matrix_process_sample(self, vec_get(buffer, i)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# naad_fdn_matrix_reset -- clear all delay lines, cursors and damping state to
# silence. Ports MatrixFdn::reset.
# ================================================================
fn naad_fdn_matrix_reset(self) {
    var buffers = MatrixFdn_buffers(self);
    var positions = MatrixFdn_positions(self);
    var damping_state = MatrixFdn_damping_state(self);
    var i = 0;
    while (i < MATRIX_FDN_N) {
        var line = vec_get(buffers, i);
        var len = vec_len(line);
        var j = 0;
        while (j < len) {
            vec_set(line, j, 0);
            j = j + 1;
        }
        vec_set(positions, i, 0);
        vec_set(damping_state, i, 0);
        i = i + 1;
    }
    return 0;
}

# --- acoustics_binaural.cyr ---

# acoustics_binaural.cyr -- binaural HRTF spatialization wrapper over goonj.
#
# Ports rust-old/src/acoustics/binaural.rs. A thin wrapper: it builds a small
# concrete shoebox room plus a minimal direction-dependent HRTF dataset, calls
# goonj's generate_binaural_ir to obtain a stereo (left/right ear) impulse
# response, then convolves mono input into headphone-ready stereo via two ring
# buffers. f32 -> f64 throughout (hisab/goonj are f64-only). Rust's serde
# derives and the serde round-trip test are dropped (no serde in Cyrius). The
# `(f32, f32)` tuple returned by process_sample becomes a BinauralStereo struct
# (naad-distinct name; goonj owns BinauralIr/BinauralAngles/HrtfPair). Vec<f32>
# IRs and ring buffers become stdlib vecs (f64 stored directly). Result<Self>
# collapses to the struct pointer on success or ERR_COMPUTATION (sample_rate 0).
#
# Requires (from the build/test unit): lib/hisab.cyr (hvec3_new), lib/goonj.cyr
# (acoustic_room_shoebox, acoustic_material_concrete, ir_config_new,
# hrtf_pair_new, hrtf_dataset_from_pairs, generate_binaural_ir, BinauralIr_*,
# math constants F64_ONE/HALF/ONE_HALF/PI/PI_2, f64_*), src/error.cyr
# (ERR_COMPUTATION). No `include` lines.

# ================================================================
# Float literals (IEEE-754 bit patterns).
# ================================================================
var BIN_MAX_TIME   = 0x3fd3333333333333;   # 0.3  (IrConfig max_time_seconds)
var BIN_GAIN_FLOOR = 0x3fb999999999999a;   # 0.1  (minimum ear gain)
var BIN_DECAY_K    = 0x4008000000000000;   # 3.0  (HRIR decay rate; negated below)

# Fixed synthetic HRIR length (Rust `hrir_len = 32`).
var BIN_HRIR_LEN = 32;

# ================================================================
# BinauralStereo -- a (left, right) sample pair; replaces Rust's `(f32, f32)`
# tuple return from process_sample.
# ================================================================
#derive(accessors)
struct BinauralStereo { left; right; }

# ================================================================
# BinauralProcessor -- binaural HRTF processor for mono -> stereo spatialization.
#   left_ir / right_ir       : left/right ear impulse responses (vecs, dropped
#                              in Rust serde; regenerated by rebuild)
#   left_buffer / right_buffer : per-ear convolution ring buffers (vecs)
#   position                 : current write cursor into the ring buffers
#   sample_rate              : Hz
#   azimuth / elevation      : source direction the IRs were generated for (rad)
# ================================================================
#derive(accessors)
struct BinauralProcessor {
    left_ir;
    right_ir;
    left_buffer;
    right_buffer;
    position;
    sample_rate;
    azimuth;
    elevation;
}

# ================================================================
# naad_binaural_make_pair -- build one synthetic HrtfPair for direction
# (az, el). Interaural level difference derives from sin(az); a simple
# exponential decay shapes the impulse. Mirrors the `make_pair` closure.
# ================================================================
#must_use
fn naad_binaural_make_pair(az, el) {
    var half_sin = f64_mul(f64_sin(az), F64_HALF);
    var left_gain = f64_max(f64_sub(F64_ONE, half_sin), BIN_GAIN_FLOOR);
    var right_gain = f64_max(f64_add(F64_ONE, half_sin), BIN_GAIN_FLOOR);
    var neg_k = f64_neg(BIN_DECAY_K);

    var left = vec_new();
    var right = vec_new();
    var i = 0;
    while (i < BIN_HRIR_LEN) {
        var decay = f64_exp(f64_div(f64_mul(neg_k, f64_from(i)), f64_from(BIN_HRIR_LEN)));
        vec_push(left, f64_mul(left_gain, decay));
        vec_push(right, f64_mul(right_gain, decay));
        i = i + 1;
    }
    return hrtf_pair_new(az, el, left, right);
}

# ================================================================
# naad_binaural_build_minimal_hrtf -- assemble the minimal HRTF dataset:
# front, right (+π/2), left (-π/2), back (π), and the requested direction.
# Mirrors `build_minimal_hrtf`.
# ================================================================
#must_use
fn naad_binaural_build_minimal_hrtf(azimuth, elevation, sample_rate) {
    var pairs = vec_new();
    vec_push(pairs, naad_binaural_make_pair(f64_from(0), f64_from(0)));
    vec_push(pairs, naad_binaural_make_pair(F64_PI_2, f64_from(0)));
    vec_push(pairs, naad_binaural_make_pair(f64_neg(F64_PI_2), f64_from(0)));
    vec_push(pairs, naad_binaural_make_pair(F64_PI, f64_from(0)));
    vec_push(pairs, naad_binaural_make_pair(azimuth, elevation));
    return hrtf_dataset_from_pairs(pairs, sample_rate);
}

# ================================================================
# naad_binaural_new -- create a binaural processor for a source direction.
# Builds a 6x4x3 concrete shoebox, a minimal HRTF dataset, and generates the
# stereo IR via goonj. Returns the struct pointer on success or ERR_COMPUTATION
# when sample_rate is 0. Ports BinauralProcessor::new.
# ================================================================
#must_use
fn naad_binaural_new(azimuth, elevation, sample_rate) {
    if (sample_rate == 0) { return ERR_COMPUTATION; }

    var room = acoustic_room_shoebox(
    f64_from(6), f64_from(4), f64_from(3), acoustic_material_concrete());
    var source = hvec3_new(f64_from(2), F64_ONE_HALF, f64_from(2));
    var listener = hvec3_new(f64_from(4), F64_ONE_HALF, f64_from(2));

    var hrtf = naad_binaural_build_minimal_hrtf(azimuth, elevation, sample_rate);
    var ir_config = ir_config_new(sample_rate, 2, 500, 20, BIN_MAX_TIME, 42);
    var binaural = generate_binaural_ir(source, listener, room, hrtf, ir_config);

    var left_ir = BinauralIr_left(binaural);
    var right_ir = BinauralIr_right(binaural);
    var ir_len = vec_len(left_ir);
    if (vec_len(right_ir) > ir_len) { ir_len = vec_len(right_ir); }
    if (ir_len < 1) { ir_len = 1; }

    var left_buffer = vec_new();
    var right_buffer = vec_new();
    var i = 0;
    while (i < ir_len) {
        vec_push(left_buffer, 0);
        vec_push(right_buffer, 0);
        i = i + 1;
    }

    var self = alloc(sizeof(BinauralProcessor));
    BinauralProcessor_set_left_ir(self, left_ir);
    BinauralProcessor_set_right_ir(self, right_ir);
    BinauralProcessor_set_left_buffer(self, left_buffer);
    BinauralProcessor_set_right_buffer(self, right_buffer);
    BinauralProcessor_set_position(self, 0);
    BinauralProcessor_set_sample_rate(self, sample_rate);
    BinauralProcessor_set_azimuth(self, azimuth);
    BinauralProcessor_set_elevation(self, elevation);
    return self;
}

# ================================================================
# naad_binaural_process_sample -- process a mono `input` into stereo (left,
# right) as a BinauralStereo. Time-domain convolution against each ear IR via
# the ring buffers. Ports BinauralProcessor::process_sample.
# ================================================================
#inline
#must_use
fn naad_binaural_process_sample(self, input) {
    var left_ir = BinauralProcessor_left_ir(self);
    var right_ir = BinauralProcessor_right_ir(self);
    var left_len = vec_len(left_ir);
    var right_len = vec_len(right_ir);

    var res = alloc(sizeof(BinauralStereo));
    if (left_len == 0 && right_len == 0) {
        BinauralStereo_set_left(res, input);
        BinauralStereo_set_right(res, input);
        return res;
    }

    var left_buffer = BinauralProcessor_left_buffer(self);
    var right_buffer = BinauralProcessor_right_buffer(self);
    var buf_len = vec_len(left_buffer);
    if (buf_len == 0) {
        BinauralStereo_set_left(res, input);
        BinauralStereo_set_right(res, input);
        return res;
    }

    var position = BinauralProcessor_position(self);
    vec_set(left_buffer, position, input);
    vec_set(right_buffer, position, input);

    var left_out = 0;
    var k = 0;
    while (k < left_len) {
        var lidx = position + buf_len - k;
        lidx = lidx % buf_len;
        left_out = f64_add(left_out, f64_mul(vec_get(left_buffer, lidx), vec_get(left_ir, k)));
        k = k + 1;
    }

    var right_out = 0;
    k = 0;
    while (k < right_len) {
        var ridx = position + buf_len - k;
        ridx = ridx % buf_len;
        right_out = f64_add(right_out, f64_mul(vec_get(right_buffer, ridx), vec_get(right_ir, k)));
        k = k + 1;
    }

    var next = position + 1;
    next = next % buf_len;
    BinauralProcessor_set_position(self, next);

    BinauralStereo_set_left(res, left_out);
    BinauralStereo_set_right(res, right_out);
    return res;
}

# ================================================================
# naad_binaural_rebuild -- regenerate IRs and buffers from the stored
# azimuth/elevation/sample_rate (IRs are transient across a serde boundary in
# Rust). Returns ERR_NONE on success or a negative ERR_* if regeneration fails.
# Ports BinauralProcessor::rebuild.
# ================================================================
#must_use
fn naad_binaural_rebuild(self) {
    var fresh = naad_binaural_new(
    BinauralProcessor_azimuth(self), BinauralProcessor_elevation(self),
    BinauralProcessor_sample_rate(self));
    if (naad_is_err(fresh) == 1) { return fresh; }
    BinauralProcessor_set_left_ir(self, BinauralProcessor_left_ir(fresh));
    BinauralProcessor_set_right_ir(self, BinauralProcessor_right_ir(fresh));
    BinauralProcessor_set_left_buffer(self, BinauralProcessor_left_buffer(fresh));
    BinauralProcessor_set_right_buffer(self, BinauralProcessor_right_buffer(fresh));
    BinauralProcessor_set_position(self, 0);
    return ERR_NONE;
}

# ================================================================
# naad_binaural_is_loaded -- 1 if the processor holds a non-empty left IR
# (false only after a serde-style reset). Ports BinauralProcessor::is_loaded.
# ================================================================
#must_use
fn naad_binaural_is_loaded(self) {
    if (vec_len(BinauralProcessor_left_ir(self)) > 0) { return 1; }
    return 0;
}

# --- acoustics_analysis.cyr ---

# acoustics_analysis.cyr -- naad acoustic-analysis metrics (thin goonj wrapper).
#
# Ports rust-old/src/acoustics/analysis.rs. Wraps goonj's ISO 3382-1 analysis
# functions to compute room acoustic metrics from an impulse response: clarity
# (C50, C80), definition (D50), speech transmission index (STI), and a quick
# Sabine-style reverberation-time (RT60) estimate. Also wraps goonj's
# absorption-placement advisor to recommend which walls to treat. f32 -> f64
# throughout. Rust's serde derives and the serde round-trip tests are dropped.
#
# Cross-crate goonj mapping (discovered from lib/goonj.cyr + goonj src/tests):
#   goonj::impulse::ImpulseResponse{..}       -> impulse_response_new(samples,
#                                                            sample_rate, rt60)
#   goonj::analysis::clarity_c50              -> clarity_c50(ir)
#   goonj::analysis::clarity_c80              -> clarity_c80(ir)
#   goonj::analysis::definition_d50           -> definition_d50(ir)
#   goonj::analysis::sti_estimate             -> sti_estimate(ir)
#   goonj::room::AcousticRoom::shoebox        -> acoustic_room_shoebox(l,w,h,mat)
#   goonj::analysis::suggest_absorption_placement
#                                             -> suggest_absorption_placement(
#                                                            room, target_rt60)
#   AbsorptionSuggestion.{wall_index,rt60_sensitivity,current_absorption}
#                                             -> AbsorptionSuggestion_* accessors
# The wall material name resolves through naad_acoustics_material_by_name
# (src/acoustics.cyr) and the RoomReverbConfig struct + accessors come from
# src/acoustics_room.cyr (reused, not redefined). Rust's Result<T> maps to:
# a positive struct/vec pointer on success, or a negative ERR_COMPUTATION on
# empty IR / zero sample rate / unknown material / non-positive dimensions.
#
# Requires (from the build/test unit): stdlib alloc/vec + math/ganita (F64_TWO,
# f64_add/sub/mul/div/neg/exp, f64_from/to, f64_lt/le/ge), the goonj bundle
# (impulse_response_new, clarity_c50/c80, definition_d50, sti_estimate,
# acoustic_room_shoebox, suggest_absorption_placement, AbsorptionSuggestion_*),
# and the naad L0 modules error.cyr (ERR_COMPUTATION, NAAD_EPSILON) +
# acoustics.cyr (naad_acoustics_material_by_name) + acoustics_room.cyr
# (RoomReverbConfig accessors). This file has no `include` lines.

# 0.001 -- energy-decay threshold ratio for the RT60 estimate (-30 dB point).
var NAAD_RT60_THRESHOLD = 0x3F50624DD2F1A9FC;

# ================================================================
# RoomMetrics -- room acoustic metrics computed from an impulse response.
#   c50  : clarity C50 in dB -- early (0-50 ms) to late energy ratio
#   c80  : clarity C80 in dB -- early (0-80 ms) to late energy ratio
#   d50  : definition D50 -- fraction of energy in first 50 ms (0..1)
#   sti  : speech transmission index (0..1)
#   rt60 : reverberation time RT60 in seconds
# ================================================================
#derive(accessors)
struct RoomMetrics {
    c50;
    c80;
    d50;
    sti;
    rt60;
}

# Build a RoomMetrics. Ports the Rust struct literal.
#must_use
fn naad_analysis_room_metrics_new(c50, c80, d50, sti, rt60) {
    var m = alloc(sizeof(RoomMetrics));
    RoomMetrics_set_c50(m, c50);
    RoomMetrics_set_c80(m, c80);
    RoomMetrics_set_d50(m, d50);
    RoomMetrics_set_sti(m, sti);
    RoomMetrics_set_rt60(m, rt60);
    return m;
}

# ================================================================
# naad_analysis_estimate_rt60 -- quick RT60 estimate from an impulse response
# via its energy-decay curve. Finds the time at which cumulative energy is
# within 0.001 of the total (the -30 dB point) and doubles it for the RT60
# estimate; falls back to the full IR length. Empty IR or zero sample rate ->
# 0.0; near-silent IR (< f32::EPSILON total energy) -> 0.0. `ir` is a vec of
# f64 samples, `sample_rate` an integer in Hz. Ports estimate_rt60.
# ================================================================
#inline
#must_use
fn naad_analysis_estimate_rt60(ir, sample_rate) {
    var n = vec_len(ir);
    if (n == 0) { return 0; }
    if (sample_rate == 0) { return 0; }

    # Total energy of the impulse response.
    var total_energy = 0;
    var j = 0;
    while (j < n) {
        var s = vec_get(ir, j);
        total_energy = f64_add(total_energy, f64_mul(s, s));
        j = j + 1;
    }
    if (f64_lt(total_energy, NAAD_EPSILON) == 1) { return 0; }

    var cumulative = 0;
    var threshold = f64_mul(total_energy, NAAD_RT60_THRESHOLD);
    var i = 0;
    while (i < n) {
        var s = vec_get(ir, i);
        cumulative = f64_add(cumulative, f64_mul(s, s));
        if (f64_ge(cumulative, f64_sub(total_energy, threshold)) == 1) {
            # Time to reach -30 dB, doubled for the RT60 estimate.
            var t30 = f64_div(f64_from(i), f64_from(sample_rate));
            return f64_mul(t30, F64_TWO);
        }
        i = i + 1;
    }

    # Fallback: use the full IR length as an upper bound.
    return f64_div(f64_from(n), f64_from(sample_rate));
}

# ================================================================
# naad_analysis_analyze_impulse_response -- analyze an impulse response and
# compute the full RoomMetrics set (C50/C80/D50/STI/RT60). Builds a goonj
# ImpulseResponse from the sample vec then feeds each goonj analysis metric;
# RT60 uses naad's own energy-decay estimate. Returns the RoomMetrics pointer
# on success, or a negative ERR_COMPUTATION if the IR is empty or the sample
# rate is zero. `ir` is a vec of f64 samples, `sample_rate` an integer in Hz.
# Ports analyze_impulse_response.
# ================================================================
#must_use
fn naad_analysis_analyze_impulse_response(ir, sample_rate) {
    if (vec_len(ir) == 0) { return ERR_COMPUTATION; }
    if (sample_rate == 0) { return ERR_COMPUTATION; }

    # rt60 field is 0.0 here -- the analysis metrics do not read it.
    var goonj_ir = impulse_response_new(ir, sample_rate, 0);

    var c50 = clarity_c50(goonj_ir);
    var c80 = clarity_c80(goonj_ir);
    var d50 = definition_d50(goonj_ir);
    var sti = sti_estimate(goonj_ir);
    var rt60 = naad_analysis_estimate_rt60(ir, sample_rate);

    return naad_analysis_room_metrics_new(c50, c80, d50, sti, rt60);
}

# ================================================================
# WallAbsorptionAdvice -- one wall's contribution to RT60 if its absorption is
# increased.
#   wall_index         : wall index in the shoebox geometry (0 = floor,
#                        1 = ceiling, 2-5 = side walls)
#   rt60_sensitivity   : change in RT60 (seconds) per unit absorption bump on
#                        this wall (negative shortens reverb -- the desirable
#                        case for taming a live room)
#   current_absorption : current average absorption of this wall (0 = perfectly
#                        reflective, 1 = perfectly absorptive)
# ================================================================
#derive(accessors)
struct WallAbsorptionAdvice {
    wall_index;
    rt60_sensitivity;
    current_absorption;
}

# Build a WallAbsorptionAdvice. Ports the Rust struct literal.
#must_use
fn naad_analysis_wall_absorption_advice_new(wall_index, rt60_sensitivity, current_absorption) {
    var a = alloc(sizeof(WallAbsorptionAdvice));
    WallAbsorptionAdvice_set_wall_index(a, wall_index);
    WallAbsorptionAdvice_set_rt60_sensitivity(a, rt60_sensitivity);
    WallAbsorptionAdvice_set_current_absorption(a, current_absorption);
    return a;
}

# ================================================================
# naad_analysis_suggest_absorption -- recommend acoustic treatment placement to
# bring a virtual room toward a target RT60. Builds a goonj shoebox AcousticRoom
# from `config`, asks goonj which walls most affect reverb time if their
# absorption is increased, then maps the goonj AbsorptionSuggestions into naad
# WallAbsorptionAdvice records. Returns the advice vec (sorted most-impactful
# first, matching goonj) on success, or a negative ERR_COMPUTATION if the wall
# material name is unknown or the room dimensions are non-positive.
# Ports suggest_absorption.
# ================================================================
#must_use
fn naad_analysis_suggest_absorption(config, target_rt60) {
    var material = naad_acoustics_material_by_name(RoomReverbConfig_wall_material_name(config));
    if (material == 0) { return ERR_COMPUTATION; }

    if (f64_le(RoomReverbConfig_length(config), 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(RoomReverbConfig_width(config), 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(RoomReverbConfig_height(config), 0) == 1) { return ERR_COMPUTATION; }

    var room = acoustic_room_shoebox(RoomReverbConfig_length(config),
    RoomReverbConfig_width(config), RoomReverbConfig_height(config), material);
    var suggestions = suggest_absorption_placement(room, target_rt60);

    var advice = vec_new();
    var n = vec_len(suggestions);
    var i = 0;
    while (i < n) {
        var s = vec_get(suggestions, i);
        vec_push(advice, naad_analysis_wall_absorption_advice_new(
        AbsorptionSuggestion_wall_index(s),
        AbsorptionSuggestion_rt60_sensitivity(s),
        AbsorptionSuggestion_current_absorption(s)));
        i = i + 1;
    }
    return advice;
}

# --- acoustics_convolution.cyr ---

# acoustics_convolution.cyr -- naad convolution reverb (thin goonj wrapper).
#
# Ports rust-old/src/acoustics/convolution.rs. Applies a pre-computed impulse
# response to an audio stream via direct time-domain convolution (per sample)
# or FFT convolution (per block, through hisab num_fft/num_ifft). An IR can be
# supplied raw or generated from a goonj shoebox-room simulation. f32 -> f64
# throughout. Rust's serde derives and the reusable Complex scratch vectors are
# dropped -- process_block allocates its interleaved complex buffers per call,
# which is behaviourally identical.
#
# Cross-crate mapping (discovered from lib/goonj.cyr + goonj src/tests, and
# reused from the already-green src/acoustics_room.cyr wrapper):
#   goonj::room::AcousticRoom::shoebox   -> acoustic_room_shoebox(l, w, h, mat)
#   goonj::impulse::IrConfig{..}         -> ir_config_new(rate, order, rays,
#                                                          bounces, secs, seed)
#   goonj::impulse::generate_ir          -> generate_ir(src, lis, room, cfg)
#   MultibandIr::to_broadband            -> multiband_ir_to_broadband(mi)
#   ImpulseResponse.samples              -> ImpulseResponse_samples(ir)
#   hisab::Vec3::new                     -> hvec3_new (config already stores it)
#   hisab::Complex + hisab::num::fft/ifft-> num_fft/num_ifft over an interleaved
#                                           complex buffer alloc(n*16): re at
#                                           +i*16, im at +i*16+8.
# The wall material name resolves through naad_acoustics_material_by_name
# (src/acoustics.cyr). Result<Self> -> struct pointer on success, or a negative
# ERR_COMPUTATION on unknown material / non-positive dimensions. Reuses
# RoomReverbConfig + its accessors from src/acoustics_room.cyr. No `include`.

# ================================================================
# ConvolutionReverb -- convolution reverb processor.
#   ir            : impulse-response samples (vec of f64, may be empty)
#   input_buffer  : ring-buffer of recent inputs (len == max(ir_len, 1))
#   position      : current write position in the ring buffer
#   mix           : wet/dry mix in [0, 1] (0 = fully dry, 1 = fully wet)
# The Rust scratch_ir / scratch_in / scratch_product Complex vectors are a
# performance cache only; the Cyrius port allocates them per process_block.
# ================================================================
#derive(accessors)
struct ConvolutionReverb {
    ir;
    input_buffer;
    position;
    mix;
}

# ================================================================
# naad_convolution_from_ir -- create a convolution reverb from a raw impulse
# response `ir` (vec of f64) and a `mix` clamped to [0, 1]. The input ring
# buffer is sized to max(ir_len, 1) and zero-filled. Ports ConvolutionReverb::
# from_ir.
# ================================================================
#must_use
fn naad_convolution_from_ir(ir, mix) {
    var ir_len = vec_len(ir);
    var buf_len = ir_len;
    if (buf_len < 1) { buf_len = 1; }

    var input_buffer = vec_new();
    var i = 0;
    while (i < buf_len) {
        vec_push(input_buffer, 0);
        i = i + 1;
    }

    var self = alloc(sizeof(ConvolutionReverb));
    ConvolutionReverb_set_ir(self, ir);
    ConvolutionReverb_set_input_buffer(self, input_buffer);
    ConvolutionReverb_set_position(self, 0);
    ConvolutionReverb_set_mix(self, f64_clamp(mix, 0, F64_ONE));
    return self;
}

# ================================================================
# naad_convolution_from_room -- create a convolution reverb from a goonj room
# simulation. Builds a shoebox room, generates a broadband impulse response via
# image-source + diffuse rain (order 3, 2000 diffuse rays, 30 bounces, 1.0 s,
# seed 42 -- the Rust IrConfig literal), and loads it fully wet (mix 1.0).
# Returns the struct pointer on success, or a negative ERR_COMPUTATION if the
# wall material name is unknown or the room dimensions are not positive.
# Ports ConvolutionReverb::from_room. Reuses RoomReverbConfig from
# src/acoustics_room.cyr.
# ================================================================
#must_use
fn naad_convolution_from_room(config) {
    var material = naad_acoustics_material_by_name(RoomReverbConfig_wall_material_name(config));
    if (material == 0) { return ERR_COMPUTATION; }

    if (f64_le(RoomReverbConfig_length(config), 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(RoomReverbConfig_width(config), 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(RoomReverbConfig_height(config), 0) == 1) { return ERR_COMPUTATION; }

    var room = acoustic_room_shoebox(RoomReverbConfig_length(config),
    RoomReverbConfig_width(config), RoomReverbConfig_height(config), material);

    var source = RoomReverbConfig_source_position(config);
    var listener = RoomReverbConfig_listener_position(config);

    var ir_config = ir_config_new(RoomReverbConfig_sample_rate(config), 3, 2000, 30, F64_ONE, 42);

    var multiband = generate_ir(source, listener, room, ir_config);
    var broadband = multiband_ir_to_broadband(multiband);
    var ir = ImpulseResponse_samples(broadband);

    return naad_convolution_from_ir(ir, F64_ONE);
}

# ================================================================
# naad_convolution_process_sample -- process a single audio sample via direct
# time-domain convolution with the stored impulse response, returning a mix of
# dry input and wet convolved output. An empty IR passes the input through
# unchanged. Ports ConvolutionReverb::process_sample.
# ================================================================
#inline
#must_use
fn naad_convolution_process_sample(self, input) {
    var ir = ConvolutionReverb_ir(self);
    var ir_len = vec_len(ir);
    if (ir_len == 0) { return input; }

    var buf = ConvolutionReverb_input_buffer(self);
    var pos = ConvolutionReverb_position(self);
    vec_set(buf, pos, input);

    # wet = sum(input_buffer[(pos + ir_len - k) % ir_len] * ir[k]).
    var wet = 0;
    var k = 0;
    while (k < ir_len) {
        var idx_raw = pos + ir_len - k;
        var idx = idx_raw % ir_len;
        wet = f64_add(wet, f64_mul(vec_get(buf, idx), vec_get(ir, k)));
        k = k + 1;
    }

    var nextp = pos + 1;
    var np = nextp % ir_len;
    ConvolutionReverb_set_position(self, np);

    # input * (1 - mix) + wet * mix.
    var mix = ConvolutionReverb_mix(self);
    var dry = f64_sub(F64_ONE, mix);
    return f64_add(f64_mul(input, dry), f64_mul(wet, mix));
}

# ================================================================
# naad_convolution_passthrough -- copy min(len(input), len(output)) samples
# from input to output. Mirrors the zipped dry-copy fallback the Rust
# process_block takes when the IR is empty or the input block is empty.
# ================================================================
fn naad_convolution_passthrough(input, output) {
    var n_in = vec_len(input);
    var n_out = vec_len(output);
    var limit = n_in;
    if (n_out < limit) { limit = n_out; }
    var i = 0;
    while (i < limit) {
        vec_set(output, i, vec_get(input, i));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# naad_convolution_process_block_direct -- direct per-sample fallback used when
# an FFT reports failure: writes process_sample(input[i]) into output[i] for
# min(len(input), len(output)) samples. Mirrors Rust's zipped process_sample
# fallback.
# ================================================================
fn naad_convolution_process_block_direct(self, input, output) {
    var n_in = vec_len(input);
    var n_out = vec_len(output);
    var limit = n_in;
    if (n_out < limit) { limit = n_out; }
    var i = 0;
    while (i < limit) {
        vec_set(output, i, naad_convolution_process_sample(self, vec_get(input, i)));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# naad_convolution_next_pow2 -- smallest power of two >= v (>= 1 for v <= 1).
# Ports usize::next_power_of_two for the FFT sizing.
# ================================================================
#must_use
fn naad_convolution_next_pow2(v) {
    var p = 1;
    while (p < v) { p = p << 1; }
    return p;
}

# ================================================================
# naad_convolution_process_block -- process a block of samples through FFT-based
# linear convolution (hisab num_fft / num_ifft), writing the wet/dry mix into
# `output`. Both `input` and `output` are vec handles; up to min(len) samples
# are written. An empty IR or empty input block copies the dry signal through.
# On (never-reached, size is always a power of two) FFT failure it falls back to
# direct per-sample convolution. Ports ConvolutionReverb::process_block.
#
# The IR (zero-padded) and the input block (zero-padded) are transformed to the
# frequency domain, multiplied pointwise, and inverse-transformed; the first
# block_len real parts form the wet signal. FFT length is the next power of two
# >= ir_len + block_len - 1 so the circular convolution equals the linear one.
# ================================================================
fn naad_convolution_process_block(self, input, output) {
    var ir = ConvolutionReverb_ir(self);
    var ir_len = vec_len(ir);
    var block_len = vec_len(input);
    if (ir_len == 0) { return naad_convolution_passthrough(input, output); }
    if (block_len == 0) { return naad_convolution_passthrough(input, output); }

    var span = ir_len + block_len - 1;
    var fft_len = naad_convolution_next_pow2(span);

    # Interleaved complex scratch: re at +i*16, im at +i*16+8.
    var ir_buf = alloc(fft_len * 16);
    var in_buf = alloc(fft_len * 16);

    # IR -> ir_buf (real = sample for i < ir_len, else 0; im = 0).
    var i = 0;
    while (i < fft_len) {
        var re = 0;
        if (i < ir_len) { re = vec_get(ir, i); }
        store64(ir_buf + i * 16, re);
        store64(ir_buf + i * 16 + 8, 0);
        i = i + 1;
    }

    # input block -> in_buf (real = sample for i < block_len, else 0; im = 0).
    var j = 0;
    while (j < fft_len) {
        var re2 = 0;
        if (j < block_len) { re2 = vec_get(input, j); }
        store64(in_buf + j * 16, re2);
        store64(in_buf + j * 16 + 8, 0);
        j = j + 1;
    }

    # Forward FFT both. Fall back to direct convolution on failure.
    var e1 = num_fft(ir_buf, fft_len);
    if (e1 != 0) { return naad_convolution_process_block_direct(self, input, output); }
    var e2 = num_fft(in_buf, fft_len);
    if (e2 != 0) { return naad_convolution_process_block_direct(self, input, output); }

    # Pointwise multiply in the frequency domain into prod.
    var prod = alloc(fft_len * 16);
    var m = 0;
    while (m < fft_len) {
        var ar = load64(ir_buf + m * 16);
        var ai = load64(ir_buf + m * 16 + 8);
        var br = load64(in_buf + m * 16);
        var bi = load64(in_buf + m * 16 + 8);
        # (ar+ai i)(br+bi i) = (ar*br - ai*bi) + (ar*bi + ai*br) i.
        var pr = f64_sub(f64_mul(ar, br), f64_mul(ai, bi));
        var pi = f64_add(f64_mul(ar, bi), f64_mul(ai, br));
        store64(prod + m * 16, pr);
        store64(prod + m * 16 + 8, pi);
        m = m + 1;
    }

    # Inverse FFT. Fall back to direct convolution on failure.
    var e3 = num_ifft(prod, fft_len);
    if (e3 != 0) { return naad_convolution_process_block_direct(self, input, output); }

    # Extract the real part and apply the mix over the block.
    var mix = ConvolutionReverb_mix(self);
    var dry = f64_sub(F64_ONE, mix);
    var n_out = vec_len(output);
    var limit = block_len;
    if (n_out < limit) { limit = n_out; }
    var o = 0;
    while (o < limit) {
        var wet = load64(prod + o * 16);
        var inp = vec_get(input, o);
        vec_set(output, o, f64_add(f64_mul(inp, dry), f64_mul(wet, mix)));
        o = o + 1;
    }
    return 0;
}

# ================================================================
# naad_convolution_rebuild_from_ir -- replace the IR (e.g. after a serde-free
# restore), resizing and zeroing the input ring buffer and resetting position.
# The Rust FFT scratch is dropped in this port, so there is nothing to clear.
# Ports ConvolutionReverb::rebuild_from_ir.
# ================================================================
fn naad_convolution_rebuild_from_ir(self, ir) {
    var ir_len = vec_len(ir);
    var buf_len = ir_len;
    if (buf_len < 1) { buf_len = 1; }

    var input_buffer = vec_new();
    var i = 0;
    while (i < buf_len) {
        vec_push(input_buffer, 0);
        i = i + 1;
    }

    ConvolutionReverb_set_input_buffer(self, input_buffer);
    ConvolutionReverb_set_position(self, 0);
    ConvolutionReverb_set_ir(self, ir);
    return 0;
}

# ================================================================
# naad_convolution_ir_len -- length of the impulse response in samples.
# Ports ConvolutionReverb::ir_len.
# ================================================================
#must_use
fn naad_convolution_ir_len(self) {
    return vec_len(ConvolutionReverb_ir(self));
}

# ================================================================
# naad_convolution_is_loaded -- 1 if an IR is loaded, 0 otherwise (false after
# a serde-free restore). Ports ConvolutionReverb::is_loaded.
# ================================================================
#must_use
fn naad_convolution_is_loaded(self) {
    if (vec_len(ConvolutionReverb_ir(self)) == 0) { return 0; }
    return 1;
}

# --- acoustics_coupled.cyr ---

# acoustics_coupled.cyr -- naad coupled-room decay analysis (goonj wrapper).
#
# Ports rust-old/src/acoustics/coupled.rs. Wraps goonj's coupled-rooms
# simulation: two acoustic spaces joined by a portal (e.g. live room <->
# control room, stage <-> audience). The combined decay is *not* a single
# exponential -- energy in the smaller, more absorptive room decays first
# ("early"), then is sustained by spillover from the larger / more
# reverberant room ("late"), giving the characteristic double-slope decay
# of coupled-volume halls and cathedrals with reverberant side chapels.
# f32 -> f64 throughout. Rust's serde derives are dropped.
#
# Cross-crate goonj mapping (discovered from lib/goonj.cyr + goonj src/tests):
#   goonj::portal::Portal{..}          -> portal_new(pos, normal, w, h)
#   goonj::room::AcousticRoom::shoebox -> acoustic_room_shoebox(l, w, h, mat)
#   goonj::coupled::CoupledRooms{..}    -> CoupledRooms struct + CoupledRooms_set_*
#   goonj::coupled::coupled_room_decay  -> coupled_room_decay(coupled)
#   goonj::coupled::CoupledDecay.<f>    -> CoupledDecay_rt60_early/rt60_late/
#                                          early_amplitude/coupling_strength
#   hisab::Vec3::new                    -> hvec3_new(x, y, z)  (positions/normals)
# The wall material name resolves through naad_acoustics_material_by_name
# (src/acoustics.cyr); the room config reuses RoomReverbConfig from
# src/acoustics_room.cyr. Result<Self> -> struct pointer on success or a
# negative ERR_COMPUTATION on unknown material / non-positive dimensions.
#
# Requires (from the build/test unit): stdlib alloc + math (f64_le), hisab
# (hvec3_new), the goonj bundle (portal_new, acoustic_room_shoebox,
# CoupledRooms, coupled_room_decay, CoupledDecay_*), and the naad L0 modules
# error.cyr (ERR_COMPUTATION, naad_is_err) + acoustics.cyr
# (naad_acoustics_material_by_name) + acoustics_room.cyr (RoomReverbConfig_*).
# This file has no `include` lines.

# ================================================================
# CoupledPortal -- a portal opening connecting two rooms.
#   position: centre of the opening, HVec3 [x, y, z] in metres
#             (in room_a's coordinate frame)
#   normal  : direction HVec3 [x, y, z] (unit-ish), pointing from room_a
#             into room_b
#   width   : opening width in metres
#   height  : opening height in metres
# The Rust `[f32; 3]` position/normal arrays map to hisab HVec3 points.
# ================================================================
#derive(accessors)
struct CoupledPortal {
    position;
    normal;
    width;
    height;
}

# Build a CoupledPortal. `position` / `normal` are HVec3 pointers
# (hvec3_new). Ports the Rust struct literal.
#must_use
fn naad_coupled_portal_new(position, normal, width, height) {
    var p = alloc(sizeof(CoupledPortal));
    CoupledPortal_set_position(p, position);
    CoupledPortal_set_normal(p, normal);
    CoupledPortal_set_width(p, width);
    CoupledPortal_set_height(p, height);
    return p;
}

# ================================================================
# CoupledRoomConfig -- configuration for a two-room coupled-decay sim.
#   room_a: the first (typically smaller / more absorptive) room config
#   room_b: the second (typically larger / more reverberant) room config
#   portal: CoupledPortal connecting the two rooms
# room_a / room_b are naad RoomReverbConfig pointers (src/acoustics_room.cyr).
# ================================================================
#derive(accessors)
struct CoupledRoomConfig {
    room_a;
    room_b;
    portal;
}

# Build a CoupledRoomConfig. Ports the Rust struct literal.
#must_use
fn naad_coupled_room_config_new(room_a, room_b, portal) {
    var c = alloc(sizeof(CoupledRoomConfig));
    CoupledRoomConfig_set_room_a(c, room_a);
    CoupledRoomConfig_set_room_b(c, room_b);
    CoupledRoomConfig_set_portal(c, portal);
    return c;
}

# ================================================================
# CoupledDecayResult -- result of a coupled-decay analysis. Two RT60
# values describe the double-slope: rt60_early is the initial fast decay
# (energy escaping through the portal + absorbed by the first room),
# rt60_late the slower tail sustained by spillover. early_amplitude is the
# relative amplitude of the early component (0..1); coupling_strength
# summarises how strongly the rooms exchange energy (0 = isolated,
# 1 = fully coupled).
# ================================================================
#derive(accessors)
struct CoupledDecayResult {
    rt60_early;
    rt60_late;
    early_amplitude;
    coupling_strength;
}

# ================================================================
# naad_coupled_build_room -- build a goonj AcousticRoom from a naad
# RoomReverbConfig. Returns the room pointer on success, or a negative
# ERR_COMPUTATION if the wall material name is unknown or the room
# dimensions are not positive. Ports the private `build_room` helper.
# ================================================================
#must_use
fn naad_coupled_build_room(config) {
    var material = naad_acoustics_material_by_name(RoomReverbConfig_wall_material_name(config));
    if (material == 0) { return ERR_COMPUTATION; }

    if (f64_le(RoomReverbConfig_length(config), 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(RoomReverbConfig_width(config), 0) == 1) { return ERR_COMPUTATION; }
    if (f64_le(RoomReverbConfig_height(config), 0) == 1) { return ERR_COMPUTATION; }

    return acoustic_room_shoebox(RoomReverbConfig_length(config),
    RoomReverbConfig_width(config), RoomReverbConfig_height(config), material);
}

# ================================================================
# naad_coupled_analyze_decay -- run the coupled-decay analysis for a
# two-room configuration. Builds the underlying goonj rooms + portal, then
# asks goonj for the double-slope decay parameters. Returns the
# CoupledDecayResult pointer on success, or a negative ERR_COMPUTATION if
# either room's material name is unknown or any room dimension is
# non-positive. Ports `analyze_coupled_decay`.
# ================================================================
#must_use
fn naad_coupled_analyze_decay(config) {
    var room_a = naad_coupled_build_room(CoupledRoomConfig_room_a(config));
    if (naad_is_err(room_a) == 1) { return ERR_COMPUTATION; }
    var room_b = naad_coupled_build_room(CoupledRoomConfig_room_b(config));
    if (naad_is_err(room_b) == 1) { return ERR_COMPUTATION; }

    var np = CoupledRoomConfig_portal(config);
    var portal = portal_new(CoupledPortal_position(np), CoupledPortal_normal(np),
    CoupledPortal_width(np), CoupledPortal_height(np));

    var coupled = alloc(sizeof(CoupledRooms));
    CoupledRooms_set_room_a(coupled, room_a);
    CoupledRooms_set_room_b(coupled, room_b);
    CoupledRooms_set_portal(coupled, portal);

    var decay = coupled_room_decay(coupled);

    var out = alloc(sizeof(CoupledDecayResult));
    CoupledDecayResult_set_rt60_early(out, CoupledDecay_rt60_early(decay));
    CoupledDecayResult_set_rt60_late(out, CoupledDecay_rt60_late(decay));
    CoupledDecayResult_set_early_amplitude(out, CoupledDecay_early_amplitude(decay));
    CoupledDecayResult_set_coupling_strength(out, CoupledDecay_coupling_strength(decay));
    return out;
}
