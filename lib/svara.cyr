# svara.cyr -- bundled distribution
# Version: 3.1.0
# Generated by: cyrius distlib
# Do not edit -- rebuild with: cyrius distlib

# --- error.cyr ---

# error.cyr -- svara error codes + shared DSP tolerances and base helpers.
# L0 base module: included FIRST by every build/test entry. Modules never
# `include` each other -- the entry file orders them.
#
# Ports rust-old/src/error.rs (the `SvaraError` enum) AND the two validators
# from rust-old/src/dsp.rs (validate_sample_rate / validate_duration), which
# the whole crate leans on. Rust carried a String payload per variant; the
# Cyrius port uses integer codes -- validators return SVARA_ERR_NONE (0) on
# success or a negative code on failure; diagnostic text via svara_err_name().
#
# NAMING: every svara top-level symbol is `svara_`/`SVARA_`/`SV_`-prefixed so
# the svara distlib coexists with naad's bundle in one flat namespace (naad
# already exports validate_sample_rate / flush_denormal / ERR_NONE / etc.).
#
# FLOATS: svara's Rust was f32; the Cyrius port is f64 throughout (hisab/naad
# are f64-only). SV_EPSILON preserves the f32::EPSILON (2^-23) tolerance the
# Rust tests used, promoted to f64. svara does NOT flush denormals (its Rust
# never did) -- adding a flush would diverge near-zero output from the oracle.

# ================================================================
# Error codes (was `enum SvaraError`). One per Rust variant, in order.
# ================================================================
var SVARA_ERR_NONE             = 0;
var SVARA_ERR_INVALID_FORMANT  = (0 - 1);   # formant frequency/bandwidth out of range
var SVARA_ERR_INVALID_PHONEME  = (0 - 2);   # unrecognized / unsupported phoneme
var SVARA_ERR_INVALID_PITCH    = (0 - 3);   # f0 out of range
var SVARA_ERR_INVALID_DURATION = (0 - 4);   # duration out of range
var SVARA_ERR_ARTICULATION     = (0 - 5);   # articulation step failed during synthesis
var SVARA_ERR_COMPUTATION      = (0 - 6);   # numeric computation produced invalid result

# ================================================================
# Shared f64 tolerances / sentinels (IEEE-754 bit patterns). Exported for
# consumers (filters, tests). SV_EPSILON = f32::EPSILON promoted to f64.
# ================================================================
var SV_EPSILON = 0x3E80000000000000;   # f32::EPSILON = 2^-23 ~ 1.192e-7
var SV_POS_INF = 0x7FF0000000000000;   # +inf
var SV_NEG_INF = 0xFFF0000000000000;   # -inf

# 1 if `code` is an error (negative), 0 otherwise.
#must_use
fn svara_is_err(code) {
    if (code < 0) { return 1; }
    return 0;
}

# Static name for an error code (diagnostics / logging).
#must_use
fn svara_err_name(code) {
    if (code == SVARA_ERR_NONE) { return "none"; }
    if (code == SVARA_ERR_INVALID_FORMANT) { return "invalid formant"; }
    if (code == SVARA_ERR_INVALID_PHONEME) { return "invalid phoneme"; }
    if (code == SVARA_ERR_INVALID_PITCH) { return "invalid pitch"; }
    if (code == SVARA_ERR_INVALID_DURATION) { return "invalid duration"; }
    if (code == SVARA_ERR_ARTICULATION) { return "articulation failed"; }
    if (code == SVARA_ERR_COMPUTATION) { return "computation error"; }
    return "unknown error";
}

# Finite test: 1 iff x is neither +/-inf nor NaN. abs(x) < +inf holds for
# finite x, fails for infinities (inf < inf is false) and NaN (any NaN
# compare is false). Mirrors Rust `f32::is_finite`. `0` reads as +0.0 bits.
#must_use
fn svara_is_finite(x) {
    return f64_lt(f64_abs(x), SV_POS_INF);
}

# ================================================================
# validate_sample_rate -- SVARA_ERR_NONE if positive and finite, else
# SVARA_ERR_INVALID_FORMANT. Ports rust-old/src/dsp.rs::validate_sample_rate.
# NOTE (parity): the Rust source returns SvaraError::InvalidFormant for a bad
# sample rate (not a dedicated variant) -- preserved exactly. `0` == +0.0.
# ================================================================
#must_use
fn svara_validate_sample_rate(sample_rate) {
    if (f64_le(sample_rate, 0) == 1) { return SVARA_ERR_INVALID_FORMANT; }
    if (svara_is_finite(sample_rate) == 0) { return SVARA_ERR_INVALID_FORMANT; }
    return SVARA_ERR_NONE;
}

# ================================================================
# validate_duration -- SVARA_ERR_NONE if positive and finite, else
# SVARA_ERR_INVALID_DURATION. Ports rust-old/src/dsp.rs::validate_duration.
# ================================================================
#must_use
fn svara_validate_duration(duration) {
    if (f64_le(duration, 0) == 1) { return SVARA_ERR_INVALID_DURATION; }
    if (svara_is_finite(duration) == 0) { return SVARA_ERR_INVALID_DURATION; }
    return SVARA_ERR_NONE;
}

# ================================================================
# svara_map_naad_error -- fold a naad backend error code into a SvaraError.
# Ports rust-old/src/dsp.rs::map_naad_error (naad-backend only): the Rust
# helper wrapped any NaadError as SvaraError::ComputationError with a context
# string; the string/logging is dropped, the classification preserved.
# ================================================================
#must_use
fn svara_map_naad_error(naad_code) {
    return SVARA_ERR_COMPUTATION;
}

# --- rng.cyr ---

# rng.cyr -- deterministic PCG32 PRNG for synthesis noise generation.
# Ports rust-old/src/rng.rs (Rng struct + PCG32). Shared by glottal source
# (aspiration) and phoneme synthesis (plosive/fricative bursts); seedable for
# reproducible jitter/shimmer/breathiness. There is no seedable float RNG in
# the Cyrius stdlib, so this is hand-ported (naad's raw-cell PRNG pattern).
#
# u64 semantics on i64: wrapping_mul/wrapping_add == plain `*`/`+` (i64 wraps
# two's-complement, bit-identical to u64). `>>` is LOGICAL (zero-fill) == u64
# shift. u32 truncation == `& 0xFFFFFFFF`.
#
# NOTE (parity): next_f32's doc comment claims [-1.0, 1.0] but the Rust CODE
# yields [0.0, 1.0) -- `(next_u32() >> 1) as i32` is always non-negative. The
# code (the oracle) is ported, not the comment. f32->f64 promotion: Rust used
# `1.0 / i32::MAX as f32` which rounds i32::MAX to 2^31, so the scale is exactly
# 2^-31 (and 2^-32 for the unsigned variant).
#
# serde: Rng was Serialize/Deserialize for state persistence; its JSON codec
# lands with svara's serde surface, tracked in docs/development/roadmap.md
# (state = two u64 slots).

var SVARA_RNG_DEFAULT_SEED = 42;                 # default deterministic seed

var SVARA_PCG_MULT   = 6_364_136_223_846_793_005; # PCG32 LCG multiplier
var SVARA_U32_MASK   = 0xFFFFFFFF;                 # low 32 bits
var SVARA_INV_I32MAX = 0x3E00000000000000;        # 2^-31 = 1.0 / (i32::MAX as f32)
var SVARA_INV_U32MAX = 0x3DF0000000000000;        # 2^-32 = 1.0 / (u32::MAX as f32)

#derive(accessors)
struct SvRng { state; inc; }

# next_u32 -- PCG32 output function. Defined before its callers (single-pass).
# NOT #must_use: it advances internal state, and svara_rng_new intentionally
# discards two warm-up draws during seeding.
#inline
fn svara_rng_next_u32(self) {
    var old_state = SvRng_state(self);
    # state = old * MULT + inc  (u64 wrapping via i64 wrap)
    SvRng_set_state(self, old_state * SVARA_PCG_MULT + SvRng_inc(self));
    # xor_shifted = (((old >> 18) ^ old) >> 27) as u32
    var xor_shifted = (((old_state >> 18) ^ old_state) >> 27) & SVARA_U32_MASK;
    # rot = (old >> 59) as u32   (top 5 bits -> 0..31)
    var rot = (old_state >> 59) & 31;
    # rotate-right by rot: (x >> rot) | (x << ((-rot) & 31)), masked to u32
    var neg = (0 - rot) & 31;
    return ((xor_shifted >> rot) | (xor_shifted << neg)) & SVARA_U32_MASK;
}

# new(seed) -- PCG32 seeding (svara's exact sequence). Calls next_u32 twice.
#must_use
fn svara_rng_new(seed) {
    var self = alloc(sizeof(SvRng));
    SvRng_set_state(self, 0);
    SvRng_set_inc(self, (seed << 1) | 1);
    svara_rng_next_u32(self);
    SvRng_set_state(self, SvRng_state(self) + seed);   # wrapping_add(seed)
    svara_rng_next_u32(self);
    return self;
}

# next_f32 -- value in [0.0, 1.0). bits = (next_u32() >> 1) in [0, 2^31-1].
#inline
#must_use
fn svara_rng_next_f32(self) {
    var bits = svara_rng_next_u32(self) >> 1;
    return f64_mul(f64_from(bits), SVARA_INV_I32MAX);
}

# next_f32_unsigned -- value in [0.0, 1.0). next_u32() * 2^-32.
#inline
#must_use
fn svara_rng_next_f32_unsigned(self) {
    return f64_mul(f64_from(svara_rng_next_u32(self)), SVARA_INV_U32MAX);
}

# --- smooth.cyr ---

# smooth.cyr -- one-pole exponential parameter smoother (click-free param changes).
# Ports rust-old/src/smooth.rs (SmoothedParam). When a synthesis parameter jumps,
# the discontinuity clicks; this glides it toward a target over a time constant
# (~63% after 1τ, ~95% after 3τ). f32->f64 promotion throughout.
#
# alpha semantics: 0.0 = instant (current := target), 1.0 = never moves.
# next() short-circuits when converged (|current-target| < 1e-8), matching Rust.
#
# serde: SmoothedParam was Serialize/Deserialize; its JSON codec lands with
# svara's serde surface, tracked in docs/development/roadmap.md.

var SVARA_DEFAULT_SMOOTH_TIME = 0x3F747AE147AE147B;   # 0.005 s (~5 ms, fast for speech)
var SVARA_SMOOTH_CONVERGED    = 0x3E45798EE2308C3A;   # 1e-8 convergence threshold

#derive(accessors)
struct SvSmoothedParam { current; target; alpha; }

# alpha_from_time -- exp(-1/(time_secs*sample_rate)); 0.0 (instant) if either
# input is non-positive. Defined before its callers (single-pass). `0` == +0.0.
#must_use
fn svara_smooth_alpha_from_time(time_secs, sample_rate) {
    if (f64_le(time_secs, 0) == 1) { return 0; }
    if (f64_le(sample_rate, 0) == 1) { return 0; }
    var samples = f64_mul(time_secs, sample_rate);
    return f64_exp(f64_div(f64_neg(F64_ONE), samples));
}

# new(initial, sample_rate) -- smoother at `initial`, default 5 ms time constant.
#must_use
fn svara_smooth_new(initial, sample_rate) {
    var self = alloc(sizeof(SvSmoothedParam));
    SvSmoothedParam_set_current(self, initial);
    SvSmoothedParam_set_target(self, initial);
    SvSmoothedParam_set_alpha(self, svara_smooth_alpha_from_time(SVARA_DEFAULT_SMOOTH_TIME, sample_rate));
    return self;
}

# with_time(initial, smooth_time_secs, sample_rate) -- custom time constant.
#must_use
fn svara_smooth_with_time(initial, smooth_time_secs, sample_rate) {
    var self = alloc(sizeof(SvSmoothedParam));
    SvSmoothedParam_set_current(self, initial);
    SvSmoothedParam_set_target(self, initial);
    SvSmoothedParam_set_alpha(self, svara_smooth_alpha_from_time(smooth_time_secs, sample_rate));
    return self;
}

# set_target -- new target to glide toward.
#inline
fn svara_smooth_set_target(self, target) {
    SvSmoothedParam_set_target(self, target);
}

# next -- return current smoothed value and advance one sample.
#inline
fn svara_smooth_next(self) {
    var current = SvSmoothedParam_current(self);
    var target = SvSmoothedParam_target(self);
    if (f64_lt(f64_abs(f64_sub(current, target)), SVARA_SMOOTH_CONVERGED) == 1) {
        SvSmoothedParam_set_current(self, target);
    } else {
        var alpha = SvSmoothedParam_alpha(self);
        # current = alpha*current + (1-alpha)*target
        SvSmoothedParam_set_current(self,
        f64_add(f64_mul(alpha, current), f64_mul(f64_sub(F64_ONE, alpha), target)));
    }
    return SvSmoothedParam_current(self);
}

# value -- current value without advancing.
#inline
#must_use
fn svara_smooth_value(self) {
    return SvSmoothedParam_current(self);
}

# set_immediate -- set both current and target (no smoothing).
#inline
fn svara_smooth_set_immediate(self, value) {
    SvSmoothedParam_set_current(self, value);
    SvSmoothedParam_set_target(self, value);
}

# --- lod.cyr ---

# lod.cyr -- level-of-detail quality control for multi-voice scenarios.
# Ports rust-old/src/lod.rs (Quality enum + pipeline-stage predicates). Lower
# quality skips expensive synthesis stages to cut CPU per voice. Pure config
# logic, no float. serde on Quality dropped (tracked in docs/development/roadmap.md).

# Quality levels (was `enum Quality`). Order matches the Rust variant order.
var SVARA_QUALITY_FULL    = 0;   # all stages
var SVARA_QUALITY_REDUCED = 1;   # 3 formants, no subglottal, no interaction
var SVARA_QUALITY_MINIMAL = 2;   # 2 formants, no nasal/subglottal/interaction/lip

# max_formants -- Full=5, Reduced=3, Minimal=2.
#must_use
fn svara_quality_max_formants(q) {
    if (q == SVARA_QUALITY_FULL) { return 5; }
    if (q == SVARA_QUALITY_REDUCED) { return 3; }
    return 2;
}

# use_nasal_coupling -- Full/Reduced only.
#must_use
fn svara_quality_use_nasal_coupling(q) {
    if (q == SVARA_QUALITY_MINIMAL) { return 0; }
    return 1;
}

# use_subglottal -- Full only.
#must_use
fn svara_quality_use_subglottal(q) {
    if (q == SVARA_QUALITY_FULL) { return 1; }
    return 0;
}

# use_interaction -- Full only.
#must_use
fn svara_quality_use_interaction(q) {
    if (q == SVARA_QUALITY_FULL) { return 1; }
    return 0;
}

# use_lip_radiation -- Full/Reduced only.
#must_use
fn svara_quality_use_lip_radiation(q) {
    if (q == SVARA_QUALITY_MINIMAL) { return 0; }
    return 1;
}

# --- formant.cyr ---

# formant.cyr -- formant filtering + vowel target definitions.
# Ports rust-old/src/formant.rs. Formants are vocal-tract resonances; this is
# a parallel bank of bandpass biquad resonators (Peterson&Barney / Hillenbrand
# 1995 vowel data). f32 -> f64 throughout (Rust computed coeffs in f64 then
# truncated to f32; the port keeps f64 end-to-end -- strictly more precise,
# within tolerance parity). Self-contained: NO naad dependency (the SOA bank is
# svara's own topology, not naad's BiquadFilter). Requires stdlib math/ganita
# (F64_*, f64_cos/sin builtins, f64_sinh, f64_clamp/lerp) + error.cyr.
#
# Cyrius structs have no array fields, so BiquadBankSoa's nine [f32; 8] arrays
# become nine raw f64 buffers (SVARA_MAX_FORMANTS slots each) held as struct
# fields; the hot loop indexes them with load64/store64. serde on Formant /
# VowelTarget / FormantFilter is dropped (tracked in docs/development/roadmap.md).

var SVARA_MAX_FORMANTS = 8;   # fixed bank width (unused slots zeroed)

# Default formant amplitudes F1..F5 (linear) for the parallel bank.
var SVARA_AMP_0 = 0x3FF0000000000000;   # 1.0
var SVARA_AMP_1 = 0x3FE999999999999A;   # 0.8
var SVARA_AMP_2 = 0x3FE0000000000000;   # 0.5
var SVARA_AMP_3 = 0x3FD3333333333333;   # 0.3
var SVARA_AMP_4 = 0x3FC999999999999A;   # 0.2

# ================================================================
# Formant -- a single resonance spec (frequency, bandwidth, amplitude in Hz/Hz/linear).
# ================================================================
#derive(accessors)
#derive(Serialize)
struct SvFormant { frequency: f64; bandwidth: f64; amplitude: f64; }

#must_use
fn svara_formant_new(frequency, bandwidth, amplitude) {
    var self = alloc(sizeof(SvFormant));
    SvFormant_set_frequency(self, frequency);
    SvFormant_set_bandwidth(self, bandwidth);
    SvFormant_set_amplitude(self, amplitude);
    return self;
}

# ================================================================
# Vowel categories (was `enum Vowel`) -> integer constants.
# ================================================================
var SVARA_VOWEL_A     = 0;   # /a/ open front unrounded
var SVARA_VOWEL_E     = 1;   # /e/ close-mid front unrounded
var SVARA_VOWEL_I     = 2;   # /i/ close front unrounded
var SVARA_VOWEL_O     = 3;   # /o/ close-mid back rounded
var SVARA_VOWEL_U     = 4;   # /u/ close back rounded
var SVARA_VOWEL_SCHWA = 5;   # schwa mid central
var SVARA_VOWEL_OPENO = 6;   # open-O open-mid back rounded
var SVARA_VOWEL_ASH   = 7;   # near-open front
var SVARA_VOWEL_NEARI = 8;   # near-close near-front
var SVARA_VOWEL_NEARU = 9;   # near-close near-back

# ================================================================
# VowelTarget -- F1..F5 frequencies + B1..B5 bandwidths (Hz).
# ================================================================
#derive(accessors)
#derive(Serialize)
struct SvVowelTarget {
    f1: f64; f2: f64; f3: f64; f4: f64; f5: f64;
    b1: f64; b2: f64; b3: f64; b4: f64; b5: f64;
}

# with_bandwidths -- explicit frequencies and bandwidths.
#must_use
fn svara_vowel_target_with_bandwidths(f1, f2, f3, f4, f5, b1, b2, b3, b4, b5) {
    var self = alloc(sizeof(SvVowelTarget));
    SvVowelTarget_set_f1(self, f1);
    SvVowelTarget_set_f2(self, f2);
    SvVowelTarget_set_f3(self, f3);
    SvVowelTarget_set_f4(self, f4);
    SvVowelTarget_set_f5(self, f5);
    SvVowelTarget_set_b1(self, b1);
    SvVowelTarget_set_b2(self, b2);
    SvVowelTarget_set_b3(self, b3);
    SvVowelTarget_set_b4(self, b4);
    SvVowelTarget_set_b5(self, b5);
    return self;
}

# new -- frequencies with default bandwidths [60, 80, 100, 120, 140] Hz.
#must_use
fn svara_vowel_target_new(f1, f2, f3, f4, f5) {
    return svara_vowel_target_with_bandwidths(f1, f2, f3, f4, f5,
    f64_from(60), f64_from(80), f64_from(100), f64_from(120), f64_from(140));
}

# from_vowel -- Hillenbrand et al. (1995) male averages, per-vowel bandwidths.
#must_use
fn svara_vowel_target_from_vowel(vowel) {
    if (vowel == SVARA_VOWEL_A) {
        return svara_vowel_target_with_bandwidths(
        f64_from(768), f64_from(1333), f64_from(2522), f64_from(3300), f64_from(3750),
        f64_from(90), f64_from(100), f64_from(120), f64_from(140), f64_from(160));
    }
    if (vowel == SVARA_VOWEL_E) {
        return svara_vowel_target_with_bandwidths(
        f64_from(476), f64_from(2089), f64_from(2691), f64_from(3300), f64_from(3750),
        f64_from(55), f64_from(80), f64_from(100), f64_from(120), f64_from(140));
    }
    if (vowel == SVARA_VOWEL_I) {
        return svara_vowel_target_with_bandwidths(
        f64_from(342), f64_from(2322), f64_from(3000), f64_from(3657), f64_from(3750),
        f64_from(40), f64_from(70), f64_from(90), f64_from(120), f64_from(140));
    }
    if (vowel == SVARA_VOWEL_O) {
        return svara_vowel_target_with_bandwidths(
        f64_from(497), f64_from(910), f64_from(2459), f64_from(3300), f64_from(3750),
        f64_from(65), f64_from(70), f64_from(100), f64_from(120), f64_from(140));
    }
    if (vowel == SVARA_VOWEL_U) {
        return svara_vowel_target_with_bandwidths(
        f64_from(378), f64_from(997), f64_from(2343), f64_from(3300), f64_from(3750),
        f64_from(45), f64_from(65), f64_from(90), f64_from(120), f64_from(140));
    }
    if (vowel == SVARA_VOWEL_SCHWA) {
        return svara_vowel_target_with_bandwidths(
        f64_from(523), f64_from(1588), f64_from(2469), f64_from(3300), f64_from(3750),
        f64_from(60), f64_from(80), f64_from(100), f64_from(120), f64_from(140));
    }
    if (vowel == SVARA_VOWEL_OPENO) {
        return svara_vowel_target_with_bandwidths(
        f64_from(652), f64_from(997), f64_from(2538), f64_from(3300), f64_from(3750),
        f64_from(80), f64_from(75), f64_from(110), f64_from(130), f64_from(150));
    }
    if (vowel == SVARA_VOWEL_ASH) {
        return svara_vowel_target_with_bandwidths(
        f64_from(669), f64_from(1880), f64_from(2489), f64_from(3300), f64_from(3750),
        f64_from(80), f64_from(90), f64_from(110), f64_from(130), f64_from(150));
    }
    if (vowel == SVARA_VOWEL_NEARI) {
        return svara_vowel_target_with_bandwidths(
        f64_from(427), f64_from(2034), f64_from(2684), f64_from(3300), f64_from(3750),
        f64_from(50), f64_from(75), f64_from(95), f64_from(120), f64_from(140));
    }
    # SVARA_VOWEL_NEARU (default arm)
    return svara_vowel_target_with_bandwidths(
    f64_from(469), f64_from(1122), f64_from(2434), f64_from(3300), f64_from(3750),
    f64_from(55), f64_from(70), f64_from(95), f64_from(120), f64_from(140));
}

# to_formants -- vec of 5 Formant pointers (F1..F5) with default amplitudes.
#must_use
fn svara_vowel_target_to_formants(self) {
    var out = vec_new();
    vec_push(out, svara_formant_new(SvVowelTarget_f1(self), SvVowelTarget_b1(self), SVARA_AMP_0));
    vec_push(out, svara_formant_new(SvVowelTarget_f2(self), SvVowelTarget_b2(self), SVARA_AMP_1));
    vec_push(out, svara_formant_new(SvVowelTarget_f3(self), SvVowelTarget_b3(self), SVARA_AMP_2));
    vec_push(out, svara_formant_new(SvVowelTarget_f4(self), SvVowelTarget_b4(self), SVARA_AMP_3));
    vec_push(out, svara_formant_new(SvVowelTarget_f5(self), SvVowelTarget_b5(self), SVARA_AMP_4));
    return out;
}

# interpolate -- linear blend of two targets; t clamped to [0, 1].
#must_use
fn svara_vowel_target_interpolate(from, to, t) {
    var tc = f64_clamp(t, 0, F64_ONE);
    var r = alloc(sizeof(SvVowelTarget));
    SvVowelTarget_set_f1(r, f64_lerp(SvVowelTarget_f1(from), SvVowelTarget_f1(to), tc));
    SvVowelTarget_set_f2(r, f64_lerp(SvVowelTarget_f2(from), SvVowelTarget_f2(to), tc));
    SvVowelTarget_set_f3(r, f64_lerp(SvVowelTarget_f3(from), SvVowelTarget_f3(to), tc));
    SvVowelTarget_set_f4(r, f64_lerp(SvVowelTarget_f4(from), SvVowelTarget_f4(to), tc));
    SvVowelTarget_set_f5(r, f64_lerp(SvVowelTarget_f5(from), SvVowelTarget_f5(to), tc));
    SvVowelTarget_set_b1(r, f64_lerp(SvVowelTarget_b1(from), SvVowelTarget_b1(to), tc));
    SvVowelTarget_set_b2(r, f64_lerp(SvVowelTarget_b2(from), SvVowelTarget_b2(to), tc));
    SvVowelTarget_set_b3(r, f64_lerp(SvVowelTarget_b3(from), SvVowelTarget_b3(to), tc));
    SvVowelTarget_set_b4(r, f64_lerp(SvVowelTarget_b4(from), SvVowelTarget_b4(to), tc));
    SvVowelTarget_set_b5(r, f64_lerp(SvVowelTarget_b5(from), SvVowelTarget_b5(to), tc));
    return r;
}

# ================================================================
# biquad_coefficients -- bandpass biquad, computed in f64. Writes b0,b2,a1,a2
# into `out` (4 f64 slots). b1 == 0 for bandpass, b2 == -b0.
# ================================================================
#inline
fn svara_formant_biquad_coeffs(frequency, bandwidth, sample_rate, out) {
    var omega = f64_div(f64_mul(F64_TAU, frequency), sample_rate);
    var cos_omega = f64_cos(omega);
    var sin_omega = f64_sin(omega);
    var bw_omega = f64_div(f64_mul(F64_TAU, bandwidth), sample_rate);
    var alpha = f64_mul(sin_omega, f64_sinh(f64_mul(bw_omega, F64_HALF)));
    var a0 = f64_add(F64_ONE, alpha);
    store64(out,      f64_div(alpha, a0));                                    # b0
    store64(out + 8,  f64_div(f64_neg(alpha), a0));                           # b2
    store64(out + 16, f64_div(f64_mul(f64_neg(F64_TWO), cos_omega), a0));     # a1
    store64(out + 24, f64_div(f64_sub(F64_ONE, alpha), a0));                  # a2
}

# ================================================================
# BiquadBankSoa -- SOA bank of MAX_FORMANTS bandpass biquads. Nine f64 buffers
# (b0/b2/a1/a2/amp = coeffs+weight, x1/x2/y1/y2 = delay lines) + active count.
# ================================================================
#derive(accessors)
struct SvFormantBank { b0; b2; a1; a2; amp; x1; x2; y1; y2; count; }

# zero a buffer of `n` f64 slots (bump alloc is not zeroed).
fn svara_formant_zero_buf(buf, n) {
    var i = 0;
    while (i < n) { store64(buf + i * 8, 0); i = i + 1; }
}

# bank_new -- build from a vec of Formant pointers.
#must_use
fn svara_formant_bank_new(formants, sample_rate) {
    var self = alloc(sizeof(SvFormantBank));
    var nbytes = SVARA_MAX_FORMANTS * 8;
    var b0 = alloc(nbytes); var b2 = alloc(nbytes); var a1 = alloc(nbytes);
    var a2 = alloc(nbytes); var amp = alloc(nbytes);
    var x1 = alloc(nbytes); var x2 = alloc(nbytes);
    var y1 = alloc(nbytes); var y2 = alloc(nbytes);
    svara_formant_zero_buf(b0, SVARA_MAX_FORMANTS); svara_formant_zero_buf(b2, SVARA_MAX_FORMANTS);
    svara_formant_zero_buf(a1, SVARA_MAX_FORMANTS); svara_formant_zero_buf(a2, SVARA_MAX_FORMANTS);
    svara_formant_zero_buf(amp, SVARA_MAX_FORMANTS);
    svara_formant_zero_buf(x1, SVARA_MAX_FORMANTS); svara_formant_zero_buf(x2, SVARA_MAX_FORMANTS);
    svara_formant_zero_buf(y1, SVARA_MAX_FORMANTS); svara_formant_zero_buf(y2, SVARA_MAX_FORMANTS);
    SvFormantBank_set_b0(self, b0); SvFormantBank_set_b2(self, b2);
    SvFormantBank_set_a1(self, a1); SvFormantBank_set_a2(self, a2);
    SvFormantBank_set_amp(self, amp);
    SvFormantBank_set_x1(self, x1); SvFormantBank_set_x2(self, x2);
    SvFormantBank_set_y1(self, y1); SvFormantBank_set_y2(self, y2);

    var n = vec_len(formants);
    if (n > SVARA_MAX_FORMANTS) { n = SVARA_MAX_FORMANTS; }
    SvFormantBank_set_count(self, n);

    var coeff = alloc(32);
    var i = 0;
    while (i < n) {
        var f = vec_get(formants, i);
        svara_formant_biquad_coeffs(SvFormant_frequency(f), SvFormant_bandwidth(f), sample_rate, coeff);
        store64(b0 + i * 8, load64(coeff));
        store64(b2 + i * 8, load64(coeff + 8));
        store64(a1 + i * 8, load64(coeff + 16));
        store64(a2 + i * 8, load64(coeff + 24));
        store64(amp + i * 8, SvFormant_amplitude(f));
        i = i + 1;
    }
    return self;
}

# bank_update -- recompute coefficients for slot `i` without resetting state.
fn svara_formant_bank_update(self, i, frequency, bandwidth, amplitude, sample_rate) {
    var coeff = alloc(32);
    svara_formant_biquad_coeffs(frequency, bandwidth, sample_rate, coeff);
    var off = i * 8;
    store64(SvFormantBank_b0(self) + off, load64(coeff));
    store64(SvFormantBank_b2(self) + off, load64(coeff + 8));
    store64(SvFormantBank_a1(self) + off, load64(coeff + 16));
    store64(SvFormantBank_a2(self) + off, load64(coeff + 24));
    store64(SvFormantBank_amp(self) + off, amplitude);
}

# bank_process -- one input sample through all MAX_FORMANTS slots -> weighted sum.
# Unused slots (count..MAX) have zeroed coeffs -> contribute nothing.
#inline
fn svara_formant_bank_process(self, input) {
    var b0 = SvFormantBank_b0(self); var b2 = SvFormantBank_b2(self);
    var a1 = SvFormantBank_a1(self); var a2 = SvFormantBank_a2(self);
    var amp = SvFormantBank_amp(self);
    var x1 = SvFormantBank_x1(self); var x2 = SvFormantBank_x2(self);
    var y1 = SvFormantBank_y1(self); var y2 = SvFormantBank_y2(self);
    var sum = 0;
    var i = 0;
    while (i < SVARA_MAX_FORMANTS) {
        var off = i * 8;
        var x2i = load64(x2 + off); var y1i = load64(y1 + off); var y2i = load64(y2 + off);
        # y = b0*input + b2*x2 - a1*y1 - a2*y2
        var y = f64_sub(f64_sub(f64_add(f64_mul(load64(b0 + off), input), f64_mul(load64(b2 + off), x2i)),
        f64_mul(load64(a1 + off), y1i)),
        f64_mul(load64(a2 + off), y2i));
        store64(x2 + off, load64(x1 + off));
        store64(x1 + off, input);
        store64(y2 + off, y1i);
        store64(y1 + off, y);
        sum = f64_add(sum, f64_mul(y, load64(amp + off)));
        i = i + 1;
    }
    return sum;
}

# bank_reset -- clear the delay lines (keep coefficients).
fn svara_formant_bank_reset(self) {
    svara_formant_zero_buf(SvFormantBank_x1(self), SVARA_MAX_FORMANTS);
    svara_formant_zero_buf(SvFormantBank_x2(self), SVARA_MAX_FORMANTS);
    svara_formant_zero_buf(SvFormantBank_y1(self), SVARA_MAX_FORMANTS);
    svara_formant_zero_buf(SvFormantBank_y2(self), SVARA_MAX_FORMANTS);
}

# ================================================================
# DcBlocker -- one-pole DC-blocking high-pass: y = x - x_prev + alpha*y_prev,
# alpha for ~20 Hz cutoff. Removes DC drift from the parallel biquads.
# ================================================================
#derive(accessors)
struct SvDcBlocker { alpha; x_prev; y_prev; }

#must_use
fn svara_dc_blocker_new(sample_rate) {
    var self = alloc(sizeof(SvDcBlocker));
    # alpha = 1 - (TAU * 20 / sample_rate)
    SvDcBlocker_set_alpha(self, f64_sub(F64_ONE, f64_div(f64_mul(F64_TAU, f64_from(20)), sample_rate)));
    SvDcBlocker_set_x_prev(self, 0);
    SvDcBlocker_set_y_prev(self, 0);
    return self;
}

#inline
fn svara_dc_blocker_process(self, input) {
    # output = input - x_prev + alpha * y_prev
    var output = f64_add(f64_sub(input, SvDcBlocker_x_prev(self)),
    f64_mul(SvDcBlocker_alpha(self), SvDcBlocker_y_prev(self)));
    SvDcBlocker_set_x_prev(self, input);
    SvDcBlocker_set_y_prev(self, output);
    return output;
}

# dc_blocker_reset -- clear the DC-blocker's one-sample history to silence.
fn svara_dc_blocker_reset(self) {
    SvDcBlocker_set_x_prev(self, 0);
    SvDcBlocker_set_y_prev(self, 0);
}

# ================================================================
# FormantFilter -- parallel biquad bank + DC blocker. new() returns a pointer
# on success or a negative SVARA_ERR_* code (Result -> code/sentinel).
# ================================================================
#derive(accessors)
struct SvFormantFilter { bank; dc; sample_rate; }

# new -- validate then build. Errors: SVARA_ERR_INVALID_FORMANT.
#must_use
fn svara_formant_filter_new(formants, sample_rate) {
    if (f64_le(sample_rate, 0) == 1) { return SVARA_ERR_INVALID_FORMANT; }
    if (svara_is_finite(sample_rate) == 0) { return SVARA_ERR_INVALID_FORMANT; }
    var n = vec_len(formants);
    if (n == 0) { return SVARA_ERR_INVALID_FORMANT; }
    if (n > SVARA_MAX_FORMANTS) { return SVARA_ERR_INVALID_FORMANT; }
    var nyquist = f64_mul(sample_rate, F64_HALF);
    var i = 0;
    while (i < n) {
        var f = vec_get(formants, i);
        var freq = SvFormant_frequency(f);
        if (f64_le(freq, 0) == 1) { return SVARA_ERR_INVALID_FORMANT; }
        if (f64_ge(freq, nyquist) == 1) { return SVARA_ERR_INVALID_FORMANT; }
        if (f64_le(SvFormant_bandwidth(f), 0) == 1) { return SVARA_ERR_INVALID_FORMANT; }
        i = i + 1;
    }
    var self = alloc(sizeof(SvFormantFilter));
    SvFormantFilter_set_bank(self, svara_formant_bank_new(formants, sample_rate));
    SvFormantFilter_set_dc(self, svara_dc_blocker_new(sample_rate));
    SvFormantFilter_set_sample_rate(self, sample_rate);
    return self;
}

# update_formants -- new targets for smooth transitions; count must match.
#must_use
fn svara_formant_filter_update(self, formants) {
    var bank = SvFormantFilter_bank(self);
    var n = vec_len(formants);
    if (n != SvFormantBank_count(bank)) { return SVARA_ERR_INVALID_FORMANT; }
    var sr = SvFormantFilter_sample_rate(self);
    var i = 0;
    while (i < n) {
        var f = vec_get(formants, i);
        svara_formant_bank_update(bank, i, SvFormant_frequency(f), SvFormant_bandwidth(f), SvFormant_amplitude(f), sr);
        i = i + 1;
    }
    return SVARA_ERR_NONE;
}

# process_sample -- bank sum through the DC blocker.
#inline
fn svara_formant_filter_process_sample(self, input) {
    var raw = svara_formant_bank_process(SvFormantFilter_bank(self), input);
    return svara_dc_blocker_process(SvFormantFilter_dc(self), raw);
}

# process_block -- n samples from input buffer into output buffer (f64 slots).
fn svara_formant_filter_process_block(self, input, output, n) {
    var bank = SvFormantFilter_bank(self);
    var i = 0;
    while (i < n) {
        store64(output + i * 8, svara_formant_bank_process(bank, load64(input + i * 8)));
        i = i + 1;
    }
    var dc = SvFormantFilter_dc(self);
    var j = 0;
    while (j < n) {
        store64(output + j * 8, svara_dc_blocker_process(dc, load64(output + j * 8)));
        j = j + 1;
    }
}

# reset -- clear bank delay lines + DC blocker.
fn svara_formant_filter_reset(self) {
    svara_formant_bank_reset(SvFormantFilter_bank(self));
    svara_dc_blocker_reset(SvFormantFilter_dc(self));
}

# num_formants -- active resonator count.
#must_use
fn svara_formant_filter_num_formants(self) {
    return SvFormantBank_count(SvFormantFilter_bank(self));
}

# --- spectral.cyr ---

# spectral.cyr -- FFT-based spectral analysis for vocal synthesis.
# Ports rust-old/src/spectral.rs. Uses hisab: num_fft (in-place radix-2 FFT
# over a buffer of HComplex, 16 bytes each: re@+0, im@+8) and num_neumaier_sum
# (compensated sum of a contiguous f64 buffer). f32 -> f64 throughout (Rust
# stored f32 magnitudes; the port keeps f64 -- within tolerance parity).
#
# Requires (from the build/test unit, in order): stdlib alloc/vec/math/ganita,
# error.cyr, and hisab (lib/hisab.cyr). serde is not on Spectrum in Rust; none added.
#
# Sample/magnitude buffers are stdlib vecs holding one f64 bit pattern per slot.

var SV_TENTH = 0x3FB999999999999A;   # 0.1 (estimate_formants peak threshold factor)

# ================================================================
# Spectrum -- magnitude spectrum of one audio frame.
#   magnitudes      : vec<f64>, length fft_size/2 + 1
#   freq_resolution : Hz per bin
#   sample_rate     : Hz
# ================================================================
#derive(accessors)
struct SvSpectrum { magnitudes; freq_resolution; sample_rate; }

# smallest power of two >= n (n >= 1). Matches Rust next_power_of_two.
#must_use
fn svara_next_pow2(n) {
    var p = 1;
    while (p < n) { p = p * 2; }
    return p;
}

# bin_frequency -- Hz at bin index.
#inline
#must_use
fn svara_spectrum_bin_frequency(self, bin) {
    return f64_mul(f64_from(bin), SvSpectrum_freq_resolution(self));
}

# frequency_bin -- nearest bin index to a frequency: ((freq/res)+0.5) truncated.
#inline
#must_use
fn svara_spectrum_frequency_bin(self, freq) {
    return f64_to(f64_add(f64_div(freq, SvSpectrum_freq_resolution(self)), F64_HALF));
}

# magnitude_at -- magnitude at the bin nearest `freq` (0.0 if out of range).
#must_use
fn svara_spectrum_magnitude_at(self, freq) {
    var mags = SvSpectrum_magnitudes(self);
    var bin = svara_spectrum_frequency_bin(self, freq);
    if (bin < vec_len(mags)) { return vec_get(mags, bin); }
    return 0;
}

# peak_in_range -- writes (freq, mag) of the strongest bin in [lo_hz, hi_hz)
# into out (2 f64 slots); returns 1 if a peak was found, 0 otherwise.
#must_use
fn svara_spectrum_peak_in_range(self, lo_hz, hi_hz, out) {
    var mags = SvSpectrum_magnitudes(self);
    var len = vec_len(mags);
    var lo_bin = svara_spectrum_frequency_bin(self, lo_hz);
    var hi_bin = svara_spectrum_frequency_bin(self, hi_hz);
    if (hi_bin > len) { hi_bin = len; }
    if (lo_bin >= hi_bin) { return 0; }
    var max_mag = 0;
    var max_bin = lo_bin;
    var bin = lo_bin;
    while (bin < hi_bin) {
        var m = vec_get(mags, bin);
        if (f64_gt(m, max_mag) == 1) { max_mag = m; max_bin = bin; }
        bin = bin + 1;
    }
    store64(out, svara_spectrum_bin_frequency(self, max_bin));
    store64(out + 8, max_mag);
    return 1;
}

# sum of squared magnitudes over [lo, hi) via Neumaier compensated summation.
#must_use
fn svara_spectral_sum_squares(mags, lo, hi) {
    var n = hi - lo;
    if (n <= 0) { return 0; }
    var buf = alloc(n * 8);
    var i = 0;
    while (i < n) {
        var m = vec_get(mags, lo + i);
        store64(buf + i * 8, f64_mul(m, m));
        i = i + 1;
    }
    return num_neumaier_sum(buf, n);
}

# total_energy -- sum of squared magnitudes (Neumaier).
#must_use
fn svara_spectrum_total_energy(self) {
    var mags = SvSpectrum_magnitudes(self);
    return svara_spectral_sum_squares(mags, 0, vec_len(mags));
}

# band_energy -- sum of squared magnitudes in [lo_hz, hi_hz).
#must_use
fn svara_spectrum_band_energy(self, lo_hz, hi_hz) {
    var mags = SvSpectrum_magnitudes(self);
    var len = vec_len(mags);
    var lo_bin = svara_spectrum_frequency_bin(self, lo_hz);
    var hi_bin = svara_spectrum_frequency_bin(self, hi_hz);
    if (hi_bin > len) { hi_bin = len; }
    if (lo_bin >= hi_bin) { return 0; }
    return svara_spectral_sum_squares(mags, lo_bin, hi_bin);
}

# estimate_formants -- up to max_formants peak frequencies, ascending.
# Local maxima above 10% of the peak magnitude; keep the strongest N, sort by freq.
#must_use
fn svara_spectrum_estimate_formants(self, max_formants) {
    var mags = SvSpectrum_magnitudes(self);
    var len = vec_len(mags);
    var result = vec_new();
    if (len < 3) { return result; }

    # peak magnitude across the spectrum
    var max_mag = 0;
    var g = 0;
    while (g < len) {
        var mg = vec_get(mags, g);
        if (f64_gt(mg, max_mag) == 1) { max_mag = mg; }
        g = g + 1;
    }
    var threshold = f64_mul(max_mag, SV_TENTH);

    # collect local maxima into parallel freq/mag buffers
    var pf = alloc(len * 8);
    var pm = alloc(len * 8);
    var pc = 0;
    var i = 1;
    while (i < len - 1) {
        var m = vec_get(mags, i);
        var lft = vec_get(mags, i - 1);
        var rgt = vec_get(mags, i + 1);
        if ((f64_gt(m, lft) == 1) & (f64_gt(m, rgt) == 1) & (f64_gt(m, threshold) == 1)) {
            store64(pf + pc * 8, svara_spectrum_bin_frequency(self, i));
            store64(pm + pc * 8, m);
            pc = pc + 1;
        }
        i = i + 1;
    }
    if (pc == 0) { return result; }

    # selection sort by magnitude descending (swap freq + mag together)
    var a = 0;
    while (a < pc) {
        var best = a;
        var b = a + 1;
        while (b < pc) {
            if (f64_gt(load64(pm + b * 8), load64(pm + best * 8)) == 1) { best = b; }
            b = b + 1;
        }
        if (best != a) {
            var tf = load64(pf + a * 8); var tm = load64(pm + a * 8);
            store64(pf + a * 8, load64(pf + best * 8)); store64(pm + a * 8, load64(pm + best * 8));
            store64(pf + best * 8, tf); store64(pm + best * 8, tm);
        }
        a = a + 1;
    }

    # keep top N
    var keep = pc;
    if (keep > max_formants) { keep = max_formants; }

    # selection sort the kept prefix by frequency ascending
    var c = 0;
    while (c < keep) {
        var lo = c;
        var d = c + 1;
        while (d < keep) {
            if (f64_lt(load64(pf + d * 8), load64(pf + lo * 8)) == 1) { lo = d; }
            d = d + 1;
        }
        if (lo != c) {
            var tf2 = load64(pf + c * 8); var tm2 = load64(pm + c * 8);
            store64(pf + c * 8, load64(pf + lo * 8)); store64(pm + c * 8, load64(pm + lo * 8));
            store64(pf + lo * 8, tf2); store64(pm + lo * 8, tm2);
        }
        c = c + 1;
    }

    var k = 0;
    while (k < keep) {
        vec_push(result, load64(pf + k * 8));
        k = k + 1;
    }
    return result;
}

# ================================================================
# analyze -- magnitude spectrum of an audio frame (vec<f64>). Zero-pads to the
# next power of two, applies a Hann window, FFTs, keeps positive-frequency bins.
# Returns an SvSpectrum pointer, or SVARA_ERR_COMPUTATION on empty input / FFT failure.
# ================================================================
#must_use
fn svara_spectral_analyze(samples, sample_rate) {
    var len = vec_len(samples);
    if (len == 0) { return SVARA_ERR_COMPUTATION; }

    var fft_size = svara_next_pow2(len);
    var data = alloc(fft_size * 16);

    # window the first `len` samples into re; zero the imaginary parts + padding.
    var n = f64_from(len);
    var i = 0;
    while (i < fft_size) {
        var re = 0;
        if (i < len) {
            var window = f64_mul(F64_HALF,
            f64_sub(F64_ONE, f64_cos(f64_div(f64_mul(F64_TAU, f64_from(i)), n))));
            re = f64_mul(vec_get(samples, i), window);
        }
        store64(data + i * 16, re);
        store64(data + i * 16 + 8, 0);
        i = i + 1;
    }

    if (num_fft(data, fft_size) != 0) { return SVARA_ERR_COMPUTATION; }

    # magnitude of the positive-frequency bins (0 .. fft_size/2)
    var num_bins = fft_size / 2 + 1;
    var mags = vec_new();
    var k = 0;
    while (k < num_bins) {
        var re = load64(data + k * 16);
        var im = load64(data + k * 16 + 8);
        vec_push(mags, f64_sqrt(f64_add(f64_mul(re, re), f64_mul(im, im))));
        k = k + 1;
    }

    var self = alloc(sizeof(SvSpectrum));
    SvSpectrum_set_magnitudes(self, mags);
    SvSpectrum_set_freq_resolution(self, f64_div(sample_rate, f64_from(fft_size)));
    SvSpectrum_set_sample_rate(self, sample_rate);
    return self;
}

# rms_level -- root-mean-square level of a sample buffer (vec<f64>), Neumaier sum.
#must_use
fn svara_spectral_rms_level(samples) {
    var len = vec_len(samples);
    if (len == 0) { return 0; }
    var mean = f64_div(svara_spectral_sum_squares(samples, 0, len), f64_from(len));
    return f64_sqrt(mean);
}

# --- glottal.cyr ---

# glottal.cyr -- glottal source models (the vocal-tract excitation signal).
# Ports rust-old/src/glottal.rs (naad-backend path — the shipped 2.0.0 default).
# Models: Rosenberg B (3t^2-2t^3), LF (Liljencrants-Fant, Rd-parameterized),
# Whisper (noise-only), Creaky (irregular LF). f32 -> f64 throughout.
#
# Backend (per the port's locked decision): aspiration/whisper noise uses naad's
# NoiseGenerator (White); vibrato uses naad's Lfo (Sine). svara's own PCG32 rng
# still drives jitter/shimmer/creaky-period/diplophonia. The fallback path's
# vibrato_phase field is dropped (naad-backend uses the Lfo).
#
# Requires (from the build/test unit, in order): stdlib alloc/vec/math/ganita,
# hisab, goonj, naad (noise_new/noise_next_sample/NOISE_WHITE, modulation_lfo_new/
# modulation_lfo_next_value/modulation_lfo_set_frequency/Lfo_set_depth/
# MODULATION_LFO_SINE), error.cyr, rng.cyr. serde on GlottalSource is dropped
# (tracked in docs/development/roadmap.md).

# Glottal pulse models (was `enum GlottalModel`).
var SVARA_GLOTTAL_ROSENBERG = 0;
var SVARA_GLOTTAL_LF        = 1;
var SVARA_GLOTTAL_WHISPER   = 2;
var SVARA_GLOTTAL_CREAKY    = 3;

# Defaults + magic constants (IEEE-754 bit patterns).
var SV_G_OQ_DEF      = 0x3FE3333333333333;   # 0.6  default open quotient
var SV_G_JITTER_DEF  = 0x3F847AE147AE147B;   # 0.01 default jitter
var SV_G_SHIMMER_DEF = 0x3F947AE147AE147B;   # 0.02 default shimmer
var SV_G_0_001 = 0x3F50624DD2F1A9FC;   # 0.001
var SV_G_0_003 = 0x3F689374BC6A7EFA;   # 0.003
var SV_G_0_01  = 0x3F847AE147AE147B;   # 0.01
var SV_G_0_012 = 0x3F889374BC6A7EFA;   # 0.012
var SV_G_0_05  = 0x3FA999999999999A;   # 0.05
var SV_G_0_1   = 0x3FB999999999999A;   # 0.1
var SV_G_0_15  = 0x3FC3333333333333;   # 0.15
var SV_G_0_2   = 0x3FC999999999999A;   # 0.2
var SV_G_0_3   = 0x3FD3333333333333;   # 0.3
var SV_G_0_4   = 0x3FD999999999999A;   # 0.4
var SV_G_0_7   = 0x3FE6666666666666;   # 0.7
var SV_G_0_8   = 0x3FE999999999999A;   # 0.8
var SV_G_2_4   = 0x4003333333333333;   # 2.4
var SV_G_2_7   = 0x400599999999999A;   # 2.7
var SV_G_5_0   = 0x4014000000000000;   # 5.0

# GlottalSource -- selectable-model excitation generator (naad-backend layout).
#derive(accessors)
struct SvGlottalSource {
    model; rd; lf_ta; lf_te; lf_ee; f0; sample_rate;
    open_quotient; speed_quotient; spectral_tilt;
    jitter; shimmer; breathiness; diplophonia; diplo_phase;
    vibrato_rate; vibrato_depth; tilt_state;
    phase; current_period; current_amplitude;
    rng; aspiration_noise; vibrato_lfo;
}

# lf_params_from_rd -- derive LF (ta, te, ee) from Rd; writes 3 f64 slots.
# rd clamped to [0.3, 2.7]. Fant (1995) simplified mapping.
fn svara_lf_params_from_rd(rd, out) {
    var r = f64_clamp(rd, SV_G_0_3, SV_G_2_7);
    var norm = f64_div(f64_sub(r, SV_G_0_3), SV_G_2_4);        # (rd-0.3)/2.4
    var te = f64_add(SV_G_0_4, f64_mul(SV_G_0_2, norm));       # 0.4 + 0.2*norm
    var ta = f64_add(SV_G_0_003, f64_mul(SV_G_0_012, norm));   # 0.003 + 0.012*norm
    var ee = f64_sub(F64_ONE, f64_mul(SV_G_0_3, norm));        # 1.0 - 0.3*norm
    store64(out, ta);
    store64(out + 8, te);
    store64(out + 16, ee);
}

# apply_rd -- compute + store LF params on the source.
fn svara_glottal_apply_rd(self, rd) {
    var out = alloc(24);
    svara_lf_params_from_rd(rd, out);
    SvGlottalSource_set_lf_ta(self, load64(out));
    SvGlottalSource_set_lf_te(self, load64(out + 8));
    SvGlottalSource_set_lf_ee(self, load64(out + 16));
}

# new -- f0 in [20, 2000] Hz, sample_rate > 0 finite. Returns ptr or neg error.
#must_use
fn svara_glottal_new(f0, sample_rate) {
    if (f64_lt(f0, f64_from(20)) == 1) { return SVARA_ERR_INVALID_PITCH; }
    if (f64_gt(f0, f64_from(2000)) == 1) { return SVARA_ERR_INVALID_PITCH; }
    if (f64_le(sample_rate, 0) == 1) { return SVARA_ERR_INVALID_FORMANT; }
    if (svara_is_finite(sample_rate) == 0) { return SVARA_ERR_INVALID_FORMANT; }

    var self = alloc(sizeof(SvGlottalSource));
    SvGlottalSource_set_model(self, SVARA_GLOTTAL_ROSENBERG);
    SvGlottalSource_set_rd(self, F64_ONE);
    svara_glottal_apply_rd(self, F64_ONE);
    SvGlottalSource_set_f0(self, f0);
    SvGlottalSource_set_sample_rate(self, sample_rate);
    SvGlottalSource_set_open_quotient(self, SV_G_OQ_DEF);
    SvGlottalSource_set_speed_quotient(self, F64_TWO);
    SvGlottalSource_set_spectral_tilt(self, 0);
    SvGlottalSource_set_jitter(self, SV_G_JITTER_DEF);
    SvGlottalSource_set_shimmer(self, SV_G_SHIMMER_DEF);
    SvGlottalSource_set_breathiness(self, 0);
    SvGlottalSource_set_diplophonia(self, 0);
    SvGlottalSource_set_diplo_phase(self, 0);
    SvGlottalSource_set_vibrato_rate(self, 0);
    SvGlottalSource_set_vibrato_depth(self, 0);
    SvGlottalSource_set_tilt_state(self, 0);
    SvGlottalSource_set_phase(self, 0);
    SvGlottalSource_set_current_period(self, f64_div(sample_rate, f0));
    SvGlottalSource_set_current_amplitude(self, F64_ONE);
    SvGlottalSource_set_rng(self, svara_rng_new(SVARA_RNG_DEFAULT_SEED));
    SvGlottalSource_set_aspiration_noise(self, noise_new(NOISE_WHITE, 42));
    SvGlottalSource_set_vibrato_lfo(self, modulation_lfo_new(MODULATION_LFO_SINE, SV_G_0_001, sample_rate));
    return self;
}

# ---- setters --------------------------------------------------------------
#must_use
fn svara_glottal_set_f0(self, f0) {
    if (f64_lt(f0, f64_from(20)) == 1) { return SVARA_ERR_INVALID_PITCH; }
    if (f64_gt(f0, f64_from(2000)) == 1) { return SVARA_ERR_INVALID_PITCH; }
    SvGlottalSource_set_f0(self, f0);
    return SVARA_ERR_NONE;
}

# set_breathiness -- aspiration-noise mix, clamped [0,1].
fn svara_glottal_set_breathiness(self, amount) {
    SvGlottalSource_set_breathiness(self, f64_clamp(amount, 0, F64_ONE));
}

# set_open_quotient -- glottal open fraction, clamped [0.4,0.7].
fn svara_glottal_set_open_quotient(self, oq) {
    SvGlottalSource_set_open_quotient(self, f64_clamp(oq, SV_G_0_4, SV_G_0_7));
}

# set_speed_quotient -- opening/closing skew, clamped [0.5,5.0] (Rosenberg ignores it — v2.0 quirk).
fn svara_glottal_set_speed_quotient(self, sq) {
    SvGlottalSource_set_speed_quotient(self, f64_clamp(sq, F64_HALF, SV_G_5_0));
}

# set_jitter -- cycle-to-cycle period perturbation, clamped [0,0.05].
fn svara_glottal_set_jitter(self, j) {
    SvGlottalSource_set_jitter(self, f64_clamp(j, 0, SV_G_0_05));
}

# set_shimmer -- cycle-to-cycle amplitude perturbation, clamped [0,0.1].
fn svara_glottal_set_shimmer(self, s) {
    SvGlottalSource_set_shimmer(self, f64_clamp(s, 0, SV_G_0_1));
}

# set_spectral_tilt -- source high-frequency roll-off in dB/octave (signed).
fn svara_glottal_set_spectral_tilt(self, tilt) {
    SvGlottalSource_set_spectral_tilt(self, tilt);
}

# set_diplophonia -- alternating-pulse (period-doubling) amount, clamped [0,1].
fn svara_glottal_set_diplophonia(self, amount) {
    SvGlottalSource_set_diplophonia(self, f64_clamp(amount, 0, F64_ONE));
}

# set_model -- select the excitation model (SVARA_GLOTTAL_*).
fn svara_glottal_set_model(self, model) {
    SvGlottalSource_set_model(self, model);
}

# set_rd -- Rd clamped [0.3,2.7]; recompute LF params; switch model to LF.
fn svara_glottal_set_rd(self, rd) {
    var r = f64_clamp(rd, SV_G_0_3, SV_G_2_7);
    SvGlottalSource_set_rd(self, r);
    svara_glottal_apply_rd(self, r);
    SvGlottalSource_set_model(self, SVARA_GLOTTAL_LF);
}

# set_whisper -- noise-only excitation; reset tilt filter state.
fn svara_glottal_set_whisper(self) {
    SvGlottalSource_set_model(self, SVARA_GLOTTAL_WHISPER);
    SvGlottalSource_set_tilt_state(self, 0);
}

# set_creaky -- LF with very low Rd [0.3,0.8], irregular timing; reset tilt.
fn svara_glottal_set_creaky(self, rd) {
    var r = f64_clamp(rd, SV_G_0_3, SV_G_0_8);
    SvGlottalSource_set_rd(self, r);
    svara_glottal_apply_rd(self, r);
    SvGlottalSource_set_model(self, SVARA_GLOTTAL_CREAKY);
    SvGlottalSource_set_tilt_state(self, 0);
}

# set_vibrato -- rate Hz (>=0), depth fraction [0,0.5]. Updates the naad LFO.
fn svara_glottal_set_vibrato(self, rate, depth) {
    var r = f64_max(rate, 0);
    var d = f64_clamp(depth, 0, F64_HALF);
    SvGlottalSource_set_vibrato_rate(self, r);
    SvGlottalSource_set_vibrato_depth(self, d);
    if (f64_gt(r, 0) == 1) {
        var lfo = SvGlottalSource_vibrato_lfo(self);
        modulation_lfo_set_frequency(lfo, r);
        Lfo_set_depth(lfo, d);
    }
}

# ---- getters --------------------------------------------------------------
#must_use
fn svara_glottal_model(self) { return SvGlottalSource_model(self); }
#must_use
fn svara_glottal_rd(self) { return SvGlottalSource_rd(self); }
#inline
#must_use
fn svara_glottal_f0(self) { return SvGlottalSource_f0(self); }
#inline
#must_use
fn svara_glottal_sample_rate(self) { return SvGlottalSource_sample_rate(self); }
#inline
#must_use
fn svara_glottal_period_samples(self) { return SvGlottalSource_current_period(self); }

# ---- pulse models ---------------------------------------------------------
# rosenberg_pulse -- 3t'^2 - 2t'^3 over the open phase (t < open_quotient), else 0.
#inline
#must_use
fn svara_glottal_rosenberg_pulse(self, t) {
    var oq = SvGlottalSource_open_quotient(self);
    if (f64_lt(t, oq) == 1) {
        var tn = f64_div(t, oq);
        var tn2 = f64_mul(tn, tn);
        var tn3 = f64_mul(tn2, tn);
        # 3*tn^2 - 2*tn^3
        return f64_sub(f64_mul(f64_from(3), tn2), f64_mul(F64_TWO, tn3));
    }
    return 0;
}

# lf_pulse -- LF glottal-flow derivative: sinusoidal open phase to -Ee at te,
# exponential return over ta, then closed (0).
#inline
#must_use
fn svara_glottal_lf_pulse(self, t) {
    var te = SvGlottalSource_lf_te(self);
    var ta = SvGlottalSource_lf_ta(self);
    var ee = SvGlottalSource_lf_ee(self);
    if (f64_lt(t, te) == 1) {
        # -ee * sin(pi * t / te)
        var phase = f64_div(f64_mul(F64_PI, t), te);
        return f64_mul(f64_neg(ee), f64_sin(phase));
    }
    if (f64_lt(t, f64_add(te, ta)) == 1) {
        # -ee * exp(-(t-te)/epsilon), epsilon = max(ta, 0.001)
        var dt = f64_sub(t, te);
        var epsilon = f64_max(ta, SV_G_0_001);
        return f64_mul(f64_neg(ee), f64_exp(f64_neg(f64_div(dt, epsilon))));
    }
    return 0;
}

# whisper_sample -- noise-only with a steep (>=12 dB/oct) spectral tilt.
#inline
fn svara_glottal_whisper_sample(self) {
    var noise = noise_next_sample(SvGlottalSource_aspiration_noise(self));
    var tilt = f64_max(SvGlottalSource_spectral_tilt(self), f64_from(12));
    var alpha = f64_exp(f64_div(f64_neg(f64_mul(F64_TAU, tilt)), SvGlottalSource_sample_rate(self)));
    # filtered = (1-alpha)*noise*0.15 + alpha*tilt_state
    var filtered = f64_add(f64_mul(f64_mul(f64_sub(F64_ONE, alpha), noise), SV_G_0_15),
    f64_mul(alpha, SvGlottalSource_tilt_state(self)));
    SvGlottalSource_set_tilt_state(self, filtered);
    return filtered;
}

# new_period -- begin a new glottal cycle: vibrato -> jitter -> creaky period
# multiplication -> shimmer -> diplophonia. rng draw ORDER is load-bearing.
fn svara_glottal_new_period(self) {
    var vibrato_mod = F64_ONE;
    if (f64_gt(SvGlottalSource_vibrato_rate(self), 0) == 1) {
        var lfo_val = modulation_lfo_next_value(SvGlottalSource_vibrato_lfo(self));
        # 1 + depth * (lfo_val*2 - 1)
        vibrato_mod = f64_add(F64_ONE,
        f64_mul(SvGlottalSource_vibrato_depth(self), f64_sub(f64_mul(lfo_val, F64_TWO), F64_ONE)));
    }
    var effective_f0 = f64_mul(SvGlottalSource_f0(self), vibrato_mod);

    var rng = SvGlottalSource_rng(self);
    var base_period = f64_div(SvGlottalSource_sample_rate(self), effective_f0);
    var jitter_offset = f64_mul(f64_mul(svara_rng_next_f32(rng), SvGlottalSource_jitter(self)), base_period);
    var period = f64_max(f64_add(base_period, jitter_offset), F64_ONE);

    if (SvGlottalSource_model(self) == SVARA_GLOTTAL_CREAKY) {
        var r = f64_abs(svara_rng_next_f32(rng));
        if (f64_lt(r, SV_G_0_1) == 1) {
            period = f64_mul(period, f64_from(3));
        } elif (f64_lt(r, SV_G_0_4) == 1) {
            period = f64_mul(period, F64_TWO);
        }
    }
    SvGlottalSource_set_current_period(self, period);

    var shimmer_scale = SvGlottalSource_shimmer(self);
    if (SvGlottalSource_model(self) == SVARA_GLOTTAL_CREAKY) {
        shimmer_scale = f64_mul(shimmer_scale, f64_from(3));
    }
    var shimmer_offset = f64_mul(svara_rng_next_f32(rng), shimmer_scale);
    var amp = f64_max(f64_add(F64_ONE, shimmer_offset), SV_G_0_01);

    if (f64_gt(SvGlottalSource_diplophonia(self), 0) == 1) {
        SvGlottalSource_set_diplo_phase(self, 1 - SvGlottalSource_diplo_phase(self));
        if (SvGlottalSource_diplo_phase(self) == 1) {
            amp = f64_mul(amp, f64_sub(F64_ONE, f64_mul(SvGlottalSource_diplophonia(self), SV_G_0_8)));
        }
    }
    SvGlottalSource_set_current_amplitude(self, amp);
}

# next_sample -- one glottal-source sample. Whisper is pure noise; otherwise a
# model pulse with spectral tilt, shimmer, and gated aspiration-noise mix.
#inline
fn svara_glottal_next_sample(self) {
    if (SvGlottalSource_model(self) == SVARA_GLOTTAL_WHISPER) {
        return svara_glottal_whisper_sample(self);
    }

    var t = f64_div(SvGlottalSource_phase(self), SvGlottalSource_current_period(self));

    var pulse = 0;
    if (SvGlottalSource_model(self) == SVARA_GLOTTAL_ROSENBERG) {
        pulse = svara_glottal_rosenberg_pulse(self, t);
    } else {
        pulse = svara_glottal_lf_pulse(self, t);
    }

    # spectral tilt one-pole low-pass
    if (f64_gt(SvGlottalSource_spectral_tilt(self), 0) == 1) {
        var alpha = f64_exp(f64_div(f64_neg(f64_mul(F64_TAU, SvGlottalSource_spectral_tilt(self))),
        SvGlottalSource_sample_rate(self)));
        var filtered = f64_add(f64_mul(f64_sub(F64_ONE, alpha), pulse),
        f64_mul(alpha, SvGlottalSource_tilt_state(self)));
        SvGlottalSource_set_tilt_state(self, filtered);
        pulse = filtered;
    } else {
        SvGlottalSource_set_tilt_state(self, pulse);
    }

    pulse = f64_mul(pulse, SvGlottalSource_current_amplitude(self));

    var noise = noise_next_sample(SvGlottalSource_aspiration_noise(self));
    var noise_gate = SV_G_0_1;
    if (f64_lt(t, SvGlottalSource_open_quotient(self)) == 1) { noise_gate = F64_ONE; }
    var breath = SvGlottalSource_breathiness(self);
    # sample = pulse*(1-breath) + noise*breath*0.3*gate
    var sample = f64_add(f64_mul(pulse, f64_sub(F64_ONE, breath)),
    f64_mul(f64_mul(f64_mul(noise, breath), SV_G_0_3), noise_gate));

    var phase = f64_add(SvGlottalSource_phase(self), F64_ONE);
    if (f64_ge(phase, SvGlottalSource_current_period(self)) == 1) {
        phase = f64_sub(phase, SvGlottalSource_current_period(self));
        SvGlottalSource_set_phase(self, phase);
        svara_glottal_new_period(self);
    } else {
        SvGlottalSource_set_phase(self, phase);
    }
    return sample;
}

# --- tract.cyr ---

# tract.cyr -- vocal tract: shapes glottal excitation into speech.
# Ports rust-old/src/tract.rs (naad-backend path — the shipped 2.0.0 default).
# Pipeline: source-filter interaction feedback -> parallel FormantFilter -> nasal
# antiformant (naad Notch biquad, place-dependent) -> subglottal resonance (naad
# ~600 Hz bandpass) -> lip-radiation HPF -> gain. LOD (Quality) gates the stages.
# f32 -> f64 throughout. The fallback NasalAntiformant + sg_state/sg_coeff fields
# are dropped (naad-backend carries both filters). serde on VocalTract dropped
# (tracked in docs/development/roadmap.md).
#
# Requires (from the build/test unit): stdlib alloc/vec/math, hisab, goonj, naad
# (filter_biquad_new/process_sample/set_params/reset, FILTER_NOTCH/FILTER_BANDPASS),
# error.cyr, smooth.cyr, lod.cyr, formant.cyr, glottal.cyr.

var SV_T_LIP_DEFAULT = 0x3FEF0A3D70A3D70A;   # 0.97 default lip radiation coeff
var SV_T_0_05        = 0x3FA999999999999A;   # 0.05 default interaction + subglottal coupling
var SV_T_0_2         = 0x3FC999999999999A;   # 0.2  subglottal coupling clamp hi
var SV_T_0_3         = 0x3FD3333333333333;   # 0.3  interaction strength clamp hi

# Nasal antiformant defaults (Hz).
var SV_T_NASAL_FREQ_NEUTRAL = 250;   # neutral zero (used via f64_from)
var SV_T_NASAL_BW           = 100;   # nasal zero bandwidth (via f64_from)

# NasalPlace (was `enum NasalPlace`). Rust variant order: Bilabial, Alveolar,
# Velar, Neutral.
var SVARA_NASAL_BILABIAL = 0;   # /m/ ~750 Hz
var SVARA_NASAL_ALVEOLAR = 1;   # /n/ ~1450 Hz
var SVARA_NASAL_VELAR    = 2;   # /ŋ/ ~3000 Hz
var SVARA_NASAL_NEUTRAL  = 3;   # ~250 Hz

# antiformant_frequency -- nasal zero center for a place of articulation.
#must_use
fn svara_nasal_place_antiformant_frequency(place) {
    if (place == SVARA_NASAL_BILABIAL) { return f64_from(750); }
    if (place == SVARA_NASAL_ALVEOLAR) { return f64_from(1450); }
    if (place == SVARA_NASAL_VELAR) { return f64_from(3000); }
    return f64_from(250);   # Neutral
}

# VocalTract -- formant bank + nasal/subglottal biquads + lip radiation + gain.
#derive(accessors)
struct SvVocalTract {
    filter; nasal_coupling; nasal_antiformant; lip_prev; lip_radiation;
    interaction_strength; interaction_feedback; subglottal_coupling;
    subglottal_filter; gain; quality; sample_rate;
}

# new -- default neutral vowel (schwa), Full quality. `0` reads as +0.0.
#must_use
fn svara_tract_new(sample_rate) {
    var target = svara_vowel_target_from_vowel(SVARA_VOWEL_SCHWA);
    var filter = svara_formant_filter_new(svara_vowel_target_to_formants(target), sample_rate);
    if (svara_is_err(filter) == 1) {
        # absolute fallback: single 500 Hz formant
        var fb = vec_new();
        vec_push(fb, svara_formant_new(f64_from(500), f64_from(100), F64_ONE));
        filter = svara_formant_filter_new(fb, sample_rate);
    }

    var self = alloc(sizeof(SvVocalTract));
    SvVocalTract_set_filter(self, filter);
    SvVocalTract_set_nasal_coupling(self, svara_smooth_new(0, sample_rate));
    var nasal_q = f64_div(f64_from(SV_T_NASAL_FREQ_NEUTRAL), f64_from(SV_T_NASAL_BW));   # 2.5
    SvVocalTract_set_nasal_antiformant(self,
    filter_biquad_new(FILTER_NOTCH, sample_rate, f64_from(SV_T_NASAL_FREQ_NEUTRAL), nasal_q));
    SvVocalTract_set_lip_prev(self, 0);
    SvVocalTract_set_lip_radiation(self, SV_T_LIP_DEFAULT);
    SvVocalTract_set_interaction_strength(self, SV_T_0_05);
    SvVocalTract_set_interaction_feedback(self, 0);
    SvVocalTract_set_subglottal_coupling(self, SV_T_0_05);
    var sg_q = f64_div(f64_from(600), f64_from(80));   # 7.5
    SvVocalTract_set_subglottal_filter(self, filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_from(600), sg_q));
    SvVocalTract_set_gain(self, svara_smooth_new(F64_ONE, sample_rate));
    SvVocalTract_set_quality(self, SVARA_QUALITY_FULL);
    SvVocalTract_set_sample_rate(self, sample_rate);
    return self;
}

# ---- configuration --------------------------------------------------------
# set_formants -- rebuild the formant bank; returns SVARA_ERR_NONE or an error.
#must_use
fn svara_tract_set_formants(self, formants) {
    var f = svara_formant_filter_new(formants, SvVocalTract_sample_rate(self));
    if (svara_is_err(f) == 1) { return f; }
    SvVocalTract_set_filter(self, f);
    return SVARA_ERR_NONE;
}

#must_use
fn svara_tract_set_formants_from_target(self, target) {
    return svara_tract_set_formants(self, svara_vowel_target_to_formants(target));
}

#must_use
fn svara_tract_set_vowel(self, vowel) {
    return svara_tract_set_formants_from_target(self, svara_vowel_target_from_vowel(vowel));
}

# set_nasal_coupling -- velopharyngeal opening (smoothed), clamped [0,1].
fn svara_tract_set_nasal_coupling(self, coupling) {
    svara_smooth_set_target(SvVocalTract_nasal_coupling(self), f64_clamp(coupling, 0, F64_ONE));
}

# set_lip_radiation -- lip-radiation differentiator coefficient, clamped [0,1].
fn svara_tract_set_lip_radiation(self, coefficient) {
    SvVocalTract_set_lip_radiation(self, f64_clamp(coefficient, 0, F64_ONE));
}

# set_nasal_place -- retune the nasal antiformant (preserves filter state).
fn svara_tract_set_nasal_place(self, place) {
    var freq = svara_nasal_place_antiformant_frequency(place);
    var q = f64_div(freq, f64_from(SV_T_NASAL_BW));
    filter_biquad_set_params(SvVocalTract_nasal_antiformant(self), freq, q, 0);
}

# set_interaction_strength -- source-filter feedback amount, clamped [0,0.3].
fn svara_tract_set_interaction_strength(self, strength) {
    SvVocalTract_set_interaction_strength(self, f64_clamp(strength, 0, SV_T_0_3));
}

# set_subglottal_coupling -- subglottal-resonance coupling, clamped [0,0.2].
fn svara_tract_set_subglottal_coupling(self, strength) {
    SvVocalTract_set_subglottal_coupling(self, f64_clamp(strength, 0, SV_T_0_2));
}

# set_gain -- output gain (smoothed), floored at 0.
fn svara_tract_set_gain(self, gain) {
    svara_smooth_set_target(SvVocalTract_gain(self), f64_max(gain, 0));
}

# set_quality -- level-of-detail tier (SVARA_QUALITY_*) gating optional stages.
fn svara_tract_set_quality(self, quality) {
    SvVocalTract_set_quality(self, quality);
}

#must_use
fn svara_tract_quality(self) { return SvVocalTract_quality(self); }
#must_use
fn svara_tract_sample_rate(self) { return SvVocalTract_sample_rate(self); }

# ---- processing -----------------------------------------------------------
# process_sample -- one excitation sample through the full (LOD-gated) pipeline.
#inline
fn svara_tract_process_sample(self, input) {
    var q = SvVocalTract_quality(self);

    # source-filter interaction: feed a fraction of last output back
    var excitation = input;
    if (svara_quality_use_interaction(q) == 1) {
        excitation = f64_sub(input,
        f64_mul(SvVocalTract_interaction_strength(self), SvVocalTract_interaction_feedback(self)));
    }

    var formant_out = svara_formant_filter_process_sample(SvVocalTract_filter(self), excitation);

    # nasal coupling: blend oral vs nasalized (smoother always advances)
    var nc = svara_smooth_next(SvVocalTract_nasal_coupling(self));
    var output = formant_out;
    if ((svara_quality_use_nasal_coupling(q) == 1) & (f64_gt(nc, 0) == 1)) {
        var nasal = filter_biquad_process_sample(SvVocalTract_nasal_antiformant(self), formant_out);
        output = f64_add(f64_mul(formant_out, f64_sub(F64_ONE, nc)), f64_mul(nasal, nc));
    }

    # subglottal resonance coupling
    if ((svara_quality_use_subglottal(q) == 1) & (f64_gt(SvVocalTract_subglottal_coupling(self), 0) == 1)) {
        var sg_out = filter_biquad_process_sample(SvVocalTract_subglottal_filter(self), output);
        output = f64_add(output, f64_mul(sg_out, SvVocalTract_subglottal_coupling(self)));
    }

    # lip radiation: first-order high-pass difference
    var radiated = output;
    if (svara_quality_use_lip_radiation(q) == 1) {
        radiated = f64_sub(output, f64_mul(SvVocalTract_lip_radiation(self), SvVocalTract_lip_prev(self)));
        SvVocalTract_set_lip_prev(self, output);
    }

    SvVocalTract_set_interaction_feedback(self, radiated);
    return f64_mul(radiated, svara_smooth_next(SvVocalTract_gain(self)));
}

# synthesize_into -- fill an n-slot f64 buffer from a glottal source.
fn svara_tract_synthesize_into(self, glottal, output, n) {
    var i = 0;
    while (i < n) {
        var exc = svara_glottal_next_sample(glottal);
        store64(output + i * 8, svara_tract_process_sample(self, exc));
        i = i + 1;
    }
}

# synthesize -- allocate an n-slot f64 buffer and fill it.
#must_use
fn svara_tract_synthesize(self, glottal, n) {
    var out = alloc(n * 8);
    svara_tract_synthesize_into(self, glottal, out, n);
    return out;
}

# reset -- clear filter history + feedback state.
fn svara_tract_reset(self) {
    svara_formant_filter_reset(SvVocalTract_filter(self));
    filter_biquad_reset(SvVocalTract_nasal_antiformant(self));
    SvVocalTract_set_lip_prev(self, 0);
    SvVocalTract_set_interaction_feedback(self, 0);
    filter_biquad_reset(SvVocalTract_subglottal_filter(self));
}

# --- voice.cyr ---

# voice.cyr -- speaker voice profiles + vocal effort.
# Ports rust-old/src/voice.rs. VoiceProfile captures the acoustic parameters
# distinguishing speakers (f0, formant scaling, breathiness, vibrato, jitter/
# shimmer); VocalEffort maps a whisper..shout continuum to coordinated glottal
# parameters. f32 -> f64 throughout. Builders mutate the profile in place and
# return it (Rust's `mut self` chain). serde dropped (M-serde; roadmap.md).
#
# Requires (from the build/test unit): stdlib alloc/math, error.cyr, formant.cyr
# (VowelTarget + with_bandwidths), glottal.cyr (GlottalSource + SVARA_GLOTTAL_*).

# VocalEffort levels (was `enum VocalEffort`). Rust variant order.
var SVARA_EFFORT_WHISPER = 0;
var SVARA_EFFORT_SOFT    = 1;
var SVARA_EFFORT_NORMAL  = 2;
var SVARA_EFFORT_LOUD    = 3;
var SVARA_EFFORT_SHOUT   = 4;

# f64 literals (bit patterns) for speaker/effort parameters.
var SV_V_0008 = 0x3F80624DD2F1A9FC;   # 0.008
var SV_V_001  = 0x3F847AE147AE147B;   # 0.01
var SV_V_0012 = 0x3F889374BC6A7EFA;   # 0.012
var SV_V_0018 = 0x3F926E978D4FDF3B;   # 0.018
var SV_V_002  = 0x3F947AE147AE147B;   # 0.02
var SV_V_0025 = 0x3F9999999999999A;   # 0.025
var SV_V_003  = 0x3F9EB851EB851EB8;   # 0.03
var SV_V_004  = 0x3FA47AE147AE147B;   # 0.04
var SV_V_005  = 0x3FA999999999999A;   # 0.05
var SV_V_01   = 0x3FB999999999999A;   # 0.1
var SV_V_015  = 0x3FC3333333333333;   # 0.15
var SV_V_03   = 0x3FD3333333333333;   # 0.3
var SV_V_06   = 0x3FE3333333333333;   # 0.6
var SV_V_08   = 0x3FE999999999999A;   # 0.8
var SV_V_09   = 0x3FECCCCCCCCCCCCD;   # 0.9
var SV_V_11   = 0x3FF199999999999A;   # 1.1
var SV_V_117  = 0x3FF2B851EB851EB8;   # 1.17
var SV_V_12   = 0x3FF3333333333333;   # 1.2
var SV_V_13   = 0x3FF4CCCCCCCCCCCD;   # 1.3
var SV_V_16   = 0x3FF999999999999A;   # 1.6
var SV_V_27   = 0x400599999999999A;   # 2.7
var SV_V_55   = 0x4016000000000000;   # 5.5

# EffortParams -- coordinated acoustic changes for a vocal-effort level.
#derive(accessors)
#derive(Serialize)
struct SvEffortParams {
    model: i64; rd: f64; breathiness: f64; spectral_tilt: f64;
    f0_range_scale: f64; bandwidth_scale: f64; jitter_scale: f64; shimmer_scale: f64;
}

# VoiceProfile -- a speaker's voice characteristics.
#derive(accessors)
#derive(Serialize)
struct SvVoiceProfile {
    base_f0: f64; f0_range: f64; formant_scale: f64; breathiness: f64;
    vibrato_rate: f64; vibrato_depth: f64; jitter: f64; shimmer: f64; bandwidth_widening: f64;
}

# params -- coordinated parameters for an effort level (Traunmüller & Eriksson 2000).
#must_use
fn svara_effort_params(effort) {
    var p = alloc(sizeof(SvEffortParams));
    if (effort == SVARA_EFFORT_WHISPER) {
        SvEffortParams_set_model(p, SVARA_GLOTTAL_WHISPER);
        SvEffortParams_set_rd(p, SV_V_27);
        SvEffortParams_set_breathiness(p, F64_ONE);
        SvEffortParams_set_spectral_tilt(p, f64_from(12));
        SvEffortParams_set_f0_range_scale(p, F64_HALF);
        SvEffortParams_set_bandwidth_scale(p, SV_V_13);
        SvEffortParams_set_jitter_scale(p, 0);
        SvEffortParams_set_shimmer_scale(p, 0);
        return p;
    }
    if (effort == SVARA_EFFORT_SOFT) {
        SvEffortParams_set_model(p, SVARA_GLOTTAL_LF);
        SvEffortParams_set_rd(p, F64_TWO);
        SvEffortParams_set_breathiness(p, SV_V_015);
        SvEffortParams_set_spectral_tilt(p, f64_from(6));
        SvEffortParams_set_f0_range_scale(p, SV_V_08);
        SvEffortParams_set_bandwidth_scale(p, SV_V_11);
        SvEffortParams_set_jitter_scale(p, SV_V_12);
        SvEffortParams_set_shimmer_scale(p, SV_V_12);
        return p;
    }
    if (effort == SVARA_EFFORT_NORMAL) {
        SvEffortParams_set_model(p, SVARA_GLOTTAL_LF);
        SvEffortParams_set_rd(p, F64_ONE);
        SvEffortParams_set_breathiness(p, SV_V_002);
        SvEffortParams_set_spectral_tilt(p, F64_TWO);
        SvEffortParams_set_f0_range_scale(p, F64_ONE);
        SvEffortParams_set_bandwidth_scale(p, F64_ONE);
        SvEffortParams_set_jitter_scale(p, F64_ONE);
        SvEffortParams_set_shimmer_scale(p, F64_ONE);
        return p;
    }
    if (effort == SVARA_EFFORT_LOUD) {
        SvEffortParams_set_model(p, SVARA_GLOTTAL_LF);
        SvEffortParams_set_rd(p, SV_V_06);
        SvEffortParams_set_breathiness(p, 0);
        SvEffortParams_set_spectral_tilt(p, 0);
        SvEffortParams_set_f0_range_scale(p, SV_V_13);
        SvEffortParams_set_bandwidth_scale(p, SV_V_09);
        SvEffortParams_set_jitter_scale(p, SV_V_08);
        SvEffortParams_set_shimmer_scale(p, SV_V_08);
        return p;
    }
    # SHOUT
    SvEffortParams_set_model(p, SVARA_GLOTTAL_LF);
    SvEffortParams_set_rd(p, SV_V_03);
    SvEffortParams_set_breathiness(p, 0);
    SvEffortParams_set_spectral_tilt(p, 0);
    SvEffortParams_set_f0_range_scale(p, SV_V_16);
    SvEffortParams_set_bandwidth_scale(p, SV_V_08);
    SvEffortParams_set_jitter_scale(p, F64_HALF);
    SvEffortParams_set_shimmer_scale(p, F64_HALF);
    return p;
}

# ---- presets --------------------------------------------------------------
#must_use
fn svara_voice_new_male() {
    var self = alloc(sizeof(SvVoiceProfile));
    SvVoiceProfile_set_base_f0(self, f64_from(120));
    SvVoiceProfile_set_f0_range(self, f64_from(40));
    SvVoiceProfile_set_formant_scale(self, F64_ONE);
    SvVoiceProfile_set_breathiness(self, SV_V_002);
    SvVoiceProfile_set_vibrato_rate(self, f64_from(5));
    SvVoiceProfile_set_vibrato_depth(self, SV_V_004);
    SvVoiceProfile_set_jitter(self, SV_V_001);
    SvVoiceProfile_set_shimmer(self, SV_V_002);
    SvVoiceProfile_set_bandwidth_widening(self, 0);
    return self;
}

#must_use
fn svara_voice_new_female() {
    var self = alloc(sizeof(SvVoiceProfile));
    SvVoiceProfile_set_base_f0(self, f64_from(220));
    SvVoiceProfile_set_f0_range(self, f64_from(50));
    SvVoiceProfile_set_formant_scale(self, SV_V_117);
    SvVoiceProfile_set_breathiness(self, SV_V_005);
    SvVoiceProfile_set_vibrato_rate(self, SV_V_55);
    SvVoiceProfile_set_vibrato_depth(self, SV_V_005);
    SvVoiceProfile_set_jitter(self, SV_V_0008);
    SvVoiceProfile_set_shimmer(self, SV_V_0018);
    SvVoiceProfile_set_bandwidth_widening(self, 0);
    return self;
}

#must_use
fn svara_voice_new_child() {
    var self = alloc(sizeof(SvVoiceProfile));
    SvVoiceProfile_set_base_f0(self, f64_from(300));
    SvVoiceProfile_set_f0_range(self, f64_from(60));
    SvVoiceProfile_set_formant_scale(self, SV_V_13);
    SvVoiceProfile_set_breathiness(self, SV_V_003);
    SvVoiceProfile_set_vibrato_rate(self, f64_from(6));
    SvVoiceProfile_set_vibrato_depth(self, SV_V_003);
    SvVoiceProfile_set_jitter(self, SV_V_0012);
    SvVoiceProfile_set_shimmer(self, SV_V_0025);
    SvVoiceProfile_set_bandwidth_widening(self, 0);
    return self;
}

#must_use
fn svara_voice_default() { return svara_voice_new_male(); }

# ---- builders (mutate + return self) --------------------------------------
#must_use
fn svara_voice_with_f0(self, f0) { SvVoiceProfile_set_base_f0(self, f0); return self; }
#must_use
fn svara_voice_with_breathiness(self, b) {
    SvVoiceProfile_set_breathiness(self, f64_clamp(b, 0, F64_ONE)); return self;
}
#must_use
fn svara_voice_with_vibrato_rate(self, rate) {
    SvVoiceProfile_set_vibrato_rate(self, f64_max(rate, 0)); return self;
}
#must_use
fn svara_voice_with_vibrato_depth(self, depth) {
    SvVoiceProfile_set_vibrato_depth(self, f64_clamp(depth, 0, F64_HALF)); return self;
}
#must_use
fn svara_voice_with_jitter(self, j) {
    SvVoiceProfile_set_jitter(self, f64_clamp(j, 0, SV_V_005)); return self;
}
#must_use
fn svara_voice_with_shimmer(self, s) {
    SvVoiceProfile_set_shimmer(self, f64_clamp(s, 0, SV_V_01)); return self;
}
#must_use
fn svara_voice_with_formant_scale(self, scale) {
    SvVoiceProfile_set_formant_scale(self, f64_max(scale, SV_V_01)); return self;
}
#must_use
fn svara_voice_with_f0_range(self, range) {
    SvVoiceProfile_set_f0_range(self, f64_max(range, 0)); return self;
}
#must_use
fn svara_voice_with_bandwidth_widening(self, factor) {
    SvVoiceProfile_set_bandwidth_widening(self, f64_clamp(factor, 0, F64_TWO)); return self;
}

# with_effort -- override breathiness + scale jitter/shimmer/f0_range to match effort.
#must_use
fn svara_voice_with_effort(self, effort) {
    var p = svara_effort_params(effort);
    SvVoiceProfile_set_breathiness(self, SvEffortParams_breathiness(p));
    SvVoiceProfile_set_jitter(self, f64_mul(SvVoiceProfile_jitter(self), SvEffortParams_jitter_scale(p)));
    SvVoiceProfile_set_shimmer(self, f64_mul(SvVoiceProfile_shimmer(self), SvEffortParams_shimmer_scale(p)));
    SvVoiceProfile_set_f0_range(self, f64_mul(SvVoiceProfile_f0_range(self), SvEffortParams_f0_range_scale(p)));
    return self;
}

# ---- glottal-source construction ------------------------------------------
# create_glottal_source -- GlottalSource from the profile. Returns ptr or neg error.
#must_use
fn svara_voice_create_glottal_source(self, sample_rate) {
    var gs = svara_glottal_new(SvVoiceProfile_base_f0(self), sample_rate);
    if (svara_is_err(gs) == 1) { return gs; }
    svara_glottal_set_breathiness(gs, SvVoiceProfile_breathiness(self));
    svara_glottal_set_jitter(gs, SvVoiceProfile_jitter(self));
    svara_glottal_set_shimmer(gs, SvVoiceProfile_shimmer(self));
    svara_glottal_set_vibrato(gs, SvVoiceProfile_vibrato_rate(self), SvVoiceProfile_vibrato_depth(self));
    return gs;
}

# create_glottal_source_with_effort -- as above + effort model/tilt/scaling.
#must_use
fn svara_voice_create_glottal_source_with_effort(self, effort, sample_rate) {
    var p = svara_effort_params(effort);
    var gs = svara_glottal_new(SvVoiceProfile_base_f0(self), sample_rate);
    if (svara_is_err(gs) == 1) { return gs; }
    svara_glottal_set_breathiness(gs, SvEffortParams_breathiness(p));
    svara_glottal_set_jitter(gs, f64_mul(SvVoiceProfile_jitter(self), SvEffortParams_jitter_scale(p)));
    svara_glottal_set_shimmer(gs, f64_mul(SvVoiceProfile_shimmer(self), SvEffortParams_shimmer_scale(p)));
    svara_glottal_set_spectral_tilt(gs, SvEffortParams_spectral_tilt(p));
    svara_glottal_set_vibrato(gs, SvVoiceProfile_vibrato_rate(self), SvVoiceProfile_vibrato_depth(self));
    var model = SvEffortParams_model(p);
    if (model == SVARA_GLOTTAL_WHISPER) { svara_glottal_set_whisper(gs); }
    elif (model == SVARA_GLOTTAL_CREAKY) { svara_glottal_set_creaky(gs, SvEffortParams_rd(p)); }
    elif (model == SVARA_GLOTTAL_LF) { svara_glottal_set_rd(gs, SvEffortParams_rd(p)); }
    else { svara_glottal_set_model(gs, SVARA_GLOTTAL_ROSENBERG); }
    return gs;
}

# ---- formant scaling ------------------------------------------------------
# apply_formant_scale -- scale frequencies by formant_scale, bandwidths by
# sqrt(f0/120) (+ optional singing widening at f0>300). Returns a new VowelTarget.
#must_use
fn svara_voice_apply_formant_scale(self, target) {
    var f0 = SvVoiceProfile_base_f0(self);
    var bw_scale = f64_sqrt(f64_div(f0, f64_from(120)));
    if ((f64_gt(SvVoiceProfile_bandwidth_widening(self), 0) == 1) & (f64_gt(f0, f64_from(300)) == 1)) {
        var extra = f64_add(F64_ONE, f64_mul(SV_V_03, f64_div(f64_sub(f0, f64_from(300)), f64_from(500))));
        bw_scale = f64_mul(bw_scale,
        f64_add(F64_ONE, f64_mul(SvVoiceProfile_bandwidth_widening(self), f64_sub(extra, F64_ONE))));
    }
    var fs = SvVoiceProfile_formant_scale(self);
    return svara_vowel_target_with_bandwidths(
    f64_mul(SvVowelTarget_f1(target), fs), f64_mul(SvVowelTarget_f2(target), fs),
    f64_mul(SvVowelTarget_f3(target), fs), f64_mul(SvVowelTarget_f4(target), fs),
    f64_mul(SvVowelTarget_f5(target), fs),
    f64_mul(SvVowelTarget_b1(target), bw_scale), f64_mul(SvVowelTarget_b2(target), bw_scale),
    f64_mul(SvVowelTarget_b3(target), bw_scale), f64_mul(SvVowelTarget_b4(target), bw_scale),
    f64_mul(SvVowelTarget_b5(target), bw_scale));
}

# apply_formant_scale_with_effort -- apply_formant_scale then effort bandwidth factor.
#must_use
fn svara_voice_apply_formant_scale_with_effort(self, target, effort) {
    var base = svara_voice_apply_formant_scale(self, target);
    var ebw = SvEffortParams_bandwidth_scale(svara_effort_params(effort));
    return svara_vowel_target_with_bandwidths(
    SvVowelTarget_f1(base), SvVowelTarget_f2(base), SvVowelTarget_f3(base),
    SvVowelTarget_f4(base), SvVowelTarget_f5(base),
    f64_mul(SvVowelTarget_b1(base), ebw), f64_mul(SvVowelTarget_b2(base), ebw),
    f64_mul(SvVowelTarget_b3(base), ebw), f64_mul(SvVowelTarget_b4(base), ebw),
    f64_mul(SvVowelTarget_b5(base), ebw));
}

# --- phoneme.cyr ---

# phoneme.cyr -- IPA phoneme inventory + articulatory classification.
# Ports rust-old/src/phoneme.rs. This is the crate's largest module; it is
# ported in layers:
#   PART 1 (this bite): the 101-phoneme inventory (Phoneme enum -> integer
#     constants, in exact Rust order so indices match), PhonemeClass, and the
#     pure classification/lookup functions: class / is_voiced /
#     coarticulation_resistance. No external deps beyond error.cyr.
#   PART 2 (next): the data tables -- phoneme_formants / phoneme_duration /
#     phoneme_spectral_tilt / height_adjusted_amplitudes / f2_locus_equation /
#     VoiceOnsetTime / Nasalization -- as embedded Cyrius (like formant's
#     from_vowel), NOT externalized (a synth lib shouldn't need a runtime data file).
#   PART 3 (after voice.cyr): the per-class synthesis functions + SynthesisContext.
#
# f32 -> f64 throughout. serde on Phoneme/PhonemeClass dropped (the actual serde
# surface -- config/state types -- is tracked in docs/development/roadmap.md M-serde).

# ================================================================
# Phoneme inventory (was `enum Phoneme`) -> integer constants 0..100, in exact
# Rust variant order so any index/serialization mapping matches the oracle.
# ================================================================
# Vowels (0-14)
var SVARA_PH_VOWEL_A = 0;   var SVARA_PH_VOWEL_E = 1;   var SVARA_PH_VOWEL_I = 2;
var SVARA_PH_VOWEL_O = 3;   var SVARA_PH_VOWEL_U = 4;   var SVARA_PH_VOWEL_SCHWA = 5;
var SVARA_PH_VOWEL_OPEN_O = 6;   var SVARA_PH_VOWEL_ASH = 7;   var SVARA_PH_VOWEL_NEAR_I = 8;
var SVARA_PH_VOWEL_NEAR_U = 9;   var SVARA_PH_VOWEL_OPEN_A = 10;   var SVARA_PH_VOWEL_OPEN_E = 11;
var SVARA_PH_VOWEL_CUP_V = 12;   var SVARA_PH_VOWEL_BIRD = 13;   var SVARA_PH_VOWEL_LONG_I = 14;
# Diphthongs (15-19)
var SVARA_PH_DIPH_AI = 15;   var SVARA_PH_DIPH_AU = 16;   var SVARA_PH_DIPH_OI = 17;
var SVARA_PH_DIPH_EI = 18;   var SVARA_PH_DIPH_OU = 19;
# Plosives (20-25)
var SVARA_PH_PLOSIVE_P = 20;   var SVARA_PH_PLOSIVE_B = 21;   var SVARA_PH_PLOSIVE_T = 22;
var SVARA_PH_PLOSIVE_D = 23;   var SVARA_PH_PLOSIVE_K = 24;   var SVARA_PH_PLOSIVE_G = 25;
# Fricatives (26-34)
var SVARA_PH_FRIC_F = 26;   var SVARA_PH_FRIC_V = 27;   var SVARA_PH_FRIC_S = 28;
var SVARA_PH_FRIC_Z = 29;   var SVARA_PH_FRIC_SH = 30;   var SVARA_PH_FRIC_ZH = 31;
var SVARA_PH_FRIC_TH = 32;   var SVARA_PH_FRIC_DH = 33;   var SVARA_PH_FRIC_H = 34;
# Nasals (35-37)
var SVARA_PH_NASAL_M = 35;   var SVARA_PH_NASAL_N = 36;   var SVARA_PH_NASAL_NG = 37;
# Affricates (38-39)
var SVARA_PH_AFFR_CH = 38;   var SVARA_PH_AFFR_J = 39;
# Glottal / Tap (40-41)
var SVARA_PH_GLOTTAL_STOP = 40;   var SVARA_PH_TAP_FLAP = 41;
# Approximants / lateral (42-45)
var SVARA_PH_LATERAL_L = 42;   var SVARA_PH_APPROX_R = 43;   var SVARA_PH_APPROX_W = 44;
var SVARA_PH_APPROX_J = 45;
# IPA additional vowels (46-52)
var SVARA_PH_VOWEL_Y = 46;   var SVARA_PH_VOWEL_FRONT_ROUND_O = 47;   var SVARA_PH_VOWEL_OPEN_FRONT_ROUND_O = 48;
var SVARA_PH_VOWEL_CLOSE_BACK_UNROUNDED = 49;   var SVARA_PH_VOWEL_MID_BACK_UNROUNDED = 50;
var SVARA_PH_VOWEL_CLOSE_CENTRAL = 51;   var SVARA_PH_VOWEL_CLOSE_CENTRAL_ROUNDED = 52;
# Uvular / retroflex plosives (53-56)
var SVARA_PH_PLOSIVE_UVULAR_Q = 53;   var SVARA_PH_PLOSIVE_UVULAR_G = 54;
var SVARA_PH_PLOSIVE_RETRO_T = 55;   var SVARA_PH_PLOSIVE_RETRO_D = 56;
# Additional fricatives (57-69)
var SVARA_PH_FRIC_BILABIAL_PH = 57;   var SVARA_PH_FRIC_BILABIAL_B = 58;   var SVARA_PH_FRIC_PALATAL_C = 59;
var SVARA_PH_FRIC_PALATAL_J = 60;   var SVARA_PH_FRIC_UVULAR_CH = 61;   var SVARA_PH_FRIC_UVULAR_R = 62;
var SVARA_PH_FRIC_PHARYNGEAL_H = 63;   var SVARA_PH_FRIC_PHARYNGEAL_A = 64;   var SVARA_PH_FRIC_RETRO_S = 65;
var SVARA_PH_FRIC_RETRO_Z = 66;   var SVARA_PH_FRIC_LATERAL_S = 67;   var SVARA_PH_FRIC_LATERAL_Z = 68;
var SVARA_PH_FRIC_GLOTTAL_H = 69;
# Additional nasals (70-72)
var SVARA_PH_NASAL_RETRO = 70;   var SVARA_PH_NASAL_PALATAL = 71;   var SVARA_PH_NASAL_UVULAR = 72;
# Trills (73-75)
var SVARA_PH_TRILL_BILABIAL = 73;   var SVARA_PH_TRILL_ALVEOLAR = 74;   var SVARA_PH_TRILL_UVULAR = 75;
# Additional approximants / laterals (76-78)
var SVARA_PH_APPROX_RETRO = 76;   var SVARA_PH_LATERAL_PALATAL = 77;   var SVARA_PH_LATERAL_VELAR = 78;
# Additional flaps (79-80)
var SVARA_PH_FLAP_RETRO = 79;   var SVARA_PH_FLAP_LATERAL = 80;
# Additional affricates (81-86)
var SVARA_PH_AFFR_TS = 81;   var SVARA_PH_AFFR_DZ = 82;   var SVARA_PH_AFFR_RETRO = 83;
var SVARA_PH_AFFR_RETRO_VOICED = 84;   var SVARA_PH_AFFR_PF = 85;   var SVARA_PH_AFFR_LATERAL = 86;
# Clicks (87-91)
var SVARA_PH_CLICK_BILABIAL = 87;   var SVARA_PH_CLICK_DENTAL = 88;   var SVARA_PH_CLICK_ALVEOLAR = 89;
var SVARA_PH_CLICK_PALATAL = 90;   var SVARA_PH_CLICK_LATERAL = 91;
# Ejectives (92-96)
var SVARA_PH_EJECTIVE_P = 92;   var SVARA_PH_EJECTIVE_T = 93;   var SVARA_PH_EJECTIVE_K = 94;
var SVARA_PH_EJECTIVE_S = 95;   var SVARA_PH_EJECTIVE_CH = 96;
# Implosives (97-99)
var SVARA_PH_IMPLOSIVE_B = 97;   var SVARA_PH_IMPLOSIVE_D = 98;   var SVARA_PH_IMPLOSIVE_G = 99;
# Silence (100)
var SVARA_PH_SILENCE = 100;

var SVARA_PHONEME_COUNT = 101;

# ================================================================
# PhonemeClass (was `enum PhonemeClass`) -> integer constants 0..12.
# ================================================================
var SVARA_CLASS_PLOSIVE = 0;   var SVARA_CLASS_FRICATIVE = 1;   var SVARA_CLASS_NASAL = 2;
var SVARA_CLASS_APPROXIMANT = 3;   var SVARA_CLASS_AFFRICATE = 4;   var SVARA_CLASS_LATERAL = 5;
var SVARA_CLASS_VOWEL = 6;   var SVARA_CLASS_DIPHTHONG = 7;   var SVARA_CLASS_TRILL = 8;
var SVARA_CLASS_CLICK = 9;   var SVARA_CLASS_EJECTIVE = 10;   var SVARA_CLASS_IMPLOSIVE = 11;
var SVARA_CLASS_SILENCE = 12;

# Coarticulation-resistance values (Recasens 1999 DAC), f64 bit patterns.
var SV_PH_R01  = 0x3FB999999999999A;   # 0.10
var SV_PH_R015 = 0x3FC3333333333333;   # 0.15
var SV_PH_R02  = 0x3FC999999999999A;   # 0.20
var SV_PH_R04  = 0x3FD999999999999A;   # 0.40
var SV_PH_R05  = 0x3FE0000000000000;   # 0.50
var SV_PH_R055 = 0x3FE199999999999A;   # 0.55
var SV_PH_R06  = 0x3FE3333333333333;   # 0.60
var SV_PH_R065 = 0x3FE4CCCCCCCCCCCD;   # 0.65
var SV_PH_R07  = 0x3FE6666666666666;   # 0.70
var SV_PH_R075 = 0x3FE8000000000000;   # 0.75
var SV_PH_R085 = 0x3FEB333333333333;   # 0.85
var SV_PH_R09  = 0x3FECCCCCCCCCCCCD;   # 0.90

# ================================================================
# class -- articulatory class of a phoneme. Range-based over the ordered
# inventory (contiguous class runs), with the scattered specials explicit.
# ================================================================
#must_use
fn svara_phoneme_class(p) {
    if (p <= 14) { return SVARA_CLASS_VOWEL; }                       # 0-14 vowels
    if ((p >= 15) & (p <= 19)) { return SVARA_CLASS_DIPHTHONG; }     # 15-19
    if ((p >= 20) & (p <= 25)) { return SVARA_CLASS_PLOSIVE; }       # 20-25
    if ((p >= 26) & (p <= 34)) { return SVARA_CLASS_FRICATIVE; }     # 26-34
    if ((p >= 35) & (p <= 37)) { return SVARA_CLASS_NASAL; }         # 35-37
    if ((p >= 38) & (p <= 39)) { return SVARA_CLASS_AFFRICATE; }     # 38-39
    if (p == SVARA_PH_GLOTTAL_STOP) { return SVARA_CLASS_PLOSIVE; }  # 40
    if (p == SVARA_PH_TAP_FLAP) { return SVARA_CLASS_PLOSIVE; }      # 41
    if (p == SVARA_PH_LATERAL_L) { return SVARA_CLASS_LATERAL; }     # 42
    if ((p >= 43) & (p <= 45)) { return SVARA_CLASS_APPROXIMANT; }   # 43-45
    if ((p >= 46) & (p <= 52)) { return SVARA_CLASS_VOWEL; }         # 46-52 IPA vowels
    if ((p >= 53) & (p <= 56)) { return SVARA_CLASS_PLOSIVE; }       # 53-56 uvular/retroflex
    if ((p >= 57) & (p <= 69)) { return SVARA_CLASS_FRICATIVE; }     # 57-69
    if ((p >= 70) & (p <= 72)) { return SVARA_CLASS_NASAL; }         # 70-72
    if ((p >= 73) & (p <= 75)) { return SVARA_CLASS_TRILL; }         # 73-75
    if (p == SVARA_PH_APPROX_RETRO) { return SVARA_CLASS_APPROXIMANT; }  # 76
    if ((p >= 77) & (p <= 78)) { return SVARA_CLASS_LATERAL; }       # 77-78
    if ((p >= 79) & (p <= 80)) { return SVARA_CLASS_PLOSIVE; }       # 79-80 flaps (short contacts)
    if ((p >= 81) & (p <= 86)) { return SVARA_CLASS_AFFRICATE; }     # 81-86
    if ((p >= 87) & (p <= 91)) { return SVARA_CLASS_CLICK; }         # 87-91
    if ((p >= 92) & (p <= 96)) { return SVARA_CLASS_EJECTIVE; }      # 92-96
    if ((p >= 97) & (p <= 99)) { return SVARA_CLASS_IMPLOSIVE; }     # 97-99
    return SVARA_CLASS_SILENCE;                                      # 100
}

# ================================================================
# is_voiced -- 1 if voiced, 0 if voiceless. Voiceless set is explicit
# (clicks 87-91 + ejectives 92-96 grouped); everything else is voiced.
# ================================================================
#must_use
fn svara_phoneme_is_voiced(p) {
    if ((p >= 87) & (p <= 96)) { return 0; }   # clicks + ejectives
    if (p == SVARA_PH_SILENCE) { return 0; }
    if (p == SVARA_PH_PLOSIVE_P) { return 0; }
    if (p == SVARA_PH_PLOSIVE_T) { return 0; }
    if (p == SVARA_PH_PLOSIVE_K) { return 0; }
    if (p == SVARA_PH_PLOSIVE_UVULAR_Q) { return 0; }
    if (p == SVARA_PH_PLOSIVE_RETRO_T) { return 0; }
    if (p == SVARA_PH_FRIC_F) { return 0; }
    if (p == SVARA_PH_FRIC_S) { return 0; }
    if (p == SVARA_PH_FRIC_SH) { return 0; }
    if (p == SVARA_PH_FRIC_TH) { return 0; }
    if (p == SVARA_PH_FRIC_H) { return 0; }
    if (p == SVARA_PH_FRIC_BILABIAL_PH) { return 0; }
    if (p == SVARA_PH_FRIC_PALATAL_C) { return 0; }
    if (p == SVARA_PH_FRIC_UVULAR_CH) { return 0; }
    if (p == SVARA_PH_FRIC_PHARYNGEAL_H) { return 0; }
    if (p == SVARA_PH_FRIC_RETRO_S) { return 0; }
    if (p == SVARA_PH_FRIC_LATERAL_S) { return 0; }
    if (p == SVARA_PH_AFFR_CH) { return 0; }
    if (p == SVARA_PH_AFFR_TS) { return 0; }
    if (p == SVARA_PH_AFFR_RETRO) { return 0; }
    if (p == SVARA_PH_AFFR_PF) { return 0; }
    if (p == SVARA_PH_AFFR_LATERAL) { return 0; }
    if (p == SVARA_PH_GLOTTAL_STOP) { return 0; }
    return 1;
}

# ================================================================
# coarticulation_resistance -- Recasens (1999) DAC. Explicit per-phoneme arms,
# then a class-based default for the IPA-extension phonemes. `0` == 0.0.
# ================================================================
#must_use
fn svara_phoneme_coarticulation_resistance(p) {
    if ((p == SVARA_PH_VOWEL_I) | (p == SVARA_PH_VOWEL_LONG_I) | (p == SVARA_PH_VOWEL_NEAR_I)) { return SV_PH_R09; }
    if ((p == SVARA_PH_VOWEL_U) | (p == SVARA_PH_VOWEL_NEAR_U)) { return SV_PH_R085; }
    if ((p == SVARA_PH_FRIC_S) | (p == SVARA_PH_FRIC_Z)
    | (p == SVARA_PH_FRIC_SH) | (p == SVARA_PH_FRIC_ZH)) { return SV_PH_R085; }
    if ((p == SVARA_PH_AFFR_CH) | (p == SVARA_PH_AFFR_J)) { return SV_PH_R085; }
    if ((p == SVARA_PH_VOWEL_A) | (p == SVARA_PH_VOWEL_OPEN_A) | (p == SVARA_PH_VOWEL_ASH)) { return SV_PH_R07; }
    if ((p == SVARA_PH_VOWEL_E) | (p == SVARA_PH_VOWEL_O)
    | (p == SVARA_PH_VOWEL_OPEN_O) | (p == SVARA_PH_VOWEL_OPEN_E)) { return SV_PH_R07; }
    if ((p == SVARA_PH_PLOSIVE_T) | (p == SVARA_PH_PLOSIVE_D)
    | (p == SVARA_PH_NASAL_N) | (p == SVARA_PH_LATERAL_L)) { return SV_PH_R075; }
    if ((p == SVARA_PH_PLOSIVE_K) | (p == SVARA_PH_PLOSIVE_G) | (p == SVARA_PH_NASAL_NG)) { return SV_PH_R07; }
    if ((p == SVARA_PH_PLOSIVE_P) | (p == SVARA_PH_PLOSIVE_B) | (p == SVARA_PH_NASAL_M)) { return SV_PH_R065; }
    if ((p == SVARA_PH_FRIC_F) | (p == SVARA_PH_FRIC_V)) { return SV_PH_R06; }
    if ((p == SVARA_PH_FRIC_TH) | (p == SVARA_PH_FRIC_DH)) { return SV_PH_R06; }
    if ((p == SVARA_PH_VOWEL_CUP_V) | (p == SVARA_PH_VOWEL_BIRD)) { return SV_PH_R05; }
    if ((p == SVARA_PH_APPROX_R) | (p == SVARA_PH_APPROX_J)) { return SV_PH_R055; }
    if (p == SVARA_PH_APPROX_W) { return SV_PH_R05; }
    if (p == SVARA_PH_TAP_FLAP) { return SV_PH_R04; }
    if (p == SVARA_PH_VOWEL_SCHWA) { return SV_PH_R02; }
    if (p == SVARA_PH_FRIC_H) { return SV_PH_R015; }
    if (p == SVARA_PH_GLOTTAL_STOP) { return SV_PH_R01; }
    if (p == SVARA_PH_SILENCE) { return 0; }
    if ((p >= SVARA_PH_DIPH_AI) & (p <= SVARA_PH_DIPH_OU)) { return SV_PH_R06; }
    if ((p >= SVARA_PH_CLICK_BILABIAL) & (p <= SVARA_PH_CLICK_LATERAL)) { return SV_PH_R09; }
    if ((p >= SVARA_PH_EJECTIVE_P) & (p <= SVARA_PH_EJECTIVE_CH)) { return SV_PH_R085; }
    if ((p >= SVARA_PH_IMPLOSIVE_B) & (p <= SVARA_PH_IMPLOSIVE_G)) { return SV_PH_R07; }

    # IPA-extension defaults, keyed by class
    var c = svara_phoneme_class(p);
    if (c == SVARA_CLASS_VOWEL) { return SV_PH_R07; }
    if (c == SVARA_CLASS_PLOSIVE) { return SV_PH_R07; }
    if (c == SVARA_CLASS_FRICATIVE) { return SV_PH_R07; }
    if (c == SVARA_CLASS_NASAL) { return SV_PH_R07; }
    if (c == SVARA_CLASS_TRILL) { return SV_PH_R06; }
    if (c == SVARA_CLASS_APPROXIMANT) { return SV_PH_R055; }
    if (c == SVARA_CLASS_LATERAL) { return SV_PH_R055; }
    if (c == SVARA_CLASS_AFFRICATE) { return SV_PH_R085; }
    if (c == SVARA_CLASS_CLICK) { return SV_PH_R09; }
    if (c == SVARA_CLASS_EJECTIVE) { return SV_PH_R085; }
    if (c == SVARA_CLASS_IMPLOSIVE) { return SV_PH_R07; }
    if (c == SVARA_CLASS_DIPHTHONG) { return SV_PH_R06; }
    return 0;   # Silence
}

# ================================================================
# PART 2 -- data tables (embedded, like formant's from_vowel). Requires
# formant.cyr (VowelTarget + SVARA_VOWEL_*) and tract.cyr (NasalPlace / SVARA_NASAL_*).
# ================================================================

# Duration / VOT / misc f64 literals not already in the resistance set (SV_PH_R*).
var SV_PH_004 = 0x3FA47AE147AE147B;   # 0.04
var SV_PH_005 = 0x3FA999999999999A;   # 0.05
var SV_PH_007 = 0x3FB1EB851EB851EC;   # 0.07
var SV_PH_008 = 0x3FB47AE147AE147B;   # 0.08
var SV_PH_012 = 0x3FBEB851EB851EB8;   # 0.12
var SV_PH_018 = 0x3FC70A3D70A3D70A;   # 0.18
var SV_PH_025 = 0x3FD0000000000000;   # 0.25
var SV_PH_028 = 0x3FD1EB851EB851EC;   # 0.28
var SV_PH_030 = 0x3FD3333333333333;   # 0.30
var SV_PH_033 = 0x3FD51EB851EB851F;   # 0.33
var SV_PH_035 = 0x3FD6666666666666;   # 0.35

# int-arg VowelTarget builders (keep the table compact + under 120 cols).
#must_use
fn svara_ph_vt(f1, f2, f3, f4, f5) {
    return svara_vowel_target_new(f64_from(f1), f64_from(f2), f64_from(f3), f64_from(f4), f64_from(f5));
}
#must_use
fn svara_ph_vtb(f1, f2, f3, f4, f5, b1, b2, b3, b4, b5) {
    return svara_vowel_target_with_bandwidths(
    f64_from(f1), f64_from(f2), f64_from(f3), f64_from(f4), f64_from(f5),
    f64_from(b1), f64_from(b2), f64_from(b3), f64_from(b4), f64_from(b5));
}

# ================================================================
# f2_locus_equation -- writes (locus_hz, slope) into out (2 f64 slots) and
# returns 1 for stops/nasals with a defined locus, else 0 (Rust None).
# Sussman et al. (1991).
# ================================================================
#must_use
fn svara_f2_locus_equation(p, out) {
    if ((p == SVARA_PH_PLOSIVE_P) | (p == SVARA_PH_PLOSIVE_B) | (p == SVARA_PH_NASAL_M)) {
        store64(out, f64_from(900)); store64(out + 8, SV_PH_R085); return 1;    # bilabial
    }
    if ((p == SVARA_PH_PLOSIVE_T) | (p == SVARA_PH_PLOSIVE_D)
    | (p == SVARA_PH_NASAL_N) | (p == SVARA_PH_TAP_FLAP)) {
        store64(out, f64_from(1750)); store64(out + 8, SV_PH_R055); return 1;   # alveolar
    }
    if ((p == SVARA_PH_PLOSIVE_K) | (p == SVARA_PH_PLOSIVE_G) | (p == SVARA_PH_NASAL_NG)) {
        store64(out, f64_from(2000)); store64(out + 8, SV_PH_R07); return 1;    # velar
    }
    return 0;
}

# ================================================================
# phoneme_formants -- formant target (VowelTarget) for a phoneme. Vowels =
# steady-state targets; consonants = locus frequencies. Full 101-arm table.
# ================================================================
#must_use
fn svara_phoneme_formants(p) {
    # vowels mapping directly to formant.cyr's from_vowel
    if (p == SVARA_PH_VOWEL_A) { return svara_vowel_target_from_vowel(SVARA_VOWEL_A); }
    if (p == SVARA_PH_VOWEL_E) { return svara_vowel_target_from_vowel(SVARA_VOWEL_E); }
    if ((p == SVARA_PH_VOWEL_I) | (p == SVARA_PH_VOWEL_LONG_I)) { return svara_vowel_target_from_vowel(SVARA_VOWEL_I); }
    if (p == SVARA_PH_VOWEL_O) { return svara_vowel_target_from_vowel(SVARA_VOWEL_O); }
    if (p == SVARA_PH_VOWEL_U) { return svara_vowel_target_from_vowel(SVARA_VOWEL_U); }
    if (p == SVARA_PH_VOWEL_SCHWA) { return svara_vowel_target_from_vowel(SVARA_VOWEL_SCHWA); }
    if (p == SVARA_PH_VOWEL_OPEN_O) { return svara_vowel_target_from_vowel(SVARA_VOWEL_OPENO); }
    if (p == SVARA_PH_VOWEL_ASH) { return svara_vowel_target_from_vowel(SVARA_VOWEL_ASH); }
    if (p == SVARA_PH_VOWEL_NEAR_I) { return svara_vowel_target_from_vowel(SVARA_VOWEL_NEARI); }
    if (p == SVARA_PH_VOWEL_NEAR_U) { return svara_vowel_target_from_vowel(SVARA_VOWEL_NEARU); }
    if (p == SVARA_PH_VOWEL_OPEN_A) { return svara_ph_vtb(745, 1100, 2440, 3300, 3750, 85, 90, 110, 130, 150); }
    if (p == SVARA_PH_VOWEL_BIRD) { return svara_ph_vtb(580, 1400, 2500, 3300, 3750, 70, 80, 100, 120, 140); }
    if ((p == SVARA_PH_VOWEL_OPEN_E) | (p == SVARA_PH_VOWEL_CUP_V)) { return svara_ph_vt(600, 1770, 2500, 3300, 3750); }

    # diphthong start targets
    if ((p == SVARA_PH_DIPH_AI) | (p == SVARA_PH_DIPH_AU)) { return svara_vowel_target_from_vowel(SVARA_VOWEL_A); }
    if (p == SVARA_PH_DIPH_OI) { return svara_vowel_target_from_vowel(SVARA_VOWEL_OPENO); }
    if (p == SVARA_PH_DIPH_EI) { return svara_vowel_target_from_vowel(SVARA_VOWEL_E); }
    if (p == SVARA_PH_DIPH_OU) { return svara_vowel_target_from_vowel(SVARA_VOWEL_O); }

    # IPA-extension vowels (explicit bandwidths)
    if (p == SVARA_PH_VOWEL_Y) { return svara_ph_vtb(320, 1800, 2400, 3300, 3750, 45, 70, 90, 120, 140); }
    if (p == SVARA_PH_VOWEL_FRONT_ROUND_O) {
        return svara_ph_vtb(400, 1600, 2400, 3300, 3750, 55, 75, 95, 120, 140);
    }
    if (p == SVARA_PH_VOWEL_OPEN_FRONT_ROUND_O) {
        return svara_ph_vtb(550, 1500, 2400, 3300, 3750, 70, 80, 100, 120, 140);
    }
    if (p == SVARA_PH_VOWEL_CLOSE_BACK_UNROUNDED) {
        return svara_ph_vtb(350, 1300, 2400, 3300, 3750, 45, 65, 90, 120, 140);
    }
    if (p == SVARA_PH_VOWEL_MID_BACK_UNROUNDED) {
        return svara_ph_vtb(460, 1250, 2450, 3300, 3750, 55, 70, 95, 120, 140);
    }
    if (p == SVARA_PH_VOWEL_CLOSE_CENTRAL) {
        return svara_ph_vtb(330, 1650, 2450, 3300, 3750, 45, 70, 90, 120, 140);
    }
    if (p == SVARA_PH_VOWEL_CLOSE_CENTRAL_ROUNDED) {
        return svara_ph_vtb(310, 1500, 2300, 3300, 3750, 45, 70, 90, 120, 140);
    }

    # neutral-tract (schwa) consonants
    if ((p == SVARA_PH_FRIC_H) | (p == SVARA_PH_GLOTTAL_STOP) | (p == SVARA_PH_FRIC_GLOTTAL_H)) {
        return svara_vowel_target_from_vowel(SVARA_VOWEL_SCHWA);
    }

    # consonant locus targets (grouped by identical target)
    # bilabial locus (350, 900, 2400)
    if ((p == SVARA_PH_PLOSIVE_P) | (p == SVARA_PH_PLOSIVE_B) | (p == SVARA_PH_NASAL_M)
    | (p == SVARA_PH_FRIC_BILABIAL_PH) | (p == SVARA_PH_FRIC_BILABIAL_B)
    | (p == SVARA_PH_TRILL_BILABIAL) | (p == SVARA_PH_CLICK_BILABIAL)
    | (p == SVARA_PH_EJECTIVE_P) | (p == SVARA_PH_IMPLOSIVE_B)) {
        return svara_ph_vt(350, 900, 2400, 3300, 3750);
    }
    # alveolar locus (400, 1750, 2600)
    if ((p == SVARA_PH_PLOSIVE_T) | (p == SVARA_PH_PLOSIVE_D) | (p == SVARA_PH_NASAL_N)
    | (p == SVARA_PH_LATERAL_L) | (p == SVARA_PH_FRIC_S) | (p == SVARA_PH_FRIC_Z)
    | (p == SVARA_PH_TAP_FLAP) | (p == SVARA_PH_AFFR_TS) | (p == SVARA_PH_AFFR_DZ)
    | (p == SVARA_PH_CLICK_ALVEOLAR) | (p == SVARA_PH_EJECTIVE_T) | (p == SVARA_PH_EJECTIVE_S)
    | (p == SVARA_PH_IMPLOSIVE_D)) {
        return svara_ph_vt(400, 1750, 2600, 3300, 3750);
    }
    # velar locus (350, 1800, 2500)
    if ((p == SVARA_PH_PLOSIVE_K) | (p == SVARA_PH_PLOSIVE_G) | (p == SVARA_PH_NASAL_NG)
    | (p == SVARA_PH_EJECTIVE_K) | (p == SVARA_PH_IMPLOSIVE_G)) {
        return svara_ph_vt(350, 1800, 2500, 3300, 3750);
    }
    # labiodental (350, 1050, 2400)
    if ((p == SVARA_PH_FRIC_F) | (p == SVARA_PH_FRIC_V) | (p == SVARA_PH_AFFR_PF)) {
        return svara_ph_vt(350, 1050, 2400, 3300, 3750);
    }
    # postalveolar (350, 1600, 2500)
    if ((p == SVARA_PH_FRIC_SH) | (p == SVARA_PH_FRIC_ZH) | (p == SVARA_PH_AFFR_CH)
    | (p == SVARA_PH_AFFR_J) | (p == SVARA_PH_EJECTIVE_CH)) {
        return svara_ph_vt(350, 1600, 2500, 3300, 3750);
    }
    # dental (350, 1400, 2500)
    if ((p == SVARA_PH_FRIC_TH) | (p == SVARA_PH_FRIC_DH)) { return svara_ph_vt(350, 1400, 2500, 3300, 3750); }
    # rhotic / retroflex approximant (350, 1300, 1600)
    if ((p == SVARA_PH_APPROX_R) | (p == SVARA_PH_APPROX_RETRO)) { return svara_ph_vt(350, 1300, 1600, 3300, 3750); }
    if (p == SVARA_PH_APPROX_W) { return svara_ph_vt(300, 700, 2200, 3300, 3750); }
    if (p == SVARA_PH_APPROX_J) { return svara_ph_vt(280, 2200, 2900, 3300, 3750); }
    # uvular locus (350, 1100, 2300)
    if ((p == SVARA_PH_PLOSIVE_UVULAR_Q) | (p == SVARA_PH_PLOSIVE_UVULAR_G)
    | (p == SVARA_PH_FRIC_UVULAR_CH) | (p == SVARA_PH_FRIC_UVULAR_R)
    | (p == SVARA_PH_NASAL_UVULAR) | (p == SVARA_PH_TRILL_UVULAR) | (p == SVARA_PH_LATERAL_VELAR)) {
        return svara_ph_vt(350, 1100, 2300, 3300, 3750);
    }
    # retroflex locus (400, 1550, 2000)
    if ((p == SVARA_PH_PLOSIVE_RETRO_T) | (p == SVARA_PH_PLOSIVE_RETRO_D)
    | (p == SVARA_PH_FRIC_RETRO_S) | (p == SVARA_PH_FRIC_RETRO_Z)
    | (p == SVARA_PH_NASAL_RETRO) | (p == SVARA_PH_FLAP_RETRO)
    | (p == SVARA_PH_AFFR_RETRO) | (p == SVARA_PH_AFFR_RETRO_VOICED)) {
        return svara_ph_vt(400, 1550, 2000, 3300, 3750);
    }
    # palatal (300, 2200, 2900)
    if ((p == SVARA_PH_FRIC_PALATAL_C) | (p == SVARA_PH_FRIC_PALATAL_J) | (p == SVARA_PH_NASAL_PALATAL)) {
        return svara_ph_vt(300, 2200, 2900, 3300, 3750);
    }
    # pharyngeal (700, 1000, 2400)
    if ((p == SVARA_PH_FRIC_PHARYNGEAL_H) | (p == SVARA_PH_FRIC_PHARYNGEAL_A)) {
        return svara_ph_vt(700, 1000, 2400, 3300, 3750);
    }
    # lateral fricative / affricate (400, 1600, 2500)
    if ((p == SVARA_PH_FRIC_LATERAL_S) | (p == SVARA_PH_FRIC_LATERAL_Z)
    | (p == SVARA_PH_FLAP_LATERAL) | (p == SVARA_PH_AFFR_LATERAL)) {
        return svara_ph_vt(400, 1600, 2500, 3300, 3750);
    }
    if (p == SVARA_PH_TRILL_ALVEOLAR) { return svara_ph_vt(400, 1500, 2500, 3300, 3750); }
    if (p == SVARA_PH_LATERAL_PALATAL) { return svara_ph_vt(300, 2000, 2800, 3300, 3750); }
    # clicks (per place)
    if (p == SVARA_PH_CLICK_DENTAL) { return svara_ph_vt(400, 1500, 2600, 3300, 3750); }
    if (p == SVARA_PH_CLICK_PALATAL) { return svara_ph_vt(350, 2000, 2800, 3300, 3750); }
    if (p == SVARA_PH_CLICK_LATERAL) { return svara_ph_vt(400, 1500, 2500, 3300, 3750); }

    # Silence (and any fallthrough)
    return svara_ph_vt(500, 1500, 2500, 3300, 3750);
}

# ================================================================
# phoneme_duration -- default duration (seconds) by class.
# ================================================================
#must_use
fn svara_phoneme_duration(p) {
    var c = svara_phoneme_class(p);
    if (c == SVARA_CLASS_VOWEL) { return SV_PH_012; }
    if (c == SVARA_CLASS_DIPHTHONG) { return SV_PH_018; }
    if (c == SVARA_CLASS_PLOSIVE) { return SV_PH_008; }
    if (c == SVARA_CLASS_FRICATIVE) { return SV_PH_R01; }
    if (c == SVARA_CLASS_NASAL) { return SV_PH_008; }
    if (c == SVARA_CLASS_AFFRICATE) { return SV_PH_012; }
    if (c == SVARA_CLASS_APPROXIMANT) { return SV_PH_007; }
    if (c == SVARA_CLASS_LATERAL) { return SV_PH_007; }
    if (c == SVARA_CLASS_TRILL) { return SV_PH_R01; }
    if (c == SVARA_CLASS_CLICK) { return SV_PH_004; }
    if (c == SVARA_CLASS_EJECTIVE) { return SV_PH_R01; }
    if (c == SVARA_CLASS_IMPLOSIVE) { return SV_PH_008; }
    return SV_PH_005;   # Silence
}

# ================================================================
# phoneme_spectral_tilt -- dB/octave. Vowels/diphthongs: clamp((F1-300)/250, 0, 2);
# consonants: 0. Stevens & Hanson (1995).
# ================================================================
#must_use
fn svara_phoneme_spectral_tilt(p) {
    var c = svara_phoneme_class(p);
    if ((c == SVARA_CLASS_VOWEL) | (c == SVARA_CLASS_DIPHTHONG)) {
        var f1 = SvVowelTarget_f1(svara_phoneme_formants(p));
        return f64_clamp(f64_div(f64_sub(f1, f64_from(300)), f64_from(250)), 0, F64_TWO);
    }
    return 0;
}

# ================================================================
# height_adjusted_amplitudes -- writes 5 F1..F5 amplitudes into out. Vowels:
# attenuate F2-F5 with openness = clamp((F1-300)/500, 0, 1); else base. Fant (1960).
# ================================================================
fn svara_phoneme_height_adjusted_amplitudes(p, out) {
    var c = svara_phoneme_class(p);
    if ((c == SVARA_CLASS_VOWEL) | (c == SVARA_CLASS_DIPHTHONG)) {
        var f1 = SvVowelTarget_f1(svara_phoneme_formants(p));
        var op = f64_clamp(f64_div(f64_sub(f1, f64_from(300)), f64_from(500)), 0, F64_ONE);
        store64(out,      SVARA_AMP_0);
        store64(out + 8,  f64_mul(SVARA_AMP_1, f64_sub(F64_ONE, f64_mul(op, SV_PH_005))));
        store64(out + 16, f64_mul(SVARA_AMP_2, f64_sub(F64_ONE, f64_mul(op, SV_PH_R01))));
        store64(out + 24, f64_mul(SVARA_AMP_3, f64_sub(F64_ONE, f64_mul(op, SV_PH_R015))));
        store64(out + 32, f64_mul(SVARA_AMP_4, f64_sub(F64_ONE, f64_mul(op, SV_PH_R015))));
        return 0;
    }
    store64(out, SVARA_AMP_0);   store64(out + 8, SVARA_AMP_1);   store64(out + 16, SVARA_AMP_2);
    store64(out + 24, SVARA_AMP_3);   store64(out + 32, SVARA_AMP_4);
    return 0;
}

# ================================================================
# VoiceOnsetTime -- closure/burst/aspiration fractions for plosives (Lisker &
# Abramson 1964). `0` == 0.0.
# ================================================================
#derive(accessors)
#derive(Serialize)
struct SvVOT { closure_fraction: f64; burst_fraction: f64; aspiration_fraction: f64; }

#must_use
fn svara_vot_for_plosive(p) {
    var self = alloc(sizeof(SvVOT));
    if ((p == SVARA_PH_PLOSIVE_P) | (p == SVARA_PH_PLOSIVE_UVULAR_Q)) {
        SvVOT_set_closure_fraction(self, SV_PH_035); SvVOT_set_burst_fraction(self, SV_PH_R01);
        SvVOT_set_aspiration_fraction(self, SV_PH_025); return self;
    }
    if ((p == SVARA_PH_PLOSIVE_T) | (p == SVARA_PH_PLOSIVE_RETRO_T)) {
        SvVOT_set_closure_fraction(self, SV_PH_030); SvVOT_set_burst_fraction(self, SV_PH_R01);
        SvVOT_set_aspiration_fraction(self, SV_PH_030); return self;
    }
    if (p == SVARA_PH_PLOSIVE_K) {
        SvVOT_set_closure_fraction(self, SV_PH_030); SvVOT_set_burst_fraction(self, SV_PH_012);
        SvVOT_set_aspiration_fraction(self, SV_PH_028); return self;
    }
    if ((p == SVARA_PH_PLOSIVE_B) | (p == SVARA_PH_PLOSIVE_UVULAR_G)) {
        SvVOT_set_closure_fraction(self, SV_PH_030); SvVOT_set_burst_fraction(self, SV_PH_008);
        SvVOT_set_aspiration_fraction(self, 0); return self;
    }
    if ((p == SVARA_PH_PLOSIVE_D) | (p == SVARA_PH_PLOSIVE_RETRO_D)) {
        SvVOT_set_closure_fraction(self, SV_PH_025); SvVOT_set_burst_fraction(self, SV_PH_008);
        SvVOT_set_aspiration_fraction(self, 0); return self;
    }
    if (p == SVARA_PH_PLOSIVE_G) {
        SvVOT_set_closure_fraction(self, SV_PH_025); SvVOT_set_burst_fraction(self, SV_PH_R01);
        SvVOT_set_aspiration_fraction(self, 0); return self;
    }
    # default
    SvVOT_set_closure_fraction(self, SV_PH_033); SvVOT_set_burst_fraction(self, SV_PH_R01);
    SvVOT_set_aspiration_fraction(self, SV_PH_R01); return self;
}

# ================================================================
# Nasalization -- anticipatory nasal coupling params for a vowel preceding a
# nasal. onset=0.65, peak_coupling=0.4, place from the following nasal.
# ================================================================
#derive(accessors)
#derive(Serialize)
struct SvNasalization { onset: f64; peak_coupling: f64; place: i64; }

# for_nasal -- returns a Nasalization pointer if `nasal` is a nasal consonant,
# else 0 (null = Rust None). place maps to tract.cyr's SVARA_NASAL_*.
#must_use
fn svara_nasalization_for_nasal(nasal) {
    var place = 0;
    if (nasal == SVARA_PH_NASAL_M) { place = SVARA_NASAL_BILABIAL; }
    elif ((nasal == SVARA_PH_NASAL_N) | (nasal == SVARA_PH_NASAL_RETRO)) { place = SVARA_NASAL_ALVEOLAR; }
    elif ((nasal == SVARA_PH_NASAL_NG) | (nasal == SVARA_PH_NASAL_UVULAR)) { place = SVARA_NASAL_VELAR; }
    elif (nasal == SVARA_PH_NASAL_PALATAL) { place = SVARA_NASAL_ALVEOLAR; }
    else { return 0; }
    var self = alloc(sizeof(SvNasalization));
    SvNasalization_set_onset(self, SV_PH_R065);
    SvNasalization_set_peak_coupling(self, SV_PH_R04);
    SvNasalization_set_place(self, place);
    return self;
}

# ================================================================
# detect_nasalization -- vec parallel to `phonemes`: a Nasalization pointer for
# each vowel/diphthong followed by a nasal, else 0 (null).
# ================================================================
#must_use
fn svara_detect_nasalization(phonemes) {
    var out = vec_new();
    var n = vec_len(phonemes);
    var i = 0;
    while (i < n) {
        var c = svara_phoneme_class(vec_get(phonemes, i));
        var result = 0;
        if ((c == SVARA_CLASS_VOWEL) | (c == SVARA_CLASS_DIPHTHONG)) {
            if ((i + 1) < n) {
                result = svara_nasalization_for_nasal(vec_get(phonemes, i + 1));
            }
        }
        vec_push(out, result);
        i = i + 1;
    }
    return out;
}

# ================================================================
# PART 3a -- the free synthesize_phoneme path (per-class synthesis). Ties
# voice + glottal + tract + FormantFilter together into audio. Also requires
# glottal.cyr, tract.cyr, voice.cyr, and hisab (ease_in_out_smooth).
# synthesize_phoneme returns a vec<f64> of samples, or a negative SVARA_ERR_*.
# Per-class helpers return a raw f64 buffer (n slots) or a negative error.
# NoiseGen == svara PCG32 rng (per-class seeds match the Rust oracle).
# ================================================================

var SV_PH_08 = 0x3FE999999999999A;   # 0.8

# apply_amplitude_envelope -- attack/release ramps (hisab ease_in_out_smooth) to
# avoid clicks. ramp_len = clamp(n/10, 1, 256). Operates in place on a raw buffer.
fn svara_ph_apply_envelope(buf, n) {
    if (n == 0) { return 0; }
    var ramp = n / 10;
    if (ramp < 1) { ramp = 1; }
    if (ramp > 256) { ramp = 256; }
    var i = 0;
    while (i < ramp) {
        var e = ease_in_out_smooth(f64_div(f64_from(i), f64_from(ramp)));
        store64(buf + i * 8, f64_mul(load64(buf + i * 8), e));
        i = i + 1;
    }
    var j = 0;
    while (j < ramp) {
        var idx = n - 1 - j;
        var e2 = ease_in_out_smooth(f64_div(f64_from(j), f64_from(ramp)));
        store64(buf + idx * 8, f64_mul(load64(buf + idx * 8), e2));
        j = j + 1;
    }
    return 0;
}

# copy a raw f64 buffer of n slots into a fresh vec.
#must_use
fn svara_ph_buf_to_vec(buf, n) {
    var v = vec_new();
    var i = 0;
    while (i < n) { vec_push(v, load64(buf + i * 8)); i = i + 1; }
    return v;
}

# diphthong_end_target -- the glide's end vowel target.
#must_use
fn svara_ph_diphthong_end_target(phoneme) {
    if (phoneme == SVARA_PH_DIPH_AI) { return svara_vowel_target_from_vowel(SVARA_VOWEL_I); }
    if (phoneme == SVARA_PH_DIPH_AU) { return svara_vowel_target_from_vowel(SVARA_VOWEL_U); }
    if (phoneme == SVARA_PH_DIPH_OI) { return svara_vowel_target_from_vowel(SVARA_VOWEL_I); }
    if (phoneme == SVARA_PH_DIPH_EI) { return svara_vowel_target_from_vowel(SVARA_VOWEL_I); }
    if (phoneme == SVARA_PH_DIPH_OU) { return svara_vowel_target_from_vowel(SVARA_VOWEL_U); }
    return svara_phoneme_formants(phoneme);
}

# fricative_formants -- noise-shaping formants (vec of Formant) for frication.
#must_use
fn svara_ph_fricative_formants(phoneme) {
    var v = vec_new();
    if ((phoneme == SVARA_PH_FRIC_S) | (phoneme == SVARA_PH_FRIC_Z)
    | (phoneme == SVARA_PH_EJECTIVE_S) | (phoneme == SVARA_PH_AFFR_TS) | (phoneme == SVARA_PH_AFFR_DZ)) {
        vec_push(v, svara_formant_new(f64_from(4500), f64_from(500), F64_ONE));
        vec_push(v, svara_formant_new(f64_from(7000), f64_from(800), SV_PH_R07));
        return v;
    }
    if ((phoneme == SVARA_PH_FRIC_SH) | (phoneme == SVARA_PH_FRIC_ZH)
    | (phoneme == SVARA_PH_AFFR_CH) | (phoneme == SVARA_PH_AFFR_J) | (phoneme == SVARA_PH_EJECTIVE_CH)) {
        vec_push(v, svara_formant_new(f64_from(2800), f64_from(600), F64_ONE));
        vec_push(v, svara_formant_new(f64_from(5000), f64_from(800), SV_PH_R06));
        return v;
    }
    if ((phoneme == SVARA_PH_FRIC_F) | (phoneme == SVARA_PH_FRIC_V) | (phoneme == SVARA_PH_AFFR_PF)) {
        vec_push(v, svara_formant_new(f64_from(3000), f64_from(2000), SV_PH_R05));
        vec_push(v, svara_formant_new(f64_from(8000), f64_from(2000), SV_PH_030));
        return v;
    }
    if ((phoneme == SVARA_PH_FRIC_TH) | (phoneme == SVARA_PH_FRIC_DH)) {
        vec_push(v, svara_formant_new(f64_from(4000), f64_from(1500), SV_PH_R04));
        vec_push(v, svara_formant_new(f64_from(7500), f64_from(1500), SV_PH_030));
        return v;
    }
    if (phoneme == SVARA_PH_FRIC_H) {
        vec_push(v, svara_formant_new(f64_from(1500), f64_from(800), SV_PH_R04));
        vec_push(v, svara_formant_new(f64_from(2500), f64_from(800), SV_PH_030));
        return v;
    }
    if ((phoneme == SVARA_PH_AFFR_RETRO) | (phoneme == SVARA_PH_AFFR_RETRO_VOICED)) {
        vec_push(v, svara_formant_new(f64_from(3200), f64_from(600), F64_ONE));
        vec_push(v, svara_formant_new(f64_from(5500), f64_from(800), SV_PH_R06));
        return v;
    }
    if (phoneme == SVARA_PH_AFFR_LATERAL) {
        vec_push(v, svara_formant_new(f64_from(3500), f64_from(800), SV_PH_R07));
        vec_push(v, svara_formant_new(f64_from(6000), f64_from(1000), SV_PH_R04));
        return v;
    }
    # default noise shaping
    vec_push(v, svara_formant_new(f64_from(3000), f64_from(1000), SV_PH_R05));
    return v;
}

# ---- per-class synthesis (return raw buffer of n f64, or neg error) --------

#must_use
fn svara_ph_synth_vowel(phoneme, voice, sample_rate, n) {
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var amps = alloc(40);
    svara_phoneme_height_adjusted_amplitudes(phoneme, amps);
    var formants = vec_new();
    vec_push(formants, svara_formant_new(SvVowelTarget_f1(target), SvVowelTarget_b1(target), load64(amps)));
    vec_push(formants, svara_formant_new(SvVowelTarget_f2(target), SvVowelTarget_b2(target), load64(amps + 8)));
    vec_push(formants, svara_formant_new(SvVowelTarget_f3(target), SvVowelTarget_b3(target), load64(amps + 16)));
    vec_push(formants, svara_formant_new(SvVowelTarget_f4(target), SvVowelTarget_b4(target), load64(amps + 24)));
    vec_push(formants, svara_formant_new(SvVowelTarget_f5(target), SvVowelTarget_b5(target), load64(amps + 32)));
    var tract = svara_tract_new(sample_rate);
    var e = svara_tract_set_formants(tract, formants);
    if (svara_is_err(e) == 1) { return e; }
    var glottal = svara_voice_create_glottal_source(voice, sample_rate);
    if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
    # NOTE (v2.0.1 quirk, preserved): phoneme_spectral_tilt is metadata only,
    # not applied to the glottal source here (the one-pole tilt filter would
    # sap signal energy). Consumers apply it in post if desired.
    var buf = svara_tract_synthesize(tract, glottal, n);
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_diphthong(phoneme, voice, sample_rate, n) {
    var start = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var endt = svara_voice_apply_formant_scale(voice, svara_ph_diphthong_end_target(phoneme));
    var glottal = svara_voice_create_glottal_source(voice, sample_rate);
    if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
    var tract = svara_tract_new(sample_rate);
    var buf = alloc(n * 8);
    # Control-rate formant coefficients: re-solving the biquad bank from the
    # interpolated target on EVERY sample (the faithful-but-slow port) dominated
    # the diphthong cost. The glide target moves smoothly, so recomputing at a
    # control rate of 64 samples (~1.45 ms at 44.1 kHz — standard for formant
    # synthesizers) and holding between updates is perceptually identical while
    # cutting the per-sample coefficient re-solve ~64x. The tract's own per-sample
    # filtering still runs every sample; only the coefficient derivation is
    # control-rate.
    var ctrl = 0;
    var i = 0;
    while (i < n) {
        if (ctrl == 0) {
            var cur = svara_vowel_target_interpolate(start, endt, f64_div(f64_from(i), f64_from(n)));
            var e = svara_tract_set_formants_from_target(tract, cur);
            if (svara_is_err(e) == 1) { return e; }
            ctrl = 64;
        }
        ctrl = ctrl - 1;
        store64(buf + i * 8, svara_tract_process_sample(tract, svara_glottal_next_sample(glottal)));
        i = i + 1;
    }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_plosive(phoneme, voice, sample_rate, n) {
    var buf = alloc(n * 8);
    svara_formant_zero_buf(buf, n);
    var noise = svara_rng_new(17);
    var vot = svara_vot_for_plosive(phoneme);
    var nf = f64_from(n);
    var closure_end = f64_to(f64_mul(SvVOT_closure_fraction(vot), nf));
    var burst_end = closure_end + f64_to(f64_max(f64_mul(SvVOT_burst_fraction(vot), nf), F64_ONE));
    var aspiration_end = burst_end + f64_to(f64_mul(SvVOT_aspiration_fraction(vot), nf));
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var filter = svara_formant_filter_new(svara_vowel_target_to_formants(target), sample_rate);
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }

    var be = burst_end;
    if (be > n) { be = n; }
    var i = closure_end;
    while (i < be) {
        store64(buf + i * 8, svara_formant_filter_process_sample(filter, f64_mul(svara_rng_next_f32(noise), SV_PH_08)));
        i = i + 1;
    }
    if (aspiration_end > burst_end) {
        var asp_len = aspiration_end - burst_end;
        if (asp_len < 1) { asp_len = 1; }
        var ae = aspiration_end;
        if (ae > n) { ae = n; }
        var jj = 0;
        var k = burst_end;
        while (k < ae) {
            var decay = f64_sub(F64_ONE, f64_div(f64_from(jj), f64_from(asp_len)));
            var amp = f64_mul(f64_mul(svara_rng_next_f32(noise), SV_PH_R04), decay);
            store64(buf + k * 8, svara_formant_filter_process_sample(filter, amp));
            jj = jj + 1;
            k = k + 1;
        }
    }
    var voice_start = aspiration_end;
    if (voice_start > n) { voice_start = n; }
    if ((svara_phoneme_is_voiced(phoneme) == 1) | (voice_start < n)) {
        if (svara_phoneme_is_voiced(phoneme) == 1) {
            var glottal = svara_voice_create_glottal_source(voice, sample_rate);
            if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
            svara_glottal_set_breathiness(glottal, SV_PH_030);
            var tract = svara_tract_new(sample_rate);
            var e = svara_tract_set_formants_from_target(tract, target);
            if (svara_is_err(e) == 1) { return e; }
            var m = voice_start;
            while (m < n) {
                var vs = f64_mul(svara_tract_process_sample(tract, svara_glottal_next_sample(glottal)), F64_HALF);
                store64(buf + m * 8, vs);
                m = m + 1;
            }
        } else {
            var m2 = voice_start;
            while (m2 < n) {
                var ns = f64_mul(svara_rng_next_f32(noise), SV_PH_R015);
                store64(buf + m2 * 8, svara_formant_filter_process_sample(filter, ns));
                m2 = m2 + 1;
            }
        }
    }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_fricative(phoneme, voice, sample_rate, n) {
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var noise = svara_rng_new(31);
    var filter = svara_formant_filter_new(svara_ph_fricative_formants(phoneme), sample_rate);
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }
    var buf = alloc(n * 8);
    if (svara_phoneme_is_voiced(phoneme) == 1) {
        var glottal = svara_voice_create_glottal_source(voice, sample_rate);
        if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
        var tract = svara_tract_new(sample_rate);
        var e = svara_tract_set_formants_from_target(tract, target);
        if (svara_is_err(e) == 1) { return e; }
        var i = 0;
        while (i < n) {
            var friction = svara_formant_filter_process_sample(filter, f64_mul(svara_rng_next_f32(noise), F64_HALF));
            var voicing = f64_mul(svara_tract_process_sample(tract, svara_glottal_next_sample(glottal)), SV_PH_R04);
            store64(buf + i * 8, f64_add(friction, voicing));
            i = i + 1;
        }
    } else {
        var i = 0;
        while (i < n) {
            var ns = f64_mul(svara_rng_next_f32(noise), SV_PH_R06);
            store64(buf + i * 8, svara_formant_filter_process_sample(filter, ns));
            i = i + 1;
        }
    }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_nasal(phoneme, voice, sample_rate, n) {
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var glottal = svara_voice_create_glottal_source(voice, sample_rate);
    if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
    var tract = svara_tract_new(sample_rate);
    var e = svara_tract_set_formants_from_target(tract, target);
    if (svara_is_err(e) == 1) { return e; }
    svara_tract_set_nasal_coupling(tract, SV_PH_08);
    var place = SVARA_NASAL_NEUTRAL;
    if (phoneme == SVARA_PH_NASAL_M) { place = SVARA_NASAL_BILABIAL; }
    elif (phoneme == SVARA_PH_NASAL_N) { place = SVARA_NASAL_ALVEOLAR; }
    elif (phoneme == SVARA_PH_NASAL_NG) { place = SVARA_NASAL_VELAR; }
    svara_tract_set_nasal_place(tract, place);
    var buf = svara_tract_synthesize(tract, glottal, n);
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_approximant(phoneme, voice, sample_rate, n) {
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var glottal = svara_voice_create_glottal_source(voice, sample_rate);
    if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
    svara_glottal_set_breathiness(glottal, f64_max(SvVoiceProfile_breathiness(voice), SV_PH_R01));
    var tract = svara_tract_new(sample_rate);
    var e = svara_tract_set_formants_from_target(tract, target);
    if (svara_is_err(e) == 1) { return e; }
    var buf = svara_tract_synthesize(tract, glottal, n);
    var i = 0;
    while (i < n) { store64(buf + i * 8, f64_mul(load64(buf + i * 8), SV_PH_R07)); i = i + 1; }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_affricate(phoneme, voice, sample_rate, n) {
    var buf = alloc(n * 8);
    svara_formant_zero_buf(buf, n);
    var noise = svara_rng_new(23);
    var closure_end = n / 4;
    var burst_extra = n / 8;
    if (burst_extra < 1) { burst_extra = 1; }
    var burst_end = closure_end + burst_extra;
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var filter = svara_formant_filter_new(svara_ph_fricative_formants(phoneme), sample_rate);
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }
    var be = burst_end;
    if (be > n) { be = n; }
    var i = closure_end;
    while (i < be) {
        store64(buf + i * 8, svara_formant_filter_process_sample(filter, f64_mul(svara_rng_next_f32(noise), SV_PH_08)));
        i = i + 1;
    }
    if (svara_phoneme_is_voiced(phoneme) == 1) {
        var glottal = svara_voice_create_glottal_source(voice, sample_rate);
        if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
        var tract = svara_tract_new(sample_rate);
        var e = svara_tract_set_formants_from_target(tract, target);
        if (svara_is_err(e) == 1) { return e; }
        var m = burst_end;
        while (m < n) {
            var voiced = svara_tract_process_sample(tract, svara_glottal_next_sample(glottal));
            var fric = svara_formant_filter_process_sample(filter, f64_mul(svara_rng_next_f32(noise), F64_HALF));
            store64(buf + m * 8, f64_add(f64_mul(voiced, F64_HALF), f64_mul(fric, F64_HALF)));
            m = m + 1;
        }
    } else {
        var m2 = burst_end;
        while (m2 < n) {
            var ns = f64_mul(svara_rng_next_f32(noise), SV_PH_R06);
            store64(buf + m2 * 8, svara_formant_filter_process_sample(filter, ns));
            m2 = m2 + 1;
        }
    }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_trill(phoneme, voice, sample_rate, n) {
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var tract = svara_tract_new(sample_rate);
    var e = svara_tract_set_formants_from_target(tract, target);
    if (svara_is_err(e) == 1) { return e; }
    var glottal = svara_voice_create_glottal_source(voice, sample_rate);
    if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
    var trill_rate = f64_from(25);
    if (phoneme == SVARA_PH_TRILL_UVULAR) { trill_rate = f64_from(20); }
    elif (phoneme == SVARA_PH_TRILL_BILABIAL) { trill_rate = f64_from(15); }
    var buf = alloc(n * 8);
    var i = 0;
    while (i < n) {
        var s = svara_tract_process_sample(tract, svara_glottal_next_sample(glottal));
        var phase = f64_div(f64_mul(f64_mul(F64_TAU, trill_rate), f64_from(i)), sample_rate);
        var env = f64_add(F64_HALF, f64_mul(F64_HALF, f64_cos(phase)));
        store64(buf + i * 8, f64_mul(f64_mul(s, env), SV_PH_R07));
        i = i + 1;
    }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_click(phoneme, voice, sample_rate, n) {
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var filter = svara_formant_filter_new(svara_vowel_target_to_formants(target), sample_rate);
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }
    var noise = svara_rng_new(41);
    var buf = alloc(n * 8);
    svara_formant_zero_buf(buf, n);
    var burst_start = n * 6 / 10;
    var burst_len = n - burst_start;
    if (burst_len < 1) { burst_len = 1; }
    var jj = 0;
    var i = burst_start;
    while (i < n) {
        var env = f64_sub(F64_ONE, f64_div(f64_from(jj), f64_from(burst_len)));
        var shaped = f64_mul(f64_mul(svara_rng_next_f32(noise), env), env);
        store64(buf + i * 8, svara_formant_filter_process_sample(filter, shaped));
        jj = jj + 1;
        i = i + 1;
    }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_ejective(phoneme, voice, sample_rate, n) {
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var filter = svara_formant_filter_new(svara_vowel_target_to_formants(target), sample_rate);
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }
    var noise = svara_rng_new(43);
    var is_fric = 0;
    if ((phoneme == SVARA_PH_EJECTIVE_S) | (phoneme == SVARA_PH_EJECTIVE_CH)) { is_fric = 1; }
    var buf = alloc(n * 8);
    svara_formant_zero_buf(buf, n);
    var closure_end = n * 4 / 10;
    var burst_end = closure_end + n * 2 / 10;
    var be = burst_end;
    if (be > n) { be = n; }
    var i = closure_end;
    while (i < be) {
        store64(buf + i * 8, svara_formant_filter_process_sample(filter, svara_rng_next_f32(noise)));
        i = i + 1;
    }
    var release_len = n - burst_end;
    if (release_len < 1) { release_len = 1; }
    if (is_fric == 1) {
        var fric_filter = svara_formant_filter_new(svara_ph_fricative_formants(phoneme), sample_rate);
        if (svara_is_err(fric_filter) == 1) { return SVARA_ERR_ARTICULATION; }
        var jj = 0;
        var k = burst_end;
        while (k < n) {
            var t = f64_div(f64_from(jj), f64_from(release_len));
            var decay = f64_sub(F64_ONE, f64_mul(t, F64_HALF));
            var amp = f64_mul(f64_mul(svara_rng_next_f32(noise), SV_PH_R06), decay);
            store64(buf + k * 8, svara_formant_filter_process_sample(fric_filter, amp));
            jj = jj + 1;
            k = k + 1;
        }
    } else {
        var j2 = 0;
        var k2 = burst_end;
        while (k2 < n) {
            var t2 = f64_div(f64_from(j2), f64_from(release_len));
            var decay2 = f64_max(f64_sub(F64_ONE, t2), 0);
            var amp2 = f64_mul(f64_mul(svara_rng_next_f32(noise), SV_PH_030), decay2);
            store64(buf + k2 * 8, svara_formant_filter_process_sample(filter, amp2));
            j2 = j2 + 1;
            k2 = k2 + 1;
        }
    }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

#must_use
fn svara_ph_synth_implosive(phoneme, voice, sample_rate, n) {
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var tract = svara_tract_new(sample_rate);
    var e = svara_tract_set_formants_from_target(tract, target);
    if (svara_is_err(e) == 1) { return e; }
    var glottal = svara_voice_create_glottal_source(voice, sample_rate);
    if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
    svara_glottal_set_creaky(glottal, F64_HALF);
    var buf = alloc(n * 8);
    svara_formant_zero_buf(buf, n);
    var closure_end = n / 3;
    var i = closure_end;
    while (i < n) {
        var s = f64_mul(svara_tract_process_sample(tract, svara_glottal_next_sample(glottal)), F64_HALF);
        store64(buf + i * 8, s);
        i = i + 1;
    }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

# nasalized vowel/diphthong: ramp nasal coupling in over the final portion.
#must_use
fn svara_ph_synth_vowel_nasalized(phoneme, voice, sample_rate, n, nasal) {
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var tract = svara_tract_new(sample_rate);
    var e = svara_tract_set_formants_from_target(tract, target);
    if (svara_is_err(e) == 1) { return e; }
    svara_tract_set_nasal_place(tract, SvNasalization_place(nasal));
    var glottal = svara_voice_create_glottal_source(voice, sample_rate);
    if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
    var onset_sample = f64_to(f64_mul(SvNasalization_onset(nasal), f64_from(n)));
    var ramp_len = n - onset_sample;
    if (ramp_len < 1) { ramp_len = 1; }
    var is_diph = 0;
    var endt = 0;
    if (svara_phoneme_class(phoneme) == SVARA_CLASS_DIPHTHONG) {
        is_diph = 1;
        endt = svara_voice_apply_formant_scale(voice, svara_ph_diphthong_end_target(phoneme));
    }
    var buf = alloc(n * 8);
    var i = 0;
    while (i < n) {
        if (is_diph == 1) {
            var cur = svara_vowel_target_interpolate(target, endt, f64_div(f64_from(i), f64_from(n)));
            var e2 = svara_tract_set_formants_from_target(tract, cur);
            if (svara_is_err(e2) == 1) { return e2; }
        }
        if (i >= onset_sample) {
            var nt = f64_div(f64_from(i - onset_sample), f64_from(ramp_len));
            svara_tract_set_nasal_coupling(tract, f64_mul(SvNasalization_peak_coupling(nasal), ease_in_out_smooth(nt)));
        }
        store64(buf + i * 8, svara_tract_process_sample(tract, svara_glottal_next_sample(glottal)));
        i = i + 1;
    }
    svara_ph_apply_envelope(buf, n);
    return buf;
}

# dispatch a phoneme to its per-class synth -> raw buffer of n, or neg error.
#must_use
fn svara_ph_synth_dispatch(phoneme, voice, sample_rate, n) {
    if (phoneme == SVARA_PH_SILENCE) {
        var z = alloc(n * 8);
        svara_formant_zero_buf(z, n);
        return z;
    }
    var c = svara_phoneme_class(phoneme);
    if (c == SVARA_CLASS_VOWEL) { return svara_ph_synth_vowel(phoneme, voice, sample_rate, n); }
    if (c == SVARA_CLASS_DIPHTHONG) { return svara_ph_synth_diphthong(phoneme, voice, sample_rate, n); }
    if (c == SVARA_CLASS_PLOSIVE) { return svara_ph_synth_plosive(phoneme, voice, sample_rate, n); }
    if (c == SVARA_CLASS_FRICATIVE) { return svara_ph_synth_fricative(phoneme, voice, sample_rate, n); }
    if (c == SVARA_CLASS_NASAL) { return svara_ph_synth_nasal(phoneme, voice, sample_rate, n); }
    if (c == SVARA_CLASS_AFFRICATE) { return svara_ph_synth_affricate(phoneme, voice, sample_rate, n); }
    if ((c == SVARA_CLASS_APPROXIMANT) | (c == SVARA_CLASS_LATERAL)) {
        return svara_ph_synth_approximant(phoneme, voice, sample_rate, n);
    }
    if (c == SVARA_CLASS_TRILL) { return svara_ph_synth_trill(phoneme, voice, sample_rate, n); }
    if (c == SVARA_CLASS_CLICK) { return svara_ph_synth_click(phoneme, voice, sample_rate, n); }
    if (c == SVARA_CLASS_EJECTIVE) { return svara_ph_synth_ejective(phoneme, voice, sample_rate, n); }
    if (c == SVARA_CLASS_IMPLOSIVE) { return svara_ph_synth_implosive(phoneme, voice, sample_rate, n); }
    # Silence class
    var z2 = alloc(n * 8);
    svara_formant_zero_buf(z2, n);
    return z2;
}

# ================================================================
# synthesize_phoneme -- synthesize one phoneme with a voice profile.
# Returns a vec<f64> of samples, or a negative SVARA_ERR_*.
# ================================================================
#must_use
fn svara_phoneme_synthesize(phoneme, voice, sample_rate, duration) {
    if (f64_le(duration, 0) == 1) { return SVARA_ERR_INVALID_DURATION; }
    if (svara_is_finite(duration) == 0) { return SVARA_ERR_INVALID_DURATION; }
    if (f64_le(sample_rate, 0) == 1) { return SVARA_ERR_ARTICULATION; }
    var n = f64_to(f64_mul(duration, sample_rate));
    if (n == 0) { return vec_new(); }
    var data = svara_ph_synth_dispatch(phoneme, voice, sample_rate, n);
    if (svara_is_err(data) == 1) { return data; }
    return svara_ph_buf_to_vec(data, n);
}

# ================================================================
# synthesize_phoneme_nasalized -- as above, with anticipatory nasalization for
# a vowel/diphthong (nasal = a Nasalization pointer, or 0 for none).
# ================================================================
#must_use
fn svara_phoneme_synthesize_nasalized(phoneme, voice, sample_rate, duration, nasal) {
    if (f64_le(duration, 0) == 1) { return SVARA_ERR_INVALID_DURATION; }
    if (svara_is_finite(duration) == 0) { return SVARA_ERR_INVALID_DURATION; }
    if (f64_le(sample_rate, 0) == 1) { return SVARA_ERR_ARTICULATION; }
    var n = f64_to(f64_mul(duration, sample_rate));
    if (n == 0) { return vec_new(); }
    var c = svara_phoneme_class(phoneme);
    var is_vowel_like = 0;
    if ((c == SVARA_CLASS_VOWEL) | (c == SVARA_CLASS_DIPHTHONG)) { is_vowel_like = 1; }
    if ((is_vowel_like == 1) & (nasal != 0)) {
        var data = svara_ph_synth_vowel_nasalized(phoneme, voice, sample_rate, n, nasal);
        if (svara_is_err(data) == 1) { return data; }
        return svara_ph_buf_to_vec(data, n);
    }
    return svara_phoneme_synthesize(phoneme, voice, sample_rate, duration);
}

# ================================================================
# PART 3b -- SynthesisContext: reusable tract + glottal + scratch buffer that
# avoids per-phoneme allocation across a sequence. The `_ctx` methods differ
# subtly from the free synths (plosive/affricate use fixed n/3,n/6,n/4,n/8
# timing not VOT; approx_ctx also handles Trill; the envelope is applied once
# by synthesize()). The shared `noise` PRNG and `glottal` persist across calls.
# synthesize() returns the sample count (>=0) or a neg error; read the samples
# via svara_synthctx_buffer(ctx)[0..count].
# ================================================================
#derive(accessors)
struct SvSynthCtx { tract; glottal; noise; fric_filter; buffer; buffer_cap; sample_rate; }

# new -- build a context for a voice + sample rate. Returns ptr or neg error.
#must_use
fn svara_synthctx_new(voice, sample_rate) {
    var glottal = svara_voice_create_glottal_source(voice, sample_rate);
    if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
    var self = alloc(sizeof(SvSynthCtx));
    SvSynthCtx_set_tract(self, svara_tract_new(sample_rate));
    SvSynthCtx_set_glottal(self, glottal);
    SvSynthCtx_set_noise(self, svara_rng_new(17));
    SvSynthCtx_set_fric_filter(self, 0);
    SvSynthCtx_set_buffer(self, 0);
    SvSynthCtx_set_buffer_cap(self, 0);
    SvSynthCtx_set_sample_rate(self, sample_rate);
    return self;
}

#must_use
fn svara_synthctx_sample_rate(self) { return SvSynthCtx_sample_rate(self); }
#must_use
fn svara_synthctx_buffer(self) { return SvSynthCtx_buffer(self); }

# grow the scratch buffer to at least n slots (never shrinks).
#must_use
fn svara_synthctx_ensure_buffer(self, n) {
    if (SvSynthCtx_buffer_cap(self) < n) {
        SvSynthCtx_set_buffer(self, alloc(n * 8));
        SvSynthCtx_set_buffer_cap(self, n);
    }
    return SvSynthCtx_buffer(self);
}

# ---- per-class ctx methods (fill self.buffer[0..n]; return NONE or neg err) ----
#must_use
fn svara_synthctx_voiced(self, phoneme, voice, n, nasal) {
    var buf = SvSynthCtx_buffer(self);
    var tract = SvSynthCtx_tract(self);
    var g = SvSynthCtx_glottal(self);
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var e = svara_tract_set_formants_from_target(tract, target);
    if (svara_is_err(e) == 1) { return e; }
    svara_tract_set_nasal_coupling(tract, 0);
    var is_diph = 0;
    if (svara_phoneme_class(phoneme) == SVARA_CLASS_DIPHTHONG) { is_diph = 1; }
    var endt = 0;
    if (is_diph == 1) { endt = svara_voice_apply_formant_scale(voice, svara_ph_diphthong_end_target(phoneme)); }

    var use_nasal = 0;
    var onset = 0;
    var ramp = 1;
    if (nasal != 0) {
        use_nasal = 1;
        svara_tract_set_nasal_place(tract, SvNasalization_place(nasal));
        onset = f64_to(f64_mul(SvNasalization_onset(nasal), f64_from(n)));
        ramp = n - onset;
        if (ramp < 1) { ramp = 1; }
    }

    # fast path: plain vowel, no nasalization -> reuse synthesize_into
    if ((is_diph == 0) & (use_nasal == 0)) {
        svara_tract_synthesize_into(tract, g, buf, n);
        return SVARA_ERR_NONE;
    }

    var i = 0;
    while (i < n) {
        if (is_diph == 1) {
            var cur = svara_vowel_target_interpolate(target, endt, f64_div(f64_from(i), f64_from(n)));
            var e2 = svara_tract_set_formants_from_target(tract, cur);
            if (svara_is_err(e2) == 1) { return e2; }
        }
        if ((use_nasal == 1) & (i >= onset)) {
            var nt = f64_div(f64_from(i - onset), f64_from(ramp));
            svara_tract_set_nasal_coupling(tract, f64_mul(SvNasalization_peak_coupling(nasal), ease_in_out_smooth(nt)));
        }
        store64(buf + i * 8, svara_tract_process_sample(tract, svara_glottal_next_sample(g)));
        i = i + 1;
    }
    return SVARA_ERR_NONE;
}

#must_use
fn svara_synthctx_nasal(self, phoneme, voice, n) {
    var tract = SvSynthCtx_tract(self);
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var e = svara_tract_set_formants_from_target(tract, target);
    if (svara_is_err(e) == 1) { return e; }
    svara_tract_set_nasal_coupling(tract, SV_PH_08);
    var place = SVARA_NASAL_NEUTRAL;
    if (phoneme == SVARA_PH_NASAL_M) { place = SVARA_NASAL_BILABIAL; }
    elif (phoneme == SVARA_PH_NASAL_N) { place = SVARA_NASAL_ALVEOLAR; }
    elif (phoneme == SVARA_PH_NASAL_NG) { place = SVARA_NASAL_VELAR; }
    svara_tract_set_nasal_place(tract, place);
    svara_tract_synthesize_into(tract, SvSynthCtx_glottal(self), SvSynthCtx_buffer(self), n);
    return SVARA_ERR_NONE;
}

#must_use
fn svara_synthctx_fricative(self, phoneme, voice, n) {
    var buf = SvSynthCtx_buffer(self);
    var noise = SvSynthCtx_noise(self);
    var filter = svara_formant_filter_new(svara_ph_fricative_formants(phoneme), SvSynthCtx_sample_rate(self));
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }
    if (svara_phoneme_is_voiced(phoneme) == 1) {
        var tract = SvSynthCtx_tract(self);
        var g = SvSynthCtx_glottal(self);
        var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
        var e = svara_tract_set_formants_from_target(tract, target);
        if (svara_is_err(e) == 1) { return e; }
        svara_tract_set_nasal_coupling(tract, 0);
        var i = 0;
        while (i < n) {
            var friction = svara_formant_filter_process_sample(filter, f64_mul(svara_rng_next_f32(noise), F64_HALF));
            var voicing = f64_mul(svara_tract_process_sample(tract, svara_glottal_next_sample(g)), SV_PH_R04);
            store64(buf + i * 8, f64_add(friction, voicing));
            i = i + 1;
        }
    } else {
        var i = 0;
        while (i < n) {
            var ns = f64_mul(svara_rng_next_f32(noise), SV_PH_R06);
            store64(buf + i * 8, svara_formant_filter_process_sample(filter, ns));
            i = i + 1;
        }
    }
    SvSynthCtx_set_fric_filter(self, filter);
    return SVARA_ERR_NONE;
}

#must_use
fn svara_synthctx_plosive(self, phoneme, voice, n) {
    var buf = SvSynthCtx_buffer(self);
    var noise = SvSynthCtx_noise(self);
    var closure_end = n / 3;
    var burst_extra = n / 6;
    if (burst_extra < 1) { burst_extra = 1; }
    var burst_end = closure_end + burst_extra;
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var filter = svara_formant_filter_new(svara_vowel_target_to_formants(target), SvSynthCtx_sample_rate(self));
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }
    var z = 0;
    while (z < closure_end) { store64(buf + z * 8, 0); z = z + 1; }
    var be = burst_end;
    if (be > n) { be = n; }
    var i = closure_end;
    while (i < be) {
        store64(buf + i * 8, svara_formant_filter_process_sample(filter, f64_mul(svara_rng_next_f32(noise), SV_PH_08)));
        i = i + 1;
    }
    if (svara_phoneme_is_voiced(phoneme) == 1) {
        var tract = SvSynthCtx_tract(self);
        var g = SvSynthCtx_glottal(self);
        var e = svara_tract_set_formants_from_target(tract, target);
        if (svara_is_err(e) == 1) { return e; }
        svara_tract_set_nasal_coupling(tract, 0);
        svara_glottal_set_breathiness(g, SV_PH_R04);
        var m = burst_end;
        while (m < n) {
            store64(buf + m * 8, f64_mul(svara_tract_process_sample(tract, svara_glottal_next_sample(g)), F64_HALF));
            m = m + 1;
        }
        svara_glottal_set_breathiness(g, SvVoiceProfile_breathiness(voice));
    } else {
        var m2 = burst_end;
        while (m2 < n) {
            var ns = f64_mul(svara_rng_next_f32(noise), SV_PH_030);
            store64(buf + m2 * 8, svara_formant_filter_process_sample(filter, ns));
            m2 = m2 + 1;
        }
    }
    return SVARA_ERR_NONE;
}

#must_use
fn svara_synthctx_affricate(self, phoneme, voice, n) {
    var buf = SvSynthCtx_buffer(self);
    var noise = SvSynthCtx_noise(self);
    var closure_end = n / 4;
    var burst_extra = n / 8;
    if (burst_extra < 1) { burst_extra = 1; }
    var burst_end = closure_end + burst_extra;
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var filter = svara_formant_filter_new(svara_ph_fricative_formants(phoneme), SvSynthCtx_sample_rate(self));
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }
    var z = 0;
    while (z < closure_end) { store64(buf + z * 8, 0); z = z + 1; }
    var be = burst_end;
    if (be > n) { be = n; }
    var i = closure_end;
    while (i < be) {
        store64(buf + i * 8, svara_formant_filter_process_sample(filter, f64_mul(svara_rng_next_f32(noise), SV_PH_08)));
        i = i + 1;
    }
    if (svara_phoneme_is_voiced(phoneme) == 1) {
        var tract = SvSynthCtx_tract(self);
        var g = SvSynthCtx_glottal(self);
        var e = svara_tract_set_formants_from_target(tract, target);
        if (svara_is_err(e) == 1) { return e; }
        svara_tract_set_nasal_coupling(tract, 0);
        var m = burst_end;
        while (m < n) {
            var voiced = svara_tract_process_sample(tract, svara_glottal_next_sample(g));
            var fric = svara_formant_filter_process_sample(filter, f64_mul(svara_rng_next_f32(noise), F64_HALF));
            store64(buf + m * 8, f64_add(f64_mul(voiced, F64_HALF), f64_mul(fric, F64_HALF)));
            m = m + 1;
        }
    } else {
        var m2 = burst_end;
        while (m2 < n) {
            var ns = f64_mul(svara_rng_next_f32(noise), SV_PH_R06);
            store64(buf + m2 * 8, svara_formant_filter_process_sample(filter, ns));
            m2 = m2 + 1;
        }
    }
    return SVARA_ERR_NONE;
}

# approx_ctx also handles Lateral + Trill (per the Rust dispatch).
#must_use
fn svara_synthctx_approx(self, phoneme, voice, n) {
    var tract = SvSynthCtx_tract(self);
    var g = SvSynthCtx_glottal(self);
    var buf = SvSynthCtx_buffer(self);
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var e = svara_tract_set_formants_from_target(tract, target);
    if (svara_is_err(e) == 1) { return e; }
    svara_tract_set_nasal_coupling(tract, 0);
    svara_glottal_set_breathiness(g, f64_max(SvVoiceProfile_breathiness(voice), SV_PH_R01));
    svara_tract_synthesize_into(tract, g, buf, n);
    var i = 0;
    while (i < n) { store64(buf + i * 8, f64_mul(load64(buf + i * 8), SV_PH_R07)); i = i + 1; }
    svara_glottal_set_breathiness(g, SvVoiceProfile_breathiness(voice));
    return SVARA_ERR_NONE;
}

#must_use
fn svara_synthctx_click(self, phoneme, voice, n) {
    var buf = SvSynthCtx_buffer(self);
    var noise = SvSynthCtx_noise(self);
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var filter = svara_formant_filter_new(svara_vowel_target_to_formants(target), SvSynthCtx_sample_rate(self));
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }
    var burst_start = n * 6 / 10;
    var span = n - burst_start;
    if (span < 1) { span = 1; }
    var z = 0;
    while (z < burst_start) { store64(buf + z * 8, 0); z = z + 1; }
    var i = burst_start;
    while (i < n) {
        var env = f64_sub(F64_ONE, f64_div(f64_from(i - burst_start), f64_from(span)));
        var shaped = f64_mul(f64_mul(svara_rng_next_f32(noise), env), env);
        store64(buf + i * 8, svara_formant_filter_process_sample(filter, shaped));
        i = i + 1;
    }
    return SVARA_ERR_NONE;
}

#must_use
fn svara_synthctx_ejective(self, phoneme, voice, n) {
    var buf = SvSynthCtx_buffer(self);
    var noise = SvSynthCtx_noise(self);
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var filter = svara_formant_filter_new(svara_vowel_target_to_formants(target), SvSynthCtx_sample_rate(self));
    if (svara_is_err(filter) == 1) { return SVARA_ERR_ARTICULATION; }
    var is_fric = 0;
    if ((phoneme == SVARA_PH_EJECTIVE_S) | (phoneme == SVARA_PH_EJECTIVE_CH)) { is_fric = 1; }
    var closure_end = n * 4 / 10;
    var burst_end = closure_end + n * 2 / 10;
    var z = 0;
    while (z < closure_end) { store64(buf + z * 8, 0); z = z + 1; }
    var be = burst_end;
    if (be > n) { be = n; }
    var i = closure_end;
    while (i < be) {
        store64(buf + i * 8, svara_formant_filter_process_sample(filter, svara_rng_next_f32(noise)));
        i = i + 1;
    }
    var release_len = n - burst_end;
    if (release_len < 1) { release_len = 1; }
    if (is_fric == 1) {
        var fric_filter = svara_formant_filter_new(svara_ph_fricative_formants(phoneme), SvSynthCtx_sample_rate(self));
        if (svara_is_err(fric_filter) == 1) { return SVARA_ERR_ARTICULATION; }
        var jj = 0;
        var k = burst_end;
        while (k < n) {
            var decay = f64_sub(F64_ONE, f64_mul(f64_div(f64_from(jj), f64_from(release_len)), F64_HALF));
            var amp = f64_mul(f64_mul(svara_rng_next_f32(noise), SV_PH_R06), decay);
            store64(buf + k * 8, svara_formant_filter_process_sample(fric_filter, amp));
            jj = jj + 1;
            k = k + 1;
        }
    } else {
        var j2 = 0;
        var k2 = burst_end;
        while (k2 < n) {
            var decay2 = f64_max(f64_sub(F64_ONE, f64_div(f64_from(j2), f64_from(release_len))), 0);
            var amp2 = f64_mul(f64_mul(svara_rng_next_f32(noise), SV_PH_030), decay2);
            store64(buf + k2 * 8, svara_formant_filter_process_sample(filter, amp2));
            j2 = j2 + 1;
            k2 = k2 + 1;
        }
    }
    return SVARA_ERR_NONE;
}

#must_use
fn svara_synthctx_implosive(self, phoneme, voice, n) {
    var buf = SvSynthCtx_buffer(self);
    var tract = SvSynthCtx_tract(self);
    var g = SvSynthCtx_glottal(self);
    var target = svara_voice_apply_formant_scale(voice, svara_phoneme_formants(phoneme));
    var e = svara_tract_set_formants_from_target(tract, target);
    if (svara_is_err(e) == 1) { return e; }
    svara_tract_set_nasal_coupling(tract, 0);
    svara_glottal_set_creaky(g, F64_HALF);
    var closure_end = n / 3;
    var z = 0;
    while (z < closure_end) { store64(buf + z * 8, 0); z = z + 1; }
    var i = closure_end;
    while (i < n) {
        store64(buf + i * 8, f64_mul(svara_tract_process_sample(tract, svara_glottal_next_sample(g)), F64_HALF));
        i = i + 1;
    }
    svara_glottal_set_model(g, SVARA_GLOTTAL_ROSENBERG);
    return SVARA_ERR_NONE;
}

# ================================================================
# synthesize -- render one phoneme into the context's reused buffer.
# Returns the sample count (>=0), or a negative SVARA_ERR_*. Read samples via
# svara_synthctx_buffer(ctx)[0..count].
# ================================================================
#must_use
fn svara_synthctx_synthesize(self, phoneme, voice, duration, nasal) {
    if (f64_le(duration, 0) == 1) { return SVARA_ERR_INVALID_DURATION; }
    if (svara_is_finite(duration) == 0) { return SVARA_ERR_INVALID_DURATION; }
    var n = f64_to(f64_mul(duration, SvSynthCtx_sample_rate(self)));
    if (n == 0) { return 0; }
    var buf = svara_synthctx_ensure_buffer(self, n);
    svara_tract_reset(SvSynthCtx_tract(self));

    var g = SvSynthCtx_glottal(self);
    svara_glottal_set_model(g, SVARA_GLOTTAL_ROSENBERG);
    var fe = svara_glottal_set_f0(g, SvVoiceProfile_base_f0(voice));
    if (svara_is_err(fe) == 1) { return fe; }
    svara_glottal_set_breathiness(g, SvVoiceProfile_breathiness(voice));
    svara_glottal_set_jitter(g, SvVoiceProfile_jitter(voice));
    svara_glottal_set_shimmer(g, SvVoiceProfile_shimmer(voice));
    svara_glottal_set_vibrato(g, SvVoiceProfile_vibrato_rate(voice), SvVoiceProfile_vibrato_depth(voice));

    var e = SVARA_ERR_NONE;
    if (phoneme == SVARA_PH_SILENCE) {
        svara_formant_zero_buf(buf, n);
    } else {
        var c = svara_phoneme_class(phoneme);
        if ((c == SVARA_CLASS_VOWEL) | (c == SVARA_CLASS_DIPHTHONG)) {
            e = svara_synthctx_voiced(self, phoneme, voice, n, nasal);
        } elif (c == SVARA_CLASS_NASAL) {
            e = svara_synthctx_nasal(self, phoneme, voice, n);
        } elif (c == SVARA_CLASS_FRICATIVE) {
            e = svara_synthctx_fricative(self, phoneme, voice, n);
        } elif (c == SVARA_CLASS_PLOSIVE) {
            e = svara_synthctx_plosive(self, phoneme, voice, n);
        } elif (c == SVARA_CLASS_AFFRICATE) {
            e = svara_synthctx_affricate(self, phoneme, voice, n);
        } elif ((c == SVARA_CLASS_APPROXIMANT) | (c == SVARA_CLASS_LATERAL) | (c == SVARA_CLASS_TRILL)) {
            e = svara_synthctx_approx(self, phoneme, voice, n);
        } elif (c == SVARA_CLASS_CLICK) {
            e = svara_synthctx_click(self, phoneme, voice, n);
        } elif (c == SVARA_CLASS_EJECTIVE) {
            e = svara_synthctx_ejective(self, phoneme, voice, n);
        } elif (c == SVARA_CLASS_IMPLOSIVE) {
            e = svara_synthctx_implosive(self, phoneme, voice, n);
        } else {
            svara_formant_zero_buf(buf, n);   # Silence class
        }
    }
    if (svara_is_err(e) == 1) { return e; }
    svara_ph_apply_envelope(buf, n);
    return n;
}

# --- prosody.cyr ---

# prosody.cyr -- pitch contours, intonation patterns, lexical tones, stress.
# Ports rust-old/src/prosody.rs. Suprasegmental control: f0 trajectory, duration,
# and amplitude. f0 contour = a vec of (time, value) pairs (time in [0,1], value
# an f0 multiplier), interpolated with hisab monotone-cubic (Fritsch-Carlson, no
# overshoot). f32 -> f64 throughout. Non-integer contour values use Cyrius f64
# float literals directly. serde dropped (M-serde; roadmap.md).
#
# Requires: stdlib alloc/vec/math, hisab (calc_monotone_cubic). No project deps.

# IntonationPattern (enum -> ints).
var SVARA_INTONATION_DECLARATIVE  = 0;
var SVARA_INTONATION_INTERROGATIVE = 1;
var SVARA_INTONATION_CONTINUATION = 2;
var SVARA_INTONATION_EXCLAMATORY  = 3;

# Tone (enum -> ints). 9 lexical tones.
var SVARA_TONE_HIGH        = 0;
var SVARA_TONE_RISING      = 1;
var SVARA_TONE_DIPPING     = 2;
var SVARA_TONE_FALLING     = 3;
var SVARA_TONE_NEUTRAL     = 4;
var SVARA_TONE_LOW         = 5;
var SVARA_TONE_MID         = 6;
var SVARA_TONE_LOW_RISING  = 7;
var SVARA_TONE_HIGH_FALLING = 8;

# Stress (enum -> ints).
var SVARA_STRESS_PRIMARY    = 0;
var SVARA_STRESS_SECONDARY  = 1;
var SVARA_STRESS_UNSTRESSED = 2;

# f0 point = 16-byte pair {time@0, value@8}.
#must_use
fn svara_pt_new(t, v) { var p = alloc(16); store64(p, t); store64(p + 8, v); return p; }
#must_use
fn svara_pt_time(p) { return load64(p); }
#must_use
fn svara_pt_value(p) { return load64(p + 8); }

#derive(accessors)
struct SvProsodyContour { f0_points; duration_scale; amplitude_scale; }

# selection sort a vec of point pointers by ascending time.
fn svara_prosody_sort_points(v) {
    var n = vec_len(v);
    var a = 0;
    while (a < n) {
        var lo = a;
        var b = a + 1;
        while (b < n) {
            if (f64_lt(svara_pt_time(vec_get(v, b)), svara_pt_time(vec_get(v, lo))) == 1) { lo = b; }
            b = b + 1;
        }
        if (lo != a) {
            var tmp = vec_get(v, a);
            vec_set(v, a, vec_get(v, lo));
            vec_set(v, lo, tmp);
        }
        a = a + 1;
    }
}

# f0_at_internal -- monotone-cubic interpolation of the f0 multiplier at t.
# calc_monotone_cubic returns 0 on error; mirror Rust's unwrap_or(1.0).
#must_use
fn svara_prosody_f0_at_internal(self, t) {
    var pts = SvProsodyContour_f0_points(self);
    var n = vec_len(pts);
    if (n == 0) { return F64_ONE; }
    if (n == 1) { return svara_pt_value(vec_get(pts, 0)); }
    var tc = f64_clamp(t, 0, F64_ONE);
    var xs = alloc(n * 8);
    var ys = alloc(n * 8);
    var i = 0;
    while (i < n) {
        var p = vec_get(pts, i);
        store64(xs + i * 8, svara_pt_time(p));
        store64(ys + i * 8, svara_pt_value(p));
        i = i + 1;
    }
    var r = calc_monotone_cubic(xs, ys, n, tc);
    if (r == 0) { return F64_ONE; }
    return r;
}

#must_use
fn svara_prosody_f0_at(self, t) { return svara_prosody_f0_at_internal(self, t); }

# insert_f0_boost -- boost f0 around `position` (width), adding peak + boundary points.
fn svara_prosody_insert_f0_boost(self, position, boost, width) {
    var pts = SvProsodyContour_f0_points(self);
    var start = f64_max(f64_sub(position, width), 0);
    var end = f64_min(f64_add(position, width), F64_ONE);

    # scale existing points within `width` of `position`
    var i = 0;
    while (i < vec_len(pts)) {
        var p = vec_get(pts, i);
        var dist = f64_abs(f64_sub(svara_pt_time(p), position));
        if (f64_lt(dist, width) == 1) {
            var influence = f64_sub(F64_ONE, f64_div(dist, width));
            var factor = f64_add(F64_ONE, f64_mul(f64_sub(boost, F64_ONE), influence));
            store64(p + 8, f64_mul(svara_pt_value(p), factor));
        }
        i = i + 1;
    }

    # add a peak point unless one already sits within 0.02
    var has_nearby = 0;
    var j = 0;
    while (j < vec_len(pts)) {
        if (f64_lt(f64_abs(f64_sub(svara_pt_time(vec_get(pts, j)), position)), 0.02) == 1) { has_nearby = 1; }
        j = j + 1;
    }
    if (has_nearby == 0) {
        var base = svara_prosody_f0_at_internal(self, position);
        vec_push(pts, svara_pt_new(position, f64_mul(base, boost)));
        svara_prosody_sort_points(pts);
    }

    # ensure a boundary point at `start` (prepend by rebuilding)
    if (vec_len(pts) > 0) {
        if (f64_gt(svara_pt_time(vec_get(pts, 0)), start) == 1) {
            var nv = vec_new();
            vec_push(nv, svara_pt_new(start, svara_prosody_f0_at_internal(self, start)));
            var k = 0;
            while (k < vec_len(pts)) { vec_push(nv, vec_get(pts, k)); k = k + 1; }
            SvProsodyContour_set_f0_points(self, nv);
            pts = nv;
        }
    }
    # ensure a boundary point at `end`
    var last = vec_len(pts) - 1;
    if (last >= 0) {
        if (f64_lt(svara_pt_time(vec_get(pts, last)), end) == 1) {
            vec_push(pts, svara_pt_new(end, svara_prosody_f0_at_internal(self, end)));
        }
    }
}

# apply_stress -- primary/secondary boost f0+dur+amp; unstressed slightly reduces.
fn svara_prosody_apply_stress(self, stress, position) {
    var pos = f64_clamp(position, 0, F64_ONE);
    if (stress == SVARA_STRESS_PRIMARY) {
        svara_prosody_insert_f0_boost(self, pos, 1.10, 0.15);
        SvProsodyContour_set_duration_scale(self, f64_mul(SvProsodyContour_duration_scale(self), 1.15));
        SvProsodyContour_set_amplitude_scale(self, f64_mul(SvProsodyContour_amplitude_scale(self), 1.1));
    } elif (stress == SVARA_STRESS_SECONDARY) {
        svara_prosody_insert_f0_boost(self, pos, 1.05, 0.10);
        SvProsodyContour_set_duration_scale(self, f64_mul(SvProsodyContour_duration_scale(self), 1.05));
        SvProsodyContour_set_amplitude_scale(self, f64_mul(SvProsodyContour_amplitude_scale(self), 1.05));
    } else {
        SvProsodyContour_set_duration_scale(self, f64_mul(SvProsodyContour_duration_scale(self), 0.9));
        SvProsodyContour_set_amplitude_scale(self, f64_mul(SvProsodyContour_amplitude_scale(self), 0.95));
    }
}

# build a contour from a points vec + scales.
#must_use
fn svara_prosody_make(pts, dur, amp) {
    var c = alloc(sizeof(SvProsodyContour));
    SvProsodyContour_set_f0_points(c, pts);
    SvProsodyContour_set_duration_scale(c, dur);
    SvProsodyContour_set_amplitude_scale(c, amp);
    return c;
}

# flat -- constant f0, no scaling.
#must_use
fn svara_prosody_flat() {
    var p = vec_new();
    vec_push(p, svara_pt_new(0, F64_ONE));
    vec_push(p, svara_pt_new(F64_ONE, F64_ONE));
    return svara_prosody_make(p, F64_ONE, F64_ONE);
}

# from_pattern -- intonation contour (base_f0 unused, values are multipliers).
#must_use
fn svara_prosody_from_pattern(pattern, base_f0) {
    if (pattern == SVARA_INTONATION_DECLARATIVE) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 1.05));
        vec_push(p, svara_pt_new(0.3, 1.02));
        vec_push(p, svara_pt_new(0.6, 0.95));
        vec_push(p, svara_pt_new(0.8, 0.88));
        vec_push(p, svara_pt_new(1.0, 0.80));
        return svara_prosody_make(p, 1.0, 1.0);
    }
    if (pattern == SVARA_INTONATION_INTERROGATIVE) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 1.0));
        vec_push(p, svara_pt_new(0.4, 0.98));
        vec_push(p, svara_pt_new(0.6, 1.05));
        vec_push(p, svara_pt_new(0.8, 1.15));
        vec_push(p, svara_pt_new(1.0, 1.30));
        return svara_prosody_make(p, 1.1, 1.0);
    }
    if (pattern == SVARA_INTONATION_CONTINUATION) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 1.0));
        vec_push(p, svara_pt_new(0.3, 1.08));
        vec_push(p, svara_pt_new(0.5, 1.12));
        vec_push(p, svara_pt_new(0.7, 1.06));
        vec_push(p, svara_pt_new(1.0, 1.0));
        return svara_prosody_make(p, 1.05, 1.0);
    }
    # EXCLAMATORY
    var p = vec_new();
    vec_push(p, svara_pt_new(0.0, 1.3));
    vec_push(p, svara_pt_new(0.2, 1.25));
    vec_push(p, svara_pt_new(0.5, 1.1));
    vec_push(p, svara_pt_new(0.8, 0.9));
    vec_push(p, svara_pt_new(1.0, 0.75));
    return svara_prosody_make(p, 0.9, 1.2);
}

# to_contour -- f0 contour for a lexical tone (values are f0 multipliers).
#must_use
fn svara_tone_to_contour(tone) {
    if (tone == SVARA_TONE_HIGH) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 1.2));
        vec_push(p, svara_pt_new(0.5, 1.2));
        vec_push(p, svara_pt_new(1.0, 1.2));
        return svara_prosody_make(p, 1.0, 1.0);
    }
    if (tone == SVARA_TONE_RISING) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 0.85));
        vec_push(p, svara_pt_new(0.3, 0.85));
        vec_push(p, svara_pt_new(0.7, 1.1));
        vec_push(p, svara_pt_new(1.0, 1.25));
        return svara_prosody_make(p, 1.0, 1.0);
    }
    if (tone == SVARA_TONE_DIPPING) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 1.0));
        vec_push(p, svara_pt_new(0.2, 0.85));
        vec_push(p, svara_pt_new(0.5, 0.75));
        vec_push(p, svara_pt_new(0.8, 0.9));
        vec_push(p, svara_pt_new(1.0, 1.05));
        return svara_prosody_make(p, 1.15, 0.9);
    }
    if (tone == SVARA_TONE_FALLING) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 1.3));
        vec_push(p, svara_pt_new(0.3, 1.15));
        vec_push(p, svara_pt_new(0.7, 0.9));
        vec_push(p, svara_pt_new(1.0, 0.75));
        return svara_prosody_make(p, 0.9, 1.1);
    }
    if (tone == SVARA_TONE_NEUTRAL) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 1.0));
        vec_push(p, svara_pt_new(1.0, 0.95));
        return svara_prosody_make(p, 0.7, 0.85);
    }
    if (tone == SVARA_TONE_LOW) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 0.75));
        vec_push(p, svara_pt_new(0.5, 0.75));
        vec_push(p, svara_pt_new(1.0, 0.75));
        return svara_prosody_make(p, 1.0, 0.95);
    }
    if (tone == SVARA_TONE_MID) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 1.0));
        vec_push(p, svara_pt_new(0.5, 1.0));
        vec_push(p, svara_pt_new(1.0, 1.0));
        return svara_prosody_make(p, 1.0, 1.0);
    }
    if (tone == SVARA_TONE_LOW_RISING) {
        var p = vec_new();
        vec_push(p, svara_pt_new(0.0, 0.7));
        vec_push(p, svara_pt_new(0.4, 0.75));
        vec_push(p, svara_pt_new(0.7, 0.95));
        vec_push(p, svara_pt_new(1.0, 1.1));
        return svara_prosody_make(p, 1.0, 1.0);
    }
    # HIGH_FALLING
    var p = vec_new();
    vec_push(p, svara_pt_new(0.0, 1.35));
    vec_push(p, svara_pt_new(0.2, 1.3));
    vec_push(p, svara_pt_new(0.6, 1.0));
    vec_push(p, svara_pt_new(1.0, 0.7));
    return svara_prosody_make(p, 0.95, 1.05);
}

# --- trajectory.cyr ---

# trajectory.cyr -- formant trajectory planning across multi-phoneme windows.
# Ports rust-old/src/trajectory.rs. Instead of per-phoneme synthesis + crossfade,
# plan a continuous formant trajectory over an utterance: each phoneme's target
# is a control point; neighbors influence transitions by coarticulation resistance.
# Catmull-Rom (4-point) interpolation where neighbors exist, weighted by outer
# resistance, else sigmoid (hisab ease_in_out_smooth). f32 -> f64 throughout.
#
# Requires: stdlib alloc/vec/math, hisab (ease_in_out_smooth), error.cyr (SV_EPSILON),
# formant.cyr (VowelTarget), phoneme.cyr (phoneme_formants, coarticulation_resistance),
# voice.cyr (apply_formant_scale). serde dropped (M-serde; roadmap.md).

# FormantKeypoint -- target formants at a sample time, with coarticulation resistance.
#derive(accessors)
struct SvFormantKeypoint { time; target; resistance; }

#must_use
fn svara_keypoint_new(time, target, resistance) {
    var k = alloc(sizeof(SvFormantKeypoint));
    SvFormantKeypoint_set_time(k, time);
    SvFormantKeypoint_set_target(k, target);
    SvFormantKeypoint_set_resistance(k, resistance);
    return k;
}

#derive(accessors)
struct SvTrajectoryPlanner { keypoints; total_samples; }

# plan -- build a trajectory from parallel phonemes (vec<int>) + durations (vec<f64>).
#must_use
fn svara_trajectory_plan(phonemes, durations, voice, sample_rate) {
    var self = alloc(sizeof(SvTrajectoryPlanner));
    var kps = vec_new();
    var np = vec_len(phonemes);
    if (np == 0) {
        SvTrajectoryPlanner_set_keypoints(self, kps);
        SvTrajectoryPlanner_set_total_samples(self, 0);
        return self;
    }

    # sample offset at each phoneme boundary
    var boundaries = vec_new();
    vec_push(boundaries, 0);
    var offset = 0;
    var i = 0;
    while (i < np) {
        offset = offset + f64_to(f64_mul(vec_get(durations, i), sample_rate));
        vec_push(boundaries, offset);
        i = i + 1;
    }
    var total = offset;

    # leading keypoint at time 0
    var p0 = vec_get(phonemes, 0);
    vec_push(kps, svara_keypoint_new(0, svara_voice_apply_formant_scale(voice, svara_phoneme_formants(p0)),
    svara_phoneme_coarticulation_resistance(p0)));
    # midpoint keypoint per phoneme
    i = 0;
    while (i < np) {
        var ph = vec_get(phonemes, i);
        var mid = (vec_get(boundaries, i) + vec_get(boundaries, i + 1)) / 2;
        vec_push(kps, svara_keypoint_new(mid, svara_voice_apply_formant_scale(voice, svara_phoneme_formants(ph)),
        svara_phoneme_coarticulation_resistance(ph)));
        i = i + 1;
    }
    # trailing keypoint at end
    var pl = vec_get(phonemes, np - 1);
    vec_push(kps, svara_keypoint_new(total, svara_voice_apply_formant_scale(voice, svara_phoneme_formants(pl)),
    svara_phoneme_coarticulation_resistance(pl)));

    SvTrajectoryPlanner_set_keypoints(self, kps);
    SvTrajectoryPlanner_set_total_samples(self, total);
    return self;
}

#must_use
fn svara_trajectory_total_samples(self) { return SvTrajectoryPlanner_total_samples(self); }
#must_use
fn svara_trajectory_num_keypoints(self) { return vec_len(SvTrajectoryPlanner_keypoints(self)); }
#must_use
fn svara_trajectory_keypoints(self) { return SvTrajectoryPlanner_keypoints(self); }

# find_segment -- binary search for keypoint segment containing `sample`.
#must_use
fn svara_trajectory_find_segment(self, sample) {
    var kps = SvTrajectoryPlanner_keypoints(self);
    var n = vec_len(kps);
    var lo = 0;
    var hi = n - 1;
    if (hi < 0) { hi = 0; }
    while (lo < hi) {
        var mid = (lo + hi + 1) / 2;   # div_ceil(2)
        if (SvFormantKeypoint_time(vec_get(kps, mid)) <= sample) { lo = mid; }
        else { hi = mid - 1; }
    }
    var cap = n - 2;
    if (cap < 0) { cap = 0; }
    if (lo > cap) { lo = cap; }
    return lo;
}

# Catmull-Rom scalar: 0.5*(2b + (-a+c)t + (2a-5b+4c-d)t^2 + (-a+3b-3c+d)t^3).
#must_use
fn svara_traj_cr(a, b, c, d, t) {
    var t2 = f64_mul(t, t);
    var t3 = f64_mul(t2, t);
    var term0 = f64_mul(F64_TWO, b);
    var term1 = f64_mul(f64_add(f64_neg(a), c), t);
    var c2 = f64_sub(f64_add(f64_sub(f64_mul(F64_TWO, a), f64_mul(f64_from(5), b)), f64_mul(f64_from(4), c)), d);
    var term2 = f64_mul(c2, t2);
    var c3 = f64_add(f64_sub(f64_add(f64_neg(a), f64_mul(f64_from(3), b)), f64_mul(f64_from(3), c)), d);
    var term3 = f64_mul(c3, t3);
    return f64_mul(F64_HALF, f64_add(f64_add(f64_add(term0, term1), term2), term3));
}

# catmull_rom_vowel -- 4-point Catmull-Rom over all 10 VowelTarget components.
#must_use
fn svara_catmull_rom_vowel(p0, p1, p2, p3, t) {
    return svara_vowel_target_with_bandwidths(
    svara_traj_cr(SvVowelTarget_f1(p0), SvVowelTarget_f1(p1), SvVowelTarget_f1(p2), SvVowelTarget_f1(p3), t),
    svara_traj_cr(SvVowelTarget_f2(p0), SvVowelTarget_f2(p1), SvVowelTarget_f2(p2), SvVowelTarget_f2(p3), t),
    svara_traj_cr(SvVowelTarget_f3(p0), SvVowelTarget_f3(p1), SvVowelTarget_f3(p2), SvVowelTarget_f3(p3), t),
    svara_traj_cr(SvVowelTarget_f4(p0), SvVowelTarget_f4(p1), SvVowelTarget_f4(p2), SvVowelTarget_f4(p3), t),
    svara_traj_cr(SvVowelTarget_f5(p0), SvVowelTarget_f5(p1), SvVowelTarget_f5(p2), SvVowelTarget_f5(p3), t),
    svara_traj_cr(SvVowelTarget_b1(p0), SvVowelTarget_b1(p1), SvVowelTarget_b1(p2), SvVowelTarget_b1(p3), t),
    svara_traj_cr(SvVowelTarget_b2(p0), SvVowelTarget_b2(p1), SvVowelTarget_b2(p2), SvVowelTarget_b2(p3), t),
    svara_traj_cr(SvVowelTarget_b3(p0), SvVowelTarget_b3(p1), SvVowelTarget_b3(p2), SvVowelTarget_b3(p3), t),
    svara_traj_cr(SvVowelTarget_b4(p0), SvVowelTarget_b4(p1), SvVowelTarget_b4(p2), SvVowelTarget_b4(p3), t),
    svara_traj_cr(SvVowelTarget_b5(p0), SvVowelTarget_b5(p1), SvVowelTarget_b5(p2), SvVowelTarget_b5(p3), t));
}

# formants_at -- interpolated VowelTarget at a sample position.
#must_use
fn svara_trajectory_formants_at(self, sample) {
    var kps = SvTrajectoryPlanner_keypoints(self);
    var n = vec_len(kps);
    if (n == 0) {
        return svara_vowel_target_new(f64_from(500), f64_from(1500), f64_from(2500), f64_from(3300), f64_from(3750));
    }
    if (n == 1) { return SvFormantKeypoint_target(vec_get(kps, 0)); }

    var seg = svara_trajectory_find_segment(self, sample);
    var k0 = vec_get(kps, seg);
    var seg1 = seg + 1;
    if (seg1 > n - 1) { seg1 = n - 1; }
    var k1 = vec_get(kps, seg1);

    var span = SvFormantKeypoint_time(k1) - SvFormantKeypoint_time(k0);
    if (span < 1) { span = 1; }
    var d = sample - SvFormantKeypoint_time(k0);
    if (d < 0) { d = 0; }
    var t = f64_clamp(f64_div(f64_from(d), f64_from(span)), 0, F64_ONE);

    if ((seg > 0) & ((seg + 2) < n)) {
        var km1 = vec_get(kps, seg - 1);
        var k2 = vec_get(kps, seg + 2);
        var outer = f64_mul(f64_add(SvFormantKeypoint_resistance(km1), SvFormantKeypoint_resistance(k2)), F64_HALF);
        var catmull_weight = f64_sub(F64_ONE, outer);
        if (f64_gt(catmull_weight, 0.05) == 1) {
            var linear = svara_vowel_target_interpolate(SvFormantKeypoint_target(k0), SvFormantKeypoint_target(k1), t);
            var catmull = svara_catmull_rom_vowel(SvFormantKeypoint_target(km1), SvFormantKeypoint_target(k0),
            SvFormantKeypoint_target(k1), SvFormantKeypoint_target(k2), t);
            return svara_vowel_target_interpolate(linear, catmull, catmull_weight);
        }
    }
    var t_smooth = ease_in_out_smooth(t);
    return svara_vowel_target_interpolate(SvFormantKeypoint_target(k0), SvFormantKeypoint_target(k1), t_smooth);
}

# apply_speaking_rate -- Lindblom undershoot: resistance *= 1/rate, clamped [0,1].
fn svara_trajectory_apply_speaking_rate(self, rate) {
    if (f64_lt(f64_abs(f64_sub(rate, F64_ONE)), SV_EPSILON) == 1) { return 0; }
    var factor = f64_div(F64_ONE, rate);
    var kps = SvTrajectoryPlanner_keypoints(self);
    var i = 0;
    while (i < vec_len(kps)) {
        var kp = vec_get(kps, i);
        SvFormantKeypoint_set_resistance(kp, f64_clamp(f64_mul(SvFormantKeypoint_resistance(kp), factor), 0, F64_ONE));
        i = i + 1;
    }
    return 0;
}

# --- sequence.cyr ---

# sequence.cyr -- phoneme sequencing with coarticulation + crossfading.
# Ports rust-old/src/sequence.rs. Combines phonemes into continuous speech:
# stress-based duration/f0 scaling, consonant-cluster compression, anticipatory
# nasalization, and either resistance-weighted crossfade (render) or continuous
# trajectory-planned synthesis (render_planned). f32 -> f64 throughout.
#
# Requires: stdlib alloc/vec/math, hisab (ease_in_out_smooth), error.cyr, rng.cyr,
# formant.cyr, glottal.cyr, tract.cyr, voice.cyr, phoneme.cyr (synthesize_phoneme_
# nasalized / detect_nasalization / coarticulation_resistance / class), prosody.cyr
# (Stress / Tone / to_contour / f0_at), trajectory.cyr (plan / formants_at /
# apply_speaking_rate). serde dropped (M-serde; roadmap.md).

var SV_SEQ_MIN_CF   = 0.15;   # min crossfade fraction (high-resistance)
var SV_SEQ_MAX_CF   = 0.45;   # max crossfade fraction (low-resistance)
var SV_SEQ_CLUSTER  = 0.7;    # consonant-cluster duration compression
var SVARA_TONE_NONE = (0 - 1); # PhonemeEvent.tone sentinel for "no tone"

# PhonemeEvent -- a timed phoneme. tone = SVARA_TONE_NONE or a SVARA_TONE_* value.
#derive(accessors)
#derive(Serialize)
struct SvPhonemeEvent { phoneme: i64; duration: f64; stress: i64; tone: i64; }

#must_use
fn svara_phoneme_event_new(phoneme, duration, stress) {
    var e = alloc(sizeof(SvPhonemeEvent));
    SvPhonemeEvent_set_phoneme(e, phoneme);
    SvPhonemeEvent_set_duration(e, duration);
    SvPhonemeEvent_set_stress(e, stress);
    SvPhonemeEvent_set_tone(e, SVARA_TONE_NONE);
    return e;
}

#must_use
fn svara_phoneme_event_with_tone(phoneme, duration, stress, tone) {
    var e = svara_phoneme_event_new(phoneme, duration, stress);
    SvPhonemeEvent_set_tone(e, tone);
    return e;
}

# PhonemeSequence -- ordered events + coarticulation params.
#derive(accessors)
struct SvPhonemeSequence { events; transition_window; lookahead_onset; speaking_rate; }

#must_use
fn svara_sequence_new() {
    var s = alloc(sizeof(SvPhonemeSequence));
    SvPhonemeSequence_set_events(s, vec_new());
    SvPhonemeSequence_set_transition_window(s, 0.05);
    SvPhonemeSequence_set_lookahead_onset(s, 0.6);
    SvPhonemeSequence_set_speaking_rate(s, F64_ONE);
    return s;
}

# set_transition_window -- coarticulation crossfade seconds, floored at 0.001.
fn svara_sequence_set_transition_window(s, window) {
    SvPhonemeSequence_set_transition_window(s, f64_max(window, 0.001));
}
# set_lookahead_onset -- anticipatory-coarticulation weight, clamped [0,1].
fn svara_sequence_set_lookahead_onset(s, onset) {
    SvPhonemeSequence_set_lookahead_onset(s, f64_clamp(onset, 0, F64_ONE));
}
# set_speaking_rate -- global duration scale, clamped [0.5,3.0].
fn svara_sequence_set_speaking_rate(s, rate) {
    SvPhonemeSequence_set_speaking_rate(s, f64_clamp(rate, 0.5, 3.0));
}
#must_use
fn svara_sequence_speaking_rate(s) { return SvPhonemeSequence_speaking_rate(s); }
#must_use
fn svara_sequence_transition_window(s) { return SvPhonemeSequence_transition_window(s); }
# push -- append a phoneme event to the sequence.
fn svara_sequence_push(s, event) { vec_push(SvPhonemeSequence_events(s), event); }
#must_use
fn svara_sequence_len(s) { return vec_len(SvPhonemeSequence_events(s)); }
#must_use
fn svara_sequence_is_empty(s) {
    if (vec_len(SvPhonemeSequence_events(s)) == 0) { return 1; }
    return 0;
}
#must_use
fn svara_sequence_events(s) { return SvPhonemeSequence_events(s); }
#must_use
fn svara_sequence_total_duration(s) {
    var events = SvPhonemeSequence_events(s);
    var total = 0;
    var i = 0;
    while (i < vec_len(events)) {
        total = f64_add(total, SvPhonemeEvent_duration(vec_get(events, i)));
        i = i + 1;
    }
    return total;
}

# clone a VoiceProfile (for per-event f0 modification without mutating caller's).
#must_use
fn svara_seq_voice_clone(v) {
    var c = alloc(sizeof(SvVoiceProfile));
    SvVoiceProfile_set_base_f0(c, SvVoiceProfile_base_f0(v));
    SvVoiceProfile_set_f0_range(c, SvVoiceProfile_f0_range(v));
    SvVoiceProfile_set_formant_scale(c, SvVoiceProfile_formant_scale(v));
    SvVoiceProfile_set_breathiness(c, SvVoiceProfile_breathiness(v));
    SvVoiceProfile_set_vibrato_rate(c, SvVoiceProfile_vibrato_rate(v));
    SvVoiceProfile_set_vibrato_depth(c, SvVoiceProfile_vibrato_depth(v));
    SvVoiceProfile_set_jitter(c, SvVoiceProfile_jitter(v));
    SvVoiceProfile_set_shimmer(c, SvVoiceProfile_shimmer(v));
    SvVoiceProfile_set_bandwidth_widening(c, SvVoiceProfile_bandwidth_widening(v));
    return c;
}

# detect_consonant_clusters -- vec<0/1>: 1 where the phoneme is in a run of 2+
# adjacent consonants (non vowel/diphthong/silence).
#must_use
fn svara_seq_detect_clusters(events) {
    var n = vec_len(events);
    var flags = vec_new();
    var i = 0;
    while (i < n) { vec_push(flags, 0); i = i + 1; }
    var run_start = (0 - 1);
    i = 0;
    while (i <= n) {
        var is_cons = 0;
        if (i < n) {
            var c = svara_phoneme_class(SvPhonemeEvent_phoneme(vec_get(events, i)));
            if ((c != SVARA_CLASS_VOWEL) & (c != SVARA_CLASS_DIPHTHONG) & (c != SVARA_CLASS_SILENCE)) {
                is_cons = 1;
            }
        }
        if ((is_cons == 1) & (run_start < 0)) {
            run_start = i;
        } elif ((is_cons == 0) & (run_start >= 0)) {
            if ((i - run_start) >= 2) {
                var k = run_start;
                while (k < i) { vec_set(flags, k, 1); k = k + 1; }
            }
            run_start = (0 - 1);
        }
        i = i + 1;
    }
    return flags;
}

# effective durations: duration * stress_scale * cluster_scale.
#must_use
fn svara_seq_durations(seq, in_cluster) {
    var events = SvPhonemeSequence_events(seq);
    var n = vec_len(events);
    var durs = vec_new();
    var i = 0;
    while (i < n) {
        var e = vec_get(events, i);
        var ss = 0.9;
        var st = SvPhonemeEvent_stress(e);
        if (st == SVARA_STRESS_PRIMARY) { ss = 1.15; }
        elif (st == SVARA_STRESS_SECONDARY) { ss = 1.05; }
        var cs = F64_ONE;
        if (vec_get(in_cluster, i) == 1) { cs = SV_SEQ_CLUSTER; }
        vec_push(durs, f64_mul(f64_mul(SvPhonemeEvent_duration(e), ss), cs));
        i = i + 1;
    }
    return durs;
}

#must_use
fn svara_seq_phoneme_list(seq) {
    var events = SvPhonemeSequence_events(seq);
    var pl = vec_new();
    var i = 0;
    while (i < vec_len(events)) { vec_push(pl, SvPhonemeEvent_phoneme(vec_get(events, i))); i = i + 1; }
    return pl;
}

# sigmoid crossfade easing (hisab smootherstep), clamped.
#must_use
fn svara_seq_sigmoid_fade(t) {
    return ease_in_out_smooth(f64_clamp(t, 0, F64_ONE));
}

# crossfade_segments_variable -- blend adjacent sample vecs with per-boundary
# crossfade lengths (sigmoid). Returns the concatenated/blended sample vec.
#must_use
fn svara_seq_crossfade(segments, cf_lengths) {
    var ns = vec_len(segments);
    if (ns == 0) { return vec_new(); }
    if (ns == 1) { return vec_get(segments, 0); }
    var output = vec_new();
    var i = 0;
    while (i < ns) {
        var seg = vec_get(segments, i);
        var seglen = vec_len(seg);
        var cf_next = 0;
        if (i < vec_len(cf_lengths)) { cf_next = vec_get(cf_lengths, i); }
        var cf_prev = 0;
        if (i > 0) { cf_prev = vec_get(cf_lengths, i - 1); }
        var cfn1 = cf_next;
        if (cfn1 < 1) { cfn1 = 1; }

        if (i == 0) {
            if (seglen > cf_next) {
                var j = 0;
                var stop = seglen - cf_next;
                while (j < stop) { vec_push(output, vec_get(seg, j)); j = j + 1; }
            }
            var fs = seglen - cf_next;
            if (fs < 0) { fs = 0; }
            var k = fs;
            var jj = 0;
            while (k < seglen) {
                var w = f64_sub(F64_ONE, svara_seq_sigmoid_fade(f64_div(f64_from(jj), f64_from(cfn1))));
                vec_push(output, f64_mul(vec_get(seg, k), w));
                jj = jj + 1;
                k = k + 1;
            }
        } else {
            var fade_len = cf_prev;
            if (fade_len > seglen) { fade_len = seglen; }
            var fl1 = fade_len;
            if (fl1 < 1) { fl1 = 1; }
            var output_len = vec_len(output);
            var j = 0;
            while (j < fade_len) {
                var idx = output_len - (fade_len - j);
                if ((idx >= 0) & (idx < output_len)) {
                    var add = f64_mul(vec_get(seg, j), svara_seq_sigmoid_fade(f64_div(f64_from(j), f64_from(fl1))));
                    vec_set(output, idx, f64_add(vec_get(output, idx), add));
                }
                j = j + 1;
            }
            if (seglen > fade_len) {
                if ((i < ns - 1) & (seglen > fade_len + cf_next)) {
                    var m = fade_len;
                    var stop2 = seglen - cf_next;
                    while (m < stop2) { vec_push(output, vec_get(seg, m)); m = m + 1; }
                    var fs2 = seglen - cf_next;
                    var kk = fs2;
                    var j2 = 0;
                    while (kk < seglen) {
                        var w2 = f64_sub(F64_ONE, svara_seq_sigmoid_fade(f64_div(f64_from(j2), f64_from(cfn1))));
                        vec_push(output, f64_mul(vec_get(seg, kk), w2));
                        j2 = j2 + 1;
                        kk = kk + 1;
                    }
                } else {
                    var m2 = fade_len;
                    while (m2 < seglen) { vec_push(output, vec_get(seg, m2)); m2 = m2 + 1; }
                }
            }
        }
        i = i + 1;
    }
    return output;
}

# render -- synthesize each phoneme (stress/cluster/nasalization) and crossfade.
# Returns a vec<f64> of samples, or a negative SVARA_ERR_*.
#must_use
fn svara_sequence_render(seq, voice, sample_rate) {
    var events = SvPhonemeSequence_events(seq);
    var n = vec_len(events);
    if (n == 0) { return vec_new(); }
    var in_cluster = svara_seq_detect_clusters(events);
    var durs = svara_seq_durations(seq, in_cluster);
    var nasals = svara_detect_nasalization(svara_seq_phoneme_list(seq));

    var segments = vec_new();
    var i = 0;
    while (i < n) {
        var e = vec_get(events, i);
        var ev = svara_seq_voice_clone(voice);
        var st = SvPhonemeEvent_stress(e);
        if (st == SVARA_STRESS_PRIMARY) {
            SvVoiceProfile_set_base_f0(ev, f64_mul(SvVoiceProfile_base_f0(ev), 1.10));
        } elif (st == SVARA_STRESS_SECONDARY) {
            SvVoiceProfile_set_base_f0(ev, f64_mul(SvVoiceProfile_base_f0(ev), 1.05));
        }
        var seg = svara_phoneme_synthesize_nasalized(SvPhonemeEvent_phoneme(e), ev, sample_rate,
        vec_get(durs, i), vec_get(nasals, i));
        if (svara_is_err(seg) == 1) { return seg; }
        vec_push(segments, seg);
        i = i + 1;
    }

    var cfs = vec_new();
    var min_cf = f64_to(f64_mul(SvPhonemeSequence_transition_window(seq), sample_rate));
    i = 0;
    while (i < n - 1) {
        var rl = svara_phoneme_coarticulation_resistance(SvPhonemeEvent_phoneme(vec_get(events, i)));
        var rr = svara_phoneme_coarticulation_resistance(SvPhonemeEvent_phoneme(vec_get(events, i + 1)));
        var avg = f64_mul(f64_add(rl, rr), F64_HALF);
        var frac = f64_sub(SV_SEQ_MAX_CF, f64_mul(avg, f64_sub(SV_SEQ_MAX_CF, SV_SEQ_MIN_CF)));
        var sl = vec_len(vec_get(segments, i));
        var sl2 = vec_len(vec_get(segments, i + 1));
        if (sl2 < sl) { sl = sl2; }
        var cf_len = f64_to(f64_mul(frac, f64_from(sl)));
        if (cf_len < min_cf) { cf_len = min_cf; }
        vec_push(cfs, cf_len);
        i = i + 1;
    }
    return svara_seq_crossfade(segments, cfs);
}

# render_planned -- continuous trajectory-planned synthesis (per-sample formant
# updates). Returns a vec<f64>, or a negative SVARA_ERR_*.
#must_use
fn svara_sequence_render_planned(seq, voice, sample_rate) {
    var events = SvPhonemeSequence_events(seq);
    var n = vec_len(events);
    if (n == 0) { return vec_new(); }
    var in_cluster = svara_seq_detect_clusters(events);
    var durs = svara_seq_durations(seq, in_cluster);
    var pl = svara_seq_phoneme_list(seq);
    var nasals = svara_detect_nasalization(pl);

    var plan = svara_trajectory_plan(pl, durs, voice, sample_rate);
    svara_trajectory_apply_speaking_rate(plan, SvPhonemeSequence_speaking_rate(seq));
    var total = svara_trajectory_total_samples(plan);
    if (total == 0) { return vec_new(); }

    # phoneme boundaries in samples
    var boundaries = vec_new();
    vec_push(boundaries, 0);
    var offset = 0;
    var bi = 0;
    while (bi < n) {
        offset = offset + f64_to(f64_mul(vec_get(durs, bi), sample_rate));
        vec_push(boundaries, offset);
        bi = bi + 1;
    }

    var glottal = svara_voice_create_glottal_source(voice, sample_rate);
    if (svara_is_err(glottal) == 1) { return SVARA_ERR_ARTICULATION; }
    var tract = svara_tract_new(sample_rate);
    var noise = svara_rng_new(17);
    var out = alloc(total * 8);

    var idx = 0;
    var s = 0;
    while (s < total) {
        while (((idx + 1) < n) & (s >= vec_get(boundaries, idx + 1))) { idx = idx + 1; }
        var phoneme = SvPhonemeEvent_phoneme(vec_get(events, idx));
        var target = svara_trajectory_formants_at(plan, s);

        var nasal = vec_get(nasals, idx);
        if (nasal != 0) {
            var seg_span = vec_get(boundaries, idx + 1) - vec_get(boundaries, idx);
            var onset_off = f64_to(f64_mul(f64_from(seg_span), SvNasalization_onset(nasal)));
            var nasal_onset = vec_get(boundaries, idx) + onset_off;
            if (s >= nasal_onset) {
                var nasal_len = vec_get(boundaries, idx + 1) - nasal_onset;
                if (nasal_len < 1) { nasal_len = 1; }
                var nt = f64_div(f64_from(s - nasal_onset), f64_from(nasal_len));
                var nc = f64_mul(SvNasalization_peak_coupling(nasal), ease_in_out_smooth(nt));
                svara_tract_set_nasal_coupling(tract, nc);
                svara_tract_set_nasal_place(tract, SvNasalization_place(nasal));
            } else {
                svara_tract_set_nasal_coupling(tract, 0);
            }
        } else {
            svara_tract_set_nasal_coupling(tract, 0);
        }

        var sfe = svara_tract_set_formants_from_target(tract, target);
        if (svara_is_err(sfe) == 1) { sfe = 0; }   # ignored, like Rust `let _`

        var ev = vec_get(events, idx);
        var st = SvPhonemeEvent_stress(ev);
        var base_f0 = SvVoiceProfile_base_f0(voice);
        if (st == SVARA_STRESS_PRIMARY) { base_f0 = f64_mul(base_f0, 1.10); }
        elif (st == SVARA_STRESS_SECONDARY) { base_f0 = f64_mul(base_f0, 1.05); }
        var effective_f0 = base_f0;
        if (SvPhonemeEvent_tone(ev) != SVARA_TONE_NONE) {
            var contour = svara_tone_to_contour(SvPhonemeEvent_tone(ev));
            var seg_start = vec_get(boundaries, idx);
            var seg_len = vec_get(boundaries, idx + 1) - seg_start;
            if (seg_len < 1) { seg_len = 1; }
            var tt = f64_div(f64_from(s - seg_start), f64_from(seg_len));
            effective_f0 = f64_mul(base_f0, svara_prosody_f0_at(contour, tt));
        }
        var f0e = svara_glottal_set_f0(glottal, effective_f0);
        if (svara_is_err(f0e) == 1) { f0e = 0; }   # ignored, like Rust `let _`

        var c = svara_phoneme_class(phoneme);
        var sample = 0;
        if ((c == SVARA_CLASS_VOWEL) | (c == SVARA_CLASS_DIPHTHONG) | (c == SVARA_CLASS_APPROXIMANT)
        | (c == SVARA_CLASS_LATERAL) | (c == SVARA_CLASS_NASAL) | (c == SVARA_CLASS_IMPLOSIVE)
        | (c == SVARA_CLASS_TRILL)) {
            sample = svara_tract_process_sample(tract, svara_glottal_next_sample(glottal));
        } elif (c == SVARA_CLASS_FRICATIVE) {
            var nz = f64_mul(svara_rng_next_f32(noise), F64_HALF);
            if (svara_phoneme_is_voiced(phoneme) == 1) {
                var voicing = f64_mul(svara_tract_process_sample(tract, svara_glottal_next_sample(glottal)), SV_PH_R04);
                sample = f64_add(f64_mul(nz, SV_PH_R06), voicing);
            } else {
                sample = f64_mul(nz, SV_PH_R06);
            }
        } elif ((c == SVARA_CLASS_PLOSIVE) | (c == SVARA_CLASS_AFFRICATE)
        | (c == SVARA_CLASS_CLICK) | (c == SVARA_CLASS_EJECTIVE)) {
            var span = vec_get(boundaries, idx + 1) - vec_get(boundaries, idx);
            if (span < 1) { span = 1; }
            var bf = f64_div(f64_from(s - vec_get(boundaries, idx)), f64_from(span));
            if (f64_lt(bf, SV_PH_R04) == 1) {
                sample = 0;
            } else {
                sample = f64_mul(f64_mul(svara_rng_next_f32(noise), f64_sub(F64_ONE, bf)), F64_HALF);
            }
        }
        store64(out + s * 8, sample);
        s = s + 1;
    }

    # global attack/release envelope: ramp = clamp(total/20, 1, 256)
    var ramp = total / 20;
    if (ramp < 1) { ramp = 1; }
    if (ramp > 256) { ramp = 256; }
    var a = 0;
    while (a < ramp) {
        var e1 = ease_in_out_smooth(f64_div(f64_from(a), f64_from(ramp)));
        store64(out + a * 8, f64_mul(load64(out + a * 8), e1));
        a = a + 1;
    }
    var b = 0;
    while (b < ramp) {
        var ridx = total - 1 - b;
        var e2 = ease_in_out_smooth(f64_div(f64_from(b), f64_from(ramp)));
        store64(out + ridx * 8, f64_mul(load64(out + ridx * 8), e2));
        b = b + 1;
    }
    return svara_ph_buf_to_vec(out, total);
}

# --- pool.cyr ---

# pool.cyr -- object pooling for transient phoneme synthesis.
# Ports rust-old/src/pool.rs. SynthesisPool wraps a SynthesisContext with
# pre-warmed buffer capacity + diagnostic counters (render_count, peak_samples),
# for zero-allocation phoneme rendering. f32 -> f64 throughout.
#
# svara_synthctx_synthesize returns the sample count (>=0) with samples in the
# ctx buffer; svara_pool_render therefore returns the count and the samples are
# read via svara_pool_buffer(pool)[0..count] (valid until the next render).
#
# Requires: stdlib alloc/vec/math, error.cyr, phoneme.cyr (SynthesisContext).

#derive(accessors)
struct SvSynthesisPool { ctx; render_count; peak_samples; }

# new -- pool for a voice + sample rate. Returns ptr or neg error.
#must_use
fn svara_pool_new(voice, sample_rate) {
    var ctx = svara_synthctx_new(voice, sample_rate);
    if (svara_is_err(ctx) == 1) { return ctx; }
    var p = alloc(sizeof(SvSynthesisPool));
    SvSynthesisPool_set_ctx(p, ctx);
    SvSynthesisPool_set_render_count(p, 0);
    SvSynthesisPool_set_peak_samples(p, 0);
    return p;
}

# with_capacity -- pre-warm the buffer for phonemes up to max_duration seconds.
#must_use
fn svara_pool_with_capacity(voice, sample_rate, max_duration) {
    var p = svara_pool_new(voice, sample_rate);
    if (svara_is_err(p) == 1) { return p; }
    var warm = f64_to(f64_mul(max_duration, sample_rate));
    if (warm > 0) {
        var r = svara_synthctx_synthesize(SvSynthesisPool_ctx(p), SVARA_PH_SILENCE, voice, max_duration, 0);
        if (svara_is_err(r) == 1) { return r; }
    }
    SvSynthesisPool_set_peak_samples(p, warm);
    return p;
}

# render_nasalized -- render one phoneme through the pooled context; returns the
# sample count (samples in svara_pool_buffer) or a neg error. Tracks diagnostics.
#must_use
fn svara_pool_render_nasalized(p, phoneme, voice, duration, nasal) {
    var n = svara_synthctx_synthesize(SvSynthesisPool_ctx(p), phoneme, voice, duration, nasal);
    if (svara_is_err(n) == 1) { return n; }
    SvSynthesisPool_set_render_count(p, SvSynthesisPool_render_count(p) + 1);
    if (n > SvSynthesisPool_peak_samples(p)) { SvSynthesisPool_set_peak_samples(p, n); }
    return n;
}

#must_use
fn svara_pool_render(p, phoneme, voice, duration) {
    return svara_pool_render_nasalized(p, phoneme, voice, duration, 0);
}

# render_batch -- render parallel phonemes(vec<int>) + durations(vec<f64>),
# concatenated into a fresh vec<f64>. Returns the vec or a neg error.
#must_use
fn svara_pool_render_batch(p, phonemes, durations, voice) {
    var output = vec_new();
    var ctx = SvSynthesisPool_ctx(p);
    var np = vec_len(phonemes);
    var i = 0;
    while (i < np) {
        var n = svara_synthctx_synthesize(ctx, vec_get(phonemes, i), voice, vec_get(durations, i), 0);
        if (svara_is_err(n) == 1) { return n; }
        var buf = svara_synthctx_buffer(ctx);
        var j = 0;
        while (j < n) { vec_push(output, load64(buf + j * 8)); j = j + 1; }
        SvSynthesisPool_set_render_count(p, SvSynthesisPool_render_count(p) + 1);
        if (n > SvSynthesisPool_peak_samples(p)) { SvSynthesisPool_set_peak_samples(p, n); }
        i = i + 1;
    }
    return output;
}

# buffer holding the most recent render's samples.
#must_use
fn svara_pool_buffer(p) { return svara_synthctx_buffer(SvSynthesisPool_ctx(p)); }
#must_use
fn svara_pool_render_count(p) { return SvSynthesisPool_render_count(p); }
#must_use
fn svara_pool_peak_samples(p) { return SvSynthesisPool_peak_samples(p); }
#must_use
fn svara_pool_context(p) { return SvSynthesisPool_ctx(p); }

# reset -- zero the pool's render-count and peak-sample counters (context kept).
fn svara_pool_reset(p) {
    SvSynthesisPool_set_render_count(p, 0);
    SvSynthesisPool_set_peak_samples(p, 0);
}

# --- render.cyr ---

# render.cyr -- batch rendering API for non-real-time synthesis.
# Ports rust-old/src/render.rs. BatchRenderer renders a queue of phoneme events
# (stress-scaled + anticipatory nasalization, no crossfade) into one buffer,
# with optional per-phoneme progress. f32 -> f64 throughout.
#
# The Rust FnMut progress callback becomes a Cyrius fn-pointer + user-data
# pointer: `callptr(cb, user, progress)` (non-capturing; the idiomatic form).
#
# Requires: stdlib alloc/vec/math/fnptr, error.cyr, phoneme.cyr (SynthesisContext,
# detect_nasalization), prosody.cyr (Stress), sequence.cyr (PhonemeEvent, voice_clone),
# voice.cyr.

# RenderProgress -- progress snapshot.
#derive(accessors)
#derive(Serialize)
struct SvRenderProgress { phoneme_index: i64; total_phonemes: i64; samples_rendered: i64; }

#must_use
fn svara_render_progress_new(phoneme_index, total_phonemes, samples_rendered) {
    var p = alloc(sizeof(SvRenderProgress));
    SvRenderProgress_set_phoneme_index(p, phoneme_index);
    SvRenderProgress_set_total_phonemes(p, total_phonemes);
    SvRenderProgress_set_samples_rendered(p, samples_rendered);
    return p;
}

# fraction complete (0.0-1.0); 1.0 when there are no phonemes.
#must_use
fn svara_render_progress_fraction(p) {
    if (SvRenderProgress_total_phonemes(p) == 0) { return F64_ONE; }
    return f64_div(f64_from(SvRenderProgress_phoneme_index(p)), f64_from(SvRenderProgress_total_phonemes(p)));
}

# RenderOutput -- rendered samples (vec<f64>) + final progress.
#derive(accessors)
struct SvRenderOutput { samples; progress; }

#must_use
fn svara_render_output_new(samples, progress) {
    var o = alloc(sizeof(SvRenderOutput));
    SvRenderOutput_set_samples(o, samples);
    SvRenderOutput_set_progress(o, progress);
    return o;
}

# BatchRenderer -- phoneme queue + reusable context + cloned voice.
#derive(accessors)
struct SvBatchRenderer { events; ctx; voice; sample_rate; }

#must_use
fn svara_batch_new(voice, sample_rate) {
    var ctx = svara_synthctx_new(voice, sample_rate);
    if (svara_is_err(ctx) == 1) { return ctx; }
    var r = alloc(sizeof(SvBatchRenderer));
    SvBatchRenderer_set_events(r, vec_new());
    SvBatchRenderer_set_ctx(r, ctx);
    SvBatchRenderer_set_voice(r, svara_seq_voice_clone(voice));
    SvBatchRenderer_set_sample_rate(r, sample_rate);
    return r;
}

# push -- queue one phoneme event (phoneme, duration, stress) for batch render.
fn svara_batch_push(r, phoneme, duration, stress) {
    vec_push(SvBatchRenderer_events(r), svara_phoneme_event_new(phoneme, duration, stress));
}
# extend -- append a vec of pre-built phoneme events to the batch queue.
fn svara_batch_extend(r, events) {
    var dst = SvBatchRenderer_events(r);
    var i = 0;
    while (i < vec_len(events)) { vec_push(dst, vec_get(events, i)); i = i + 1; }
}
# clear -- drop all queued events (reuse the renderer for a fresh utterance).
fn svara_batch_clear(r) { SvBatchRenderer_set_events(r, vec_new()); }
#must_use
fn svara_batch_len(r) { return vec_len(SvBatchRenderer_events(r)); }
#must_use
fn svara_batch_is_empty(r) {
    if (vec_len(SvBatchRenderer_events(r)) == 0) { return 1; }
    return 0;
}

# render_with_progress -- render all queued phonemes; if `cb` != 0, invoke
# callptr(cb, user, progress) after each phoneme. Returns RenderOutput or neg error.
#must_use
fn svara_batch_render_with_progress(r, cb, user) {
    var events = SvBatchRenderer_events(r);
    var total = vec_len(events);
    var voice = SvBatchRenderer_voice(r);
    var ctx = SvBatchRenderer_ctx(r);
    var output = vec_new();

    var pl = vec_new();
    var i = 0;
    while (i < total) { vec_push(pl, SvPhonemeEvent_phoneme(vec_get(events, i))); i = i + 1; }
    var nasals = svara_detect_nasalization(pl);

    i = 0;
    while (i < total) {
        var e = vec_get(events, i);
        var ev = svara_seq_voice_clone(voice);
        var ss = 0.9;
        var st = SvPhonemeEvent_stress(e);
        if (st == SVARA_STRESS_PRIMARY) {
            SvVoiceProfile_set_base_f0(ev, f64_mul(SvVoiceProfile_base_f0(ev), 1.10));
            ss = 1.15;
        } elif (st == SVARA_STRESS_SECONDARY) {
            SvVoiceProfile_set_base_f0(ev, f64_mul(SvVoiceProfile_base_f0(ev), 1.05));
            ss = 1.05;
        }
        var dur = f64_mul(SvPhonemeEvent_duration(e), ss);
        var n = svara_synthctx_synthesize(ctx, SvPhonemeEvent_phoneme(e), ev, dur, vec_get(nasals, i));
        if (svara_is_err(n) == 1) { return n; }
        var buf = svara_synthctx_buffer(ctx);
        var j = 0;
        while (j < n) { vec_push(output, load64(buf + j * 8)); j = j + 1; }
        if (cb != 0) {
            var cbr = callptr(cb, user, svara_render_progress_new(i + 1, total, vec_len(output)));
            if (cbr < 0) { return cbr; }
        }
        i = i + 1;
    }
    return svara_render_output_new(output, svara_render_progress_new(total, total, vec_len(output)));
}

# render_all -- render synchronously, no progress callback.
#must_use
fn svara_batch_render_all(r) {
    return svara_batch_render_with_progress(r, 0, 0);
}

# --- bridge.cyr ---

# bridge.cyr -- dependency-free ecosystem-integration glue.
# Ports rust-old/src/bridge.rs. Pure scalar maps converting upstream AGNOS crate
# outputs (bhava emotion, vansh TTS, prani creature, goonj acoustics, badal
# weather) into svara synthesis parameters, without depending on those crates.
# f32 -> f64 throughout; non-integer constants are Cyrius float literals.
#
# Requires: stdlib math, glottal.cyr (SVARA_GLOTTAL_*), prosody.cyr
# (SVARA_INTONATION_* / SVARA_STRESS_*).

# ---- bhava (emotion/affect) ----
# rd_from_arousal -- arousal [0,1] -> Rd (2.2 calm .. 0.4 excited).
#must_use
fn svara_bridge_rd_from_arousal(arousal) {
    var a = f64_clamp(arousal, 0, F64_ONE);
    return f64_sub(2.2, f64_mul(1.8, a));
}
# vibrato_depth_from_valence -- valence [-1,1] -> depth [0,0.06].
#must_use
fn svara_bridge_vibrato_depth_from_valence(valence) {
    var v = f64_clamp(valence, f64_neg(F64_ONE), F64_ONE);
    return f64_clamp(f64_add(0.03, f64_mul(0.03, v)), 0, 0.06);
}
# breathiness_from_arousal -- 0.3 calm .. 0.02 excited.
#must_use
fn svara_bridge_breathiness_from_arousal(arousal) {
    var a = f64_clamp(arousal, 0, F64_ONE);
    return f64_sub(0.3, f64_mul(0.28, a));
}
# jitter_from_arousal -- U-shaped, min at 0.5. [0.005, 0.03].
#must_use
fn svara_bridge_jitter_from_arousal(arousal) {
    var a = f64_clamp(arousal, 0, F64_ONE);
    var dist = f64_abs(f64_sub(a, F64_HALF));
    return f64_add(0.005, f64_mul(f64_mul(0.025, dist), F64_TWO));
}
# intonation_from_emotion -- emotion category -> IntonationPattern, or -1 (None).
#must_use
fn svara_bridge_intonation_from_emotion(category) {
    if (category == 0) { return SVARA_INTONATION_DECLARATIVE; }
    if ((category == 1) | (category == 3)) { return SVARA_INTONATION_EXCLAMATORY; }
    if (category == 2) { return SVARA_INTONATION_DECLARATIVE; }
    if (category == 4) { return SVARA_INTONATION_INTERROGATIVE; }
    if (category == 5) { return SVARA_INTONATION_CONTINUATION; }
    return (0 - 1);
}
# f0_range_scale_from_arousal -- 0.6 .. 1.8.
#must_use
fn svara_bridge_f0_range_scale_from_arousal(arousal) {
    var a = f64_clamp(arousal, 0, F64_ONE);
    return f64_add(0.6, f64_mul(1.2, a));
}

# ---- vansh (TTS) ----
# duration_scale_from_speech_rate -- 1/rate clamped [0.3,3.0]; 1.0 for rate<=0.
#must_use
fn svara_bridge_duration_scale_from_speech_rate(rate) {
    if (f64_le(rate, 0) == 1) { return F64_ONE; }
    return f64_clamp(f64_div(F64_ONE, rate), 0.3, 3.0);
}
# stress_from_tobi_accent -- 0=unstressed, 1=secondary, 2+=primary.
#must_use
fn svara_bridge_stress_from_tobi_accent(level) {
    if (level == 0) { return SVARA_STRESS_UNSTRESSED; }
    if (level == 1) { return SVARA_STRESS_SECONDARY; }
    return SVARA_STRESS_PRIMARY;
}
# f0_peak_from_prominence -- 1.0 .. 1.3.
#must_use
fn svara_bridge_f0_peak_from_prominence(prominence) {
    var p = f64_clamp(prominence, 0, F64_ONE);
    return f64_add(F64_ONE, f64_mul(0.3, p));
}

# ---- prani (creature/character) ----
# formant_scale_from_body_size -- 1.4 small .. 0.85 large.
#must_use
fn svara_bridge_formant_scale_from_body_size(size) {
    var s = f64_clamp(size, 0, F64_ONE);
    return f64_sub(1.4, f64_mul(0.55, s));
}
# f0_from_body_size -- 400 small .. 70 large (Hz).
#must_use
fn svara_bridge_f0_from_body_size(size) {
    var s = f64_clamp(size, 0, F64_ONE);
    return f64_sub(f64_from(400), f64_mul(f64_from(330), s));
}
# jitter_from_age -- U-shaped, min at 0.4. [0.005, 0.04].
#must_use
fn svara_bridge_jitter_from_age(age) {
    var a = f64_clamp(age, 0, F64_ONE);
    var dist = f64_abs(f64_sub(a, 0.4));
    return f64_add(0.005, f64_div(f64_mul(0.035, dist), 0.6));
}
# glottal_model_from_effort -- writes (model, rd) into out (2 slots).
fn svara_bridge_glottal_model_from_effort(effort, out) {
    var e = f64_clamp(effort, 0, F64_ONE);
    if (f64_lt(e, 0.3) == 1) {
        store64(out, SVARA_GLOTTAL_LF);
        store64(out + 8, f64_add(F64_TWO, f64_mul(f64_sub(0.3, e), 2.3)));
    } elif (f64_gt(e, 0.7) == 1) {
        store64(out, SVARA_GLOTTAL_LF);
        store64(out + 8, f64_sub(0.8, f64_mul(f64_sub(e, 0.7), 1.5)));
    } else {
        store64(out, SVARA_GLOTTAL_ROSENBERG);
        store64(out + 8, F64_ONE);
    }
}

# ---- goonj (acoustics) ----
# gain_from_distance -- inverse-distance gain [0,1]; 1.0 if closer than ref.
#must_use
fn svara_bridge_gain_from_distance(ref_distance, distance) {
    if ((f64_le(distance, ref_distance) == 1) | (f64_le(ref_distance, 0) == 1)) { return F64_ONE; }
    return f64_clamp(f64_div(ref_distance, distance), 0, F64_ONE);
}
# bandwidth_scale_from_reverb -- 1.0 dry .. 2.0 (cap) wet.
#must_use
fn svara_bridge_bandwidth_scale_from_reverb(rt60) {
    var r = f64_max(rt60, 0);
    return f64_min(f64_add(F64_ONE, f64_mul(0.4, r)), F64_TWO);
}
# spectral_tilt_from_distance -- air absorption, capped at 6 dB/oct.
#must_use
fn svara_bridge_spectral_tilt_from_distance(distance_m) {
    return f64_min(f64_mul(distance_m, 0.005), f64_from(6));
}

# ---- badal (weather) ----
# lombard_effort_from_noise -- 1.0 (<45 dB) .. 1.8 (>85 dB).
#must_use
fn svara_bridge_lombard_effort_from_noise(ambient_db_spl) {
    if (f64_lt(ambient_db_spl, f64_from(45)) == 1) { return F64_ONE; }
    if (f64_gt(ambient_db_spl, f64_from(85)) == 1) { return 1.8; }
    return f64_add(F64_ONE, f64_div(f64_mul(0.8, f64_sub(ambient_db_spl, f64_from(45))), f64_from(40)));
}
# lombard_f0_shift -- f0 rise (Hz) in noise, capped at 30.
#must_use
fn svara_bridge_lombard_f0_shift(ambient_db_spl) {
    var excess = f64_max(f64_sub(ambient_db_spl, f64_from(50)), 0);
    return f64_min(f64_mul(excess, 0.75), f64_from(30));
}
# breathiness_reduction_from_wind -- 1.0 (<5 m/s) .. [0.2,1] reduction factor.
#must_use
fn svara_bridge_breathiness_reduction_from_wind(wind_speed_ms) {
    var wind = f64_max(wind_speed_ms, 0);
    if (f64_lt(wind, f64_from(5)) == 1) { return F64_ONE; }
    return f64_clamp(f64_sub(F64_ONE, f64_div(f64_sub(wind, f64_from(5)), f64_from(10))), 0.2, F64_ONE);
}
