fn translit_devanagari_iast() {
    var tt = _tt_new("IAST", "Deva", "Latn");
    _tt_add(tt, "अ", "a");
    _tt_add(tt, "आ", "ā");
    _tt_add(tt, "इ", "i");
    _tt_add(tt, "ई", "ī");
    _tt_add(tt, "उ", "u");
    _tt_add(tt, "ऊ", "ū");
    _tt_add(tt, "ऋ", "ṛ");
    _tt_add(tt, "ॠ", "ṝ");
