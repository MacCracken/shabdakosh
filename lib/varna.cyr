fn phoneme_quechua() {

    var b = phoneme_builder_with_capacity("qu", "Quechua", 27);
    phoneme_builder_stress(b, StressPattern.Fixed);
    # Plain stops
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "t͡ʃ", Manner.Affricate, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "q", Manner.Plosive, Place.Uvular, 0);
    # Aspirated stops
    phoneme_builder_consonant(b, "pʰ", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "tʰ", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "t͡ʃʰ", Manner.Affricate, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "kʰ", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "qʰ", Manner.Plosive, Place.Uvular, 0);
    # Ejectives
    phoneme_builder_consonant(b, "pʼ", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "tʼ", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "t͡ʃʼ", Manner.Affricate, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "kʼ", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "qʼ", Manner.Plosive, Place.Uvular, 0);
    # Fricatives
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "h", Manner.Fricative, Place.Glottal, 0);
    # Nasals
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ɲ", Manner.Nasal, Place.Palatal, 1);
    # Approximants & liquids
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "r", Manner.TapFlap, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "w", Manner.Approximant, Place.LabialVelar, 1);
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    # Three-vowel system (typologically notable)
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "a", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    return phoneme_builder_build(b);
}

fn phoneme_guarani() {

    var b = phoneme_builder_with_capacity("gn", "Guarani", 28);
    phoneme_builder_stress(b, StressPattern.Free);
    # Plain stops & glottal
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "ʔ", Manner.Plosive, Place.Glottal, 0);
    # Prenasalized stops (modelled as voiced plosives)
    phoneme_builder_consonant(b, "d", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ɡ", Manner.Plosive, Place.Velar, 1);
    # Affricate
    phoneme_builder_consonant(b, "t͡ʃ", Manner.Affricate, Place.Postalveolar, 0);
    # Fricatives
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "h", Manner.Fricative, Place.Glottal, 0);
    # Nasals
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ɲ", Manner.Nasal, Place.Palatal, 1);
    phoneme_builder_consonant(b, "ŋ", Manner.Nasal, Place.Velar, 1);
    # Trill & approximants
    phoneme_builder_consonant(b, "r", Manner.TapFlap, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "w", Manner.Approximant, Place.LabialVelar, 1);
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    # Oral vowels (6)
    phoneme_builder_vowel(b, "a", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "e", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "o", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "ɨ", Height.Close, Backness.Central, 0);
    # Nasal vowels (6)
    phoneme_builder_vowel(b, "ã", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "ẽ", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "ĩ", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "õ", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "ũ", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "ɨ̃", Height.Close, Backness.Central, 0);
    return phoneme_builder_build(b);
}

fn phoneme_icelandic() {

    var b = phoneme_builder_with_capacity("is", "Icelandic", 30);
    phoneme_builder_stress(b, StressPattern.Free);
    # Aspirated voiceless stops (phonemically distinctive)
    phoneme_builder_consonant(b, "pʰ", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "tʰ", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "kʰ", Manner.Plosive, Place.Velar, 0);
    # Plain (unaspirated) voiceless stops
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    # Voiced stops
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "d", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ɡ", Manner.Plosive, Place.Velar, 1);
    # Fricatives
    phoneme_builder_consonant(b, "f", Manner.Fricative, Place.Labiodental, 0);
    phoneme_builder_consonant(b, "v", Manner.Fricative, Place.Labiodental, 1);
    phoneme_builder_consonant(b, "θ", Manner.Fricative, Place.Dental, 0);
    phoneme_builder_consonant(b, "ð", Manner.Fricative, Place.Dental, 1);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "ç", Manner.Fricative, Place.Palatal, 0);
    phoneme_builder_consonant(b, "h", Manner.Fricative, Place.Glottal, 0);
    # Voiceless lateral fricative (unique feature)
    phoneme_builder_consonant(b, "ɬ", Manner.LateralFricative, Place.Alveolar, 0);
    # Voiceless nasals (pre-aspiration related)
    phoneme_builder_consonant(b, "m̥", Manner.Nasal, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "n̥", Manner.Nasal, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "ŋ̊", Manner.Nasal, Place.Velar, 0);
    # Voiced nasal + trill + approximant
    phoneme_builder_consonant(b, "r", Manner.Trill, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    # Monophthong vowels (8)
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "ɪ", Height.NearClose, Backness.Front, 0);
    phoneme_builder_vowel(b, "e", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "ɛ", Height.OpenMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "a", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "ɔ", Height.OpenMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "o", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    return phoneme_builder_build(b);
}

fn phoneme_wolof() {

    var b = phoneme_builder_with_capacity("wo", "Wolof", 33);
    phoneme_builder_stress(b, StressPattern.Free);
    # Plosives
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "d", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "ɡ", Manner.Plosive, Place.Velar, 1);
    phoneme_builder_consonant(b, "q", Manner.Plosive, Place.Uvular, 0);
    # Prenasalized stops (phonemic units, not sequences)
    phoneme_builder_consonant(b, "mb", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "nd", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ŋɡ", Manner.Plosive, Place.Velar, 1);
    phoneme_builder_consonant(b, "ɲɟ", Manner.Plosive, Place.Palatal, 1);
    # Fricatives
    phoneme_builder_consonant(b, "f", Manner.Fricative, Place.Labiodental, 0);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "x", Manner.Fricative, Place.Velar, 0);
    phoneme_builder_consonant(b, "χ", Manner.Fricative, Place.Uvular, 0);
    phoneme_builder_consonant(b, "h", Manner.Fricative, Place.Glottal, 0);
    # Nasals
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ɲ", Manner.Nasal, Place.Palatal, 1);
    phoneme_builder_consonant(b, "ŋ", Manner.Nasal, Place.Velar, 1);
    # Approximants / liquids
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "r", Manner.Trill, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "w", Manner.Approximant, Place.LabialVelar, 1);
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    # Vowels — short
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "e", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "a", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "o", Height.CloseMid, Backness.Back, 1);
    # Vowels — long
    phoneme_builder_vowel(b, "iː", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "eː", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "aː", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "oː", Height.CloseMid, Backness.Back, 1);
    return phoneme_builder_build(b);
}

fn phoneme_lao() {

    var b = phoneme_builder_with_capacity("lo", "Lao", 29);
    phoneme_builder_stress(b, StressPattern.Tonal);
    var t = vec_new();
    vec_push(t, "˧");
    vec_push(t, "˨˩");
    vec_push(t, "˥˩");
    vec_push(t, "˦˥");
    vec_push(t, "˩˧˥");
    vec_push(t, "˧˥");
    phoneme_builder_tones(b, t);
    # Plosives
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "pʰ", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "tʰ", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "d", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "kʰ", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "ʔ", Manner.Plosive, Place.Glottal, 0);
    # Affricates
    phoneme_builder_consonant(b, "t͡ɕ", Manner.Affricate, Place.Palatal, 0);
    phoneme_builder_consonant(b, "t͡ɕʰ", Manner.Affricate, Place.Palatal, 0);
    # Fricatives
    phoneme_builder_consonant(b, "f", Manner.Fricative, Place.Labiodental, 0);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "h", Manner.Fricative, Place.Glottal, 0);
    # Nasals
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ŋ", Manner.Nasal, Place.Velar, 1);
    # Approximants / liquids
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "w", Manner.Approximant, Place.LabialVelar, 1);
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    # Vowels — short/long pairs
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "iː", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "ɯ", Height.Close, Backness.Back, 0);
    phoneme_builder_vowel(b, "ɯː", Height.Close, Backness.Back, 0);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "uː", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "e", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "eː", Height.CloseMid, Backness.Front, 0);
    # Diphthong
    phoneme_builder_vowel(b, "ia", Height.CloseMid, Backness.Front, 0);
    return phoneme_builder_build(b);
}

fn phoneme_mongolian() {

    var b = phoneme_builder_with_capacity("mn", "Mongolian", 35);
    phoneme_builder_stress(b, StressPattern.Free);
    # Plosives
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "d", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "ɡ", Manner.Plosive, Place.Velar, 1);
    # Affricates
    phoneme_builder_consonant(b, "t͡s", Manner.Affricate, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "d͡z", Manner.Affricate, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "t͡ʃ", Manner.Affricate, Place.Postalveolar, 0);
    # Fricatives
    phoneme_builder_consonant(b, "f", Manner.Fricative, Place.Labiodental, 0);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "z", Manner.Fricative, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ʃ", Manner.Fricative, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "x", Manner.Fricative, Place.Velar, 0);
    phoneme_builder_consonant(b, "χ", Manner.Fricative, Place.Uvular, 0);
    # Lateral fricative
    phoneme_builder_consonant(b, "ɮ", Manner.LateralFricative, Place.Alveolar, 1);
    # Nasals
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ŋ", Manner.Nasal, Place.Velar, 1);
    # Approximants / liquids
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "r", Manner.Trill, Place.Alveolar, 1);
    # Vowels — back harmony set (short)
    phoneme_builder_vowel(b, "a", Height.Open, Backness.Back, 0);
    phoneme_builder_vowel(b, "o", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "ɔ", Height.OpenMid, Backness.Back, 1);
    # Vowels — front harmony set (short)
    phoneme_builder_vowel(b, "e", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "ø", Height.CloseMid, Backness.Front, 1);
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    # Vowels — long pairs
    phoneme_builder_vowel(b, "aː", Height.Open, Backness.Back, 0);
    phoneme_builder_vowel(b, "oː", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "uː", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "ɔː", Height.OpenMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "eː", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "øː", Height.CloseMid, Backness.Front, 1);
    phoneme_builder_vowel(b, "iː", Height.Close, Backness.Front, 0);
    return phoneme_builder_build(b);
}

# --- allophone.cyr ---

# src/allophone.cyr — context-dependent allophone rules.
#
# Ported from rust-old/src/phoneme/allophone.rs.
#
# AllophoneRule (32B):    [0]=phoneme [8]=allophone [16]=environment [24]=obligatory(0/1)
# AllophoneRuleSet (16B): [0]=language_code [8]=rules(vec)
#
# Environment is modeled as plain int constants. The v1.x parametrized
# Before(PhonemeClass)/After(PhonemeClass) variants are deferred — no current
# ruleset uses them, and PhonemeClass's names (Vowel/Consonant/Nasal/Plosive/
# Fricative) would collide with the Manner/PhonemeKind enum constants.

enum Environment {
    WordInitial = 0;
    WordFinal = 1;
    Intervocalic = 2;
    PreVocalic = 3;
    PostVocalic = 4;
    SyllableFinal = 5;
    SyllableInitial = 6;
    PreStress = 7;
    Unstressed = 8;
}

fn _arule_new(phoneme, allophone, env, obligatory) {
    var r = alloc(32);
    store64(r, phoneme);
    store64(r + 8, allophone);
    store64(r + 16, env);
    store64(r + 24, obligatory);
    return r;
}

fn allophone_rule_phoneme(r) { return load64(r); }
fn allophone_rule_allophone(r) { return load64(r + 8); }
fn allophone_rule_environment(r) { return load64(r + 16); }
fn allophone_rule_obligatory(r) { return load64(r + 24); }

fn _aset_new(code) {
    var s = alloc(16);
    store64(s, code);
    store64(s + 8, vec_new());
    return s;
}

fn _aset_add(s, phoneme, allophone, env, obligatory) {
    vec_push(load64(s + 8), _arule_new(phoneme, allophone, env, obligatory));
    return s;
}

fn allophone_language_code(s) { return load64(s); }
fn allophone_rules(s) { return load64(s + 8); }

# All allophone rules for a phoneme — vec of rule ptrs (possibly empty).
fn allophone_rules_for(s, phoneme) {
    var rules = load64(s + 8);
    var n = vec_len(rules);
    var out = vec_new();
    var i = 0;
    while (i < n) {
        var r = vec_get(rules, i);
        if (streq(load64(r), phoneme) == 1) { vec_push(out, r); }
        i = i + 1;
    }
    return out;
}

# Surface realization of a phoneme in an environment — the allophone if a rule
# matches (first wins), else the phoneme unchanged.
fn allophone_realize(s, phoneme, env) {
    var rules = load64(s + 8);
    var n = vec_len(rules);
    var i = 0;
    while (i < n) {
        var r = vec_get(rules, i);
        if (streq(load64(r), phoneme) == 1 && load64(r + 16) == env) { return load64(r + 8); }
        i = i + 1;
    }
    return phoneme;
}

# --- Pre-built rule sets -------------------------------------------

# English (General American) allophone rules.
fn allophone_english() {
    var s = _aset_new("en");
    _aset_add(s, "t", "ɾ", Environment.Intervocalic, 0);
    _aset_add(s, "t", "tʰ", Environment.WordInitial, 1);
    _aset_add(s, "p", "pʰ", Environment.WordInitial, 1);
    _aset_add(s, "k", "kʰ", Environment.WordInitial, 1);
    _aset_add(s, "l", "ɫ", Environment.SyllableFinal, 1);
    _aset_add(s, "ə", "ɨ", Environment.Unstressed, 0);
    return s;
}

# --- syllable.cyr ---

# src/syllable.cyr — syllable structure + phonotactic constraints.
#
# Ported from rust-old/src/phoneme/syllable.rs.
#
# SyllableTemplate (32B):      [0]=max_onset [8]=max_coda [16]=complex_nucleus(0/1) [24]=pattern
# PhonotacticConstraint (32B): [0]=kind [8]=position [16]=sequences(vec) [24]=description
# Phonotactics (24B):          [0]=language_code [8]=syllable(template) [16]=constraints(vec)
#
# is_permitted returns tri-state: 1 = permitted, 0 = forbidden, (0-1) = unspecified.

enum ConstraintKind {
    Permitted = 0;
    Forbidden = 1;
}

enum SyllablePosition {
    Onset = 0;
    Coda = 1;
    Nucleus = 2;
    AcrossBoundary = 3;
}

# --- SyllableTemplate ----------------------------------------------

fn _syllable_new(max_onset, max_coda, complex_nucleus, pattern) {
    var t = alloc(32);
    store64(t, max_onset);
    store64(t + 8, max_coda);
    store64(t + 16, complex_nucleus);
    store64(t + 24, pattern);
    return t;
}

fn syllable_max_onset(t) { return load64(t); }
fn syllable_max_coda(t) { return load64(t + 8); }
fn syllable_complex_nucleus(t) { return load64(t + 16); }
fn syllable_pattern(t) { return load64(t + 24); }

fn syllable_allows_onset_clusters(t) {
    if (load64(t) > 1) { return 1; }
    return 0;
}

fn syllable_allows_coda_clusters(t) {
    if (load64(t + 8) > 1) { return 1; }
    return 0;
}

fn syllable_allows_closed_syllables(t) {
    if (load64(t + 8) > 0) { return 1; }
    return 0;
}

# --- Constraints ---------------------------------------------------

fn _constraint_new(kind, position, description) {
    var c = alloc(32);
    store64(c, kind);
    store64(c + 8, position);
    store64(c + 16, vec_new());
    store64(c + 24, description);
    return c;
}

fn _constraint_add_seq(c, seq) {
    vec_push(load64(c + 16), seq);
    return c;
}

fn constraint_kind(c) { return load64(c); }
fn constraint_position(c) { return load64(c + 8); }
fn constraint_sequences(c) { return load64(c + 16); }
fn constraint_description(c) { return load64(c + 24); }

# --- Phonotactics --------------------------------------------------

fn _phonotactics_new(code, syllable) {
    var p = alloc(24);
    store64(p, code);
    store64(p + 8, syllable);
    store64(p + 16, vec_new());
    return p;
}

fn _phonotactics_add(p, constraint) {
    vec_push(load64(p + 16), constraint);
    return p;
}

fn phonotactics_language_code(p) { return load64(p); }
fn phonotactics_syllable(p) { return load64(p + 8); }
fn phonotactics_constraints(p) { return load64(p + 16); }

# Convenience accessors delegating to the syllable template.
fn phonotactics_max_onset(p) { return syllable_max_onset(load64(p + 8)); }
fn phonotactics_max_coda(p) { return syllable_max_coda(load64(p + 8)); }
fn phonotactics_pattern(p) { return syllable_pattern(load64(p + 8)); }
fn phonotactics_allows_onset_clusters(p) { return syllable_allows_onset_clusters(load64(p + 8)); }
fn phonotactics_allows_coda_clusters(p) { return syllable_allows_coda_clusters(load64(p + 8)); }
fn phonotactics_allows_closed_syllables(p) { return syllable_allows_closed_syllables(load64(p + 8)); }

# All constraints at a syllable position — vec of constraint ptrs.
fn phonotactics_constraints_at(p, position) {
    var cs = load64(p + 16);
    var n = vec_len(cs);
    var out = vec_new();
    var i = 0;
    while (i < n) {
        var c = vec_get(cs, i);
        if (load64(c + 8) == position) { vec_push(out, c); }
        i = i + 1;
    }
    return out;
}

# Tri-state: 1 permitted, 0 forbidden, (0-1) unspecified. First match wins.
fn phonotactics_is_permitted(p, sequence, position) {
    var cs = load64(p + 16);
    var n = vec_len(cs);
    var i = 0;
    while (i < n) {
        var c = vec_get(cs, i);
        if (load64(c + 8) == position) {
            var seqs = load64(c + 16);
            var m = vec_len(seqs);
            var j = 0;
            while (j < m) {
                if (streq(vec_get(seqs, j), sequence) == 1) {
                    if (load64(c) == ConstraintKind.Permitted) { return 1; }
                    return 0;
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    return 0 - 1;
}

# --- Pre-built phonotactic profiles --------------------------------

fn phonotactics_english() {
    var p = _phonotactics_new("en", _syllable_new(3, 4, 1, "(C)(C)(C)V(C)(C)(C)(C)"));
    var ok = _constraint_new(ConstraintKind.Permitted, SyllablePosition.Onset, "English /s/+stop onset clusters");
    _constraint_add_seq(ok, "st");
    _constraint_add_seq(ok, "sp");
    _constraint_add_seq(ok, "sk");
    _constraint_add_seq(ok, "str");
    _constraint_add_seq(ok, "spr");
    _constraint_add_seq(ok, "skr");
    _constraint_add_seq(ok, "spl");
    _constraint_add_seq(ok, "skw");
    _constraint_add_seq(ok, "stj");
    _constraint_add_seq(ok, "spj");
    _constraint_add_seq(ok, "skj");
    _phonotactics_add(p, ok);
    var no = _constraint_new(ConstraintKind.Forbidden, SyllablePosition.Onset, "Forbidden English onset sequences");
    _constraint_add_seq(no, "sr");
    _constraint_add_seq(no, "tl");
    _constraint_add_seq(no, "dl");
    _constraint_add_seq(no, "ŋ");
    _phonotactics_add(p, no);
    return p;
}

fn phonotactics_sanskrit() {
    var p = _phonotactics_new("sa", _syllable_new(2, 2, 1, "(C)(C)V(C)(C)"));
    var ok = _constraint_new(ConstraintKind.Permitted, SyllablePosition.Onset, "Sanskrit stop+liquid onset clusters");
    _constraint_add_seq(ok, "pr");
    _constraint_add_seq(ok, "kr");
    _constraint_add_seq(ok, "tr");
    _constraint_add_seq(ok, "sr");
    _constraint_add_seq(ok, "pl");
    _constraint_add_seq(ok, "kl");
    _phonotactics_add(p, ok);
    return p;
}

fn phonotactics_japanese() {
    var p = _phonotactics_new("ja", _syllable_new(1, 1, 1, "(C)V(N)"));
    var ok = _constraint_new(ConstraintKind.Permitted, SyllablePosition.Coda, "Only moraic nasal permitted in Japanese coda");  #skip-lint
    _constraint_add_seq(ok, "n");
    _constraint_add_seq(ok, "ɴ");
    _phonotactics_add(p, ok);
    return p;
}

# --- grammar.cyr ---

# src/grammar.cyr — grammatical typology profiles by ISO 639 code.
# Ported from rust-old/src/grammar/mod.rs.
#
# GrammarProfile (64B): [0]=language_code [8]=morphology [16]=word_order
#   [24]=case_count [32]=has_gender [40]=gender_count [48]=has_dual [56]=has_classifiers

enum Morphology {
    Isolating = 0;
    Agglutinative = 1;
    Fusional = 2;
    Polysynthetic = 3;
}

# WordOrder.Free (case-marked free order) is omitted: no profile uses it, and
# the name would collide with StressPattern.Free (phoneme.cyr).
enum WordOrder {
    SVO = 0;
    SOV = 1;
    VSO = 2;
    VOS = 3;
    OVS = 4;
    OSV = 5;
}

fn _gp_new(code, morph, order, case_count, has_gender, gender_count, has_dual, has_classifiers) {
    var g = alloc(64);
    store64(g, code);
    store64(g + 8, morph);
    store64(g + 16, order);
    store64(g + 24, case_count);
    store64(g + 32, has_gender);
    store64(g + 40, gender_count);
    store64(g + 48, has_dual);
    store64(g + 56, has_classifiers);
    return g;
}

fn grammar_language_code(g) { return load64(g); }
fn grammar_morphology(g) { return load64(g + 8); }
fn grammar_word_order(g) { return load64(g + 16); }
fn grammar_case_count(g) { return load64(g + 24); }
fn grammar_has_gender(g) { return load64(g + 32); }
fn grammar_gender_count(g) { return load64(g + 40); }
fn grammar_has_dual(g) { return load64(g + 48); }
fn grammar_has_classifiers(g) { return load64(g + 56); }

fn grammar_english() {
    return _gp_new("en", Morphology.Fusional, WordOrder.SVO, 2, 0, 0, 0, 0);
}

fn grammar_arabic() {
    return _gp_new("ar", Morphology.Fusional, WordOrder.VSO, 3, 1, 2, 1, 0);
}

fn grammar_mandarin() {
    return _gp_new("zh", Morphology.Isolating, WordOrder.SVO, 0, 0, 0, 0, 1);
}

fn grammar_hindi() {
    return _gp_new("hi", Morphology.Fusional, WordOrder.SOV, 3, 1, 2, 0, 0);
}

fn grammar_japanese() {
    return _gp_new("ja", Morphology.Agglutinative, WordOrder.SOV, 0, 0, 0, 0, 1);
}

fn grammar_spanish() {
    return _gp_new("es", Morphology.Fusional, WordOrder.SVO, 0, 1, 2, 0, 0);
}

fn grammar_french() {
    return _gp_new("fr", Morphology.Fusional, WordOrder.SVO, 0, 1, 2, 0, 0);
}

fn grammar_german() {
    return _gp_new("de", Morphology.Fusional, WordOrder.SVO, 4, 1, 3, 0, 0);
}

fn grammar_russian() {
    return _gp_new("ru", Morphology.Fusional, WordOrder.SVO, 6, 1, 3, 0, 0);
}

fn grammar_korean() {
    return _gp_new("ko", Morphology.Agglutinative, WordOrder.SOV, 0, 0, 0, 0, 1);
}

fn grammar_portuguese() {
    return _gp_new("pt", Morphology.Fusional, WordOrder.SVO, 0, 1, 2, 0, 0);
}

# Grammar profile for a language, or 0 if none.
fn grammar_by_code(code) {
    if (streq(code, "en") == 1) { return grammar_english(); }
    if (streq(code, "ar") == 1) { return grammar_arabic(); }
    if (streq(code, "zh") == 1) { return grammar_mandarin(); }
    if (streq(code, "hi") == 1) { return grammar_hindi(); }
    if (streq(code, "ja") == 1) { return grammar_japanese(); }
    if (streq(code, "es") == 1) { return grammar_spanish(); }
    if (streq(code, "fr") == 1) { return grammar_french(); }
    if (streq(code, "de") == 1) { return grammar_german(); }
    if (streq(code, "ru") == 1) { return grammar_russian(); }
    if (streq(code, "ko") == 1) { return grammar_korean(); }
    if (streq(code, "pt") == 1) { return grammar_portuguese(); }
    return 0;
}

# All language codes with grammar profiles — vec of cstrings.
fn grammar_all_codes() {
    var c = vec_new();
    vec_push(c, "en");
    vec_push(c, "ar");
    vec_push(c, "zh");
    vec_push(c, "hi");
    vec_push(c, "ja");
    vec_push(c, "es");
    vec_push(c, "fr");
    vec_push(c, "de");
    vec_push(c, "ru");
    vec_push(c, "ko");
    vec_push(c, "pt");
    return c;
}

# --- lexicon.cyr ---

# src/lexicon.cyr — core vocabulary types + Lexicon queries.
#
# Ported from rust-old/src/lexicon/mod.rs.
#
# LexEntry (48B): [0]=word [8]=ipa [16]=gloss [24]=pos
#                 [32]=frequency_rank [40]=swadesh_index   ((0-1) = None for both)
# Lexicon (16B):  [0]=language_code [8]=entries(vec)

enum PartOfSpeech {
    Noun = 0;
    Verb = 1;
    Adjective = 2;
    Adverb = 3;
    Pronoun = 4;
    Preposition = 5;
    Conjunction = 6;
    Interjection = 7;
    Determiner = 8;
    Particle = 9;
    Numeral = 10;
}

fn _lex_entry_new(word, ipa, gloss, pos, frequency_rank, swadesh_index) {
    var e = alloc(48);
    store64(e, word);
    store64(e + 8, ipa);
    store64(e + 16, gloss);
    store64(e + 24, pos);
    store64(e + 32, frequency_rank);
    store64(e + 40, swadesh_index);
    return e;
}

fn lex_word(e) { return load64(e); }
fn lex_ipa(e) { return load64(e + 8); }
fn lex_gloss(e) { return load64(e + 16); }
fn lex_pos(e) { return load64(e + 24); }
fn lex_frequency_rank(e) { return load64(e + 32); }
fn lex_swadesh_index(e) { return load64(e + 40); }

fn _lexicon_new(code) {
    var lex = alloc(16);
    store64(lex, code);
    store64(lex + 8, vec_new());
    return lex;
}

fn _lexicon_add(lex, entry) {
    vec_push(load64(lex + 8), entry);
    return lex;
}

fn lexicon_language_code(lex) { return load64(lex); }
fn lexicon_entries(lex) { return load64(lex + 8); }

# Insertion-sort a vec of LexEntry ptrs ascending by the i64 field at `off`.
fn _lex_sort_by_offset(v, off) {
    var n = vec_len(v);
    var i = 1;
    while (i < n) {
        var key = vec_get(v, i);
        var kv = load64(key + off);
        var j = i - 1;
        while (j >= 0 && load64(vec_get(v, j) + off) > kv) {
            vec_set(v, j + 1, vec_get(v, j));
            j = j - 1;
        }
        vec_set(v, j + 1, key);
        i = i + 1;
    }
    return v;
}

# Look up a word by its native form — entry ptr, or 0 if absent.
fn lexicon_find(lex, word) {
    var entries = load64(lex + 8);
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (streq(load64(e), word) == 1) { return e; }
        i = i + 1;
    }
    return 0;
}

# Look up an entry by English gloss — entry ptr, or 0 if absent.
fn lexicon_find_gloss(lex, gloss) {
    var entries = load64(lex + 8);
    var n = vec_len(entries);
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (streq(load64(e + 16), gloss) == 1) { return e; }
        i = i + 1;
    }
    return 0;
}

# All Swadesh entries (swadesh_index set), sorted by index — vec of entry ptrs.
fn lexicon_swadesh(lex) {
    var entries = load64(lex + 8);
    var n = vec_len(entries);
    var out = vec_new();
    var i = 0;
    while (i < n) {
        var e = vec_get(entries, i);
        if (load64(e + 40) >= 0) { vec_push(out, e); }
        i = i + 1;
    }
    _lex_sort_by_offset(out, 40);
    return out;
}

# The N most frequent entries (frequency_rank set), sorted ascending by rank.
fn lexicon_most_frequent(lex, n) {
    var entries = load64(lex + 8);
    var cnt = vec_len(entries);
    var ranked = vec_new();
    var i = 0;
    while (i < cnt) {
        var e = vec_get(entries, i);
        if (load64(e + 32) >= 0) { vec_push(ranked, e); }
        i = i + 1;
    }
    _lex_sort_by_offset(ranked, 32);
    var out = vec_new();
    var rn = vec_len(ranked);
    var k = 0;
    while (k < n && k < rn) {
        vec_push(out, vec_get(ranked, k));
        k = k + 1;
    }
    return out;
}

# --- swadesh.cyr ---

# src/swadesh.cyr — Swadesh-25 starter lists for 10 core languages.
# Ported from rust-old/src/lexicon/swadesh.rs (data transpiled byte-exact).
# Requires src/lexicon.cyr. Entries carry frequency_rank = None (0-1).

fn _sw_entry(lex, word, ipa, gloss, pos, swadesh) {
    _lexicon_add(lex, _lex_entry_new(word, ipa, gloss, pos, 0 - 1, swadesh));
    return lex;
}

fn swadesh_count(lex) { return vec_len(lexicon_entries(lex)); }
fn swadesh_entry(lex, i) { return vec_get(lexicon_entries(lex), i); }
fn swadesh_entry_index(e) { return lex_swadesh_index(e); }
fn swadesh_entry_word(e) { return lex_word(e); }
fn swadesh_entry_ipa(e) { return lex_ipa(e); }
fn swadesh_entry_gloss(e) { return lex_gloss(e); }
fn swadesh_find_gloss(lex, gloss) { return lexicon_find_gloss(lex, gloss); }

# --- Pre-built Swadesh-25 lists ------------------------------------

fn swadesh_arabic() {
    var lex = _lexicon_new("ar");
    _sw_entry(lex, "أنا", "ʔana", "I", PartOfSpeech.Pronoun, 1);
    _sw_entry(lex, "أنتَ", "ʔanta", "you", PartOfSpeech.Pronoun, 2);
    _sw_entry(lex, "نحن", "naħnu", "we", PartOfSpeech.Pronoun, 3);
    _sw_entry(lex, "هذا", "haːðaː", "this", PartOfSpeech.Determiner, 4);
    _sw_entry(lex, "ذلك", "ðaːlika", "that", PartOfSpeech.Determiner, 5);
    _sw_entry(lex, "مَن", "man", "who", PartOfSpeech.Pronoun, 6);
    _sw_entry(lex, "ما", "maː", "what", PartOfSpeech.Pronoun, 7);
    _sw_entry(lex, "لا", "laː", "not", PartOfSpeech.Particle, 8);
    _sw_entry(lex, "كل", "kull", "all", PartOfSpeech.Adjective, 9);
    _sw_entry(lex, "كثير", "kaθiːr", "many", PartOfSpeech.Adjective, 10);
    _sw_entry(lex, "واحد", "waːħid", "one", PartOfSpeech.Numeral, 11);
    _sw_entry(lex, "اثنان", "iθnaːn", "two", PartOfSpeech.Numeral, 12);
    _sw_entry(lex, "كبير", "kabiːr", "big", PartOfSpeech.Adjective, 13);
    _sw_entry(lex, "طويل", "tˤawiːl", "long", PartOfSpeech.Adjective, 14);
    _sw_entry(lex, "صغير", "sˤaɣiːr", "small", PartOfSpeech.Adjective, 15);
