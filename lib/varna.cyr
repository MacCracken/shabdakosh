# English (General American): 24 consonants + 12 vowels. Stress: free.
fn phoneme_english() {
    var b = phoneme_builder_with_capacity("en", "English", 36);
    phoneme_builder_stress(b, StressPattern.Free);
    # Plosives
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "d", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "ɡ", Manner.Plosive, Place.Velar, 1);
    # Fricatives
    phoneme_builder_consonant(b, "f", Manner.Fricative, Place.Labiodental, 0);
    phoneme_builder_consonant(b, "v", Manner.Fricative, Place.Labiodental, 1);
    phoneme_builder_consonant(b, "θ", Manner.Fricative, Place.Dental, 0);
    phoneme_builder_consonant(b, "ð", Manner.Fricative, Place.Dental, 1);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "z", Manner.Fricative, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ʃ", Manner.Fricative, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "ʒ", Manner.Fricative, Place.Postalveolar, 1);
    phoneme_builder_consonant(b, "h", Manner.Fricative, Place.Glottal, 0);
    # Nasals
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ŋ", Manner.Nasal, Place.Velar, 1);
    # Approximants
    phoneme_builder_consonant(b, "ɹ", Manner.Approximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "w", Manner.Approximant, Place.LabialVelar, 1);
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    # Affricates
    phoneme_builder_consonant(b, "t͡ʃ", Manner.Affricate, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "d͡ʒ", Manner.Affricate, Place.Postalveolar, 1);
    # Vowels (General American)
    phoneme_builder_vowel(b, "iː", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "ɪ", Height.NearClose, Backness.Front, 0);
    phoneme_builder_vowel(b, "eɪ", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "ɛ", Height.OpenMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "æ", Height.NearOpen, Backness.Front, 0);
    phoneme_builder_vowel(b, "ɑː", Height.Open, Backness.Back, 0);
    phoneme_builder_vowel(b, "ɔː", Height.OpenMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "oʊ", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "ʊ", Height.NearClose, Backness.Back, 1);
    phoneme_builder_vowel(b, "uː", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "ʌ", Height.OpenMid, Backness.Central, 0);
    phoneme_builder_vowel(b, "ə", Height.Mid, Backness.Central, 0);
    return phoneme_builder_build(b);
}

# Sanskrit (Classical): 36 consonants + 14 vowels. Stress: pitch accent.
fn phoneme_sanskrit() {
    var b = phoneme_builder_with_capacity("sa", "Sanskrit", 50);
    phoneme_builder_stress(b, StressPattern.PitchAccent);
    # Kavarga (velar)
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "kʰ", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "ɡ", Manner.Plosive, Place.Velar, 1);
    phoneme_builder_consonant(b, "ɡʰ", Manner.Plosive, Place.Velar, 1);
    phoneme_builder_consonant(b, "ŋ", Manner.Nasal, Place.Velar, 1);
    # Chavarga (palatal)
    phoneme_builder_consonant(b, "t͡ɕ", Manner.Affricate, Place.Palatal, 0);
    phoneme_builder_consonant(b, "t͡ɕʰ", Manner.Affricate, Place.Palatal, 0);
    phoneme_builder_consonant(b, "d͡ʑ", Manner.Affricate, Place.Palatal, 1);
    phoneme_builder_consonant(b, "d͡ʑʰ", Manner.Affricate, Place.Palatal, 1);
    phoneme_builder_consonant(b, "ɲ", Manner.Nasal, Place.Palatal, 1);
    # Tavarga (retroflex)
    phoneme_builder_consonant(b, "ʈ", Manner.Plosive, Place.Retroflex, 0);
    phoneme_builder_consonant(b, "ʈʰ", Manner.Plosive, Place.Retroflex, 0);
    phoneme_builder_consonant(b, "ɖ", Manner.Plosive, Place.Retroflex, 1);
    phoneme_builder_consonant(b, "ɖʰ", Manner.Plosive, Place.Retroflex, 1);
    phoneme_builder_consonant(b, "ɳ", Manner.Nasal, Place.Retroflex, 1);
    # Tavarga (dental)
    phoneme_builder_consonant(b, "t̪", Manner.Plosive, Place.Dental, 0);
    phoneme_builder_consonant(b, "t̪ʰ", Manner.Plosive, Place.Dental, 0);
    phoneme_builder_consonant(b, "d̪", Manner.Plosive, Place.Dental, 1);
    phoneme_builder_consonant(b, "d̪ʰ", Manner.Plosive, Place.Dental, 1);
    phoneme_builder_consonant(b, "n̪", Manner.Nasal, Place.Dental, 1);
    # Pavarga (bilabial)
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "pʰ", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "bʰ", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    # Antastha (semivowels/approximants)
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    phoneme_builder_consonant(b, "r", Manner.Trill, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ʋ", Manner.Approximant, Place.Labiodental, 1);
    # Ushman (sibilants/fricatives)
    phoneme_builder_consonant(b, "ɕ", Manner.Fricative, Place.Palatal, 0);
    phoneme_builder_consonant(b, "ʂ", Manner.Fricative, Place.Retroflex, 0);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "ɦ", Manner.Fricative, Place.Glottal, 1);
    # Additional
    phoneme_builder_consonant(b, "ɭ", Manner.LateralApproximant, Place.Retroflex, 1);
    phoneme_builder_consonant(b, "kʂ", Manner.Affricate, Place.Velar, 0);
    phoneme_builder_consonant(b, "d͡ʑɲ", Manner.Affricate, Place.Palatal, 1);
    # Vowels (svara) — short
    phoneme_builder_vowel(b, "ɐ", Height.NearOpen, Backness.Central, 0);
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "r̩", Height.Close, Backness.Central, 0);
    phoneme_builder_vowel(b, "l̩", Height.Close, Backness.Central, 0);
    # Long
    phoneme_builder_vowel(b, "ɐː", Height.NearOpen, Backness.Central, 0);
    phoneme_builder_vowel(b, "iː", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "uː", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "r̩ː", Height.Close, Backness.Central, 0);
    phoneme_builder_vowel(b, "l̩ː", Height.Close, Backness.Central, 0);
    # Diphthongs
    phoneme_builder_vowel(b, "eː", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "ɐi", Height.NearOpen, Backness.Front, 0);
    phoneme_builder_vowel(b, "oː", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "ɐu", Height.NearOpen, Backness.Back, 1);
    return phoneme_builder_build(b);
}

# Greek (Modern Standard): 20 consonants + 5 vowels. Stress: free.
fn phoneme_greek() {
    var b = phoneme_builder_with_capacity("el", "Greek", 25);
    phoneme_builder_stress(b, StressPattern.Free);
    # Plosives
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "d", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "ɡ", Manner.Plosive, Place.Velar, 1);
    # Fricatives
    phoneme_builder_consonant(b, "f", Manner.Fricative, Place.Labiodental, 0);
    phoneme_builder_consonant(b, "v", Manner.Fricative, Place.Labiodental, 1);
    phoneme_builder_consonant(b, "θ", Manner.Fricative, Place.Dental, 0);
    phoneme_builder_consonant(b, "ð", Manner.Fricative, Place.Dental, 1);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "z", Manner.Fricative, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "x", Manner.Fricative, Place.Velar, 0);
    phoneme_builder_consonant(b, "ɣ", Manner.Fricative, Place.Velar, 1);
    # Nasals
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    # Liquids
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "r", Manner.Trill, Place.Alveolar, 1);
    # Affricates
    phoneme_builder_consonant(b, "t͡s", Manner.Affricate, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "d͡z", Manner.Affricate, Place.Alveolar, 1);
    # Vowels (5-vowel system)
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "e", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "a", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "o", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    return phoneme_builder_build(b);
}

