    _nsys_add(sys, "μ", 40);
    _nsys_add(sys, "ν", 50);
    _nsys_add(sys, "ξ", 60);
    _nsys_add(sys, "ο", 70);
    _nsys_add(sys, "π", 80);
    _nsys_add(sys, "ρ", 100);
    _nsys_add(sys, "σ", 200);
    _nsys_add(sys, "ς", 200);
    _nsys_add(sys, "τ", 300);
    _nsys_add(sys, "υ", 400);
    _nsys_add(sys, "φ", 500);
    _nsys_add(sys, "χ", 600);
