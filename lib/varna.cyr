# --- error.cyr ---

# src/error.cyr — VarnaError codes for varna
#
# Cyrius has no throw/catch; fallible calls return a sentinel (0 / -1) and the
# caller checks. This enum gives stable codes for the conditions the v1.x Rust
# crate modeled as the VarnaError enum. `varna_error_str` renders a message.
#
# Ported from rust-old/src/error.rs (VarnaError).

enum VarnaError {
    VARNA_OK = 0;
    VARNA_UNKNOWN_LANGUAGE = 1;
    VARNA_UNKNOWN_SCRIPT = 2;
    VARNA_PHONEME_NOT_IN_INVENTORY = 3;
    VARNA_INVALID_IPA = 4;
    VARNA_WORD_NOT_FOUND = 5;
}

fn varna_error_str(code) {
    if (code == VARNA_OK) { return "ok"; }
    if (code == VARNA_UNKNOWN_LANGUAGE) { return "unknown language"; }
    if (code == VARNA_UNKNOWN_SCRIPT) { return "unknown script"; }
    if (code == VARNA_PHONEME_NOT_IN_INVENTORY) { return "phoneme not in inventory"; }
    if (code == VARNA_INVALID_IPA) { return "invalid IPA symbol"; }
    if (code == VARNA_WORD_NOT_FOUND) { return "word not found"; }
    return "unknown error";
}

# --- util.cyr ---

# src/util.cyr — shared low-level helpers.

# UTF-8 byte length of the codepoint whose lead byte is b (0-255).
# Valid lead bytes: 0x00-0x7F=1, 0xC0-0xDF=2, 0xE0-0xEF=3, 0xF0-0xF7=4.
fn _utf8_len(b) {
    if (b < 0x80) { return 1; }
    if (b < 0xE0) { return 2; }
    if (b < 0xF0) { return 3; }
    return 4;
}

# --- phoneme.cyr ---

# src/phoneme.cyr — IPA phoneme inventories, articulatory features.
#
# Ported from rust-old/src/phoneme/mod.rs. Records are heap structs (alloc +
# store64/load64 at 8-byte slots); enums are integer constants; IPA symbols are
# cstring literals compared with streq. Sentinel 0 = "not found" (was Option).
#
# Memory layout
#   Phoneme   (40B): [0]=ipa  [8]=kind  [16]=f0  [24]=f1  [32]=f2
#                    consonant → f0=manner f1=place    f2=voiced(0/1)
#                    vowel     → f0=height f1=backness f2=rounded(0/1)
#   Inventory (40B): [0]=code  [8]=name  [16]=phonemes(vec)  [24]=stress  [32]=tones(vec|0)

enum Manner {
    Plosive = 0;
    Nasal = 1;
    Trill = 2;
    TapFlap = 3;
    Fricative = 4;
    LateralFricative = 5;
    Approximant = 6;
    LateralApproximant = 7;
    Affricate = 8;
}

enum Place {
    Bilabial = 0;
    Labiodental = 1;
    Dental = 2;
    Alveolar = 3;
    Postalveolar = 4;
    Retroflex = 5;
    Palatal = 6;
    Velar = 7;
    Uvular = 8;
    Pharyngeal = 9;
    Glottal = 10;
    LabialVelar = 11;
}

enum Height {
    Close = 0;
    NearClose = 1;
    CloseMid = 2;
    Mid = 3;
    OpenMid = 4;
    NearOpen = 5;
    Open = 6;
}

enum Backness {
    Front = 0;
    Central = 1;
    Back = 2;
}

enum StressPattern {
    Fixed = 0;
    Free = 1;
    PitchAccent = 2;
    Tonal = 3;
}

enum PhonemeKind {
    Consonant = 0;
    Vowel = 1;
}

# --- Phoneme constructors + accessors ------------------------------

fn phoneme_consonant(ipa, manner, place, voiced) {
    var p = alloc(40);
    store64(p, ipa);
    store64(p + 8, PhonemeKind.Consonant);
    store64(p + 16, manner);
    store64(p + 24, place);
    store64(p + 32, voiced);
    return p;
}

fn phoneme_vowel(ipa, height, backness, rounded) {
    var p = alloc(40);
    store64(p, ipa);
    store64(p + 8, PhonemeKind.Vowel);
    store64(p + 16, height);
    store64(p + 24, backness);
    store64(p + 32, rounded);
    return p;
}

fn phoneme_ipa(p) { return load64(p); }
fn phoneme_kind(p) { return load64(p + 8); }
fn phoneme_manner(p) { return load64(p + 16); }
fn phoneme_place(p) { return load64(p + 24); }
fn phoneme_voiced(p) { return load64(p + 32); }
fn phoneme_height(p) { return load64(p + 16); }
fn phoneme_backness(p) { return load64(p + 24); }
fn phoneme_rounded(p) { return load64(p + 32); }

# --- Inventory builder ---------------------------------------------
# The builder and the inventory share one 40-byte layout; build() is identity.

fn phoneme_builder_with_capacity(code, name, cap) {
    var inv = alloc(40);
    store64(inv, code);
    store64(inv + 8, name);
    store64(inv + 16, vec_new());
    store64(inv + 24, StressPattern.Free);
    store64(inv + 32, 0);
    return inv;
}

fn phoneme_builder_new(code, name) {
    return phoneme_builder_with_capacity(code, name, 48);
}

fn phoneme_builder_stress(inv, pattern) {
    store64(inv + 24, pattern);
    return inv;
}

fn phoneme_builder_tones(inv, tones) {
    store64(inv + 32, tones);
    return inv;
}

fn phoneme_builder_consonant(inv, ipa, manner, place, voiced) {
    vec_push(load64(inv + 16), phoneme_consonant(ipa, manner, place, voiced));
    return inv;
}

fn phoneme_builder_vowel(inv, ipa, height, backness, rounded) {
    vec_push(load64(inv + 16), phoneme_vowel(ipa, height, backness, rounded));
    return inv;
}

fn phoneme_builder_phoneme(inv, p) {
    vec_push(load64(inv + 16), p);
    return inv;
}

fn phoneme_builder_build(inv) { return inv; }

# --- Inventory accessors + queries ---------------------------------

fn phoneme_language_code(inv) { return load64(inv); }
fn phoneme_language_name(inv) { return load64(inv + 8); }
fn phoneme_list(inv) { return load64(inv + 16); }
fn phoneme_stress(inv) { return load64(inv + 24); }
fn phoneme_tones(inv) { return load64(inv + 32); }

fn phoneme_consonant_count(inv) {
    var ph = load64(inv + 16);
    var n = vec_len(ph);
    var count = 0;
    var i = 0;
    while (i < n) {
        if (phoneme_kind(vec_get(ph, i)) == PhonemeKind.Consonant) { count = count + 1; }
        i = i + 1;
    }
    return count;
}

fn phoneme_vowel_count(inv) {
    var ph = load64(inv + 16);
    var n = vec_len(ph);
    var count = 0;
    var i = 0;
    while (i < n) {
        if (phoneme_kind(vec_get(ph, i)) == PhonemeKind.Vowel) { count = count + 1; }
        i = i + 1;
    }
    return count;
}

# Look up a phoneme by IPA symbol — returns the Phoneme ptr, or 0 if absent.
fn phoneme_find(inv, ipa) {
    var ph = load64(inv + 16);
    var n = vec_len(ph);
    var i = 0;
    while (i < n) {
        var p = vec_get(ph, i);
        if (streq(phoneme_ipa(p), ipa) == 1) { return p; }
        i = i + 1;
    }
    return 0;
}

fn phoneme_has(inv, ipa) {
    if (phoneme_find(inv, ipa) != 0) { return 1; }
    return 0;
}

