fn numerals_egyptian_hieroglyphic() {
    var sys = _nsys_new("Egyp", "Egyptian Hieroglyphic Numerals", NumeralSystemKind.Other);
    _nsys_add(sys, "𓏺", 1);
    _nsys_add(sys, "𓎆", 10);
    _nsys_add(sys, "𓍢", 100);
    _nsys_add(sys, "𓆼", 1000);
    _nsys_add(sys, "𓂭", 10000);
    _nsys_add(sys, "𓆐", 100000);
    _nsys_add(sys, "𓁨", 1000000);
    return sys;
}

fn numerals_chinese_rod_numerals() {
    var sys = _nsys_new("Hani", "Chinese Rod Numerals", NumeralSystemKind.Decimal);
    _nsys_add(sys, "𝍠", 1);
    _nsys_add(sys, "𝍡", 2);
    _nsys_add(sys, "𝍢", 3);
    _nsys_add(sys, "𝍣", 4);
    _nsys_add(sys, "𝍤", 5);
    _nsys_add(sys, "𝍥", 6);
    _nsys_add(sys, "𝍦", 7);
    _nsys_add(sys, "𝍧", 8);
    _nsys_add(sys, "𝍨", 9);
    return sys;
}

# --- transliteration.cyr ---

# src/transliteration.cyr — bidirectional script transliteration tables.
# Ported from rust-old/src/script/transliteration.rs (data transpiled byte-exact).
#
# TransliterationTable (32B): [0]=scheme [8]=source_script [16]=target_script
#                             [24]=forward(vec of pairs)
# pair (16B): [0]=src(cstr) [8]=tgt(cstr)
# Requires src/util.cyr (_utf8_len). transliterate_char/reverse-lookup return 0
# when unmapped; transliterate() returns a fresh cstring.

fn _tt_new(scheme, src_script, tgt_script) {
    var tt = alloc(32);
    store64(tt, scheme);
    store64(tt + 8, src_script);
    store64(tt + 16, tgt_script);
    store64(tt + 24, vec_new());
    return tt;
}

fn _tt_add(tt, src, tgt) {
    var pair = alloc(16);
    store64(pair, src);
    store64(pair + 8, tgt);
    vec_push(load64(tt + 24), pair);
    return tt;
}

fn translit_scheme(tt) { return load64(tt); }
fn translit_source_script(tt) { return load64(tt + 8); }
fn translit_target_script(tt) { return load64(tt + 16); }
fn translit_forward(tt) { return load64(tt + 24); }

# Transliterate a single source grapheme — target cstr, or 0 if unmapped.
fn translit_char(tt, ch) {
    var fwd = load64(tt + 24);
    var n = vec_len(fwd);
    var i = 0;
    while (i < n) {
        var pair = vec_get(fwd, i);
        if (streq(load64(pair), ch) == 1) { return load64(pair + 8); }
        i = i + 1;
    }
    return 0;
}

# Reverse map (target -> source) as a hashmap; last source wins on collision.
fn translit_reverse_map(tt) {
    var fwd = load64(tt + 24);
    var n = vec_len(fwd);
    var rev = map_new();
    var i = 0;
    while (i < n) {
        var pair = vec_get(fwd, i);
        map_set(rev, load64(pair + 8), load64(pair));
        i = i + 1;
    }
    return rev;
}

# Transliterate a string by greedily matching the longest source sequence
# (up to 4 codepoints). Unmapped graphemes pass through unchanged.
fn translit_apply(tt, input) {
    var inlen = strlen(input);
    var out = alloc(inlen * 4 + 16);
    var olen = 0;
    var p = 0;
    while (p < inlen) {
        var l1 = _utf8_len(load8(input + p) & 0xFF);
        var b2 = p + l1;
        var l2 = 0;
        if (b2 < inlen) { l2 = _utf8_len(load8(input + b2) & 0xFF); }
        var b3 = b2 + l2;
        var l3 = 0;
        if (b3 < inlen) { l3 = _utf8_len(load8(input + b3) & 0xFF); }
        var b4 = b3 + l3;
        var l4 = 0;
        if (b4 < inlen) { l4 = _utf8_len(load8(input + b4) & 0xFF); }
        var lens = vec_new();
        vec_push(lens, l1);
        vec_push(lens, l1 + l2);
        vec_push(lens, l1 + l2 + l3);
        vec_push(lens, l1 + l2 + l3 + l4);
        var matched = 0;
        var k = 3;
        while (k >= 0 && matched == 0) {
            var elen = vec_get(lens, k);
            var cand = alloc(elen + 1);
            memcpy(cand, input + p, elen);
            store8(cand + elen, 0);
            var rep = translit_char(tt, cand);
            if (rep != 0) {
                var rlen = strlen(rep);
                memcpy(out + olen, rep, rlen);
                olen = olen + rlen;
                p = p + elen;
                matched = 1;
            }
            k = k - 1;
        }
        if (matched == 0) {
            memcpy(out + olen, input + p, l1);
            olen = olen + l1;
            p = p + l1;
        }
    }
    store8(out + olen, 0);
    return out;
}

