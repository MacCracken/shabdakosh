    if (streq(code, "ar") == 1) { return phoneme_classical_arabic(); }
    if (streq(code, "grc") == 1) { return phoneme_koine_greek(); }
    if (streq(code, "lzh") == 1) { return phoneme_literary_chinese(); }
    if (streq(code, "zh") == 1) { return phoneme_mandarin(); }
    if (streq(code, "hi") == 1) { return phoneme_hindi(); }
    if (streq(code, "bn") == 1) { return phoneme_bengali(); }
    if (streq(code, "ta") == 1) { return phoneme_tamil(); }
    if (streq(code, "ur") == 1) { return phoneme_urdu(); }
    if (streq(code, "ja") == 1) { return phoneme_japanese(); }
    if (streq(code, "es") == 1) { return phoneme_spanish(); }
    if (streq(code, "fr") == 1) { return phoneme_french(); }
    if (streq(code, "de") == 1) { return phoneme_german(); }
    if (streq(code, "ru") == 1) { return phoneme_russian(); }
    if (streq(code, "ko") == 1) { return phoneme_korean(); }
    if (streq(code, "pt") == 1) { return phoneme_portuguese(); }
    if (streq(code, "it") == 1) { return phoneme_italian(); }
    if (streq(code, "nl") == 1) { return phoneme_dutch(); }
    if (streq(code, "pl") == 1) { return phoneme_polish(); }
    if (streq(code, "am") == 1) { return phoneme_amharic(); }
    if (streq(code, "ha") == 1) { return phoneme_hausa(); }
    if (streq(code, "id") == 1) { return phoneme_indonesian(); }
    if (streq(code, "fa") == 1) { return phoneme_persian(); }
    if (streq(code, "he") == 1) { return phoneme_hebrew(); }
    if (streq(code, "ka") == 1) { return phoneme_georgian(); }
    if (streq(code, "cs") == 1) { return phoneme_czech(); }
    if (streq(code, "hu") == 1) { return phoneme_hungarian(); }
    if (streq(code, "ro") == 1) { return phoneme_romanian(); }
    if (streq(code, "my") == 1) { return phoneme_burmese(); }
    if (streq(code, "km") == 1) { return phoneme_khmer(); }
