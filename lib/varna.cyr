    _sw_entry(lex, "إنسان", "ʔinsaːn", "person", PartOfSpeech.Noun, 18);
    _sw_entry(lex, "سمك", "samak", "fish", PartOfSpeech.Noun, 19);
    _sw_entry(lex, "طير", "tˤajr", "bird", PartOfSpeech.Noun, 20);
