fn numerals_babylonian_sexagesimal() {
    var sys = _nsys_new("Xsux", "Babylonian Sexagesimal", NumeralSystemKind.Other);
    _nsys_add(sys, "𒐕", 1);
    _nsys_add(sys, "𒐖", 2);
    _nsys_add(sys, "𒐗", 3);
    _nsys_add(sys, "𒐘", 4);
