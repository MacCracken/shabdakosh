    phoneme_builder_consonant(b, "ɳ", Manner.Nasal, Place.Retroflex, 1);
    # Dentals
    phoneme_builder_consonant(b, "t̪", Manner.Plosive, Place.Dental, 0);
    phoneme_builder_consonant(b, "t̪ʰ", Manner.Plosive, Place.Dental, 0);
    phoneme_builder_consonant(b, "d̪", Manner.Plosive, Place.Dental, 1);
    phoneme_builder_consonant(b, "d̪ʱ", Manner.Plosive, Place.Dental, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    # Bilabials
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "pʰ", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "bʱ", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    # Approximants & liquids
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    phoneme_builder_consonant(b, "r", Manner.TapFlap, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ʋ", Manner.Approximant, Place.Labiodental, 1);
    # Fricatives
    phoneme_builder_consonant(b, "f", Manner.Fricative, Place.Labiodental, 0);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "z", Manner.Fricative, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ʃ", Manner.Fricative, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "x", Manner.Fricative, Place.Velar, 0);
    phoneme_builder_consonant(b, "ɣ", Manner.Fricative, Place.Velar, 1);
    phoneme_builder_consonant(b, "ɦ", Manner.Fricative, Place.Glottal, 1);
    # Vowels (short and long pairs + schwa)
    phoneme_builder_vowel(b, "ə", Height.Mid, Backness.Central, 0);
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "iː", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "uː", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "e", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "eː", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "ɛː", Height.OpenMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "o", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "ɔː", Height.OpenMid, Backness.Back, 1);
    return phoneme_builder_build(b);
}

fn phoneme_amharic() {

    var b = phoneme_builder_with_capacity("am", "Amharic", 34);
    phoneme_builder_stress(b, StressPattern.Fixed);
    # Plain plosives
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "d", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "ɡ", Manner.Plosive, Place.Velar, 1);
    phoneme_builder_consonant(b, "ʔ", Manner.Plosive, Place.Glottal, 0);
    # Ejectives
    phoneme_builder_consonant(b, "pʼ", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "tʼ", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "kʼ", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "t͡ʃʼ", Manner.Affricate, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "t͡sʼ", Manner.Affricate, Place.Alveolar, 0);
    # Affricates
    phoneme_builder_consonant(b, "t͡ʃ", Manner.Affricate, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "d͡ʒ", Manner.Affricate, Place.Postalveolar, 1);
    # Fricatives
    phoneme_builder_consonant(b, "f", Manner.Fricative, Place.Labiodental, 0);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "z", Manner.Fricative, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ʃ", Manner.Fricative, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "x", Manner.Fricative, Place.Velar, 0);
    phoneme_builder_consonant(b, "h", Manner.Fricative, Place.Glottal, 0);
    # Nasals
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ɲ", Manner.Nasal, Place.Palatal, 1);
    # Approximants / liquids
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "r", Manner.Trill, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    phoneme_builder_consonant(b, "w", Manner.Approximant, Place.LabialVelar, 1);
    # Vowels (7-vowel system — the seven Ethiopic orders)
    phoneme_builder_vowel(b, "ä", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "a", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "e", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "ɨ", Height.Close, Backness.Central, 0);
    phoneme_builder_vowel(b, "o", Height.CloseMid, Backness.Back, 1);
    return phoneme_builder_build(b);
}

fn phoneme_hausa() {

    var b = phoneme_builder_with_capacity("ha", "Hausa", 35);
    phoneme_builder_stress(b, StressPattern.Tonal);
    var t = vec_new();
    vec_push(t, "˥");
    vec_push(t, "˩");
    phoneme_builder_tones(b, t);
    # Plain plosives
    phoneme_builder_consonant(b, "p", Manner.Plosive, Place.Bilabial, 0);
    phoneme_builder_consonant(b, "b", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "t", Manner.Plosive, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "d", Manner.Plosive, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "k", Manner.Plosive, Place.Velar, 0);
    phoneme_builder_consonant(b, "ɡ", Manner.Plosive, Place.Velar, 1);
    phoneme_builder_consonant(b, "ʔ", Manner.Plosive, Place.Glottal, 0);
    phoneme_builder_consonant(b, "ʔʲ", Manner.Plosive, Place.Palatal, 0);
    # Implosives (bilabial + alveolar)
    phoneme_builder_consonant(b, "ɓ", Manner.Plosive, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "ɗ", Manner.Plosive, Place.Alveolar, 1);
    # Ejective
    phoneme_builder_consonant(b, "kʼ", Manner.Plosive, Place.Velar, 0);
    # Affricates
    phoneme_builder_consonant(b, "t͡ʃ", Manner.Affricate, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "d͡ʒ", Manner.Affricate, Place.Postalveolar, 1);
    phoneme_builder_consonant(b, "t͡s", Manner.Affricate, Place.Alveolar, 0);
    # Fricatives
    phoneme_builder_consonant(b, "f", Manner.Fricative, Place.Labiodental, 0);
    phoneme_builder_consonant(b, "s", Manner.Fricative, Place.Alveolar, 0);
    phoneme_builder_consonant(b, "z", Manner.Fricative, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "ʃ", Manner.Fricative, Place.Postalveolar, 0);
    phoneme_builder_consonant(b, "h", Manner.Fricative, Place.Glottal, 0);
    # Nasals
    phoneme_builder_consonant(b, "m", Manner.Nasal, Place.Bilabial, 1);
    phoneme_builder_consonant(b, "n", Manner.Nasal, Place.Alveolar, 1);
    # Approximants / liquids
    phoneme_builder_consonant(b, "l", Manner.LateralApproximant, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "r", Manner.Trill, Place.Alveolar, 1);
    phoneme_builder_consonant(b, "j", Manner.Approximant, Place.Palatal, 1);
    phoneme_builder_consonant(b, "w", Manner.Approximant, Place.LabialVelar, 1);
    # Vowels: 5 short + 5 long
    phoneme_builder_vowel(b, "a", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "aː", Height.Open, Backness.Central, 0);
    phoneme_builder_vowel(b, "e", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "eː", Height.CloseMid, Backness.Front, 0);
    phoneme_builder_vowel(b, "i", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "iː", Height.Close, Backness.Front, 0);
    phoneme_builder_vowel(b, "o", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "oː", Height.CloseMid, Backness.Back, 1);
    phoneme_builder_vowel(b, "u", Height.Close, Backness.Back, 1);
    phoneme_builder_vowel(b, "uː", Height.Close, Backness.Back, 1);
    return phoneme_builder_build(b);
}

fn phoneme_indonesian() {

