    var lex = _lexicon_new("es");
    _sw_entry(lex, "yo", "ɟ͡ʝo", "I", PartOfSpeech.Pronoun, 1);
    _sw_entry(lex, "tú", "tu", "you", PartOfSpeech.Pronoun, 2);
    _sw_entry(lex, "nosotros", "nosotɾos", "we", PartOfSpeech.Pronoun, 3);
    _sw_entry(lex, "esto", "esto", "this", PartOfSpeech.Determiner, 4);
    _sw_entry(lex, "eso", "eso", "that", PartOfSpeech.Determiner, 5);
    _sw_entry(lex, "quién", "kjen", "who", PartOfSpeech.Pronoun, 6);
    _sw_entry(lex, "qué", "ke", "what", PartOfSpeech.Pronoun, 7);
    _sw_entry(lex, "no", "no", "not", PartOfSpeech.Particle, 8);
    _sw_entry(lex, "todo", "toðo", "all", PartOfSpeech.Adjective, 9);
    _sw_entry(lex, "mucho", "mutʃo", "many", PartOfSpeech.Adjective, 10);
    _sw_entry(lex, "uno", "uno", "one", PartOfSpeech.Numeral, 11);
