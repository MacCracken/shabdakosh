# Swadesh lexicon for a language, or 0 if none.
fn swadesh_by_code(code) {
    if (streq(code, "ar") == 1) { return swadesh_arabic(); }
    if (streq(code, "zh") == 1) { return swadesh_mandarin(); }
    if (streq(code, "hi") == 1) { return swadesh_hindi(); }
    if (streq(code, "ja") == 1) { return swadesh_japanese(); }
    if (streq(code, "es") == 1) { return swadesh_spanish(); }
    if (streq(code, "fr") == 1) { return swadesh_french(); }
    if (streq(code, "de") == 1) { return swadesh_german(); }
    if (streq(code, "ru") == 1) { return swadesh_russian(); }
    if (streq(code, "ko") == 1) { return swadesh_korean(); }
    if (streq(code, "pt") == 1) { return swadesh_portuguese(); }
    return 0;
}

# All language codes with Swadesh data — vec of cstrings.
fn swadesh_all_codes() {
    var c = vec_new();
    vec_push(c, "ar");
    vec_push(c, "zh");
    vec_push(c, "hi");
    vec_push(c, "ja");
    vec_push(c, "es");
    vec_push(c, "fr");
    vec_push(c, "de");
    vec_push(c, "ru");
    vec_push(c, "ko");
    vec_push(c, "pt");
    return c;
}

# --- cognate.cyr ---

# src/cognate.cyr — cognate sets + etymology.
#
# Ported from rust-old/src/lexicon/cognate.rs.
#
# CognateSet (32B):   [0]=proto_form(cstr|0) [8]=proto_language(cstr|0) [16]=gloss [24]=entries(vec)
# CognateEntry (24B): [0]=language [8]=word [16]=ipa
# Etymology (32B):    [0]=source_language [8]=source_form [16]=borrowing_type [24]=period(cstr|0)

enum BorrowingType {
    Loanword = 0;
    Calque = 1;
    SemanticLoan = 2;
    Inherited = 3;
}

fn _cognate_entry_new(language, word, ipa) {
    var e = alloc(24);
    store64(e, language);
    store64(e + 8, word);
    store64(e + 16, ipa);
    return e;
}

fn cognate_entry_language(e) { return load64(e); }
fn cognate_word(e) { return load64(e + 8); }
fn cognate_ipa(e) { return load64(e + 16); }

fn _cognate_set_new(proto_form, proto_language, gloss) {
    var s = alloc(32);
    store64(s, proto_form);
    store64(s + 8, proto_language);
    store64(s + 16, gloss);
    store64(s + 24, vec_new());
    return s;
}

fn _cognate_set_add(s, language, word, ipa) {
    vec_push(load64(s + 24), _cognate_entry_new(language, word, ipa));
    return s;
}

fn cognate_proto_form(s) { return load64(s); }
fn cognate_proto_language(s) { return load64(s + 8); }
fn cognate_gloss(s) { return load64(s + 16); }
fn cognate_entries(s) { return load64(s + 24); }

# Cognate entry for a language code — entry ptr, or 0 if absent.
fn cognate_for_language(s, code) {
    var es = load64(s + 24);
    var n = vec_len(es);
    var i = 0;
    while (i < n) {
        var e = vec_get(es, i);
        if (streq(load64(e), code) == 1) { return e; }
        i = i + 1;
    }
    return 0;
}

fn cognate_language_count(s) { return vec_len(load64(s + 24)); }

fn etymology_new(source_language, source_form, borrowing_type, period) {
    var e = alloc(32);
    store64(e, source_language);
    store64(e + 8, source_form);
    store64(e + 16, borrowing_type);
    store64(e + 24, period);
    return e;
}

fn etymology_source_language(e) { return load64(e); }
fn etymology_source_form(e) { return load64(e + 8); }
fn etymology_borrowing_type(e) { return load64(e + 16); }
fn etymology_period(e) { return load64(e + 24); }

# --- Pre-built cognate sets ----------------------------------------

# Water cognates across Indo-European languages.
fn cognate_water() {
    var s = _cognate_set_new("*wódr̥", "Proto-Indo-European", "water");
    _cognate_set_add(s, "en", "water", "ˈwɔːtər");
    _cognate_set_add(s, "de", "Wasser", "ˈvasɐ");
    _cognate_set_add(s, "ru", "вода", "vɐˈda");
    _cognate_set_add(s, "sa", "उदन्", "udán");
    _cognate_set_add(s, "el", "ύδωρ", "ˈiðor");
    return s;
}

# --- dialect.cyr ---

# src/dialect.cyr — language-variety overlays on a base inventory.
#
# Ported from rust-old/src/dialect.rs. Requires phoneme.cyr (apply) and
# allophone.cyr (AllophoneRule overrides).
#
# LanguageVariety (56B): [0]=code [8]=name [16]=parent [24]=kind
#   [32]=added_phonemes(vec) [40]=removed_phonemes(vec) [48]=allophone_overrides(vec)

# VarietyKind.Historical is omitted: its name would collide with the
# ScriptStatus.Historical enum constant (Cyrius enum variants share one flat
# symbol namespace). No pre-built variety uses it.
enum VarietyKind {
    Regional = 0;
    NationalStandard = 1;
    Sociolect = 2;
    Creole = 3;
}

fn _variety_new(code, name, parent, kind) {
    var v = alloc(56);
    store64(v, code);
    store64(v + 8, name);
    store64(v + 16, parent);
    store64(v + 24, kind);
    store64(v + 32, vec_new());
    store64(v + 40, vec_new());
    store64(v + 48, vec_new());
    return v;
}

fn _variety_add_added(v, ipa) { vec_push(load64(v + 32), ipa); return v; }
fn _variety_add_removed(v, ipa) { vec_push(load64(v + 40), ipa); return v; }
fn _variety_add_override(v, rule) { vec_push(load64(v + 48), rule); return v; }

fn dialect_code(v) { return load64(v); }
fn dialect_name(v) { return load64(v + 8); }
fn dialect_parent(v) { return load64(v + 16); }
fn dialect_kind(v) { return load64(v + 24); }
fn dialect_added(v) { return load64(v + 32); }
fn dialect_removed(v) { return load64(v + 40); }
fn dialect_overrides(v) { return load64(v + 48); }

# Does this variety add a phoneme not in the parent?
fn dialect_adds(v, ipa) {
    var added = load64(v + 32);
    var n = vec_len(added);
    var i = 0;
    while (i < n) {
        if (streq(vec_get(added, i), ipa) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Does this variety remove a phoneme from the parent?
fn dialect_removes(v, ipa) {
    var removed = load64(v + 40);
    var n = vec_len(removed);
    var i = 0;
    while (i < n) {
        if (streq(vec_get(removed, i), ipa) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Apply this variety's overlay to a parent inventory, producing a new inventory
# (parent phonemes minus removed, plus added as Mid/Central vowels).
fn dialect_apply(v, parent) {
    var inv = phoneme_builder_with_capacity(load64(v), load64(v + 8), 48);
    store64(inv + 24, phoneme_stress(parent));
    store64(inv + 32, phoneme_tones(parent));
    var dst = load64(inv + 16);
    var pph = phoneme_list(parent);
    var n = vec_len(pph);
    var i = 0;
    while (i < n) {
        var p = vec_get(pph, i);
        if (dialect_removes(v, phoneme_ipa(p)) == 0) { vec_push(dst, p); }
        i = i + 1;
    }
    var added = load64(v + 32);
    var m = vec_len(added);
    var j = 0;
    while (j < m) {
        var ipa = vec_get(added, j);
        if (phoneme_has(inv, ipa) == 0) {
            vec_push(dst, phoneme_vowel(ipa, Height.Mid, Backness.Central, 0));
        }
        j = j + 1;
    }
    return inv;
}

# --- Pre-built varieties -------------------------------------------

# British English (Received Pronunciation).
fn dialect_british_english() {
    var v = _variety_new("en-GB", "British English (RP)", "en", VarietyKind.NationalStandard);
    _variety_add_added(v, "ɒ");
    _variety_add_removed(v, "ɹ");
    _variety_add_override(v, _arule_new("t", "t", Environment.Intervocalic, 1));
    return v;
}

# --- script.cyr ---

# src/script.cyr — writing-system metadata, queryable by ISO 15924 code.
#
# Ported from rust-old/src/script/mod.rs.
#
# Script (64B): [0]=code [8]=name [16]=type [24]=direction [32]=status
#               [40]=attestation(cstr|0) [48]=unicode_ranges(vec) [56]=languages(vec)
# range (16B):  [0]=lo  [8]=hi

enum ScriptType {
    Alphabet = 0;
    Abugida = 1;
    Abjad = 2;
    Syllabary = 3;
    Logographic = 4;
    Mixed = 5;
}

enum Direction {
    LeftToRight = 0;
    RightToLeft = 1;
    TopToBottom = 2;
    Bidirectional = 3;
}

enum ScriptStatus {
    Living = 0;
    Limited = 1;
    Historical = 2;
}

fn _range_new(lo, hi) {
    var r = alloc(16);
    store64(r, lo);
    store64(r + 8, hi);
    return r;
}

fn _script_new(code, name, stype, dir, status, attestation) {
    var s = alloc(64);
    store64(s, code);
    store64(s + 8, name);
    store64(s + 16, stype);
    store64(s + 24, dir);
    store64(s + 32, status);
    store64(s + 40, attestation);
    store64(s + 48, vec_new());
    store64(s + 56, vec_new());
    return s;
}

fn _script_add_range(s, lo, hi) {
    vec_push(load64(s + 48), _range_new(lo, hi));
    return s;
}

fn _script_add_lang(s, code) {
    vec_push(load64(s + 56), code);
    return s;
}

fn script_code(s) { return load64(s); }
fn script_name(s) { return load64(s + 8); }
fn script_type(s) { return load64(s + 16); }
fn script_direction(s) { return load64(s + 24); }
fn script_status(s) { return load64(s + 32); }
fn script_attestation(s) { return load64(s + 40); }
fn script_unicode_ranges(s) { return load64(s + 48); }
fn script_languages(s) { return load64(s + 56); }

# Check whether a Unicode code point falls within this script's ranges.
fn script_contains_codepoint(s, cp) {
    var ranges = load64(s + 48);
    var n = vec_len(ranges);
    var i = 0;
    while (i < n) {
        var r = vec_get(ranges, i);
        if (cp >= load64(r) && cp <= load64(r + 8)) { return 1; }
        i = i + 1;
    }
    return 0;
}

# --- Pre-built script metadata -------------------------------------

fn script_latin() {
    var s = _script_new("Latn", "Latin", ScriptType.Alphabet, Direction.LeftToRight, ScriptStatus.Living, 0);
    _script_add_range(s, 0x0041, 0x005A);
    _script_add_range(s, 0x0061, 0x007A);
    _script_add_range(s, 0x00C0, 0x00FF);
    _script_add_range(s, 0x0100, 0x024F);
    _script_add_lang(s, "en");
    _script_add_lang(s, "fr");
    _script_add_lang(s, "es");
    _script_add_lang(s, "de");
    _script_add_lang(s, "pt");
    _script_add_lang(s, "it");
    return s;
}

fn script_arabic() {
    var s = _script_new("Arab", "Arabic", ScriptType.Abjad, Direction.RightToLeft, ScriptStatus.Living, 0);
    _script_add_range(s, 0x0600, 0x06FF);
    _script_add_range(s, 0x0750, 0x077F);
    _script_add_range(s, 0xFB50, 0xFDFF);
    _script_add_range(s, 0xFE70, 0xFEFF);
    _script_add_lang(s, "ar");
    _script_add_lang(s, "fa");
    _script_add_lang(s, "ur");
    return s;
}

fn script_devanagari() {
    var s = _script_new("Deva", "Devanagari", ScriptType.Abugida, Direction.LeftToRight, ScriptStatus.Living, 0);
    _script_add_range(s, 0x0900, 0x097F);
    _script_add_range(s, 0xA8E0, 0xA8FF);
    _script_add_lang(s, "hi");
    _script_add_lang(s, "sa");
    _script_add_lang(s, "mr");
    _script_add_lang(s, "ne");
    return s;
}

fn script_cjk() {
    var s = _script_new("Hani", "CJK Unified Ideographs", ScriptType.Logographic, Direction.LeftToRight, ScriptStatus.Living, 0);  #skip-lint
    _script_add_range(s, 0x4E00, 0x9FFF);
    _script_add_range(s, 0x3400, 0x4DBF);
    _script_add_range(s, 0x20000, 0x2A6DF);
    _script_add_lang(s, "zh");
    _script_add_lang(s, "ja");
    _script_add_lang(s, "ko");
    return s;
}

fn script_cyrillic() {
    var s = _script_new("Cyrl", "Cyrillic", ScriptType.Alphabet, Direction.LeftToRight, ScriptStatus.Living, 0);
    _script_add_range(s, 0x0400, 0x04FF);
    _script_add_range(s, 0x0500, 0x052F);
    _script_add_lang(s, "ru");
    _script_add_lang(s, "uk");
    _script_add_lang(s, "bg");
    _script_add_lang(s, "sr");
    return s;
}

fn script_hangul() {
    var s = _script_new("Hang", "Hangul", ScriptType.Alphabet, Direction.LeftToRight, ScriptStatus.Living, 0);
    _script_add_range(s, 0xAC00, 0xD7AF);
    _script_add_range(s, 0x1100, 0x11FF);
    _script_add_range(s, 0x3130, 0x318F);
    _script_add_lang(s, "ko");
    return s;
}

fn script_kana() {
    var s = _script_new("Kana", "Kana (Hiragana + Katakana)", ScriptType.Syllabary, Direction.LeftToRight, ScriptStatus.Living, 0);  #skip-lint
    _script_add_range(s, 0x3040, 0x309F);
    _script_add_range(s, 0x30A0, 0x30FF);
    _script_add_range(s, 0x31F0, 0x31FF);
    _script_add_lang(s, "ja");
    return s;
}

fn script_greek() {
    var s = _script_new("Grek", "Greek", ScriptType.Alphabet, Direction.LeftToRight, ScriptStatus.Living, 0);
    _script_add_range(s, 0x0370, 0x03FF);
    _script_add_range(s, 0x1F00, 0x1FFF);
    _script_add_lang(s, "el");
    return s;
}

fn script_cuneiform() {
    var s = _script_new("Xsux", "Cuneiform", ScriptType.Logographic, Direction.LeftToRight, ScriptStatus.Historical, "3400 BCE – 75 CE");  #skip-lint
    _script_add_range(s, 0x12000, 0x1237F);
    _script_add_range(s, 0x12400, 0x1247F);
    _script_add_range(s, 0x12480, 0x1254F);
    _script_add_lang(s, "sux");
    _script_add_lang(s, "akk");
    return s;
}

fn script_egyptian() {
    var s = _script_new("Egyp", "Egyptian Hieroglyphs", ScriptType.Logographic, Direction.RightToLeft, ScriptStatus.Historical, "3200 BCE – 400 CE");  #skip-lint
    _script_add_range(s, 0x13000, 0x1342F);
    _script_add_range(s, 0x13430, 0x1345F);
    _script_add_lang(s, "egy");
    return s;
}

# --- Lookup --------------------------------------------------------

# Look up a script by ISO 15924 code — Script ptr, or 0 if unregistered.
fn script_by_code(code) {
    if (streq(code, "Latn") == 1) { return script_latin(); }
    if (streq(code, "Arab") == 1) { return script_arabic(); }
    if (streq(code, "Deva") == 1) { return script_devanagari(); }
    if (streq(code, "Hani") == 1) { return script_cjk(); }
    if (streq(code, "Cyrl") == 1) { return script_cyrillic(); }
    if (streq(code, "Hang") == 1) { return script_hangul(); }
    if (streq(code, "Kana") == 1) { return script_kana(); }
    if (streq(code, "Grek") == 1) { return script_greek(); }
    if (streq(code, "Xsux") == 1) { return script_cuneiform(); }
    if (streq(code, "Egyp") == 1) { return script_egyptian(); }
    return 0;
}

# All registered ISO 15924 script codes — vec of cstrings.
fn script_all_codes() {
    var c = vec_new();
    vec_push(c, "Latn");
    vec_push(c, "Arab");
    vec_push(c, "Deva");
    vec_push(c, "Hani");
    vec_push(c, "Cyrl");
    vec_push(c, "Hang");
    vec_push(c, "Kana");
    vec_push(c, "Grek");
    vec_push(c, "Xsux");
    vec_push(c, "Egyp");
    return c;
}

# --- registry.cyr ---

# src/registry.cyr — central ISO 639 language lookup.
# Ported from rust-old/src/registry.rs. Maps codes -> LanguageInfo / phoneme
# inventory / primary script code. Needs phoneme.cyr + inventories.cyr.
#
# LanguageInfo (24B): [0]=code  [8]=name  [16]=scripts(vec of cstrings)

var _varna_langs = 0;   # vec of LanguageInfo ptrs, lazily built

fn _li_new(code, name, sc) {
    var li = alloc(24);
    store64(li, code);
    store64(li + 8, name);
    var sv = vec_new();
    vec_push(sv, sc);
    store64(li + 16, sv);
    return li;
}

fn registry_info_code(li) { return load64(li); }
fn registry_info_name(li) { return load64(li + 8); }
fn registry_info_scripts(li) { return load64(li + 16); }

fn _registry_build() {
    var r = vec_new();
    vec_push(r, _li_new("en", "English", "Latn"));
    vec_push(r, _li_new("sa", "Sanskrit", "Deva"));
    vec_push(r, _li_new("el", "Greek", "Grek"));
    vec_push(r, _li_new("yua", "Yucatec Maya", "Latn"));
    vec_push(r, _li_new("sw", "Swahili", "Latn"));
    vec_push(r, _li_new("yo", "Yoruba", "Latn"));
    vec_push(r, _li_new("zu", "Zulu", "Latn"));
    vec_push(r, _li_new("th", "Thai", "Thai"));
    vec_push(r, _li_new("vi", "Vietnamese", "Latn"));
    vec_push(r, _li_new("tl", "Tagalog", "Latn"));
    vec_push(r, _li_new("tr", "Turkish", "Latn"));
    vec_push(r, _li_new("fi", "Finnish", "Latn"));
    vec_push(r, _li_new("haw", "Hawaiian", "Latn"));
    vec_push(r, _li_new("nah", "Nahuatl", "Latn"));
    vec_push(r, _li_new("la", "Latin", "Latn"));
    vec_push(r, _li_new("ar", "Arabic", "Arab"));
    vec_push(r, _li_new("grc", "Koine Greek", "Grek"));
    vec_push(r, _li_new("lzh", "Literary Chinese", "Hani"));
    vec_push(r, _li_new("zh", "Mandarin Chinese", "Hani"));
    vec_push(r, _li_new("hi", "Hindi", "Deva"));
    vec_push(r, _li_new("bn", "Bengali", "Beng"));
    vec_push(r, _li_new("ta", "Tamil", "Taml"));
    vec_push(r, _li_new("ur", "Urdu", "Arab"));
    vec_push(r, _li_new("ja", "Japanese", "Kana"));
    vec_push(r, _li_new("es", "Spanish", "Latn"));
    vec_push(r, _li_new("fr", "French", "Latn"));
    vec_push(r, _li_new("de", "German", "Latn"));
    vec_push(r, _li_new("ru", "Russian", "Cyrl"));
    vec_push(r, _li_new("ko", "Korean", "Hang"));
    vec_push(r, _li_new("pt", "Portuguese", "Latn"));
    vec_push(r, _li_new("it", "Italian", "Latn"));
    vec_push(r, _li_new("nl", "Dutch", "Latn"));
    vec_push(r, _li_new("pl", "Polish", "Latn"));
    vec_push(r, _li_new("am", "Amharic", "Ethi"));
    vec_push(r, _li_new("ha", "Hausa", "Latn"));
    vec_push(r, _li_new("id", "Indonesian", "Latn"));
    vec_push(r, _li_new("fa", "Persian", "Arab"));
    vec_push(r, _li_new("he", "Hebrew", "Hebr"));
    vec_push(r, _li_new("ka", "Georgian", "Geor"));
    vec_push(r, _li_new("cs", "Czech", "Latn"));
    vec_push(r, _li_new("hu", "Hungarian", "Latn"));
    vec_push(r, _li_new("ro", "Romanian", "Latn"));
    vec_push(r, _li_new("my", "Burmese", "Mymr"));
    vec_push(r, _li_new("km", "Khmer", "Khmr"));
    vec_push(r, _li_new("so", "Somali", "Latn"));
    vec_push(r, _li_new("qu", "Quechua", "Latn"));
    vec_push(r, _li_new("gn", "Guarani", "Latn"));
    vec_push(r, _li_new("is", "Icelandic", "Latn"));
    vec_push(r, _li_new("wo", "Wolof", "Latn"));
    vec_push(r, _li_new("lo", "Lao", "Laoo"));
    vec_push(r, _li_new("mn", "Mongolian", "Cyrl"));
    return r;
}

fn registry_languages() {
    if (_varna_langs == 0) { _varna_langs = _registry_build(); }
    return _varna_langs;
}

# Look up a language by ISO 639 code — LanguageInfo ptr, or 0 if unknown.
fn registry_info(code) {
    var langs = registry_languages();
    var n = vec_len(langs);
    var i = 0;
    while (i < n) {
        var li = vec_get(langs, i);
        if (streq(registry_info_code(li), code) == 1) { return li; }
        i = i + 1;
    }
    return 0;
}

# All registered ISO 639 codes — vec of cstrings.
fn registry_all_codes() {
    var langs = registry_languages();
    var n = vec_len(langs);
    var codes = vec_new();
    var i = 0;
    while (i < n) {
        vec_push(codes, registry_info_code(vec_get(langs, i)));
        i = i + 1;
    }
    return codes;
}

# Primary script ISO 15924 code for a language, or 0 if unknown.
fn registry_primary_script_code(code) {
    var li = registry_info(code);
    if (li == 0) { return 0; }
    var sv = registry_info_scripts(li);
    if (vec_len(sv) == 0) { return 0; }
    return vec_get(sv, 0);
}

# Primary Script object for a language, or 0 if unknown / script unregistered.
# Requires src/script.cyr to be included before src/registry.cyr.
fn registry_primary_script(code) {
    var sc = registry_primary_script_code(code);
    if (sc == 0) { return 0; }
    return script_by_code(sc);
}

# Phoneme inventory for a language, or 0 if unavailable.
fn registry_phonemes(code) {
    if (streq(code, "en") == 1) { return phoneme_english(); }
    if (streq(code, "sa") == 1) { return phoneme_sanskrit(); }
    if (streq(code, "el") == 1) { return phoneme_greek(); }
    if (streq(code, "yua") == 1) { return phoneme_yucatec_maya(); }
    if (streq(code, "sw") == 1) { return phoneme_swahili(); }
