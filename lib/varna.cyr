    _sw_entry(lex, "شجرة", "ʃad͡ʒara", "tree", PartOfSpeech.Noun, 22);
    _sw_entry(lex, "ماء", "maːʔ", "water", PartOfSpeech.Noun, 23);
    _sw_entry(lex, "نار", "naːr", "fire", PartOfSpeech.Noun, 24);
    _sw_entry(lex, "شمس", "ʃams", "sun", PartOfSpeech.Noun, 25);
    return lex;
}

