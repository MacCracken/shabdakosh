# goonj.cyr -- bundled distribution
# Version: 2.0.0
# Generated by: cyrius distlib
# Do not edit -- rebuild with: cyrius distlib

# --- error.cyr ---

# error.cyr -- goonj error codes + shared tolerances
# Usage: included by build/test entry; do not `include` other src modules.
#
# Ports rust-old/src/error.rs (GoonjError enum). Rust carried a String
# payload per variant; Cyrius uses integer codes — functions return 0
# (ERR_NONE) on success or a negative code on failure. Diagnostic
# strings, where needed, come from goonj_err_name().

var ERR_NONE              = 0;
var ERR_INVALID_GEOMETRY  = (0 - 1);   # invalid room/wall geometry (too few vertices, etc.)
var ERR_INVALID_MATERIAL  = (0 - 2);   # invalid material params (absorption outside 0..1)
var ERR_INVALID_FREQUENCY = (0 - 3);   # invalid frequency (negative Hz, etc.)
var ERR_PROPAGATION_FAILED = (0 - 4);  # propagation computation failed
var ERR_COMPUTATION       = (0 - 5);   # general computation error (e.g. WAV export I/O)

# ================================================================
# Shared tolerances / sentinels (f64 bit patterns)
# ================================================================
# goonj's Rust source was f32; the Cyrius port is f64 throughout
# (hisab's HVec3 is f64-only). GOONJ_EPSILON preserves the f32::EPSILON
# guard thresholds the Rust code used, promoted to f64.
var GOONJ_EPSILON = 0x3E80000000000000;   # f32::EPSILON = 1.1920929e-7
var F64_NEG_INF   = 0xFFF0000000000000;   # -inf (pressure_to_db_spl of <=0 pressure)

# 1 if `code` is an error (negative), 0 otherwise.
fn goonj_is_err(code) {
    if (code < 0) { return 1; }
    return 0;
}

# Static name for an error code (for diagnostics / logging).
fn goonj_err_name(code) {
    if (code == ERR_NONE) { return "none"; }
    if (code == ERR_INVALID_GEOMETRY) { return "invalid geometry"; }
    if (code == ERR_INVALID_MATERIAL) { return "invalid material"; }
    if (code == ERR_INVALID_FREQUENCY) { return "invalid frequency"; }
    if (code == ERR_PROPAGATION_FAILED) { return "propagation failed"; }
    if (code == ERR_COMPUTATION) { return "computation error"; }
    return "unknown error";
}

# --- material.cyr ---

# material.cyr -- acoustic materials: frequency-dependent absorption /
# scattering (AcousticMaterial), wall transmission loss
# (WallConstruction), and the JCAL porous-absorber model (JcalMaterial).
#
# Ports rust-old/src/material.rs. f32 → f64. Rust's `serde` derive is
# dropped (no serde in Cyrius); the serde round-trip test is therefore
# omitted. String `name` is stored as a cstring pointer; the `[f32; 8]`
# absorption array is an inline 8×f64 block via manual struct layout.
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON), stdlib
# math/ganita (F64_*, f64_pow/sqrt/tanh/ln) and string (streq).

# 8 octave bands, 63 Hz – 8 kHz (ISO 3382-1).
enum NumBands { NUM_BANDS = 8 }

# AcousticMaterial inline layout: name ptr | 8×f64 absorption | scattering.
enum AmLayout {
    AM_NAME = 0,
    AM_ABS  = 8,    # offsets 8..72 (8 f64)
    AM_SCAT = 72,
    AM_SIZE = 80,
}

# Physics constants that aren't clean hundredths (f64 bit patterns).
var ETA       = 0x3EF2FAAE876767EE;   # 1.81e-5  dynamic viscosity of air
var PERM_MW   = 0x3E19C511DC3A41DF;   # 1.5e-9   mineral-wool thermal permeability
var PERM_FOAM = 0x3E29C511DC3A41DF;   # 3.0e-9   open-cell-foam thermal permeability

# n/100 and n/1000 as f64 — keeps absorption tables and loss factors
# readable (every value in material.rs is an exact hundredth/thousandth).
fn pct(n)   { return f64_div(f64_from(n), f64_from(100)); }
fn milli(n) { return f64_div(f64_from(n), f64_from(1000)); }

# log10(x) = ln(x) / ln(10)
fn _mat_log10(x) { return f64_div(f64_ln(x), F64_LN10); }

# Octave-band centre frequency (Hz) by index 0..7. All integers.
#must_use
fn frequency_band(i) {
    if (i == 0) { return f64_from(63); }
    if (i == 1) { return f64_from(125); }
    if (i == 2) { return f64_from(250); }
    if (i == 3) { return f64_from(500); }
    if (i == 4) { return f64_from(1000); }
    if (i == 5) { return f64_from(2000); }
    if (i == 6) { return f64_from(4000); }
    if (i == 7) { return f64_from(8000); }
    return 0;
}

# ================================================================
# AcousticMaterial
# ================================================================
fn am_name(m)              { return load64(m + AM_NAME); }
fn am_scattering(m)        { return load64(m + AM_SCAT); }
fn am_absorption_band(m, band) { return load64(m + AM_ABS + band * 8); }
fn _am_set_band(m, band, v)    { store64(m + AM_ABS + band * 8, v); return 0; }

# Build a material from a name, 8 absorption values, and scattering.
#must_use
fn _am_make(name, a0, a1, a2, a3, a4, a5, a6, a7, scattering) {
    var m = alloc(AM_SIZE);
    store64(m + AM_NAME, name);
    store64(m + AM_SCAT, scattering);
    _am_set_band(m, 0, a0);
    _am_set_band(m, 1, a1);
    _am_set_band(m, 2, a2);
    _am_set_band(m, 3, a3);
    _am_set_band(m, 4, a4);
    _am_set_band(m, 5, a5);
    _am_set_band(m, 6, a6);
    _am_set_band(m, 7, a7);
    return m;
}

# Absorption tables: pct(n) = n/100 per octave band (63 Hz … 8 kHz), then scattering.
#must_use
fn acoustic_material_concrete() {
    return _am_make("concrete", pct(1), pct(1), pct(1), pct(2), pct(2), pct(2), pct(3), pct(4), pct(10));
}
#must_use
fn acoustic_material_carpet() {
    return _am_make("carpet", pct(2), pct(8), pct(24), pct(57), pct(69), pct(71), pct(73), pct(73), pct(40));
}
#must_use
fn acoustic_material_glass() {
    return _am_make("glass", pct(35), pct(35), pct(25), pct(18), pct(12), pct(7), pct(4), pct(2), pct(5));
}
#must_use
fn acoustic_material_wood() {
    return _am_make("wood", pct(15), pct(15), pct(11), pct(10), pct(7), pct(6), pct(7), pct(7), pct(15));
}
#must_use
fn acoustic_material_curtain() {
    return _am_make("curtain", pct(3), pct(7), pct(31), pct(49), pct(75), pct(70), pct(65), pct(65), pct(50));
}
#must_use
fn acoustic_material_drywall() {
    return _am_make("drywall", pct(29), pct(29), pct(10), pct(5), pct(4), pct(7), pct(9), pct(9), pct(10));
}
#must_use
fn acoustic_material_tile() {
    return _am_make("tile", pct(1), pct(1), pct(1), pct(1), pct(1), pct(2), pct(2), pct(2), pct(5));
}

# Validated constructor: `absorption` is a pointer to 8 f64. Returns the
# material pointer, or 0 if any absorption value or the scattering
# coefficient is outside 0.0–1.0 (Rust's Result::Err path).
#must_use
fn acoustic_material_new(name, absorption, scattering) {
    var i = 0;
    while (i < NUM_BANDS) {
        var a = load64(absorption + i * 8);
        if (f64_lt(a, 0) == 1) { return 0; }
        if (f64_gt(a, F64_ONE) == 1) { return 0; }
        i = i + 1;
    }
    if (f64_lt(scattering, 0) == 1) { return 0; }
    if (f64_gt(scattering, F64_ONE) == 1) { return 0; }

    var m = alloc(AM_SIZE);
    store64(m + AM_NAME, name);
    store64(m + AM_SCAT, scattering);
    i = 0;
    while (i < NUM_BANDS) {
        _am_set_band(m, i, load64(absorption + i * 8));
        i = i + 1;
    }
    return m;
}

# Average absorption across all bands.
#must_use
fn average_absorption(m) {
    var sum = 0;
    var i = 0;
    while (i < NUM_BANDS) {
        sum = f64_add(sum, am_absorption_band(m, i));
        i = i + 1;
    }
    return f64_div(sum, f64_from(NUM_BANDS));
}

# Absorption at band index 0..7; 0.0 if out of range.
#must_use
fn absorption_at_band(m, band) {
    if (band < 0) { return 0; }
    if (band < NUM_BANDS) { return am_absorption_band(m, band); }
    return 0;
}

# ================================================================
# WallConstruction — sound transmission loss
# ================================================================
#derive(accessors)
struct WallConstruction { surface_density; critical_frequency; loss_factor; }

#must_use
fn wall_construction_new(surface_density, critical_frequency, loss_factor) {
    var w = alloc(sizeof(WallConstruction));
    WallConstruction_set_surface_density(w, surface_density);
    WallConstruction_set_critical_frequency(w, critical_frequency);
    WallConstruction_set_loss_factor(w, loss_factor);
    return w;
}

#must_use
fn wall_drywall_single() { return wall_construction_new(f64_from(10), f64_from(2500), milli(14)); }
#must_use
fn wall_drywall_double() { return wall_construction_new(f64_from(20), f64_from(2500), milli(20)); }
#must_use
fn wall_concrete_150mm() { return wall_construction_new(f64_from(350), f64_from(130), milli(10)); }
#must_use
fn wall_glass_6mm()      { return wall_construction_new(f64_from(15), f64_from(2000), milli(20)); }

# Sound Reduction Index (transmission loss, dB) at a frequency.
# Mass law below coincidence, Davy-style correction around/above it.
#must_use
fn transmission_loss_db(wall, frequency) {
    var m = WallConstruction_surface_density(wall);
    var fc = WallConstruction_critical_frequency(wall);
    var loss_factor = WallConstruction_loss_factor(wall);
    if (f64_le(frequency, 0) == 1) { return 0; }
    if (f64_le(m, 0) == 1) { return 0; }

    # Mass law: TL = 20·log10(π·f·m / ρ₀c₀) − 3, ρ₀c₀ ≈ 415.
    var mass_arg = f64_div(f64_mul(f64_mul(F64_PI, frequency), m), f64_from(415));
    var mass_law = f64_sub(f64_mul(f64_from(20), _mat_log10(mass_arg)), f64_from(3));

    var half_fc = f64_mul(fc, F64_HALF);
    var two_fc = f64_mul(fc, F64_TWO);

    if (f64_lt(frequency, half_fc) == 1) {
        # Below coincidence: pure mass law.
        return f64_max(mass_law, 0);
    }
    if (f64_lt(frequency, two_fc) == 1) {
        # Near coincidence: mass law + coincidence dip.
        var dip_inner = f64_add(loss_factor,
            f64_div(m, f64_mul(f64_from(485), f64_sqrt(frequency))));
        var coincidence_dip = f64_mul(f64_from(10), _mat_log10(dip_inner));
        return f64_max(f64_add(mass_law, coincidence_dip), 0);
    }
    # Above coincidence: mass law + damping-controlled increase.
    var above = f64_add(f64_add(mass_law,
        f64_mul(f64_from(10), _mat_log10(f64_max(loss_factor, milli(1))))), f64_from(5));
    return f64_max(above, 0);
}

# Transmission coefficient (energy ratio 0..1): τ = 10^(−TL/10).
#must_use
fn transmission_coefficient(wall, frequency) {
    var tl = transmission_loss_db(wall, frequency);
    return f64_pow(f64_from(10), f64_div(f64_neg(tl), f64_from(10)));
}

# ================================================================
# JcalMaterial — Johnson-Champoux-Allard-Lafarge porous model
# ================================================================
#derive(accessors)
struct JcalMaterial {
    flow_resistivity;
    porosity;
    tortuosity;
    viscous_length;
    thermal_length;
    thermal_permeability;
}

#must_use
fn jcal_material_new(flow_resistivity, porosity, tortuosity, viscous_length, thermal_length, thermal_permeability) {
    var j = alloc(sizeof(JcalMaterial));
    JcalMaterial_set_flow_resistivity(j, flow_resistivity);
    JcalMaterial_set_porosity(j, porosity);
    JcalMaterial_set_tortuosity(j, tortuosity);
    JcalMaterial_set_viscous_length(j, viscous_length);
    JcalMaterial_set_thermal_length(j, thermal_length);
    JcalMaterial_set_thermal_permeability(j, thermal_permeability);
    return j;
}

# Microns → meters: n·1e-6.
fn _microns(n) { return f64_div(f64_from(n), f64_from(1000000)); }

#must_use
fn jcal_mineral_wool() {
    return jcal_material_new(f64_from(30000), pct(97), pct(106), _microns(100), _microns(200), PERM_MW);
}
#must_use
fn jcal_open_cell_foam() {
    return jcal_material_new(f64_from(10000), pct(98), pct(102), _microns(150), _microns(300), PERM_FOAM);
}

# Surface impedance magnitude normalized to ρ₀c₀, for a rigid-backed
# layer of given thickness. Returns 1.0 for degenerate inputs.
#must_use
fn jcal_surface_impedance_magnitude(mat, frequency, thickness) {
    var phi = JcalMaterial_porosity(mat);
    if (f64_le(frequency, 0) == 1) { return F64_ONE; }
    if (f64_le(thickness, 0) == 1) { return F64_ONE; }
    if (f64_le(phi, 0) == 1) { return F64_ONE; }

    var omega = f64_mul(F64_TAU, frequency);
    var sigma = JcalMaterial_flow_resistivity(mat);
    var alpha_inf = JcalMaterial_tortuosity(mat);
    var lambda_v = JcalMaterial_viscous_length(mat);
    var lambda_t = JcalMaterial_thermal_length(mat);

    var rho_0 = pct(121);          # 1.21 kg/m³
    var c_0 = f64_from(343);       # 343 m/s
    var gamma = pct(140);          # 1.4
    var p_0 = f64_from(101325);    # 101325 Pa
    var pr = pct(71);              # 0.71 Prandtl number

    # Johnson effective density (viscous), magnitude approximation.
    var visc_ratio = f64_div(f64_mul(sigma, phi), f64_mul(f64_mul(omega, rho_0), alpha_inf));
    var lambda_term = 0;
    if (f64_gt(lambda_v, 0) == 1) {
        var num = f64_mul(f64_mul(f64_mul(f64_from(4), omega), rho_0),
            f64_mul(f64_mul(alpha_inf, alpha_inf), ETA));
        var den = f64_mul(f64_mul(f64_mul(sigma, sigma), f64_mul(phi, phi)),
            f64_mul(lambda_v, lambda_v));
        lambda_term = f64_div(num, den);
    }
    var inner = f64_sqrt(f64_add(F64_ONE, lambda_term));
    var g_visc = f64_sqrt(f64_sqrt(f64_add(F64_ONE,
        f64_mul(f64_mul(visc_ratio, visc_ratio), f64_mul(inner, inner)))));
    var rho_eff_mag = f64_div(f64_mul(f64_mul(rho_0, alpha_inf), g_visc), phi);

    # Champoux-Allard-Lafarge bulk modulus (thermal).
    var thermal_ratio = 0;
    if (f64_gt(lambda_t, 0) == 1) {
        var kappa = milli(26);     # 0.026 thermal conductivity
        var c_p = f64_from(1005);  # 1005 specific heat
        var num2 = f64_mul(f64_from(8), kappa);
        var den2 = f64_mul(f64_mul(f64_mul(lambda_t, lambda_t), c_p),
            f64_mul(f64_mul(rho_0, pr), omega));
        thermal_ratio = f64_div(num2, den2);
    }
    var thermal_factor = f64_sqrt(f64_add(F64_ONE, f64_mul(thermal_ratio, thermal_ratio)));
    var denom = f64_sub(gamma, f64_div(f64_sub(gamma, F64_ONE), thermal_factor));
    var k_eff_mag = 0;
    if (f64_gt(f64_abs(denom), GOONJ_EPSILON) == 1) {
        k_eff_mag = f64_div(f64_mul(gamma, p_0), f64_mul(phi, denom));
    } else {
        k_eff_mag = f64_div(f64_mul(gamma, p_0), phi);
    }

    var z_c = f64_sqrt(f64_mul(rho_eff_mag, k_eff_mag));
    var k_mag = f64_mul(omega, f64_sqrt(f64_div(rho_eff_mag, k_eff_mag)));

    # Surface impedance of rigid-backed layer: |Z_s| ≈ Z_c / |tanh(k·d)|.
    var kd = f64_mul(k_mag, thickness);
    var tanh_kd = f64_max(f64_abs(f64_tanh(kd)), pct(1));
    var z_s = f64_div(z_c, tanh_kd);

    var rho_c = f64_mul(rho_0, c_0);
    return f64_max(f64_div(z_s, rho_c), pct(1));
}

# Normal-incidence absorption coefficient (0..1) for a layer.
#must_use
fn jcal_absorption_coefficient(mat, frequency, thickness) {
    var z_norm = jcal_surface_impedance_magnitude(mat, frequency, thickness);
    var r = f64_abs(f64_div(f64_sub(z_norm, F64_ONE), f64_add(z_norm, F64_ONE)));
    return f64_clamp(f64_sub(F64_ONE, f64_mul(r, r)), 0, F64_ONE);
}

# --- propagation.cyr ---

# propagation.cyr -- sound propagation: speed of sound, inverse-square
# law, SPL/pressure conversions, atmospheric absorption, Doppler, and
# ground reflection (Miki 1990).
#
# Ports rust-old/src/propagation.rs. f32 → f64 throughout (hisab is
# f64-only). Vec3 wind/temperature profiles use hisab's HVec3. The Rust
# `speed_fn` closure (a captured `impl Fn(f32)->f32`) becomes the
# fn-pointer + context-pointer pattern: refract_ray_step takes
# `(speed_fn, ctx)` and calls `fncall2(speed_fn, ctx, height)`;
# trace_ray_atmospheric threads a mutable TraceCtx (wind, temp, dir).
#
# Self-contained: no `include` lines. Relies on error.cyr (GOONJ_EPSILON,
# F64_NEG_INF) and stdlib math/ganita (F64_PI, F64_ONE, F64_LN10,
# f64_pow/exp/ln/sqrt/sin/…) being present in the build/test unit.

# ================================================================
# Constants (f64 bit patterns; decimal in comments for traceability)
# ================================================================
var C_SOUND_BASE   = 0x4074B4CCCCCCCCCD;   # 331.3   m/s at 0 °C
var C_SOUND_TCOEFF = 0x3FE3645A1CAC0831;   # 0.606   m/s per °C
var KELVIN_OFFSET  = 0x4071126666666666;   # 273.15  °C → K
var T_REF_K        = 0x4072526666666666;   # 293.15  K (20 °C reference)
var T_TRIPLE       = 0x4071128F5C28F5C3;   # 273.16  K (triple point of water)
var CSAT_A         = 0xC01B56A161E4F766;   # -6.8346
var CSAT_EXP       = 0x3FF42D0E56041893;   # 1.261
var CSAT_B         = 0x401275DCC63F1412;   # 4.6151
var FRO2_B         = 0x40E3BA0000000000;   # 4.04e4
var FRO2_C         = 0x3F947AE147AE147B;   # 0.02
var FRO2_D         = 0x3FD90624DD2F1AA0;   # 0.391
var FRN2_C         = 0xC010AE147AE147AE;   # -4.17
var ONE_THIRD      = 0x3FD5555555555555;   # 0.3333333333333333
var ALPHA_A        = 0x3DB43B23BAF4CD2D;   # 1.84e-11
var T_EXP          = 0xC004000000000000;   # -2.5
var O2_COEFF       = 0x3F8A1CAC083126E9;   # 0.01275
var O2_EXPNUM      = 0xC0A17E3333333333;   # -2239.1
var N2_COEFF       = 0x3FBB573EAB367A10;   # 0.10680
var N2_EXPNUM      = 0xC0AA300000000000;   # -3352.0
var NP_TO_DB       = 0x40215F3B645A1CAC;   # 8.686   (1 Np = 8.686 dB)
var P_REF          = 0x3EF4F8B588E368F1;   # 2.0e-5  Pa (20 µPa reference)
var MIKI_ZR        = 0x3FB1E4F765FD8ADB;   # 0.0699
var MIKI_EXP       = 0xBFE4395810624DD3;   # -0.632
var MIKI_ZI        = 0xBFBB6AE7D566CF42;   # -0.1071

# log10(x) = ln(x) / ln(10)
fn _prop_log10(x) {
    return f64_div(f64_ln(x), F64_LN10);
}

# ================================================================
# Speed of sound: c = 331.3 + 0.606 * T(°C)
# ================================================================
#must_use
fn speed_of_sound(temperature_celsius) {
    return f64_add(C_SOUND_BASE, f64_mul(C_SOUND_TCOEFF, temperature_celsius));
}

# Sound intensity at distance via inverse-square law: I = P / (4π r²).
#must_use
fn inverse_square_law(power, distance) {
    if (f64_le(distance, 0) == 1) { return 0; }
    var denom = f64_mul(f64_mul(f64_from(4), F64_PI), f64_mul(distance, distance));
    return f64_div(power, denom);
}

# SPL drop with distance (dB): ΔL = 20·log10(r2/r1).
#must_use
fn spl_drop_with_distance(distance_ref, distance) {
    if (f64_le(distance_ref, 0) == 1) { return 0; }
    if (f64_le(distance, 0) == 1) { return 0; }
    return f64_mul(f64_from(20), _prop_log10(f64_div(distance, distance_ref)));
}

# ================================================================
# Atmospheric absorption (ISO 9613-1 / ANSI S1.26), dB/m.
# Valid: 50 Hz–10 kHz, −20–+50 °C, 10–100 % RH.
# ================================================================
#must_use
fn atmospheric_absorption(frequency_hz, humidity_percent, temperature_celsius, pressure_atm) {
    if (f64_le(frequency_hz, 0) == 1) { return 0; }
    if (f64_le(humidity_percent, 0) == 1) { return 0; }
    if (f64_le(pressure_atm, 0) == 1) { return 0; }

    var t_kelvin = f64_max(f64_add(temperature_celsius, KELVIN_OFFSET), F64_ONE);
    var f = frequency_hz;
    var p_rel = pressure_atm;

    # Molar concentration of water vapour from relative humidity.
    var t01_ratio = f64_div(T_TRIPLE, t_kelvin);
    var c_sat = f64_add(f64_mul(CSAT_A, f64_pow(t01_ratio, CSAT_EXP)), CSAT_B);
    var h = f64_div(f64_mul(humidity_percent, f64_pow(f64_from(10), c_sat)), p_rel);

    # Oxygen relaxation frequency.
    var o2_inner = f64_div(f64_mul(f64_mul(FRO2_B, h), f64_add(FRO2_C, h)), f64_add(FRO2_D, h));
    var fr_o2 = f64_mul(p_rel, f64_add(f64_from(24), o2_inner));

    # Nitrogen relaxation frequency.
    var tref_ratio = f64_div(T_REF_K, t_kelvin);
    var n2_exp_arg = f64_mul(FRN2_C, f64_sub(f64_pow(tref_ratio, ONE_THIRD), F64_ONE));
    var n2_inner = f64_mul(f64_mul(f64_from(280), h), f64_exp(n2_exp_arg));
    var fr_n2 = f64_mul(f64_mul(p_rel, f64_sqrt(tref_ratio)), f64_add(f64_from(9), n2_inner));

    var f2 = f64_mul(f, f);
    var t_ratio = f64_div(t_kelvin, T_REF_K);

    # Classical + rotational term.
    var classical = f64_mul(f64_mul(ALPHA_A, f64_div(F64_ONE, p_rel)), f64_sqrt(t_ratio));

    # O2 and N2 relaxation terms.
    var o2_term = f64_div(
        f64_mul(f64_mul(O2_COEFF, f64_exp(f64_div(O2_EXPNUM, t_kelvin))), fr_o2),
        f64_add(f64_mul(fr_o2, fr_o2), f2));
    var n2_term = f64_div(
        f64_mul(f64_mul(N2_COEFF, f64_exp(f64_div(N2_EXPNUM, t_kelvin))), fr_n2),
        f64_add(f64_mul(fr_n2, fr_n2), f2));

    var relax = f64_mul(f64_pow(t_ratio, T_EXP), f64_add(o2_term, n2_term));
    var alpha = f64_mul(f2, f64_add(classical, relax));

    # Nepers/m → dB/m, clamp at 0.
    return f64_max(f64_mul(alpha, NP_TO_DB), 0);
}

# ================================================================
# Doppler-shifted frequency: f' = f·(c + v_listener)/(c + v_source)
# ================================================================
#must_use
fn doppler_shift(source_frequency, source_velocity, listener_velocity, c_sound) {
    var denom = f64_add(c_sound, source_velocity);
    if (f64_lt(f64_abs(denom), GOONJ_EPSILON) == 1) { return source_frequency; }
    return f64_div(f64_mul(source_frequency, f64_add(c_sound, listener_velocity)), denom);
}

# dB SPL → pressure (Pa): p = p_ref · 10^(dB/20), p_ref = 20 µPa.
#must_use
fn db_spl_to_pressure(db_spl) {
    return f64_mul(P_REF, f64_pow(f64_from(10), f64_div(db_spl, f64_from(20))));
}

# pressure (Pa) → dB SPL: dB = 20·log10(p/p_ref). Returns −inf for p≤0.
#must_use
fn pressure_to_db_spl(pressure_pa) {
    if (f64_le(pressure_pa, 0) == 1) { return F64_NEG_INF; }
    return f64_mul(f64_from(20), _prop_log10(f64_div(pressure_pa, P_REF)));
}

# ================================================================
# Ground impedance (flow resistivity, Pa·s/m²) + Miki (1990) model.
# ================================================================
#derive(accessors)
struct GroundImpedance { flow_resistivity; }

#must_use
fn ground_impedance_new(flow_resistivity) {
    var g = alloc(sizeof(GroundImpedance));
    GroundImpedance_set_flow_resistivity(g, flow_resistivity);
    return g;
}
#must_use
fn ground_impedance_grass()     { return ground_impedance_new(f64_from(200000)); }
#must_use
fn ground_impedance_hard_soil() { return ground_impedance_new(f64_from(2000000)); }
#must_use
fn ground_impedance_asphalt()   { return ground_impedance_new(f64_from(20000000)); }

# Ground reflection coefficient magnitude (0..1) via the Miki (1990) model.
#must_use
fn ground_reflection_coefficient(frequency_hz, grazing_angle_rad, impedance) {
    var resistivity = GroundImpedance_flow_resistivity(impedance);
    if (f64_le(frequency_hz, 0) == 1) { return F64_ONE; }
    if (f64_le(resistivity, 0) == 1) { return F64_ONE; }

    var x = f64_div(frequency_hz, resistivity);
    var x_pow = f64_pow(x, MIKI_EXP);
    var z_real = f64_add(F64_ONE, f64_mul(MIKI_ZR, x_pow));
    var z_imag = f64_mul(MIKI_ZI, x_pow);

    var sin_theta = f64_sin(grazing_angle_rad);
    var num_real = f64_sub(f64_mul(z_real, sin_theta), F64_ONE);
    var num_imag = f64_mul(z_imag, sin_theta);
    var den_real = f64_add(f64_mul(z_real, sin_theta), F64_ONE);
    var den_imag = f64_mul(z_imag, sin_theta);

    var num_mag2 = f64_add(f64_mul(num_real, num_real), f64_mul(num_imag, num_imag));
    var den_mag2 = f64_add(f64_mul(den_real, den_real), f64_mul(den_imag, den_imag));

    if (f64_lt(den_mag2, GOONJ_EPSILON) == 1) { return F64_ONE; }
    return f64_clamp(f64_sqrt(f64_div(num_mag2, den_mag2)), 0, F64_ONE);
}

# ================================================================
# Atmospheric profiles (Vec3-based) — requires hisab HVec3.
# ================================================================

# Wind profile: `direction` is an HVec3 pointer (normalized direction),
# speed_ground in m/s, gradient in (m/s)/m.
#derive(accessors)
struct WindProfile { direction; speed_ground; gradient; }

# Temperature profile: ground temperature in °C, lapse rate in °C/m
# (negative = inversion).
#derive(accessors)
struct TemperatureProfile { ground_temp_celsius; lapse_rate; }

#must_use
fn wind_profile_new(direction, speed_ground, gradient) {
    var w = alloc(sizeof(WindProfile));
    WindProfile_set_direction(w, direction);
    WindProfile_set_speed_ground(w, speed_ground);
    WindProfile_set_gradient(w, gradient);
    return w;
}

#must_use
fn temperature_profile_new(ground_temp_celsius, lapse_rate) {
    var t = alloc(sizeof(TemperatureProfile));
    TemperatureProfile_set_ground_temp_celsius(t, ground_temp_celsius);
    TemperatureProfile_set_lapse_rate(t, lapse_rate);
    return t;
}

# Effective speed of sound at height, accounting for wind:
# c_eff = base + wind_speed(height) · cos(angle between wind & ray).
#must_use
fn refracted_speed(base_speed, wind, ray_direction, height) {
    var wind_speed = f64_add(WindProfile_speed_ground(wind),
        f64_mul(WindProfile_gradient(wind), height));
    var cos_angle = hvec3_dot(WindProfile_direction(wind), ray_direction);
    return f64_add(base_speed, f64_mul(wind_speed, cos_angle));
}

# Speed of sound at height, from the temperature gradient.
#must_use
fn speed_at_height(profile, height) {
    var temp = f64_add(TemperatureProfile_ground_temp_celsius(profile),
        f64_mul(TemperatureProfile_lapse_rate(profile), height));
    return speed_of_sound(temp);
}

# ================================================================
# Stratified-atmosphere ray refraction (Snell's law).
# ================================================================

# Result of one refraction step: new origin + new direction (HVec3 ptrs).
# Replaces Rust's `(Vec3, Vec3)` tuple return.
#derive(accessors)
struct RayStep { origin; direction; }

#must_use
fn _ray_step_make(origin, direction) {
    var rs = alloc(sizeof(RayStep));
    RayStep_set_origin(rs, origin);
    RayStep_set_direction(rs, direction);
    return rs;
}

# Advance a ray one step through a stratified medium, bending its
# direction per Snell's law from the local speed gradient.
#   speed_fn : fn(ctx, height) -> f64   (ctx may be 0 if unused)
# Returns a RayStep.
#must_use
fn refract_ray_step(origin, direction, speed_fn, ctx, step_size) {
    var height = HVec3_y(origin);
    var c_current = fncall2(speed_fn, ctx, height);

    var new_origin = hvec3_add(origin, hvec3_scale(direction, step_size));
    var new_height = HVec3_y(new_origin);
    var c_new = fncall2(speed_fn, ctx, new_height);

    if (f64_lt(f64_abs(c_current), GOONJ_EPSILON) == 1) {
        return _ray_step_make(new_origin, direction);
    }

    # Horizontal component is conserved; adjust the vertical part.
    var horizontal = hvec3_new(HVec3_x(direction), 0, HVec3_z(direction));
    var h_len = hvec3_length(horizontal);
    if (f64_lt(h_len, GOONJ_EPSILON) == 1) {
        # Purely vertical ray — no refraction.
        return _ray_step_make(new_origin, direction);
    }

    var sin_ratio = f64_div(h_len, c_current);
    var new_sin = f64_mul(sin_ratio, c_new);
    if (f64_ge(new_sin, F64_ONE) == 1) {
        # Total internal reflection — ray turns horizontal.
        return _ray_step_make(new_origin, hvec3_scale(horizontal, f64_div(F64_ONE, h_len)));
    }

    var new_cos = f64_sqrt(f64_sub(F64_ONE, f64_mul(new_sin, new_sin)));
    var vert_sign = F64_ONE;
    if (f64_lt(HVec3_y(direction), 0) == 1) { vert_sign = f64_neg(F64_ONE); }
    var nd = hvec3_new(
        f64_mul(f64_div(HVec3_x(direction), h_len), new_sin),
        f64_mul(vert_sign, new_cos),
        f64_mul(f64_div(HVec3_z(direction), h_len), new_sin));

    var len = hvec3_length(nd);
    var new_dir = direction;
    if (f64_gt(len, GOONJ_EPSILON) == 1) { new_dir = hvec3_scale(nd, f64_div(F64_ONE, len)); }
    return _ray_step_make(new_origin, new_dir);
}

# Context for the atmospheric speed callback: captures the wind and
# temperature profiles plus the current ray direction (mutated per step).
#derive(accessors)
struct TraceCtx { wind; temp; current_dir; }

# Speed callback for trace_ray_atmospheric — the ported `speed_fn` closure.
#must_use
fn _trace_speed_fn(ctx, h) {
    var base = speed_at_height(TraceCtx_temp(ctx), h);
    return refracted_speed(base, TraceCtx_wind(ctx), TraceCtx_current_dir(ctx), h);
}

# Trace a ray through a stratified atmosphere; returns a vec of HVec3
# positions (the path). Replaces Rust's `Vec<Vec3>`.
#must_use
fn trace_ray_atmospheric(source, direction, wind, temp, max_distance, step_size) {
    var path = vec_new();
    var len = hvec3_length(direction);
    if (f64_le(len, GOONJ_EPSILON) == 1) {
        vec_push(path, source);
        return path;
    }
    var dir = hvec3_scale(direction, f64_div(F64_ONE, len));
    var pos = source;

    # max_iterations = min((max_distance / max(step_size, 0.001)) as u32, 1_000_000)
    var step_floor = f64_max(step_size, f64_div(F64_ONE, f64_from(1000)));
    var max_iter = f64_to(f64_div(max_distance, step_floor));
    if (max_iter > 1000000) { max_iter = 1000000; }

    vec_push(path, pos);
    var total_distance = 0;
    var iteration = 0;

    var ctx = alloc(sizeof(TraceCtx));
    TraceCtx_set_wind(ctx, wind);
    TraceCtx_set_temp(ctx, temp);

    var go = 1;
    while (go == 1) {
        if (f64_ge(total_distance, max_distance) == 1) { go = 0; }
        if (iteration >= max_iter) { go = 0; }
        if (go == 1) {
            iteration = iteration + 1;
            var step = f64_min(step_size, f64_sub(max_distance, total_distance));
            TraceCtx_set_current_dir(ctx, dir);
            var rs = refract_ray_step(pos, dir, &_trace_speed_fn, ctx, step);
            var new_pos = RayStep_origin(rs);
            if (f64_lt(HVec3_y(new_pos), 0) == 1) {
                # Ray crosses the ground: interpolate to y = 0 and stop.
                if (f64_gt(f64_abs(HVec3_y(dir)), GOONJ_EPSILON) == 1) {
                    var t = f64_div(f64_neg(HVec3_y(pos)), HVec3_y(dir));
                    var ground = hvec3_add(pos, hvec3_scale(dir, f64_max(t, 0)));
                    vec_push(path, ground);
                }
                go = 0;
            } else {
                pos = new_pos;
                dir = RayStep_direction(rs);
                total_distance = f64_add(total_distance, step);
                vec_push(path, pos);
            }
        }
    }
    return path;
}

# --- resonance.cyr ---

# resonance.cyr -- room resonance: axial modes, Schroeder frequency,
# modal density.
#
# Ports rust-old/src/resonance.rs. f32 → f64. The Rust `Vec<f32>` returns
# (axial_modes, all_axial_modes) become stdlib `vec` handles holding f64
# bit patterns (8 bytes each — an f64 stores directly as the i64 slot).
# Establishes the dynamic-array idiom for the rest of the port.
#
# Requires (from the build/test unit): stdlib math (F64_PI, F64_TWO) and
# vec (vec_new/push/len/get/set); alloc_init() must have run.

# Axial room-mode frequency for one dimension: f_n = n·c / (2·L).
# Returns 0 for non-positive length or mode number 0.
#must_use
fn room_mode(dimension_length, mode_number, speed_of_sound) {
    if (f64_le(dimension_length, 0) == 1) { return 0; }
    if (mode_number == 0) { return 0; }
    return f64_div(f64_mul(f64_from(mode_number), speed_of_sound),
        f64_mul(F64_TWO, dimension_length));
}

# Push every axial mode of `dim` below `max_frequency` onto `dst`.
fn _append_axial_modes(dst, dim, max_frequency, speed_of_sound) {
    var n = 1;
    var go = 1;
    while (go == 1) {
        var f = room_mode(dim, n, speed_of_sound);
        if (f64_gt(f, max_frequency) == 1) { go = 0; }
        if (f64_le(f, 0) == 1) { go = 0; }
        if (go == 1) {
            vec_push(dst, f);
            n = n + 1;
        }
    }
    return 0;
}

# All axial modes for one dimension below max_frequency (ascending by n).
#must_use
fn axial_modes(dimension_length, max_frequency, speed_of_sound) {
    var modes = vec_new();
    _append_axial_modes(modes, dimension_length, max_frequency, speed_of_sound);
    return modes;
}

# Ascending insertion sort of a vec by f64 value.
fn _vec_sort_f64(v) {
    var n = vec_len(v);
    var i = 1;
    while (i < n) {
        var key = vec_get(v, i);
        var j = i - 1;
        var go = 1;
        while (go == 1) {
            if (j < 0) { go = 0; }
            if (go == 1) {
                if (f64_gt(vec_get(v, j), key) == 1) {
                    vec_set(v, j + 1, vec_get(v, j));
                    j = j - 1;
                } else {
                    go = 0;
                }
            }
        }
        vec_set(v, j + 1, key);
        i = i + 1;
    }
    return 0;
}

# All axial modes for a shoebox (length, width, height) below
# max_frequency, sorted ascending.
#must_use
fn all_axial_modes(length, width, height, max_frequency, speed_of_sound) {
    var modes = vec_new();
    _append_axial_modes(modes, length, max_frequency, speed_of_sound);
    _append_axial_modes(modes, width, max_frequency, speed_of_sound);
    _append_axial_modes(modes, height, max_frequency, speed_of_sound);
    _vec_sort_f64(modes);
    return modes;
}

# Schroeder frequency: f_s = 2000·√(RT60 / V). Modal below, diffuse above.
#must_use
fn schroeder_frequency(rt60, volume) {
    if (f64_le(volume, 0) == 1) { return 0; }
    if (f64_le(rt60, 0) == 1) { return 0; }
    return f64_mul(f64_from(2000), f64_sqrt(f64_div(rt60, volume)));
}

# Modal density (modes per Hz): n(f) = 4π·V·f² / c³.
#must_use
fn modal_density(frequency, volume, speed_of_sound) {
    if (f64_le(speed_of_sound, 0) == 1) { return 0; }
    var c3 = f64_mul(f64_mul(speed_of_sound, speed_of_sound), speed_of_sound);
    var numer = f64_mul(f64_mul(f64_mul(f64_from(4), F64_PI), volume),
        f64_mul(frequency, frequency));
    return f64_div(numer, c3);
}

# --- ambisonics.cyr ---

# ambisonics.cyr -- Ambisonics encoding: spatial sound-field
# representation. B-Format (1st order) and Higher-Order Ambisonics
# (up to 3rd order) encode a direction (HVec3) into channel gains via
# real spherical harmonics (ACN ordering, SN3D normalization).
#
# Ports rust-old/src/ambisonics.rs. f32 -> f64 throughout (hisab is
# f64-only). Rust's `serde` derive is dropped (no serde in Cyrius); the
# serde round-trip test is therefore omitted. The `Vec<f32>` channels
# (BFormatIr) and `Vec<Vec<f32>>` channel set (HoaIr) become stdlib `vec`
# handles holding f64 bit patterns / nested vec pointers. The fixed
# `[f32; 16]` spherical-harmonic array becomes a 16-slot f64 buffer.
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON), stdlib
# math/ganita (F64_ONE/TWO/HALF, f64_*, f64_sin/cos/acos/atan2/sqrt),
# vec (vec_new/push/len/get/set), and hisab (hvec3_*, HVec3_x/y/z).
# alloc_init() must have run.

# Maximum supported order and the (3+1)^2 = 16 channel count.
enum HoaConst {
    MAX_HOA_ORDER    = 3,
    MAX_HOA_CHANNELS = 16,
}

# ================================================================
# IR structs
# ================================================================
# 1st-order Ambisonics (B-Format) IR: W, X, Y, Z channels (each a vec
# of f64 samples) + sample rate (Hz).
#derive(accessors)
struct BFormatIr { w; x; y; z; sample_rate; }

# 3rd-order Ambisonics IR: ACN-ordered channels (vec of vecs) + order +
# sample rate (Hz).
#derive(accessors)
struct HoaIr { channels; order; sample_rate; }

# A vec of `n` zero samples (0 == +0.0 bit pattern).
#must_use
fn _zeros_vec(n) {
    var v = vec_new();
    var i = 0;
    while (i < n) {
        vec_push(v, 0);
        i = i + 1;
    }
    return v;
}

# ================================================================
# B-Format (1st order) encoding
# ================================================================
# Encode a single reflection into B-Format (1st-order Ambisonics).
# W receives the amplitude directly; X/Y/Z receive amplitude scaled by
# the direction cosines (SN3D/ACN AmbiX: W = 1.0, X/Y/Z = cosines).
fn encode_bformat(amplitude, direction, delay_samples, ir) {
    if (delay_samples >= vec_len(BFormatIr_w(ir))) { return 0; }
    if (f64_lt(f64_abs(amplitude), GOONJ_EPSILON) == 1) { return 0; }

    var w = BFormatIr_w(ir);
    var x = BFormatIr_x(ir);
    var y = BFormatIr_y(ir);
    var z = BFormatIr_z(ir);
    vec_set(w, delay_samples, f64_add(vec_get(w, delay_samples), amplitude));
    vec_set(x, delay_samples, f64_add(vec_get(x, delay_samples), f64_mul(amplitude, HVec3_x(direction))));
    vec_set(y, delay_samples, f64_add(vec_get(y, delay_samples), f64_mul(amplitude, HVec3_y(direction))));
    vec_set(z, delay_samples, f64_add(vec_get(z, delay_samples), f64_mul(amplitude, HVec3_z(direction))));
    return 0;
}

# ================================================================
# Higher-Order Ambisonics encoding
# ================================================================
# Encode a single reflection into HOA (ACN/SN3D). Computes real
# spherical-harmonic coefficients up to the IR's order.
fn encode_hoa(amplitude, direction, delay_samples, ir) {
    var order = HoaIr_order(ir);
    var num_channels = (order + 1) * (order + 1);
    var channels = HoaIr_channels(ir);

    var first_len = 0;
    if (vec_len(channels) > 0) { first_len = vec_len(vec_get(channels, 0)); }
    if (delay_samples >= first_len) { return 0; }
    if (f64_lt(f64_abs(amplitude), GOONJ_EPSILON) == 1) { return 0; }
    if (vec_len(channels) < num_channels) { return 0; }

    # Direction -> spherical coordinates.
    var r = hvec3_length(direction);
    if (f64_lt(r, GOONJ_EPSILON) == 1) { return 0; }
    var theta = f64_acos(f64_div(HVec3_z(direction), r));     # inclination from +Z
    var phi = f64_atan2(HVec3_y(direction), HVec3_x(direction)); # azimuth from +X

    var sh = spherical_harmonics(order, theta, phi);
    # Iterate over the 16 SH entries, taking the first num_channels.
    var limit = num_channels;
    if (limit > MAX_HOA_CHANNELS) { limit = MAX_HOA_CHANNELS; }
    var ch = 0;
    while (ch < limit) {
        if (ch < vec_len(channels)) {
            var chan = vec_get(channels, ch);
            var coeff = load64(sh + ch * 8);
            vec_set(chan, delay_samples, f64_add(vec_get(chan, delay_samples), f64_mul(amplitude, coeff)));
        }
        ch = ch + 1;
    }
    return 0;
}

# ================================================================
# Real spherical harmonics (ACN ordering, SN3D normalization)
# ================================================================
# Compute real spherical harmonics up to `order` into a fresh 16-slot
# f64 buffer (zero-filled above the requested order). SN3D factors from
# Nachbar et al., "AmbiX -- A Suggested Ambisonics Format," AES 2011.
#must_use
fn spherical_harmonics(order, theta, phi) {
    var sh = alloc(MAX_HOA_CHANNELS * 8);
    var i = 0;
    while (i < MAX_HOA_CHANNELS) {
        store64(sh + i * 8, 0);
        i = i + 1;
    }
    var ord = order;
    if (ord > MAX_HOA_ORDER) { ord = MAX_HOA_ORDER; }

    var cos_t = f64_cos(theta);
    var sin_t = f64_sin(theta);

    # Order 0: Y_0^0 = 1 (SN3D factor = 1).
    store64(sh + 0 * 8, F64_ONE);

    if (ord >= 1) {
        # SN3D order-1 factors are all 1.0.
        store64(sh + 1 * 8, f64_mul(sin_t, f64_sin(phi)));  # ACN 1: Y_1^{-1}
        store64(sh + 2 * 8, cos_t);                         # ACN 2: Y_1^0
        store64(sh + 3 * 8, f64_mul(sin_t, f64_cos(phi)));  # ACN 3: Y_1^1
    }

    if (ord >= 2) {
        var sin2 = f64_mul(sin_t, sin_t);
        var cos2 = f64_mul(cos_t, cos_t);
        var sc = f64_mul(sin_t, cos_t);
        var n2_2 = f64_div(f64_sqrt(f64_from(3)), F64_TWO);   # m=+-2: sqrt(3)/2
        var n2_1 = f64_sqrt(f64_from(3));                     # m=+-1: sqrt(3)
        var c1_5 = f64_div(f64_from(3), F64_TWO);             # 1.5
        var two_phi = f64_mul(F64_TWO, phi);
        store64(sh + 4 * 8, f64_mul(f64_mul(n2_2, sin2), f64_sin(two_phi)));  # ACN 4: Y_2^{-2}
        store64(sh + 5 * 8, f64_mul(f64_mul(n2_1, sc), f64_sin(phi)));        # ACN 5: Y_2^{-1}
        store64(sh + 6 * 8, f64_sub(f64_mul(c1_5, cos2), F64_HALF));          # ACN 6: Y_2^0
        store64(sh + 7 * 8, f64_mul(f64_mul(n2_1, sc), f64_cos(phi)));        # ACN 7: Y_2^1
        store64(sh + 8 * 8, f64_mul(f64_mul(n2_2, sin2), f64_cos(two_phi)));  # ACN 8: Y_2^2
    }

    if (ord >= 3) {
        var sin2b = f64_mul(sin_t, sin_t);
        var sin3 = f64_mul(sin2b, sin_t);
        var cos2b = f64_mul(cos_t, cos_t);
        var s2c = f64_mul(sin2b, cos_t);
        var n3_3 = f64_sqrt(f64_div(f64_from(5), f64_from(8)));   # m=+-3: sqrt(5/8)
        var n3_2 = f64_div(f64_sqrt(f64_from(15)), F64_TWO);      # m=+-2: sqrt(15)/2
        var n3_1 = f64_sqrt(f64_div(f64_from(3), f64_from(8)));   # m=+-1: sqrt(3/8)
        var c2_5 = f64_div(f64_from(5), F64_TWO);                 # 2.5
        var c1_5b = f64_div(f64_from(3), F64_TWO);               # 1.5
        var two_phi = f64_mul(F64_TWO, phi);
        var three_phi = f64_mul(f64_from(3), phi);
        var five_cos2_m1 = f64_sub(f64_mul(f64_from(5), cos2b), F64_ONE);
        store64(sh + 9 * 8, f64_mul(f64_mul(n3_3, sin3), f64_sin(three_phi)));         # ACN 9
        store64(sh + 10 * 8, f64_mul(f64_mul(n3_2, s2c), f64_sin(two_phi)));           # ACN 10
        store64(sh + 11 * 8, f64_mul(f64_mul(n3_1, sin_t), f64_mul(five_cos2_m1, f64_sin(phi)))); # ACN 11
        store64(sh + 12 * 8,
        f64_sub(f64_mul(f64_mul(c2_5, cos2b), cos_t), f64_mul(c1_5b, cos_t)));     # ACN 12
        store64(sh + 13 * 8, f64_mul(f64_mul(n3_1, sin_t), f64_mul(five_cos2_m1, f64_cos(phi)))); # ACN 13
        store64(sh + 14 * 8, f64_mul(f64_mul(n3_2, s2c), f64_cos(two_phi)));           # ACN 14
        store64(sh + 15 * 8, f64_mul(f64_mul(n3_3, sin3), f64_cos(three_phi)));        # ACN 15
    }

    return sh;
}

# ================================================================
# IR constructors
# ================================================================
# Empty B-Format IR: four zero channels of `num_samples`.
#must_use
fn new_bformat_ir(num_samples, sample_rate) {
    var ir = alloc(sizeof(BFormatIr));
    BFormatIr_set_w(ir, _zeros_vec(num_samples));
    BFormatIr_set_x(ir, _zeros_vec(num_samples));
    BFormatIr_set_y(ir, _zeros_vec(num_samples));
    BFormatIr_set_z(ir, _zeros_vec(num_samples));
    BFormatIr_set_sample_rate(ir, sample_rate);
    return ir;
}

# Empty HOA IR: (order+1)^2 zero channels of `num_samples`.
#must_use
fn new_hoa_ir(order, num_samples, sample_rate) {
    var num_channels = (order + 1) * (order + 1);
    var channels = vec_new();
    var i = 0;
    while (i < num_channels) {
        vec_push(channels, _zeros_vec(num_samples));
        i = i + 1;
    }
    var ir = alloc(sizeof(HoaIr));
    HoaIr_set_channels(ir, channels);
    HoaIr_set_order(ir, order);
    HoaIr_set_sample_rate(ir, sample_rate);
    return ir;
}

# --- scattering.cyr ---

# scattering.cyr -- vector-based scattering model for diffuse reflections.
#
# Ports rust-old/src/scattering.rs. Cosine-weighted hemisphere sampling
# (Malley's method) for Lambert diffuse reflection, plus the ODEON-style
# vector-based scatter direction that blends specular and diffuse:
#   dir = (1 - s) * specular + s * random_hemisphere.
# f32 → f64 throughout (hisab's HVec3 is f64-only). u1/u2 are
# caller-supplied uniform randoms in [0, 1) — there is no internal RNG.
# orthonormal_basis returns a Basis struct (replaces Rust's (Vec3, Vec3)
# tuple, like propagation's RayStep).
#
# Self-contained: no `include` lines. Relies on error.cyr (GOONJ_EPSILON),
# hisab HVec3 (hvec3_*/HVec3_*), and stdlib math (F64_ONE, F64_TAU,
# f64_sqrt/sin/cos/max/abs/…) being present in the build/test unit.

# Helper-axis threshold for the basis: pick X unless |n.x| >= 0.9, then Y.
var SCAT_HELPER_THRESHOLD = 0x3FECCCCCCCCCCCCD;   # 0.9

# Orthonormal basis result — replaces Rust's `(Vec3, Vec3)` tuple return.
#derive(accessors)
struct Basis { tangent; bitangent; }

#must_use
fn _basis_make(tangent, bitangent) {
    var b = alloc(sizeof(Basis));
    Basis_set_tangent(b, tangent);
    Basis_set_bitangent(b, bitangent);
    return b;
}

# Build an orthonormal basis from a single normal vector. Returns a Basis
# whose tangent and bitangent are perpendicular to the normal.
#must_use
fn orthonormal_basis(n) {
    # Choose a helper vector not parallel to n.
    var helper = hvec3_unit_x();
    if (f64_ge(f64_abs(HVec3_x(n)), SCAT_HELPER_THRESHOLD) == 1) { helper = hvec3_unit_y(); }
    var tangent = hvec3_cross(n, helper);
    var len = hvec3_length(tangent);
    if (f64_gt(len, GOONJ_EPSILON) == 1) {
        tangent = hvec3_scale(tangent, f64_div(F64_ONE, len));
    } else {
        tangent = hvec3_unit_x();
    }
    var bitangent = hvec3_cross(n, tangent);
    return _basis_make(tangent, bitangent);
}

# Generate a cosine-weighted random direction on the hemisphere around
# `normal` via Malley's method: a uniform disk sample projected up to the
# hemisphere (probability ∝ cos θ, Lambert's law). u1/u2 ∈ [0, 1).
#must_use
fn cosine_hemisphere_sample(normal, u1, u2) {
    # Malley's method: uniform disk → hemisphere projection.
    var r = f64_sqrt(u1);
    var theta = f64_mul(F64_TAU, u2);
    var x = f64_mul(r, f64_cos(theta));
    var y = f64_mul(r, f64_sin(theta));
    var z = f64_sqrt(f64_max(f64_sub(F64_ONE, u1), 0));   # cos(elevation)

    # Build orthonormal basis from the normal.
    var basis = orthonormal_basis(normal);
    var tangent = Basis_tangent(basis);
    var bitangent = Basis_bitangent(basis);

    var dir = hvec3_add(
    hvec3_add(hvec3_scale(tangent, x), hvec3_scale(bitangent, y)),
    hvec3_scale(normal, z));
    var len = hvec3_length(dir);
    if (f64_gt(len, GOONJ_EPSILON) == 1) {
        return hvec3_scale(dir, f64_div(F64_ONE, len));
    }
    return normal;
}

# Compute the scattered reflection direction (ODEON-style vector-based
# scattering): blend specular and a cosine-weighted random direction by
# the scattering coefficient, dir = (1 - s)*specular + s*diffuse, then
# normalize. u1/u2 ∈ [0, 1).
#must_use
fn scatter_direction(specular, normal, scattering, u1, u2) {
    if (f64_lt(scattering, GOONJ_EPSILON) == 1) { return specular; }
    if (f64_ge(scattering, f64_sub(F64_ONE, GOONJ_EPSILON)) == 1) {
        return cosine_hemisphere_sample(normal, u1, u2);
    }

    var diffuse = cosine_hemisphere_sample(normal, u1, u2);
    var blended = hvec3_add(
    hvec3_scale(specular, f64_sub(F64_ONE, scattering)),
    hvec3_scale(diffuse, scattering));
    var len = hvec3_length(blended);
    if (f64_gt(len, GOONJ_EPSILON) == 1) {
        return hvec3_scale(blended, f64_div(F64_ONE, len));
    }
    return specular;
}

# --- dark_velvet_noise.cyr ---

# dark_velvet_noise.cyr -- Dark Velvet Noise reverb: non-exponential late
# reverberation synthesized from sparse stochastic pulse sequences.
#
# Ports rust-old/src/dark_velvet_noise.rs. f32 -> f64 throughout. Rust's
# serde derive on DvnConfig/DecayEnvelope is dropped (no serde in Cyrius);
# the serde round-trip test is therefore omitted. The DecayEnvelope sum
# type (an enum with payloads) becomes a tagged struct: kind 0 =
# Exponential (rt60 field), kind 1 = PiecewiseDb (breakpoints field). The
# Vec<(f32, f32)> breakpoints become a stdlib vec holding interleaved
# (time, level_db) f64 pairs; the returned Vec<f32> IR becomes a stdlib
# vec of f64 bit patterns. The private Xorshift64 PRNG keeps its C-style
# bit ops (^ << >> &). Reference: Fagerstrom et al., "Non-Exponential
# Reverberation with Dark Velvet Noise," JAES 72(6), 2024.
#
# Requires (from the build/test unit): stdlib alloc/vec (alloc_init,
# vec_*), math/ganita (F64_ONE/TWO/HALF/TAU, f64_*), and error.cyr
# (GOONJ_EPSILON). The module file itself has no `include` lines.

# Maximum allowed IR length in samples (192_000 * 600), matching the
# impulse generator's saturation cap.
var MAX_IR_SAMPLES = 115200000;

# Default xorshift64 seed (0xCAFE_BABE_F00D_D15C) from Rust's Default impl.
var DVN_DEFAULT_SEED = 0xCAFEBABEF00DD15C;

# ================================================================
# DecayEnvelope -- decay-envelope shape for the velvet-noise tail.
#   kind        : 0 = Exponential, 1 = PiecewiseDb
#   rt60        : reverberation time (s), used when kind == 0
#   breakpoints : stdlib vec of interleaved (time_s, level_db) f64 pairs,
#                 sorted ascending by time, used when kind == 1
# ================================================================
#derive(accessors)
struct DecayEnvelope { kind; rt60; breakpoints; }

# Exponential decay: 60 dB amplitude drop over rt60_seconds.
#must_use
fn decay_exponential(rt60_seconds) {
    var e = alloc(sizeof(DecayEnvelope));
    DecayEnvelope_set_kind(e, 0);
    DecayEnvelope_set_rt60(e, rt60_seconds);
    DecayEnvelope_set_breakpoints(e, 0);
    return e;
}

# Piecewise-linear-in-dB envelope from interleaved (time_s, level_db) pairs.
#must_use
fn decay_piecewise_db(breakpoints) {
    var e = alloc(sizeof(DecayEnvelope));
    DecayEnvelope_set_kind(e, 1);
    DecayEnvelope_set_rt60(e, 0);
    DecayEnvelope_set_breakpoints(e, breakpoints);
    return e;
}

# Breakpoint helpers over the interleaved (time, level_db) layout.
#must_use
fn _bp_count(bp) { return vec_len(bp) / 2; }
#must_use
fn _bp_time(bp, i) { return vec_get(bp, i * 2); }
#must_use
fn _bp_db(bp, i) { return vec_get(bp, i * 2 + 1); }

# ================================================================
# DvnConfig -- configuration for Dark Velvet Noise IR synthesis.
#   sample_rate                  : u32 Hz
#   pulse_density_hz             : f32 pulses/second (typical 1000-4000)
#   duration_seconds             : f32 total IR duration
#   decay                        : DecayEnvelope pointer
#   coloration_initial_cutoff_hz : f32 low-pass cutoff at t = 0
#   coloration_final_cutoff_hz   : f32 low-pass cutoff at t = duration
#   seed                         : u64 xorshift64 seed
# ================================================================
#derive(accessors)
struct DvnConfig {
    sample_rate;
    pulse_density_hz;
    duration_seconds;
    decay;
    coloration_initial_cutoff_hz;
    coloration_final_cutoff_hz;
    seed;
}

#must_use
fn dvn_config_new(sample_rate, pulse_density_hz, duration_seconds, decay, init_cutoff, final_cutoff, seed) {
    var c = alloc(sizeof(DvnConfig));
    DvnConfig_set_sample_rate(c, sample_rate);
    DvnConfig_set_pulse_density_hz(c, pulse_density_hz);
    DvnConfig_set_duration_seconds(c, duration_seconds);
    DvnConfig_set_decay(c, decay);
    DvnConfig_set_coloration_initial_cutoff_hz(c, init_cutoff);
    DvnConfig_set_coloration_final_cutoff_hz(c, final_cutoff);
    DvnConfig_set_seed(c, seed);
    return c;
}

# Default configuration (mirrors Rust's Default impl): 48 kHz, 2000
# pulses/s, 2 s, exponential RT60 = 1.5 s, 16 kHz -> 800 Hz coloration.
#must_use
fn dvn_config_default() {
    var decay = decay_exponential(f64_div(f64_from(3), f64_from(2)));
    return dvn_config_new(48000, f64_from(2000), f64_from(2), decay, f64_from(16000), f64_from(800),
    DVN_DEFAULT_SEED);
}

# ================================================================
# Xorshift64 -- private PRNG (no external rand dependency).
# ================================================================
#derive(accessors)
struct Xorshift64 { state; }

#must_use
fn xorshift64_new(seed) {
    var r = alloc(sizeof(Xorshift64));
    if (seed == 0) {
        Xorshift64_set_state(r, 0x5555555555555555);
    } else {
        Xorshift64_set_state(r, seed);
    }
    return r;
}

# One xorshift64 step. Bit ops are C-style on the i64 state; the shift
# semantics only need internal consistency for determinism.
fn xorshift64_next_u64(rng) {
    var x = Xorshift64_state(rng);
    x = x ^ (x << 13);
    x = x ^ (x >> 7);
    x = x ^ (x << 17);
    Xorshift64_set_state(rng, x);
    return x;
}

# ================================================================
# Envelope evaluation.
# ================================================================

# Piecewise-linear-in-dB envelope value at time t. Outside the breakpoint
# range the endpoint level is held; empty breakpoints are silent.
#must_use
fn piecewise_db_value(bp, t) {
    var count = _bp_count(bp);
    if (count == 0) { return 0; }
    var db0 = _bp_db(bp, 0);
    if (count == 1) { return f64_pow(f64_from(10), f64_div(db0, f64_from(20))); }
    if (f64_le(t, _bp_time(bp, 0)) == 1) {
        return f64_pow(f64_from(10), f64_div(db0, f64_from(20)));
    }
    var last_db = _bp_db(bp, count - 1);
    if (f64_ge(t, _bp_time(bp, count - 1)) == 1) {
        return f64_pow(f64_from(10), f64_div(last_db, f64_from(20)));
    }
    var w = 0;
    while (w < count - 1) {
        var t_a = _bp_time(bp, w);
        var t_b = _bp_time(bp, w + 1);
        if (f64_ge(t, t_a) == 1) {
            if (f64_le(t, t_b) == 1) {
                var db_a = _bp_db(bp, w);
                var db_b = _bp_db(bp, w + 1);
                var span = f64_max(f64_sub(t_b, t_a), GOONJ_EPSILON);
                var frac = f64_div(f64_sub(t, t_a), span);
                var db = f64_add(db_a, f64_mul(f64_sub(db_b, db_a), frac));
                return f64_pow(f64_from(10), f64_div(db, f64_from(20)));
            }
        }
        w = w + 1;
    }
    return 0;
}

# Envelope amplitude at time t for the configured decay shape.
#must_use
fn envelope_value(env, t) {
    if (DecayEnvelope_kind(env) == 0) {
        var rt60 = DecayEnvelope_rt60(env);
        if (f64_le(rt60, 0) == 1) { return 0; }
        var expo = f64_div(f64_mul(f64_neg(f64_from(3)), t), rt60);
        return f64_pow(f64_from(10), expo);
    }
    return piecewise_db_value(DecayEnvelope_breakpoints(env), t);
}

# ================================================================
# synthesize_dvn_ir -- Dark Velvet Noise impulse response.
# Returns an empty vec for degenerate configs (sample_rate == 0,
# duration_seconds <= 0, pulse_density_hz <= 0).
# ================================================================
#must_use
fn synthesize_dvn_ir(config) {
    var sample_rate = DvnConfig_sample_rate(config);
    var pulse_density_hz = DvnConfig_pulse_density_hz(config);
    var duration_seconds = DvnConfig_duration_seconds(config);

    if (sample_rate == 0) { return vec_new(); }
    if (f64_le(duration_seconds, 0) == 1) { return vec_new(); }
    if (f64_le(pulse_density_hz, 0) == 1) { return vec_new(); }

    var num_samples = f64_to(f64_mul(duration_seconds, f64_from(sample_rate)));
    if (num_samples > MAX_IR_SAMPLES) { num_samples = MAX_IR_SAMPLES; }
    if (num_samples == 0) { return vec_new(); }

    var out = vec_new();
    var z = 0;
    while (z < num_samples) {
        vec_push(out, 0);
        z = z + 1;
    }

    # Cell size in samples; saturate at one pulse per sample.
    var td = f64_max(f64_div(f64_from(sample_rate), pulse_density_hz), F64_ONE);
    var td_int = f64_to(td);
    if (td_int < 1) { td_int = 1; }

    var rng = xorshift64_new(DvnConfig_seed(config));
    var inv_sr = f64_div(F64_ONE, f64_from(sample_rate));
    var decay = DvnConfig_decay(config);

    # Stage 1: place sparse pulses with envelope amplitude.
    var cell_start = 0;
    while (cell_start < num_samples) {
        var cell_end = cell_start + td_int;
        if (cell_end > num_samples) { cell_end = num_samples; }
        var cell_len = cell_end - cell_start;
        var r = xorshift64_next_u64(rng);
        # Unsigned-style index in [0, cell_len): C modulo can go negative.
        var k = r % cell_len;
        if (k < 0) { k = k + cell_len; }
        var bit = (r >> 32) & 1;
        var sign = F64_ONE;
        if (bit == 1) { sign = f64_neg(F64_ONE); }
        var idx = cell_start + k;
        var t = f64_mul(f64_from(idx), inv_sr);
        var env = envelope_value(decay, t);
        vec_set(out, idx, f64_mul(sign, env));
        cell_start = cell_end;
    }

    # Stage 2: time-varying 1-pole low-pass for "dark" coloration.
    # a[n] = 1 - exp(-2*pi*fc[n]/fs); fc interpolated linearly between the
    # initial and final cutoffs (linear-in-a perceptual approximation).
    var f0 = f64_max(DvnConfig_coloration_initial_cutoff_hz(config), F64_ONE);
    var f1 = f64_max(DvnConfig_coloration_final_cutoff_hz(config), F64_ONE);
    var twopi_inv_sr = f64_mul(F64_TAU, inv_sr);
    var a0 = f64_sub(F64_ONE, f64_exp(f64_mul(f64_neg(twopi_inv_sr), f0)));
    var a1 = f64_sub(F64_ONE, f64_exp(f64_mul(f64_neg(twopi_inv_sr), f1)));
    var inv_n = f64_div(F64_ONE, f64_from(num_samples));
    var y_prev = 0;
    var n = 0;
    while (n < num_samples) {
        var frac = f64_mul(f64_from(n), inv_n);
        var a = f64_add(a0, f64_mul(f64_sub(a1, a0), frac));
        var s = vec_get(out, n);
        var y = f64_add(f64_mul(a, s), f64_mul(f64_sub(F64_ONE, a), y_prev));
        vec_set(out, n, y);
        y_prev = y;
        n = n + 1;
    }

    return out;
}

# --- logging.cyr ---

# logging.cyr -- diagnostic logging, backed by sakshi.
#
# Ports rust-old/src/logging.rs (which set up a `tracing_subscriber`). The
# Cyrius port routes logging through the sakshi dependency (lib/sakshi.cyr,
# pulled transitively via hisab) so goonj can emit error-locating diagnostics
# when the library is in use, with a **verbose mode** for deeper diagnosis.
#
# Levels mirror sakshi's SK_* (0 = fatal … 5 = trace); the runtime threshold
# is set via sakshi_set_level (a message at level L is emitted iff
# L <= threshold). Output defaults to stderr. sakshi compiles all level
# bodies in (SAKSHI_LEVEL defaults to 5), so the runtime threshold is the
# only control needed.
#
# Names are `logging_`/`goonj_log_`-prefixed (flat namespace). Requires
# lib/sakshi.cyr + stdlib string (strlen) in the build unit.

enum LogLevel {
    LOG_FATAL = 0,
    LOG_ERROR = 1,
    LOG_WARN  = 2,
    LOG_INFO  = 3,
    LOG_DEBUG = 4,
    LOG_TRACE = 5,
}

# Initialize logging at the default WARN threshold (matches the Rust default
# of "warn"), emitting to stderr. Returns 0.
fn logging_init() {
    sakshi_set_output(SK_OUT_STDERR);
    sakshi_set_level(LOG_WARN);
    return 0;
}

# Verbose init: TRACE threshold to stderr — emit everything, for diagnosis.
fn logging_init_verbose() {
    sakshi_set_output(SK_OUT_STDERR);
    sakshi_set_level(LOG_TRACE);
    return 0;
}

# Try-init parity shim: same as logging_init; the sakshi model never fails.
fn logging_try_init() {
    return logging_init();
}

# Set / get the runtime log threshold (LOG_FATAL … LOG_TRACE).
fn logging_set_level(level) {
    sakshi_set_level(level);
    return 0;
}
fn logging_get_level() {
    return sakshi_get_level();
}

# Level-gated log calls. `msg` is a cstring literal; length via strlen.
fn goonj_log_fatal(msg) { sakshi_fatal(msg, strlen(msg)); return 0; }
fn goonj_log_error(msg) { sakshi_error(msg, strlen(msg)); return 0; }
fn goonj_log_warn(msg)  { sakshi_warn(msg, strlen(msg)); return 0; }
fn goonj_log_info(msg)  { sakshi_info(msg, strlen(msg)); return 0; }
fn goonj_log_debug(msg) { sakshi_debug(msg, strlen(msg)); return 0; }
fn goonj_log_trace(msg) { sakshi_trace(msg, strlen(msg)); return 0; }

# --- hybrid.cyr ---

# hybrid.cyr -- hybrid frequency crossover: blending low-frequency
# wave-based results (FDTD/FEM/BEM) with high-frequency geometric
# results (ray/image-source/radiosity) at a crossover frequency near
# the Schroeder frequency of the room.
#
# Ports rust-old/src/hybrid.rs. f32 → f64. Rust's `serde` derive on
# CrossoverConfig is dropped (no serde in Cyrius); there is no
# serde-specific test to port. The Rust `[f32; NUM_BANDS]` return arrays
# become alloc'd 8×f64 buffers (read with load64(buf + band*8)).
#
# Requires (from the build/test unit): material.cyr (NUM_BANDS,
# frequency_band) and stdlib math/ganita (F64_ONE, F64_LN2,
# f64_exp/ln/clamp/max/div/mul/add/sub/neg). alloc_init() must have run.

# Floor for the transition bandwidth: transition_octaves.max(0.1).
var BW_MIN = 0x3FB999999999999A;   # 0.1

# log2(x) = ln(x) / ln(2)
fn _hybrid_log2(x) { return f64_div(f64_ln(x), F64_LN2); }

# ================================================================
# CrossoverConfig — crossover frequency + transition bandwidth.
# ================================================================
#derive(accessors)
struct CrossoverConfig { crossover_hz; transition_octaves; }

#must_use
fn crossover_config_new(crossover_hz, transition_octaves) {
    var c = alloc(sizeof(CrossoverConfig));
    CrossoverConfig_set_crossover_hz(c, crossover_hz);
    CrossoverConfig_set_transition_octaves(c, transition_octaves);
    return c;
}

# Rust Default: crossover_hz = 500.0, transition_octaves = 1.0.
#must_use
fn crossover_config_default() {
    return crossover_config_new(f64_from(500), F64_ONE);
}

# ================================================================
# blend_weights — per-band wave-vs-geometric blend weights.
# 0.0 = fully wave-based, 1.0 = fully geometric; smooth sigmoid
# centred on the crossover frequency in log-frequency space.
# Returns an alloc'd 8×f64 buffer.
# ================================================================
#must_use
fn blend_weights(config) {
    var fc = CrossoverConfig_crossover_hz(config);
    var bw = f64_max(CrossoverConfig_transition_octaves(config), BW_MIN);
    var out = alloc(NUM_BANDS * 8);
    var band = 0;
    while (band < NUM_BANDS) {
        var f = frequency_band(band);
        if (f64_le(fc, 0) == 1) {
            # all geometric
            store64(out + band * 8, F64_ONE);
        } else {
            # Sigmoid blend in log-frequency space:
            # octaves_above = (f / fc).log2() / bw
            var octaves_above = f64_div(_hybrid_log2(f64_div(f, fc)), bw);
            # weight = 1.0 / (1.0 + (-4.0 * octaves_above).exp())
            var exp_arg = f64_mul(f64_neg(f64_from(4)), octaves_above);
            var weight = f64_div(F64_ONE, f64_add(F64_ONE, f64_exp(exp_arg)));
            store64(out + band * 8, f64_clamp(weight, 0, F64_ONE));
        }
        band = band + 1;
    }
    return out;
}

# ================================================================
# blend_results — combine per-band wave + geometric results using the
# crossover weights. Returns an alloc'd 8×f64 buffer:
#   wave[band]*(1-w[band]) + geometric[band]*w[band].
# ================================================================
#must_use
fn blend_results(wave_result, geometric_result, config) {
    var weights = blend_weights(config);
    var out = alloc(NUM_BANDS * 8);
    var band = 0;
    while (band < NUM_BANDS) {
        var w = load64(weights + band * 8);
        var wave = load64(wave_result + band * 8);
        var geom = load64(geometric_result + band * 8);
        var blended = f64_add(f64_mul(wave, f64_sub(F64_ONE, w)), f64_mul(geom, w));
        store64(out + band * 8, blended);
        band = band + 1;
    }
    return out;
}

# --- directivity.cyr ---

# directivity.cyr -- source directivity patterns for frequency-dependent
# sound radiation: analytical patterns (omni / cardioid / subcardioid /
# supercardioid / figure-8) plus tabulated balloon data.
#
# Ports rust-old/src/directivity.rs. f32 → f64 throughout (hisab is
# f64-only). Rust's `serde` derive is dropped (no serde in Cyrius); the
# serde round-trip test is therefore omitted. The payload-carrying enum
# `DirectivityPattern` becomes an integer `kind` tag + a `balloon`
# pointer (0 for analytical patterns). The `[Vec<f32>; NUM_BANDS]`
# balloon gain table is an inline 8×pointer block via manual layout.
#
# Requires (from the build/test unit): material.cyr (NUM_BANDS), stdlib
# math/ganita (F64_*, f64_clamp/acos/abs/max/...) and vec
# (vec_new/push/len/get), and hisab (hvec3_dot). alloc_init() must run.

# -1.0 as an f64 bit pattern — the clamp lower bound for cos θ.
var DIR_NEG_ONE = 0xBFF0000000000000;   # -1.0

# Pattern kind tags (replaces Rust's payload-carrying enum variants).
enum DirPatternKind {
    PAT_OMNI = 0,
    PAT_CARDIOID = 1,
    PAT_SUBCARDIOID = 2,
    PAT_SUPERCARDIOID = 3,
    PAT_FIGURE8 = 4,
    PAT_TABULATED = 5,
}

# DirectivityBalloon inline layout: azimuths vec | elevations vec |
# 8 per-band gain vecs (offsets 16..80).
enum DbLayout {
    DB_AZ = 0,
    DB_EL = 8,
    DB_GAINS = 16,   # 8 pointers, offsets 16..80
    DB_SIZE = 80,
}

# n/100 as f64 — cardioid coefficients are all exact hundredths.
fn _dir_pct(n) { return f64_div(f64_from(n), f64_from(100)); }

# ================================================================
# DirectivityBalloon — measured per-band gain table
# ================================================================
fn directivity_balloon_azimuths(b)   { return load64(b + DB_AZ); }
fn directivity_balloon_elevations(b) { return load64(b + DB_EL); }
fn directivity_balloon_gain_band(b, band) { return load64(b + DB_GAINS + band * 8); }

# Build a balloon from an azimuths vec, an elevations vec, and `gains`
# (a pointer to NUM_BANDS vec handles, one per octave band).
#must_use
fn directivity_balloon_new(azimuths, elevations, gains) {
    var b = alloc(DB_SIZE);
    store64(b + DB_AZ, azimuths);
    store64(b + DB_EL, elevations);
    var i = 0;
    while (i < NUM_BANDS) {
        store64(b + DB_GAINS + i * 8, load64(gains + i * 8));
        i = i + 1;
    }
    return b;
}

# Fill an 8×f64 output buffer with 1.0 (the [1.0; NUM_BANDS] fallback).
fn _dir_fill_ones(out) {
    var i = 0;
    while (i < NUM_BANDS) {
        store64(out + i * 8, F64_ONE);
        i = i + 1;
    }
    return out;
}

# Nearest-neighbour index in `vals` to `target` (first minimum wins, as
# Rust's `min_by(... partial_cmp ...).unwrap_or(0)`).
#must_use
fn _dir_nearest_idx(vals, target) {
    var n = vec_len(vals);
    if (n == 0) { return 0; }
    var best = 0;
    var best_diff = f64_abs(f64_sub(vec_get(vals, 0), target));
    var i = 1;
    while (i < n) {
        var d = f64_abs(f64_sub(vec_get(vals, i), target));
        if (f64_lt(d, best_diff) == 1) {
            best = i;
            best_diff = d;
        }
        i = i + 1;
    }
    return best;
}

# Interpolate per-band gain via nearest-neighbour lookup. Returns a
# pointer to NUM_BANDS f64 (replaces Rust's `[f32; NUM_BANDS]`).
#must_use
fn _dir_interpolate_per_band(balloon, direction, front) {
    var out = alloc(NUM_BANDS * 8);
    var az = directivity_balloon_azimuths(balloon);
    var el = directivity_balloon_elevations(balloon);
    if (vec_len(az) == 0) { return _dir_fill_ones(out); }
    if (vec_len(el) == 0) { return _dir_fill_ones(out); }

    # Polar angle from the front axis; axisymmetric fallback (el = 0).
    var cos_theta = f64_clamp(hvec3_dot(direction, front), DIR_NEG_ONE, F64_ONE);
    var theta = f64_acos(cos_theta);
    var target_az = theta;
    var target_el = 0;   # 0.0

    var az_idx = _dir_nearest_idx(az, target_az);
    var el_idx = _dir_nearest_idx(el, target_el);
    var flat_idx = el_idx * vec_len(az) + az_idx;

    var band = 0;
    while (band < NUM_BANDS) {
        var g = directivity_balloon_gain_band(balloon, band);
        var v = F64_ONE;
        if (flat_idx < vec_len(g)) {
            v = vec_get(g, flat_idx);
        }
        store64(out + band * 8, v);
        band = band + 1;
    }
    return out;
}

# Broadband gain = mean of the per-band gains.
#must_use
fn _dir_interpolate_broadband(balloon, direction, front) {
    var pb = _dir_interpolate_per_band(balloon, direction, front);
    var sum = 0;
    var i = 0;
    while (i < NUM_BANDS) {
        sum = f64_add(sum, load64(pb + i * 8));
        i = i + 1;
    }
    return f64_div(sum, f64_from(NUM_BANDS));
}

# ================================================================
# DirectivityPattern — kind tag + optional balloon pointer
# ================================================================
#derive(accessors)
struct DirectivityPattern { kind; balloon; }

#must_use
fn directivity_omnidirectional() {
    var p = alloc(sizeof(DirectivityPattern));
    DirectivityPattern_set_kind(p, PAT_OMNI);
    DirectivityPattern_set_balloon(p, 0);
    return p;
}
#must_use
fn directivity_cardioid() {
    var p = alloc(sizeof(DirectivityPattern));
    DirectivityPattern_set_kind(p, PAT_CARDIOID);
    DirectivityPattern_set_balloon(p, 0);
    return p;
}
#must_use
fn directivity_subcardioid() {
    var p = alloc(sizeof(DirectivityPattern));
    DirectivityPattern_set_kind(p, PAT_SUBCARDIOID);
    DirectivityPattern_set_balloon(p, 0);
    return p;
}
#must_use
fn directivity_supercardioid() {
    var p = alloc(sizeof(DirectivityPattern));
    DirectivityPattern_set_kind(p, PAT_SUPERCARDIOID);
    DirectivityPattern_set_balloon(p, 0);
    return p;
}
#must_use
fn directivity_figure8() {
    var p = alloc(sizeof(DirectivityPattern));
    DirectivityPattern_set_kind(p, PAT_FIGURE8);
    DirectivityPattern_set_balloon(p, 0);
    return p;
}
#must_use
fn directivity_tabulated(balloon) {
    var p = alloc(sizeof(DirectivityPattern));
    DirectivityPattern_set_kind(p, PAT_TABULATED);
    DirectivityPattern_set_balloon(p, balloon);
    return p;
}

# Directivity gain for a direction relative to the front axis (linear,
# 1.0 = on-axis reference). `direction` and `front` are HVec3 pointers.
#must_use
fn directivity_gain(pattern, direction, front) {
    var kind = DirectivityPattern_kind(pattern);
    if (kind == PAT_OMNI) { return F64_ONE; }
    if (kind == PAT_CARDIOID) {
        # gain = max(0.5·(1 + cos θ), 0)
        var c = f64_clamp(hvec3_dot(direction, front), DIR_NEG_ONE, F64_ONE);
        return f64_max(f64_mul(F64_HALF, f64_add(F64_ONE, c)), 0);
    }
    if (kind == PAT_SUBCARDIOID) {
        # gain = 0.75 + 0.25·cos θ
        var c = f64_clamp(hvec3_dot(direction, front), DIR_NEG_ONE, F64_ONE);
        return f64_add(_dir_pct(75), f64_mul(_dir_pct(25), c));
    }
    if (kind == PAT_SUPERCARDIOID) {
        # gain = max(0.37 + 0.63·cos θ, 0)
        var c = f64_clamp(hvec3_dot(direction, front), DIR_NEG_ONE, F64_ONE);
        return f64_max(f64_add(_dir_pct(37), f64_mul(_dir_pct(63), c)), 0);
    }
    if (kind == PAT_FIGURE8) {
        # gain = |cos θ|
        var c = f64_clamp(hvec3_dot(direction, front), DIR_NEG_ONE, F64_ONE);
        return f64_abs(c);
    }
    if (kind == PAT_TABULATED) {
        return _dir_interpolate_broadband(DirectivityPattern_balloon(pattern), direction, front);
    }
    return F64_ONE;
}

# Per-band directivity gain. Returns a pointer to NUM_BANDS f64. For
# analytical patterns every band equals the broadband gain.
#must_use
fn directivity_gain_per_band(pattern, direction, front) {
    var kind = DirectivityPattern_kind(pattern);
    if (kind == PAT_TABULATED) {
        return _dir_interpolate_per_band(DirectivityPattern_balloon(pattern), direction, front);
    }
    var g = directivity_gain(pattern, direction, front);
    var out = alloc(NUM_BANDS * 8);
    var i = 0;
    while (i < NUM_BANDS) {
        store64(out + i * 8, g);
        i = i + 1;
    }
    return out;
}

# --- room.cyr ---

# room.cyr -- room geometry: walls (polygon + material + normal), room
# geometry (wall collection), shoebox builder, volume/surface/absorption
# queries, and the BVH-accelerated room wrapper.
#
# Ports rust-old/src/room.rs. f32 → f64 throughout (hisab is f64-only).
# Rust's `serde` derive is dropped (no serde in Cyrius); the serde
# round-trip behaviour has no test to port here. `Vec<Vec3>` vertex lists
# and `Vec<Wall>` wall lists become stdlib `vec` handles holding HVec3 /
# Wall pointers. `AcousticMaterial` is shared by pointer across the six
# shoebox walls (Rust cloned for ownership; the data is read-only here).
# `hisab::geo::{Aabb, Bvh}` map to hisab's GeoAabb / bvh_build.
#
# Requires (from the build/test unit): stdlib math/ganita (F64_*, f64_*),
# vec (vec_new/push/len/get/set), hisab (hvec3_*, geo_aabb_new, bvh_build),
# and material.cyr (average_absorption). alloc_init() must have run.

# Non-integer / sentinel f64 bit patterns (decimal in comments).
var ROOM_PAD     = 0x3F50624DD2F1A9FC;   # 0.001  AABB pad (avoid zero-thickness slabs)
var ROOM_POS_INF = 0x7FF0000000000000;   # +inf
var ROOM_NEG_INF = 0xFFF0000000000000;   # -inf

# ================================================================
# Structs
# ================================================================
# A wall: polygon vertices (vec of HVec3, min 3), material ptr, outward normal.
#derive(accessors)
struct Wall { vertices; material; normal; }

# Room geometry: a vec of Wall pointers.
#derive(accessors)
struct RoomGeometry { walls; }

# Acoustic room: geometry + environmental conditions.
#derive(accessors)
struct AcousticRoom { geometry; temperature_celsius; humidity_percent; }

# BVH-accelerated room: an AcousticRoom plus a BVH built from wall AABBs.
#derive(accessors)
struct AcceleratedRoom { room; bvh; }

# ================================================================
# Wall
# ================================================================
#must_use
fn wall_new(vertices, material, normal) {
    var w = alloc(sizeof(Wall));
    Wall_set_vertices(w, vertices);
    Wall_set_material(w, material);
    Wall_set_normal(w, normal);
    return w;
}

# Build a vec of four HVec3 vertices (the shoebox face winding).
#must_use
fn _verts4(a, b, c, d) {
    var v = vec_new();
    vec_push(v, a);
    vec_push(v, b);
    vec_push(v, c);
    vec_push(v, d);
    return v;
}

# Area of a convex polygon wall via fan triangulation from vertex 0.
# total += |(v_i - v0) × (v_{i+1} - v0)| · 0.5 for i in 1..len-1.
#must_use
fn wall_area(wall) {
    var verts = Wall_vertices(wall);
    var n = vec_len(verts);
    if (n < 3) { return 0; }
    var total = 0;
    var v0 = vec_get(verts, 0);
    var i = 1;
    while (i < n - 1) {
        var a = hvec3_sub(vec_get(verts, i), v0);
        var b = hvec3_sub(vec_get(verts, i + 1), v0);
        total = f64_add(total, f64_mul(hvec3_length(hvec3_cross(a, b)), F64_HALF));
        i = i + 1;
    }
    return total;
}

# Sabine absorption area: area × average absorption coefficient.
#must_use
fn wall_absorption_area(wall) {
    return f64_mul(wall_area(wall), average_absorption(Wall_material(wall)));
}

# Axis-aligned bounding box of the wall's vertices, padded by 0.001 to
# avoid zero-thickness slabs. Empty vertex list → zero-size box at origin.
#must_use
fn wall_aabb(wall) {
    var verts = Wall_vertices(wall);
    var n = vec_len(verts);
    if (n == 0) {
        return geo_aabb_new(hvec3_zero(), hvec3_zero());
    }
    var mn = vec_get(verts, 0);
    var mx = vec_get(verts, 0);
    var i = 1;
    while (i < n) {
        var v = vec_get(verts, i);
        mn = hvec3_min(mn, v);
        mx = hvec3_max(mx, v);
        i = i + 1;
    }
    var pad = hvec3_splat(ROOM_PAD);
    return geo_aabb_new(hvec3_sub(mn, pad), hvec3_add(mx, pad));
}

# ================================================================
# RoomGeometry
# ================================================================
# Total surface area: sum of all wall areas.
#must_use
fn room_geometry_surface_area(geom) {
    var walls = RoomGeometry_walls(geom);
    var n = vec_len(walls);
    var sum = 0;
    var i = 0;
    while (i < n) {
        sum = f64_add(sum, wall_area(vec_get(walls, i)));
        i = i + 1;
    }
    return sum;
}

# Total Sabine absorption: sum of each wall's absorption area.
#must_use
fn room_geometry_total_absorption(geom) {
    var walls = RoomGeometry_walls(geom);
    var n = vec_len(walls);
    var sum = 0;
    var i = 0;
    while (i < n) {
        sum = f64_add(sum, wall_absorption_area(vec_get(walls, i)));
        i = i + 1;
    }
    return sum;
}

# Build a BVH from the wall AABBs. Returns 0 for an empty room (matches
# hisab bvh_build's count==0 path).
#must_use
fn room_geometry_build_bvh(geom) {
    var walls = RoomGeometry_walls(geom);
    var n = vec_len(walls);
    if (n == 0) { return 0; }
    var aabbs = alloc(n * 8);
    var i = 0;
    while (i < n) {
        store64(aabbs + i * 8, wall_aabb(vec_get(walls, i)));
        i = i + 1;
    }
    return bvh_build(aabbs, n);
}

# Shoebox (rectangular) room with uniform material on all six surfaces.
# Normals point outward. Order: floor, ceiling, front (z=0), back (z=width),
# left (x=0), right (x=length).
#must_use
fn room_geometry_shoebox(length, width, height, material) {
    var walls = vec_new();

    # Floor (y = 0), normal (0, -1, 0).
    vec_push(walls, wall_new(
    _verts4(
    hvec3_new(0, 0, 0),
    hvec3_new(length, 0, 0),
    hvec3_new(length, 0, width),
    hvec3_new(0, 0, width)),
    material,
    hvec3_new(0, f64_neg(F64_ONE), 0)));

    # Ceiling (y = height), normal (0, 1, 0).
    vec_push(walls, wall_new(
    _verts4(
    hvec3_new(0, height, width),
    hvec3_new(length, height, width),
    hvec3_new(length, height, 0),
    hvec3_new(0, height, 0)),
    material,
    hvec3_new(0, F64_ONE, 0)));

    # Front wall (z = 0), normal (0, 0, -1).
    vec_push(walls, wall_new(
    _verts4(
    hvec3_new(0, height, 0),
    hvec3_new(length, height, 0),
    hvec3_new(length, 0, 0),
    hvec3_new(0, 0, 0)),
    material,
    hvec3_new(0, 0, f64_neg(F64_ONE))));

    # Back wall (z = width), normal (0, 0, 1).
    vec_push(walls, wall_new(
    _verts4(
    hvec3_new(0, 0, width),
    hvec3_new(length, 0, width),
    hvec3_new(length, height, width),
    hvec3_new(0, height, width)),
    material,
    hvec3_new(0, 0, F64_ONE)));

    # Left wall (x = 0), normal (-1, 0, 0).
    vec_push(walls, wall_new(
    _verts4(
    hvec3_new(0, 0, 0),
    hvec3_new(0, 0, width),
    hvec3_new(0, height, width),
    hvec3_new(0, height, 0)),
    material,
    hvec3_new(f64_neg(F64_ONE), 0, 0)));

    # Right wall (x = length), normal (1, 0, 0).
    vec_push(walls, wall_new(
    _verts4(
    hvec3_new(length, height, 0),
    hvec3_new(length, height, width),
    hvec3_new(length, 0, width),
    hvec3_new(length, 0, 0)),
    material,
    hvec3_new(F64_ONE, 0, 0)));

    var g = alloc(sizeof(RoomGeometry));
    RoomGeometry_set_walls(g, walls);
    return g;
}

# Volume from the axis-aligned bounding box of all wall vertices. Scans
# every vertex (independent of wall ordering). Accurate only for shoeboxes.
# Degenerate extents (≤ 0 on any axis) → 0.
#must_use
fn room_geometry_volume_shoebox(geom) {
    var walls = RoomGeometry_walls(geom);
    var nw = vec_len(walls);
    var mn = hvec3_splat(ROOM_POS_INF);
    var mx = hvec3_splat(ROOM_NEG_INF);
    var i = 0;
    while (i < nw) {
        var verts = Wall_vertices(vec_get(walls, i));
        var nv = vec_len(verts);
        var j = 0;
        while (j < nv) {
            var v = vec_get(verts, j);
            mn = hvec3_min(mn, v);
            mx = hvec3_max(mx, v);
            j = j + 1;
        }
        i = i + 1;
    }
    var ext = hvec3_sub(mx, mn);
    var ex = HVec3_x(ext);
    var ey = HVec3_y(ext);
    var ez = HVec3_z(ext);
    if (f64_le(ex, 0) == 1) { return 0; }
    if (f64_le(ey, 0) == 1) { return 0; }
    if (f64_le(ez, 0) == 1) { return 0; }
    return f64_mul(f64_mul(ex, ey), ez);
}

# ================================================================
# AcousticRoom
# ================================================================
# Shoebox acoustic room with default conditions (20 °C, 50 % humidity).
#must_use
fn acoustic_room_shoebox(length, width, height, material) {
    var r = alloc(sizeof(AcousticRoom));
    AcousticRoom_set_geometry(r, room_geometry_shoebox(length, width, height, material));
    AcousticRoom_set_temperature_celsius(r, f64_from(20));
    AcousticRoom_set_humidity_percent(r, f64_from(50));
    return r;
}

# ================================================================
# AcceleratedRoom
# ================================================================
# Build an accelerated room: wraps a room with a BVH over its wall AABBs.
#must_use
fn accelerated_room_new(room) {
    var ar = alloc(sizeof(AcceleratedRoom));
    AcceleratedRoom_set_room(ar, room);
    AcceleratedRoom_set_bvh(ar, room_geometry_build_bvh(AcousticRoom_geometry(room)));
    return ar;
}

# --- metamaterial.cyr ---

# metamaterial.cyr -- acoustic metamaterials: engineered structures with
# frequency-dependent effective parameters (negative stiffness / density,
# doubly-negative, and a lookup-table form for measured data).
#
# Ports rust-old/src/metamaterial.rs. f32 -> f64 throughout. Rust's `serde`
# derive is dropped (no serde in Cyrius); the two serde round-trip tests are
# therefore omitted. The payload-carrying `Metamaterial` enum becomes a
# manual tagged union (tag + two 8-byte slots); the `(f32, f32)` tuple
# returned by `evaluate` becomes an `MmComplex` struct. `Vec<(f32, f32)>`
# lookup rows become a flat stdlib `vec` (freq, absorption, freq, ...).
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON),
# material.cyr (acoustic_material_new, frequency_band, NUM_BANDS), stdlib
# math/ganita (F64_*, f64_*) and vec; alloc_init() must have run.

# ================================================================
# Constants (f64 bit patterns; decimal in comments for traceability)
# ================================================================
# Characteristic impedance of air, Z0 = rho0*c at 20 C, 1 atm (rayls).
var AIR_IMPEDANCE_RAYLS = 0x4079D00000000000;   # 413.0
# Reference air density at 20 C (kg/m^3).
var AIR_DENSITY         = 0x3FF347AE147AE148;   # 1.205
# Reference air bulk modulus K0 = rho0*c^2 at 20 C (Pa).
var AIR_BULK_MODULUS    = 0x4101558000000000;   # 1.42e5 = 142000.0

# Metamaterial variant tags.
enum MmTag {
    MM_NEG_STIFFNESS   = 0,
    MM_NEG_DENSITY     = 1,
    MM_DOUBLY_NEGATIVE = 2,
    MM_LOOKUP_TABLE    = 3,
}

# Tagged-union layout: tag | slot A | slot B.
#   NegativeStiffness: A = k_eff (LorentzianResonance ptr), B = rho   (f64)
#   NegativeDensity:   A = rho_eff (ptr),                   B = k_mod (f64)
#   DoublyNegative:    A = k_eff (ptr),                     B = rho_eff (ptr)
#   LookupTable:       A = rows (vec handle),               B = unused
enum MmLayout {
    MM_TAG  = 0,
    MM_A    = 8,
    MM_B    = 16,
    MM_SIZE = 24,
}

# ================================================================
# LorentzianResonance -- X(w) = X_bg * [1 - w_p^2 / (w^2 - w_0^2 + i*g*w)]
# ================================================================
#derive(accessors)
struct LorentzianResonance { center_hz; plasma_hz; damping_hz; background_value; }

# Complex value (re, im) -- replaces Rust's (f32, f32) tuple return.
#derive(accessors)
struct MmComplex { re; im; }

#must_use
fn lorentzian_resonance_new(center_hz, plasma_hz, damping_hz, background_value) {
    var r = alloc(sizeof(LorentzianResonance));
    LorentzianResonance_set_center_hz(r, center_hz);
    LorentzianResonance_set_plasma_hz(r, plasma_hz);
    LorentzianResonance_set_damping_hz(r, damping_hz);
    LorentzianResonance_set_background_value(r, background_value);
    return r;
}

# Pick background_value so the DC value (w->0) equals dc_value exactly.
# X(0) = X_bg * (1 + (w_p/w_0)^2); invert for X_bg.
#must_use
fn lorentzian_with_dc_value(center_hz, plasma_hz, damping_hz, dc_value) {
    var center = f64_max(center_hz, GOONJ_EPSILON);
    var ratio = f64_div(plasma_hz, center);
    var factor = f64_add(F64_ONE, f64_mul(ratio, ratio));
    var bg = f64_div(dc_value, factor);
    return lorentzian_resonance_new(center_hz, plasma_hz, damping_hz, bg);
}

# Evaluate X(w) at frequency_hz; returns an MmComplex (re, im).
#must_use
fn lorentzian_evaluate(r, frequency_hz) {
    var omega = f64_mul(F64_TAU, frequency_hz);
    var omega_0 = f64_mul(F64_TAU, LorentzianResonance_center_hz(r));
    var omega_p = f64_mul(F64_TAU, LorentzianResonance_plasma_hz(r));
    var gamma = f64_mul(F64_TAU, LorentzianResonance_damping_hz(r));
    var omega2 = f64_mul(omega, omega);
    var omega_0_2 = f64_mul(omega_0, omega_0);
    var omega_p_2 = f64_mul(omega_p, omega_p);
    var diff = f64_sub(omega2, omega_0_2);
    var denom = f64_add(f64_mul(diff, diff), f64_mul(f64_mul(gamma, gamma), omega2));
    var bg = LorentzianResonance_background_value(r);

    var c = alloc(sizeof(MmComplex));
    if (f64_lt(denom, GOONJ_EPSILON) == 1) {
        MmComplex_set_re(c, bg);
        MmComplex_set_im(c, 0);
        return c;
    }
    # real = X_bg * (1 - w_p^2 * (w^2 - w_0^2) / denom)
    var real = f64_mul(bg, f64_sub(F64_ONE, f64_div(f64_mul(omega_p_2, diff), denom)));
    # imag = X_bg * w_p^2 * g * w / denom
    var imag = f64_div(f64_mul(f64_mul(bg, omega_p_2), f64_mul(gamma, omega)), denom);
    MmComplex_set_re(c, real);
    MmComplex_set_im(c, imag);
    return c;
}

# Real part of X(w) -- negative around resonance for strong enough plasma_hz.
#must_use
fn lorentzian_real_part(r, frequency_hz) {
    return MmComplex_re(lorentzian_evaluate(r, frequency_hz));
}

# ================================================================
# Metamaterial constructors (tagged union)
# ================================================================
#must_use
fn metamaterial_negative_stiffness(k_eff, rho) {
    var m = alloc(MM_SIZE);
    store64(m + MM_TAG, MM_NEG_STIFFNESS);
    store64(m + MM_A, k_eff);
    store64(m + MM_B, rho);
    return m;
}

#must_use
fn metamaterial_negative_density(rho_eff, k_modulus) {
    var m = alloc(MM_SIZE);
    store64(m + MM_TAG, MM_NEG_DENSITY);
    store64(m + MM_A, rho_eff);
    store64(m + MM_B, k_modulus);
    return m;
}

#must_use
fn metamaterial_doubly_negative(k_eff, rho_eff) {
    var m = alloc(MM_SIZE);
    store64(m + MM_TAG, MM_DOUBLY_NEGATIVE);
    store64(m + MM_A, k_eff);
    store64(m + MM_B, rho_eff);
    return m;
}

#must_use
fn metamaterial_lookup_table(rows) {
    var m = alloc(MM_SIZE);
    store64(m + MM_TAG, MM_LOOKUP_TABLE);
    store64(m + MM_A, rows);
    store64(m + MM_B, 0);
    return m;
}

# New (freq, absorption) lookup-row vec, and a paired-push helper.
#must_use
fn mm_rows_new() { return vec_new(); }
fn mm_rows_push(rows, frequency_hz, absorption) {
    vec_push(rows, frequency_hz);
    vec_push(rows, absorption);
    return 0;
}

# ================================================================
# Normal-incidence bulk absorption from complex (K_eff, rho_eff) vs air.
# Z = sqrt(rho*K), R = (Z - Z0)/(Z + Z0), alpha = 1 - |R|^2.
# ================================================================
#must_use
fn _mm_impedance_absorption(k_re, k_im, rho_re, rho_im) {
    # rho * K (complex multiply)
    var prod_r = f64_sub(f64_mul(rho_re, k_re), f64_mul(rho_im, k_im));
    var prod_i = f64_add(f64_mul(rho_re, k_im), f64_mul(rho_im, k_re));
    # Principal sqrt(prod) = sqrt|prod| * (cos(arg/2) + i*sin(arg/2))
    var mag = f64_sqrt(f64_add(f64_mul(prod_r, prod_r), f64_mul(prod_i, prod_i)));
    var phase = f64_atan2(prod_i, prod_r);
    var sqrt_mag = f64_sqrt(mag);
    var half_phase = f64_mul(phase, F64_HALF);
    var z_r = f64_mul(sqrt_mag, f64_cos(half_phase));
    var z_i = f64_mul(sqrt_mag, f64_sin(half_phase));
    # R = (Z - Z0)/(Z + Z0)
    var num_r = f64_sub(z_r, AIR_IMPEDANCE_RAYLS);
    var num_i = z_i;
    var den_r = f64_add(z_r, AIR_IMPEDANCE_RAYLS);
    var den_i = z_i;
    var den_mag2 = f64_add(f64_mul(den_r, den_r), f64_mul(den_i, den_i));
    if (f64_lt(den_mag2, GOONJ_EPSILON) == 1) {
        return F64_ONE;
    }
    var r_mag2 = f64_div(f64_add(f64_mul(num_r, num_r), f64_mul(num_i, num_i)), den_mag2);
    return f64_clamp(f64_sub(F64_ONE, r_mag2), 0, F64_ONE);
}

# Linear interpolation of a sorted (freq, absorption) lookup table.
# Outside the range the endpoint absorption is held.
#must_use
fn _mm_lookup_absorption(rows, frequency_hz) {
    var len = vec_len(rows);
    if (len == 0) { return 0; }
    var nrows = len / 2;
    var f0 = vec_get(rows, 0);
    var a0 = vec_get(rows, 1);
    if (nrows == 1) { return f64_clamp(a0, 0, F64_ONE); }
    if (f64_le(frequency_hz, f0) == 1) { return f64_clamp(a0, 0, F64_ONE); }
    var last_f = vec_get(rows, (nrows - 1) * 2);
    var last_a = vec_get(rows, (nrows - 1) * 2 + 1);
    if (f64_ge(frequency_hz, last_f) == 1) { return f64_clamp(last_a, 0, F64_ONE); }

    var i = 0;
    while (i < nrows - 1) {
        var f_a = vec_get(rows, i * 2);
        var a_a = vec_get(rows, i * 2 + 1);
        var f_b = vec_get(rows, (i + 1) * 2);
        var a_b = vec_get(rows, (i + 1) * 2 + 1);
        # if frequency_hz >= f_a && frequency_hz <= f_b  (sequential ifs)
        if (f64_ge(frequency_hz, f_a) == 1) {
            if (f64_le(frequency_hz, f_b) == 1) {
                var span = f64_max(f64_sub(f_b, f_a), GOONJ_EPSILON);
                var frac = f64_div(f64_sub(frequency_hz, f_a), span);
                var val = f64_add(a_a, f64_mul(f64_sub(a_b, a_a), frac));
                return f64_clamp(val, 0, F64_ONE);
            }
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Metamaterial queries
# ================================================================
# Absorption coefficient at frequency_hz, in 0..1.
#must_use
fn metamaterial_absorption_at(m, frequency_hz) {
    var tag = load64(m + MM_TAG);
    if (tag == MM_NEG_STIFFNESS) {
        var k = lorentzian_evaluate(load64(m + MM_A), frequency_hz);
        var rho = load64(m + MM_B);
        return _mm_impedance_absorption(MmComplex_re(k), MmComplex_im(k), rho, 0);
    }
    if (tag == MM_NEG_DENSITY) {
        var k_modulus = load64(m + MM_B);
        var rho = lorentzian_evaluate(load64(m + MM_A), frequency_hz);
        return _mm_impedance_absorption(k_modulus, 0, MmComplex_re(rho), MmComplex_im(rho));
    }
    if (tag == MM_DOUBLY_NEGATIVE) {
        var k = lorentzian_evaluate(load64(m + MM_A), frequency_hz);
        var rho = lorentzian_evaluate(load64(m + MM_B), frequency_hz);
        return _mm_impedance_absorption(MmComplex_re(k), MmComplex_im(k), MmComplex_re(rho), MmComplex_im(rho));
    }
    # MM_LOOKUP_TABLE
    return _mm_lookup_absorption(load64(m + MM_A), frequency_hz);
}

# Absorption coefficients for the 8 ISO octave bands (63-8000 Hz).
# Returns a pointer to an inline 8*f64 buffer.
#must_use
fn metamaterial_absorption_bands(m) {
    var buf = alloc(NUM_BANDS * 8);
    var band = 0;
    while (band < NUM_BANDS) {
        store64(buf + band * 8, metamaterial_absorption_at(m, frequency_band(band)));
        band = band + 1;
    }
    return buf;
}

# Convert to an AcousticMaterial for use as a wall material.
# Returns the material pointer, or 0 on the Result::Err path (invalid params).
#must_use
fn metamaterial_to_acoustic_material(m, name, scattering) {
    var bands = metamaterial_absorption_bands(m);
    return acoustic_material_new(name, bands, scattering);
}

# --- fdn.cyr ---

# fdn.cyr -- Feedback Delay Network (FDN) for late-reverberation synthesis.
#
# Ports rust-old/src/fdn.rs. f32 -> f64 throughout. Rust's serde derive on
# FdnConfig is dropped (no serde in Cyrius). The nested `Vec<Vec<f32>>`
# delay lines become a stdlib `vec` of `vec` handles; the `Vec<u32>` /
# `Vec<f32>` / `Vec<usize>` fields are stdlib `vec`s holding the value
# directly in each 8-byte slot (f64 as its bit pattern, counts as ints).
# Methods become free `fdn_*` functions taking the struct pointer.
#
# Requires (from the build/test unit): stdlib alloc/vec (alloc_init, vec_*),
# math/ganita (F64_ONE/TWO/HALF, f64_*), and propagation.cyr
# (speed_of_sound). The module file itself has no `include` lines.

# ================================================================
# FdnConfig -- reverberator configuration.
#   num_delays     : delay-line count (usize)
#   delay_lengths  : vec<u32> delay lengths in samples (one per line)
#   feedback_gains : vec<f32> per-line absorption gains (empty = auto)
#   sample_rate    : u32 Hz
#   target_rt60    : f32 seconds (used when feedback_gains is empty)
# ================================================================
#derive(accessors)
struct FdnConfig { num_delays; delay_lengths; feedback_gains; sample_rate; target_rt60; }

# ================================================================
# Fdn -- N parallel delay lines + Householder feedback matrix.
#   delay_lines     : vec of vec<f32> ring buffers
#   write_positions : vec<usize> per-line write cursor
#   feedback_gains  : vec<f32> per-line gains
#   scratch         : vec<f32> per-sample read buffer (no per-sample alloc)
#   sample_rate     : u32 Hz (retained; unused in processing, as in Rust)
# ================================================================
#derive(accessors)
struct Fdn { delay_lines; write_positions; feedback_gains; scratch; sample_rate; }

# ================================================================
# fdn_config_for_room -- 8-line FDN config from room dimensions.
# ================================================================

# Samples for one base delay: (2.0 * d / c * sample_rate) as u32, min 1.
fn _delay_samples(d, c, sample_rate) {
    var samples_f = f64_mul(f64_div(f64_mul(F64_TWO, d), c), f64_from(sample_rate));
    var samples = f64_to(samples_f);
    if (samples < 1) { samples = 1; }
    return samples;
}

# FDN config for a shoebox room: 8 delay lines whose lengths approximate
# the room's modal round-trip times. Mirrors fdn_config_for_room.
#must_use
fn fdn_config_for_room(length, width, height, rt60, sample_rate) {
    var c = speed_of_sound(f64_from(20));

    # base_delays[0..8] from Rust (round-trip distances per dimension/combo).
    var d0 = length;
    var d1 = width;
    var d2 = height;
    var d3 = f64_mul(f64_add(length, width), F64_HALF);
    var d4 = f64_mul(f64_add(length, height), F64_HALF);
    var d5 = f64_mul(f64_add(width, height), F64_HALF);
    var d6 = f64_div(f64_add(f64_add(length, width), height), f64_from(3));
    var d7 = f64_max(f64_max(length, width), height);

    var delay_lengths = vec_new();
    vec_push(delay_lengths, _delay_samples(d0, c, sample_rate));
    vec_push(delay_lengths, _delay_samples(d1, c, sample_rate));
    vec_push(delay_lengths, _delay_samples(d2, c, sample_rate));
    vec_push(delay_lengths, _delay_samples(d3, c, sample_rate));
    vec_push(delay_lengths, _delay_samples(d4, c, sample_rate));
    vec_push(delay_lengths, _delay_samples(d5, c, sample_rate));
    vec_push(delay_lengths, _delay_samples(d6, c, sample_rate));
    vec_push(delay_lengths, _delay_samples(d7, c, sample_rate));

    var config = alloc(sizeof(FdnConfig));
    FdnConfig_set_num_delays(config, 8);
    FdnConfig_set_delay_lengths(config, delay_lengths);
    FdnConfig_set_feedback_gains(config, vec_new());
    FdnConfig_set_sample_rate(config, sample_rate);
    FdnConfig_set_target_rt60(config, rt60);
    return config;
}

# ================================================================
# fdn_new -- build an FDN from configuration.
# ================================================================
#must_use
fn fdn_new(config) {
    var n = FdnConfig_num_delays(config);
    var delay_lengths = FdnConfig_delay_lengths(config);
    var dl_len = vec_len(delay_lengths);
    var sample_rate = FdnConfig_sample_rate(config);
    var target_rt60 = FdnConfig_target_rt60(config);
    var cfg_gains = FdnConfig_feedback_gains(config);

    # .take(n) on delay_lengths == min(n, dl_len).
    var take = n;
    if (dl_len < take) { take = dl_len; }

    # delay_lines: vec![0.0; len.max(1)] per taken delay length.
    var delay_lines = vec_new();
    var i = 0;
    while (i < take) {
        var len = vec_get(delay_lengths, i);
        if (len < 1) { len = 1; }
        var line = vec_new();
        var j = 0;
        while (j < len) {
            vec_push(line, 0);
            j = j + 1;
        }
        vec_push(delay_lines, line);
        i = i + 1;
    }

    # feedback_gains: use config gains if it supplies >= n; else from RT60.
    var feedback_gains = vec_new();
    if (vec_len(cfg_gains) >= n) {
        var k = 0;
        while (k < n) {
            vec_push(feedback_gains, vec_get(cfg_gains, k));
            k = k + 1;
        }
    } else {
        # gain = 10^(-3 * delay_time / RT60), delay_time = len / max(sr, 1).
        var sr = sample_rate;
        if (sr < 1) { sr = 1; }
        var g = 0;
        while (g < take) {
            var glen = vec_get(delay_lengths, g);
            var delay_time = f64_div(f64_from(glen), f64_from(sr));
            var gain = 0;
            if (f64_gt(target_rt60, 0) == 1) {
                var expo = f64_div(f64_mul(f64_neg(f64_from(3)), delay_time), target_rt60);
                gain = f64_pow(f64_from(10), expo);
            }
            vec_push(feedback_gains, gain);
            g = g + 1;
        }
    }

    # write_positions = vec![0; n], scratch = vec![0.0; n].
    var write_positions = vec_new();
    var scratch = vec_new();
    var p = 0;
    while (p < n) {
        vec_push(write_positions, 0);
        vec_push(scratch, 0);
        p = p + 1;
    }

    var fdn = alloc(sizeof(Fdn));
    Fdn_set_delay_lines(fdn, delay_lines);
    Fdn_set_write_positions(fdn, write_positions);
    Fdn_set_feedback_gains(fdn, feedback_gains);
    Fdn_set_scratch(fdn, scratch);
    Fdn_set_sample_rate(fdn, sample_rate);
    return fdn;
}

# ================================================================
# fdn_process_sample -- one input sample -> mixed output.
# Householder feedback matrix (all-pass, energy preserving); no per-sample
# allocation (reuses the scratch buffer). Not #must_use: callers legitimately
# discard the return when only advancing internal delay-line state (warmup).
# ================================================================
fn fdn_process_sample(fdn, input) {
    var delay_lines = Fdn_delay_lines(fdn);
    var n = vec_len(delay_lines);
    if (n == 0) { return input; }

    var write_positions = Fdn_write_positions(fdn);
    var scratch = Fdn_scratch(fdn);
    var feedback_gains = Fdn_feedback_gains(fdn);

    # Read each delay line into scratch; accumulate the output sum.
    var output_sum = 0;
    var i = 0;
    while (i < n) {
        var line = vec_get(delay_lines, i);
        var len = vec_len(line);
        var read_pos = (vec_get(write_positions, i) + 1) % len;
        var s = vec_get(line, read_pos);
        vec_set(scratch, i, s);
        output_sum = f64_add(output_sum, s);
        i = i + 1;
    }

    # Householder feedback: factor = 2/n, correction = factor * sum.
    var factor = f64_div(F64_TWO, f64_from(n));
    var correction = f64_mul(factor, output_sum);
    var input_per_line = f64_div(input, f64_from(n));

    i = 0;
    while (i < n) {
        var fb = f64_sub(vec_get(scratch, i), correction);
        var line = vec_get(delay_lines, i);
        var len = vec_len(line);
        var wp = vec_get(write_positions, i);
        var written = f64_add(input_per_line, f64_mul(fb, vec_get(feedback_gains, i)));
        vec_set(line, wp, written);
        vec_set(write_positions, i, (wp + 1) % len);
        i = i + 1;
    }

    # Normalized output: output_sum / sqrt(n).
    return f64_div(output_sum, f64_sqrt(f64_from(n)));
}

# ================================================================
# fdn_process_buffer -- map process_sample over a vec of input samples.
# ================================================================
#must_use
fn fdn_process_buffer(fdn, input) {
    var out = vec_new();
    var n = vec_len(input);
    var i = 0;
    while (i < n) {
        vec_push(out, fdn_process_sample(fdn, vec_get(input, i)));
        i = i + 1;
    }
    return out;
}

# ================================================================
# fdn_reset -- clear all delay lines to silence and rewind every cursor.
# ================================================================
fn fdn_reset(fdn) {
    var delay_lines = Fdn_delay_lines(fdn);
    var n = vec_len(delay_lines);
    var i = 0;
    while (i < n) {
        var line = vec_get(delay_lines, i);
        var len = vec_len(line);
        var j = 0;
        while (j < len) {
            vec_set(line, j, 0);
            j = j + 1;
        }
        i = i + 1;
    }
    var write_positions = Fdn_write_positions(fdn);
    var m = vec_len(write_positions);
    var k = 0;
    while (k < m) {
        vec_set(write_positions, k, 0);
        k = k + 1;
    }
    return 0;
}

# --- gfpe.cyr ---

# gfpe.cyr -- Green's Function Parabolic Equation (GFPE) outdoor
# propagation: one-way Helmholtz in a 2D vertical slice (range x height),
# marched by dr with the analytic PE Green's function plus a ground image
# source, an atmospheric phase screen, and a terrain staircase.
#
# Ports rust-old/src/gfpe.rs. f32 -> f64 throughout. Rust's `serde` derive
# is dropped (no serde in Cyrius); the two serialization round-trip tests
# are omitted. The complex field psi (Rust `Vec<(f32,f32)>`) becomes two
# parallel f64 buffers (real / imag) indexed by load64/store64; complex
# arithmetic is inlined to keep the O(N^2) convolution allocation-free.
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON),
# propagation.cyr (GroundImpedance + GroundImpedance_flow_resistivity),
# and stdlib math/ganita (F64_*, f64_cos/sin/sqrt/exp/pow/ln/atan) and
# vec (vec_new/push/len/get/set); alloc_init() must have run.

# ================================================================
# Constants (f64 bit patterns; decimal in comments for traceability)
# ================================================================
var GFPE_MIKI_ZR  = 0x3FB1E4F765FD8ADB;   # 0.0699   Miki Z_real coefficient
var GFPE_MIKI_EXP = 0xBFE4395810624DD3;   # -0.632   Miki frequency exponent
var GFPE_MIKI_ZI  = 0xBFBB6AE7D566CF42;   # -0.1071  Miki Z_imag coefficient
var GFPE_1E3      = 0x3F50624DD2F1A9FC;   # 0.001    minimum grazing angle
var GFPE_POS_INF  = 0x7FF0000000000000;   # +inf     blocked / out-of-range EA

# Maximum allowed grid cells (height x range), to bound memory.
var GFPE_MAX_GRID_CELLS = 10000000;

# log10(x) = ln(x) / ln(10)
fn _gfpe_log10(x) { return f64_div(f64_ln(x), F64_LN10); }

# ================================================================
# GfpeAtmosphere -- linear sound-speed gradient c(z) = ref + grad*z.
# ================================================================
#derive(accessors)
struct GfpeAtmosphere { gradient_per_m; reference_speed; }

#must_use
fn gfpe_atmosphere_new(gradient_per_m, reference_speed) {
    var a = alloc(sizeof(GfpeAtmosphere));
    GfpeAtmosphere_set_gradient_per_m(a, gradient_per_m);
    GfpeAtmosphere_set_reference_speed(a, reference_speed);
    return a;
}

# Default: flat atmosphere, 343 m/s reference.
#must_use
fn gfpe_atmosphere_default() { return gfpe_atmosphere_new(0, f64_from(343)); }

# ================================================================
# GfpeTerrain -- elevation profile along the range axis (two vecs).
# ================================================================
#derive(accessors)
struct GfpeTerrain { ranges_m; heights_m; }

#must_use
fn gfpe_terrain_new(ranges_m, heights_m) {
    var t = alloc(sizeof(GfpeTerrain));
    GfpeTerrain_set_ranges_m(t, ranges_m);
    GfpeTerrain_set_heights_m(t, heights_m);
    return t;
}

# Flat ground at z=0 over [0, max_range].
#must_use
fn gfpe_terrain_flat(max_range_m) {
    var r = vec_new();
    vec_push(r, 0);
    vec_push(r, f64_max(max_range_m, 0));
    var h = vec_new();
    vec_push(h, 0);
    vec_push(h, 0);
    return gfpe_terrain_new(r, h);
}

# Linearly interpolated ground height at range_m; endpoint held outside.
#must_use
fn gfpe_terrain_height_at(t, range_m) {
    var ranges = GfpeTerrain_ranges_m(t);
    var heights = GfpeTerrain_heights_m(t);
    var nr = vec_len(ranges);
    var nh = vec_len(heights);
    if (nr == 0) { return 0; }
    if (nr != nh) { return 0; }
    if (f64_le(range_m, vec_get(ranges, 0)) == 1) { return vec_get(heights, 0); }
    var last = nr - 1;
    if (f64_ge(range_m, vec_get(ranges, last)) == 1) { return vec_get(heights, last); }
    var i = 0;
    while (i < last) {
        var r0 = vec_get(ranges, i);
        var r1 = vec_get(ranges, i + 1);
        # range_m >= r0 && range_m <= r1
        var in_seg = 0;
        if (f64_ge(range_m, r0) == 1) {
            if (f64_le(range_m, r1) == 1) { in_seg = 1; }
        }
        if (in_seg == 1) {
            var span = f64_max(f64_sub(r1, r0), GOONJ_EPSILON);
            var frac = f64_div(f64_sub(range_m, r0), span);
            var h0 = vec_get(heights, i);
            var h1 = vec_get(heights, i + 1);
            return f64_add(h0, f64_mul(f64_sub(h1, h0), frac));
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# GfpeConfig -- simulation parameters.
# ================================================================
#derive(accessors)
struct GfpeConfig {
    frequency_hz;
    source_height_m;
    max_range_m;
    max_height_m;
    range_step_m;
    height_step_m;
    ground_impedance;
    atmosphere;
}

#must_use
fn gfpe_config_new(frequency_hz, source_height_m, max_range_m, max_height_m,
range_step_m, height_step_m, ground_impedance, atmosphere) {
    var c = alloc(sizeof(GfpeConfig));
    GfpeConfig_set_frequency_hz(c, frequency_hz);
    GfpeConfig_set_source_height_m(c, source_height_m);
    GfpeConfig_set_max_range_m(c, max_range_m);
    GfpeConfig_set_max_height_m(c, max_height_m);
    GfpeConfig_set_range_step_m(c, range_step_m);
    GfpeConfig_set_height_step_m(c, height_step_m);
    GfpeConfig_set_ground_impedance(c, ground_impedance);
    GfpeConfig_set_atmosphere(c, atmosphere);
    return c;
}

# ================================================================
# GfpeResult -- excess attenuation (dB) on the (range x height) grid.
# ================================================================
#derive(accessors)
struct GfpeResult { ranges_m; heights_m; excess_attenuation_db; }

#must_use
fn gfpe_result_new(ranges_m, heights_m, excess_attenuation_db) {
    var r = alloc(sizeof(GfpeResult));
    GfpeResult_set_ranges_m(r, ranges_m);
    GfpeResult_set_heights_m(r, heights_m);
    GfpeResult_set_excess_attenuation_db(r, excess_attenuation_db);
    return r;
}

#must_use
fn gfpe_result_num_ranges(r) { return vec_len(GfpeResult_ranges_m(r)); }
#must_use
fn gfpe_result_num_heights(r) { return vec_len(GfpeResult_heights_m(r)); }

# Excess attenuation (dB) at (range_idx, height_idx); +inf if out of range.
#must_use
fn gfpe_result_at(r, range_idx, height_idx) {
    var nz = gfpe_result_num_heights(r);
    if (range_idx >= gfpe_result_num_ranges(r)) { return GFPE_POS_INF; }
    if (height_idx >= nz) { return GFPE_POS_INF; }
    return vec_get(GfpeResult_excess_attenuation_db(r), range_idx * nz + height_idx);
}

# ================================================================
# GfpeCplx -- a complex number (real, imag) for the reflection coeff.
# ================================================================
#derive(accessors)
struct GfpeCplx { re; im; }

#must_use
fn _gfpe_cplx_one() {
    var c = alloc(sizeof(GfpeCplx));
    GfpeCplx_set_re(c, F64_ONE);
    GfpeCplx_set_im(c, 0);
    return c;
}

# Complex Miki reflection coefficient at a given grazing angle.
# Returns a GfpeCplx (1 + 0i for degenerate inputs).
#must_use
fn gfpe_ground_reflection_complex(frequency_hz, grazing_angle_rad, impedance) {
    var resistivity = GroundImpedance_flow_resistivity(impedance);
    if (f64_le(frequency_hz, 0) == 1) { return _gfpe_cplx_one(); }
    if (f64_le(resistivity, 0) == 1) { return _gfpe_cplx_one(); }

    var x = f64_div(frequency_hz, resistivity);
    # Miki normalised surface impedance Z/rho c
    var x_pow = f64_pow(x, GFPE_MIKI_EXP);
    var z_real = f64_add(F64_ONE, f64_mul(GFPE_MIKI_ZR, x_pow));
    var z_imag = f64_mul(GFPE_MIKI_ZI, x_pow);

    var sin_theta = f64_sin(grazing_angle_rad);
    var num_re = f64_sub(f64_mul(z_real, sin_theta), F64_ONE);
    var num_im = f64_mul(z_imag, sin_theta);
    var den_re = f64_add(f64_mul(z_real, sin_theta), F64_ONE);
    var den_im = f64_mul(z_imag, sin_theta);
    var den_mag2 = f64_add(f64_mul(den_re, den_re), f64_mul(den_im, den_im));
    if (f64_lt(den_mag2, GOONJ_EPSILON) == 1) { return _gfpe_cplx_one(); }

    # R = num / den = num * conj(den) / |den|^2
    var r_re = f64_div(f64_add(f64_mul(num_re, den_re), f64_mul(num_im, den_im)), den_mag2);
    var r_im = f64_div(f64_sub(f64_mul(num_im, den_re), f64_mul(num_re, den_im)), den_mag2);
    var c = alloc(sizeof(GfpeCplx));
    GfpeCplx_set_re(c, r_re);
    GfpeCplx_set_im(c, r_im);
    return c;
}

# ================================================================
# Direct half-space PE convolution (in-place into out_re/out_im).
# psi_new(z) = integral G(z,z';dr) psi(z') dz', G = free-space PE kernel
# minus a ground-image term scaled by the reflection coefficient.
# psi_re/psi_im/out_re/out_im are nz-long f64 buffers; heights is a vec.
# ================================================================
fn _gfpe_convolve_pe_step(psi_re, psi_im, heights, nz, dr, dz, k0, r_re, r_im, out_re, out_im) {
    # Free-space kernel coeff: |coeff| = sqrt(k0/(2 pi dr)); phase = -pi/4.
    var coeff_mag = f64_sqrt(f64_div(k0, f64_mul(F64_TAU, dr)));
    var coeff_phase = f64_neg(f64_div(F64_PI, f64_from(4)));
    var coeff_re = f64_mul(coeff_mag, f64_cos(coeff_phase));
    var coeff_im = f64_mul(coeff_mag, f64_sin(coeff_phase));
    var two_dr = f64_mul(F64_TWO, dr);

    var i = 0;
    while (i < nz) {
        var z = vec_get(heights, i);
        var acc_re = 0;
        var acc_im = 0;
        var j = 0;
        while (j < nz) {
            var z_prime = vec_get(heights, j);
            # Direct term: g_d = coeff * exp(i*k0*(z-z')^2/(2 dr))
            var dz_diff = f64_sub(z, z_prime);
            var phase_d = f64_div(f64_mul(k0, f64_mul(dz_diff, dz_diff)), two_dr);
            var ed_re = f64_cos(phase_d);
            var ed_im = f64_sin(phase_d);
            var gd_re = f64_sub(f64_mul(coeff_re, ed_re), f64_mul(coeff_im, ed_im));
            var gd_im = f64_add(f64_mul(coeff_re, ed_im), f64_mul(coeff_im, ed_re));
            # Image term: g_i = coeff * exp(i*k0*(z+z')^2/(2 dr)) * r_complex
            var dz_sum = f64_add(z, z_prime);
            var phase_i = f64_div(f64_mul(k0, f64_mul(dz_sum, dz_sum)), two_dr);
            var ei_re = f64_cos(phase_i);
            var ei_im = f64_sin(phase_i);
            var gif_re = f64_sub(f64_mul(coeff_re, ei_re), f64_mul(coeff_im, ei_im));
            var gif_im = f64_add(f64_mul(coeff_re, ei_im), f64_mul(coeff_im, ei_re));
            var gi_re = f64_sub(f64_mul(gif_re, r_re), f64_mul(gif_im, r_im));
            var gi_im = f64_add(f64_mul(gif_re, r_im), f64_mul(gif_im, r_re));
            # G_total = direct - image
            var gt_re = f64_sub(gd_re, gi_re);
            var gt_im = f64_sub(gd_im, gi_im);
            # contribution = G_total * psi[j], Riemann-summed with weight dz
            var pr = load64(psi_re + j * 8);
            var pim = load64(psi_im + j * 8);
            var c_re = f64_sub(f64_mul(gt_re, pr), f64_mul(gt_im, pim));
            var c_im = f64_add(f64_mul(gt_re, pim), f64_mul(gt_im, pr));
            acc_re = f64_add(acc_re, f64_mul(c_re, dz));
            acc_im = f64_add(acc_im, f64_mul(c_im, dz));
            j = j + 1;
        }
        store64(out_re + i * 8, acc_re);
        store64(out_im + i * 8, acc_im);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Record excess attenuation at the current range slice into ea_vec.
# ================================================================
fn _gfpe_record_ea(psi_re, psi_im, heights, range_m, terrain, ea_vec, r_idx, nz) {
    var ground = gfpe_terrain_height_at(terrain, range_m);
    var r_safe = f64_max(range_m, GOONJ_EPSILON);
    # 2D free-field reference: |psi_free| proportional to 1/sqrt(r).
    var free_ref = f64_div(F64_ONE, f64_sqrt(r_safe));
    var h_idx = 0;
    while (h_idx < nz) {
        var z = vec_get(heights, h_idx);
        var s_re = load64(psi_re + h_idx * 8);
        var s_im = load64(psi_im + h_idx * 8);
        var mag = f64_sqrt(f64_add(f64_mul(s_re, s_re), f64_mul(s_im, s_im)));
        # z < ground || mag < eps || free_ref < eps  -> blocked (+inf)
        var blocked = 0;
        if (f64_lt(z, ground) == 1) { blocked = 1; }
        if (f64_lt(mag, GOONJ_EPSILON) == 1) { blocked = 1; }
        if (f64_lt(free_ref, GOONJ_EPSILON) == 1) { blocked = 1; }
        var ea = GFPE_POS_INF;
        if (blocked == 0) {
            ea = f64_mul(f64_neg(f64_from(20)), _gfpe_log10(f64_div(mag, free_ref)));
        }
        vec_set(ea_vec, r_idx * nz + h_idx, ea);
        h_idx = h_idx + 1;
    }
    return 0;
}

#must_use
fn _gfpe_empty_result() { return gfpe_result_new(vec_new(), vec_new(), vec_new()); }

# ================================================================
# Solve GFPE over a terrain profile.
# ================================================================
#must_use
fn solve_gfpe(terrain, config) {
    var freq = GfpeConfig_frequency_hz(config);
    var max_range = GfpeConfig_max_range_m(config);
    var max_height = GfpeConfig_max_height_m(config);
    var range_step = GfpeConfig_range_step_m(config);
    var height_step = GfpeConfig_height_step_m(config);
    var atmosphere = GfpeConfig_atmosphere(config);
    var ref_speed = GfpeAtmosphere_reference_speed(atmosphere);
    var gradient = GfpeAtmosphere_gradient_per_m(atmosphere);

    if (f64_le(freq, 0) == 1) { return _gfpe_empty_result(); }
    if (f64_le(max_range, 0) == 1) { return _gfpe_empty_result(); }
    if (f64_le(max_height, 0) == 1) { return _gfpe_empty_result(); }
    if (f64_le(range_step, 0) == 1) { return _gfpe_empty_result(); }
    if (f64_le(height_step, 0) == 1) { return _gfpe_empty_result(); }
    if (f64_le(ref_speed, 0) == 1) { return _gfpe_empty_result(); }

    var nz = f64_to(f64_div(max_height, height_step));
    if (nz < 2) { nz = 2; }
    var num_ranges = f64_to(f64_div(max_range, range_step));
    if (num_ranges < 1) { num_ranges = 1; }
    num_ranges = num_ranges + 1;

    # saturating_mul guard in f64 to avoid i64 overflow on huge grids.
    var cells = f64_mul(f64_from(nz), f64_from(num_ranges));
    if (f64_gt(cells, f64_from(GFPE_MAX_GRID_CELLS)) == 1) { return _gfpe_empty_result(); }

    var dz = f64_div(max_height, f64_from(nz));
    var dr = range_step;
    var k0 = f64_div(f64_mul(F64_TAU, freq), ref_speed);

    # Grid coordinates.
    var heights = vec_new();
    var i = 0;
    while (i < nz) {
        vec_push(heights, f64_mul(f64_add(f64_from(i), F64_HALF), dz));
        i = i + 1;
    }
    var ranges = vec_new();
    i = 0;
    while (i < num_ranges) {
        vec_push(ranges, f64_mul(f64_from(i), dr));
        i = i + 1;
    }

    # Initial field at r=0: Gaussian starter centred at source_height_m.
    var src_h = GfpeConfig_source_height_m(config);
    var sigma = f64_max(f64_div(f64_from(4), k0), dz);
    var psi_re = alloc(nz * 8);
    var psi_im = alloc(nz * 8);
    i = 0;
    while (i < nz) {
        var z = vec_get(heights, i);
        var arg = f64_div(f64_sub(z, src_h), sigma);
        var amp = f64_exp(f64_mul(f64_neg(F64_HALF), f64_mul(arg, arg)));
        store64(psi_re + i * 8, amp);
        store64(psi_im + i * 8, 0);
        i = i + 1;
    }

    # Excess-attenuation grid (row-major), zero-filled, then record r=0.
    var ea = vec_new();
    var total = num_ranges * nz;
    i = 0;
    while (i < total) {
        vec_push(ea, 0);
        i = i + 1;
    }
    _gfpe_record_ea(psi_re, psi_im, heights, vec_get(ranges, 0), terrain, ea, 0, nz);

    # Reflection coefficient at a representative grazing angle.
    var rep_angle = f64_max(
    f64_atan(f64_div(f64_max(src_h, dz), f64_max(max_range, dr))),
    GFPE_1E3);
    var rcplx = gfpe_ground_reflection_complex(freq, rep_angle, GfpeConfig_ground_impedance(config));
    var r_re = GfpeCplx_re(rcplx);
    var r_im = GfpeCplx_im(rcplx);

    # Scratch buffers for the convolution output (ping-ponged with psi).
    var out_re = alloc(nz * 8);
    var out_im = alloc(nz * 8);

    var r_idx = 1;
    while (r_idx < num_ranges) {
        var range = vec_get(ranges, r_idx);

        # 1. Phase screen for the atmosphere (in place on psi).
        i = 0;
        while (i < nz) {
            var pz = vec_get(heights, i);
            var c_z = f64_add(ref_speed, f64_mul(gradient, pz));
            # n^2 - 1 ~ (c0/c)^2 - 1
            var ratio = f64_div(ref_speed, f64_max(c_z, F64_ONE));
            var n2_minus_1 = f64_sub(f64_mul(ratio, ratio), F64_ONE);
            var phase = f64_mul(f64_mul(f64_mul(F64_HALF, k0), n2_minus_1), dr);
            var e_re = f64_cos(phase);
            var e_im = f64_sin(phase);
            var s_re = load64(psi_re + i * 8);
            var s_im = load64(psi_im + i * 8);
            store64(psi_re + i * 8, f64_sub(f64_mul(s_re, e_re), f64_mul(s_im, e_im)));
            store64(psi_im + i * 8, f64_add(f64_mul(s_re, e_im), f64_mul(s_im, e_re)));
            i = i + 1;
        }

        # 2. Convolve with the PE Green's function, then swap psi <- out.
        _gfpe_convolve_pe_step(psi_re, psi_im, heights, nz, dr, dz, k0, r_re, r_im, out_re, out_im);
        var t_re = psi_re;
        psi_re = out_re;
        out_re = t_re;
        var t_im = psi_im;
        psi_im = out_im;
        out_im = t_im;

        # 3. Apply terrain: zero field below local ground.
        var ground = gfpe_terrain_height_at(terrain, range);
        i = 0;
        while (i < nz) {
            if (f64_lt(vec_get(heights, i), ground) == 1) {
                store64(psi_re + i * 8, 0);
                store64(psi_im + i * 8, 0);
            }
            i = i + 1;
        }

        _gfpe_record_ea(psi_re, psi_im, heights, range, terrain, ea, r_idx, nz);
        r_idx = r_idx + 1;
    }

    return gfpe_result_new(ranges, heights, ea);
}

# --- diffusion.cyr ---

# diffusion.cyr -- acoustic diffusion equation (ADE) energy-density PDE
# solver. Models sound energy density as a diffusion process (Fick's law
# analogy) for high-frequency diffuse fields: long rooms, coupled rooms,
# and industrial spaces where ray tracing struggles.
#
# Ports rust-old/src/diffusion.rs. f32 -> f64. Rust's `serde` derive is
# dropped (no serde in Cyrius); the serde round-trip test is omitted.
# Rust's `Vec<f32>` energy field -> stdlib `vec` (f64 in 8-byte slots);
# the `&[f32]` absorption/source slices -> a raw f64 buffer pointer plus
# an element count; the `[usize; 2]` dimensions -> two scalar fields.
#
# Requires (from the build/test unit): stdlib math (f64_* + F64_*),
# vec (vec_new/push/len/get/set), alloc (alloc_init must have run).
#
# Reference: Valeau et al., "On the use of a diffusion equation for
# room-acoustic prediction," JASA 119(3), 2006.

# Configuration for the acoustic diffusion equation solver. Fields:
# dx (grid spacing m), dt (time step s), nx/ny (grid cells), speed_of_sound
# (m/s), mean_free_path (m, ~ 4V/S), max_time (simulation duration s).
#derive(accessors)
struct DiffusionConfig {
    dx;
    dt;
    nx;
    ny;
    speed_of_sound;
    mean_free_path;
    max_time;
}

#must_use
fn diffusion_config_new(dx, dt, nx, ny, speed_of_sound, mean_free_path, max_time) {
    var c = alloc(sizeof(DiffusionConfig));
    DiffusionConfig_set_dx(c, dx);
    DiffusionConfig_set_dt(c, dt);
    DiffusionConfig_set_nx(c, nx);
    DiffusionConfig_set_ny(c, ny);
    DiffusionConfig_set_speed_of_sound(c, speed_of_sound);
    DiffusionConfig_set_mean_free_path(c, mean_free_path);
    DiffusionConfig_set_max_time(c, max_time);
    return c;
}

# Result of a diffusion simulation. `energy_density` is a vec of n f64
# (flattened, [y * nx + x]); dimensions = (dim_x, dim_y).
#derive(accessors)
struct DiffusionResult { energy_density; dim_x; dim_y; time_steps; dx; }

#must_use
fn _diff_result_new(energy_density, dim_x, dim_y, time_steps, dx) {
    var r = alloc(sizeof(DiffusionResult));
    DiffusionResult_set_energy_density(r, energy_density);
    DiffusionResult_set_dim_x(r, dim_x);
    DiffusionResult_set_dim_y(r, dim_y);
    DiffusionResult_set_time_steps(r, time_steps);
    DiffusionResult_set_dx(r, dx);
    return r;
}

# usize::clamp(v, 3, 2000) — cap grid size to prevent OOM (~4M cells max).
fn _diff_clamp_grid(v) {
    if (v < 3) { return 3; }
    if (v > 2000) { return 2000; }
    return v;
}

# A fresh vec of `n` zeros (f64 +0.0 shares integer 0's bit pattern).
fn _diff_zeros(n) {
    var v = vec_new();
    var i = 0;
    while (i < n) {
        vec_push(v, 0);
        i = i + 1;
    }
    return v;
}

# Solve the 2D acoustic diffusion equation on a regular grid using
# explicit finite differences (FTCS):
#   dw/dt = D*lap(w) - c/lambda * alpha * w + S(x,t),
#   D = c*lambda/3 (diffusion coefficient), lambda = mean free path.
# absorption_field / source_field are raw f64 buffers of `*_len` elems
# (pass 0/0 for an empty slice). Returns a DiffusionResult pointer.
#must_use
fn solve_diffusion_2d(config, absorption_field, absorption_len, source_field, source_len) {
    var dx = DiffusionConfig_dx(config);
    var nx = _diff_clamp_grid(DiffusionConfig_nx(config));
    var ny = _diff_clamp_grid(DiffusionConfig_ny(config));
    var n = nx * ny;

    var c = DiffusionConfig_speed_of_sound(config);
    var mfp = DiffusionConfig_mean_free_path(config);
    var dt_cfg = DiffusionConfig_dt(config);

    # Invalid config: any non-positive dx/dt/mfp/speed -> empty result.
    var bad = 0;
    if (f64_le(dx, 0) == 1) { bad = 1; }
    if (f64_le(dt_cfg, 0) == 1) { bad = 1; }
    if (f64_le(mfp, 0) == 1) { bad = 1; }
    if (f64_le(c, 0) == 1) { bad = 1; }
    if (bad == 1) {
        return _diff_result_new(_diff_zeros(n), nx, ny, 0, dx);
    }

    var d_coeff = f64_div(f64_mul(c, mfp), f64_from(3));   # diffusion coefficient
    var dx2 = f64_mul(dx, dx);

    # Stability: dt < dx^2 / (4 D) for the 2D explicit scheme; use 0.9 of it.
    var dt_max = f64_div(dx2, f64_mul(f64_from(4), d_coeff));
    var dt = f64_min(dt_cfg, f64_mul(dt_max, f64_div(f64_from(9), f64_from(10))));
    var num_steps = f64_to(f64_div(DiffusionConfig_max_time(config), dt));
    if (num_steps > 1000000) { num_steps = 1000000; }

    var w = _diff_zeros(n);       # energy density
    var w_new = _diff_zeros(n);

    # Initialize source (take at most n elements).
    var lim = source_len;
    if (lim > n) { lim = n; }
    var si = 0;
    while (si < lim) {
        vec_set(w, si, load64(source_field + si * 8));
        si = si + 1;
    }

    var ratio = f64_div(f64_mul(d_coeff, dt), dx2);
    var c_over_mfp = f64_div(c, mfp);

    var step = 0;
    while (step < num_steps) {
        var y = 1;
        while (y < ny - 1) {
            var x = 1;
            while (x < nx - 1) {
                var idx = y * nx + x;
                var wc = vec_get(w, idx);
                var laplacian = f64_sub(
                f64_add(
                f64_add(vec_get(w, idx - 1), vec_get(w, idx + 1)),
                f64_add(vec_get(w, idx - nx), vec_get(w, idx + nx))),
                f64_mul(f64_from(4), wc));

                # Absorption term (0 beyond the supplied field).
                var alpha = 0;
                if (idx < absorption_len) { alpha = load64(absorption_field + idx * 8); }
                var absorp = f64_mul(f64_mul(c_over_mfp, alpha), wc);

                var wn = f64_sub(f64_add(wc, f64_mul(ratio, laplacian)), f64_mul(dt, absorp));
                vec_set(w_new, idx, f64_max(wn, 0));   # energy can't go negative
                x = x + 1;
            }
            y = y + 1;
        }
        # std::mem::swap(&mut w, &mut w_new)
        var tmp = w;
        w = w_new;
        w_new = tmp;
        step = step + 1;
    }

    return _diff_result_new(w, nx, ny, num_steps, dx);
}

# --- fdtd.cyr ---

# fdtd.cyr -- 2D FDTD modal solver per Botteldooren 1995.
#
# Explicit finite-difference time-domain solver for the 2D acoustic wave
# equation `d2p/dt2 = c^2 grad^2 p` on a regular Cartesian grid with rigid
# (Neumann) boundaries. Best for low-frequency modal behaviour below the
# Schroeder frequency, where ray methods break down and interference
# dominates. Reference: Botteldooren, JASA 98(6), 1995.
#
# Ports rust-old/src/fdtd.rs. f32 -> f64. Rust's `serde` derive on the
# config/source/receiver/result structs is dropped (no serde in Cyrius);
# the two serde round-trip tests are therefore omitted. The `[f32; 8]`
# band-energy return becomes an alloc'd 8xf64 buffer (read with
# load64(buf + band*8)), mirroring hybrid.cyr. The grid pressure fields
# are raw alloc'd 8-byte-per-cell buffers (load64/store64) for the hot
# loop; `Vec<f32>` receiver traces + `final_pressure` use stdlib vec.
#
# Requires (from the build/test unit): material.cyr (NUM_BANDS,
# frequency_band), stdlib math/ganita (F64_*, f64_*), vec, and alloc;
# alloc_init() must have run.

# Courant-Friedrichs-Lewy upper bound for 2D FDTD: c*dt/dx <= 1/sqrt(2).
var CFL_2D_LIMIT = 0x3FE6A09E667F3BCD;   # 1/sqrt(2) ~ 0.70710678
# Maximum allowed grid cells nx*ny to bound memory.
var MAX_GRID_CELLS = 4000000;
# Maximum allowed time-step count to bound runtime.
var MAX_TIME_STEPS = 1000000;

# ================================================================
# FdtdConfig -- simulation parameters for a rigid-walled box.
#   sample_rate (int), dx (f64), speed_of_sound (f64), nx (int),
#   ny (int), duration_seconds (f64).
# ================================================================
#derive(accessors)
struct FdtdConfig {
    sample_rate;
    dx;
    speed_of_sound;
    nx;
    ny;
    duration_seconds;
}

#must_use
fn fdtd_config_new(sample_rate, dx, speed_of_sound, nx, ny, duration_seconds) {
    var c = alloc(sizeof(FdtdConfig));
    FdtdConfig_set_sample_rate(c, sample_rate);
    FdtdConfig_set_dx(c, dx);
    FdtdConfig_set_speed_of_sound(c, speed_of_sound);
    FdtdConfig_set_nx(c, nx);
    FdtdConfig_set_ny(c, ny);
    FdtdConfig_set_duration_seconds(c, duration_seconds);
    return c;
}

# Rust Default: 22050 Hz, dx 0.05 m, c 343 m/s, 80x80, 0.5 s.
#must_use
fn fdtd_config_default() {
    return fdtd_config_new(22050, pct(5), f64_from(343), 80, 80, F64_HALF);
}

# ================================================================
# FdtdSource -- additive pressure source at one grid cell.
#   ix (int), iy (int), signal (vec of f64 samples).
# ================================================================
#derive(accessors)
struct FdtdSource {
    ix;
    iy;
    signal;
}

#must_use
fn fdtd_source_new(ix, iy, signal) {
    var s = alloc(sizeof(FdtdSource));
    FdtdSource_set_ix(s, ix);
    FdtdSource_set_iy(s, iy);
    FdtdSource_set_signal(s, signal);
    return s;
}

# Gaussian pulse centred at peak_step with width sigma_steps samples;
# energy spread covers ~6 sigma steps. A broad-spectrum impulse.
#must_use
fn fdtd_source_gaussian_pulse(ix, iy, peak_step, sigma_steps, amplitude) {
    var span = f64_add(f64_from(peak_step), f64_mul(f64_from(6), sigma_steps));
    var n = f64_to(f64_ceil(span));
    if (n < 1) {
        n = 1;
    }
    var inv_sigma = f64_div(F64_ONE, f64_max(sigma_steps, F64_ONE));
    var signal = vec_new();
    var i = 0;
    while (i < n) {
        var arg = f64_mul(f64_sub(f64_from(i), f64_from(peak_step)), inv_sigma);
        var e = f64_exp(f64_mul(f64_mul(f64_neg(F64_HALF), arg), arg));
        vec_push(signal, f64_mul(amplitude, e));
        i = i + 1;
    }
    return fdtd_source_new(ix, iy, signal);
}

# ================================================================
# FdtdReceiver -- a grid cell whose pressure history is recorded.
# ================================================================
#derive(accessors)
struct FdtdReceiver {
    ix;
    iy;
}

#must_use
fn fdtd_receiver_new(ix, iy) {
    var r = alloc(sizeof(FdtdReceiver));
    FdtdReceiver_set_ix(r, ix);
    FdtdReceiver_set_iy(r, iy);
    return r;
}

# ================================================================
# FdtdResult -- solver output.
#   receiver_signals (vec of inner vecs, one per receiver),
#   final_pressure (vec, row-major y*nx + x), time_steps (int),
#   dt (f64, effective time step).
# ================================================================
#derive(accessors)
struct FdtdResult {
    receiver_signals;
    final_pressure;
    time_steps;
    dt;
}

# Empty result for degenerate input (Rust's empty_result()).
#must_use
fn fdtd_empty_result() {
    var r = alloc(sizeof(FdtdResult));
    FdtdResult_set_receiver_signals(r, vec_new());
    FdtdResult_set_final_pressure(r, vec_new());
    FdtdResult_set_time_steps(r, 0);
    FdtdResult_set_dt(r, 0);
    return r;
}

# Allocate an n-cell f64 grid buffer, zero-initialised.
#must_use
fn _fdtd_alloc_zeros(n) {
    var buf = alloc(n * 8);
    var i = 0;
    while (i < n) {
        store64(buf + i * 8, 0);
        i = i + 1;
    }
    return buf;
}

# ================================================================
# solve_fdtd_2d -- solve the 2D acoustic wave equation on a rigid box.
# `receivers` is a vec of FdtdReceiver pointers. Returns an empty result
# on degenerate input (zero grid, sub-CFL dt, out-of-range source, etc.).
# ================================================================
#must_use
fn solve_fdtd_2d(config, source, receivers) {
    var sample_rate = FdtdConfig_sample_rate(config);
    var dx = FdtdConfig_dx(config);
    var speed_of_sound = FdtdConfig_speed_of_sound(config);
    var nx = FdtdConfig_nx(config);
    var ny = FdtdConfig_ny(config);
    var duration = FdtdConfig_duration_seconds(config);

    if (sample_rate == 0) {
        return fdtd_empty_result();
    }
    if (f64_le(dx, 0) == 1) {
        return fdtd_empty_result();
    }
    if (f64_le(speed_of_sound, 0) == 1) {
        return fdtd_empty_result();
    }
    if (nx < 3) {
        return fdtd_empty_result();
    }
    if (ny < 3) {
        return fdtd_empty_result();
    }
    if (f64_le(duration, 0) == 1) {
        return fdtd_empty_result();
    }
    if (nx * ny > MAX_GRID_CELLS) {
        return fdtd_empty_result();
    }

    var source_ix = FdtdSource_ix(source);
    var source_iy = FdtdSource_iy(source);
    if (source_ix >= nx) {
        return fdtd_empty_result();
    }
    if (source_iy >= ny) {
        return fdtd_empty_result();
    }

    var dt = f64_div(F64_ONE, f64_from(sample_rate));
    var cfl = f64_div(f64_mul(speed_of_sound, dt), dx);
    if (f64_gt(cfl, CFL_2D_LIMIT) == 1) {
        return fdtd_empty_result();
    }

    var num_steps = f64_to(f64_div(duration, dt));
    if (num_steps > MAX_TIME_STEPS) {
        num_steps = MAX_TIME_STEPS;
    }
    if (num_steps == 0) {
        return fdtd_empty_result();
    }

    var n = nx * ny;
    var p_prev = _fdtd_alloc_zeros(n);
    var p_curr = _fdtd_alloc_zeros(n);
    var p_next = _fdtd_alloc_zeros(n);
    var cfl_sq = f64_mul(cfl, cfl);

    var source_signal = FdtdSource_signal(source);
    var siglen = vec_len(source_signal);

    # One inner trace vec per receiver (empty for out-of-range receivers).
    var receiver_signals = vec_new();
    var nrecv = vec_len(receivers);
    var ri = 0;
    while (ri < nrecv) {
        vec_push(receiver_signals, vec_new());
        ri = ri + 1;
    }

    var top_row = (ny - 1) * nx;
    var below_top = (ny - 2) * nx;

    var step = 0;
    while (step < num_steps) {
        # Interior 5-point Laplacian + leapfrog update.
        var y = 1;
        while (y < ny - 1) {
            var row = y * nx;
            var x = 1;
            while (x < nx - 1) {
                var idx = row + x;
                var c = load64(p_curr + idx * 8);
                var sum = f64_add(load64(p_curr + (idx - 1) * 8), load64(p_curr + (idx + 1) * 8));
                sum = f64_add(sum, load64(p_curr + (idx - nx) * 8));
                sum = f64_add(sum, load64(p_curr + (idx + nx) * 8));
                var lap = f64_sub(sum, f64_mul(f64_from(4), c));
                var two_c = f64_mul(F64_TWO, c);
                var val = f64_add(f64_sub(two_c, load64(p_prev + idx * 8)), f64_mul(cfl_sq, lap));
                store64(p_next + idx * 8, val);
                x = x + 1;
            }
            y = y + 1;
        }

        # Rigid walls: copy the adjacent interior cell (dp/dn = 0).
        var ex = 1;
        while (ex < nx - 1) {
            store64(p_next + ex * 8, load64(p_next + (ex + nx) * 8));
            store64(p_next + (top_row + ex) * 8, load64(p_next + (below_top + ex) * 8));
            ex = ex + 1;
        }
        var ey = 1;
        while (ey < ny - 1) {
            var lrow = ey * nx;
            store64(p_next + lrow * 8, load64(p_next + (lrow + 1) * 8));
            store64(p_next + (lrow + nx - 1) * 8, load64(p_next + (lrow + nx - 2) * 8));
            ey = ey + 1;
        }

        # Corners: average of adjacent edges.
        store64(p_next, f64_mul(F64_HALF, f64_add(load64(p_next + 8), load64(p_next + nx * 8))));
        var br = f64_add(load64(p_next + (nx - 2) * 8), load64(p_next + (2 * nx - 1) * 8));
        store64(p_next + (nx - 1) * 8, f64_mul(F64_HALF, br));
        var tl = f64_add(load64(p_next + (top_row + 1) * 8), load64(p_next + (top_row - nx) * 8));
        store64(p_next + top_row * 8, f64_mul(F64_HALF, tl));
        var trc = f64_add(load64(p_next + (top_row + nx - 2) * 8),
        load64(p_next + (top_row + nx - 1 - nx) * 8));
        store64(p_next + (top_row + nx - 1) * 8, f64_mul(F64_HALF, trc));

        # Source injection (additive).
        if (step < siglen) {
            var sidx = source_iy * nx + source_ix;
            store64(p_next + sidx * 8, f64_add(load64(p_next + sidx * 8), vec_get(source_signal, step)));
        }

        # Sample receivers.
        var rj = 0;
        while (rj < nrecv) {
            var rx = vec_get(receivers, rj);
            var rxix = FdtdReceiver_ix(rx);
            var rxiy = FdtdReceiver_iy(rx);
            var inrange = 0;
            if (rxix < nx) {
                if (rxiy < ny) {
                    inrange = 1;
                }
            }
            if (inrange == 1) {
                var trace = vec_get(receiver_signals, rj);
                vec_push(trace, load64(p_next + (rxiy * nx + rxix) * 8));
            }
            rj = rj + 1;
        }

        # Rotate buffers: prev<-curr, curr<-next, next<-old prev.
        var tmp = p_prev;
        p_prev = p_curr;
        p_curr = tmp;
        tmp = p_curr;
        p_curr = p_next;
        p_next = tmp;

        step = step + 1;
    }

    # final_pressure snapshot = current field after the last rotation.
    var final_pressure = vec_new();
    var fi = 0;
    while (fi < n) {
        vec_push(final_pressure, load64(p_curr + fi * 8));
        fi = fi + 1;
    }

    var result = alloc(sizeof(FdtdResult));
    FdtdResult_set_receiver_signals(result, receiver_signals);
    FdtdResult_set_final_pressure(result, final_pressure);
    FdtdResult_set_time_steps(result, num_steps);
    FdtdResult_set_dt(result, dt);
    return result;
}

# Zero an 8-band (NUM_BANDS) f64 buffer.
fn _fdtd_zero_bands(out) {
    var i = 0;
    while (i < NUM_BANDS) {
        store64(out + i * 8, 0);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# band_energies -- per-band energies from a time-domain signal via a
# single-bin Goertzel evaluation at each ISO octave centre frequency.
# `signal` is a vec of f64 samples. Returns an alloc'd NUM_BANDS x f64
# buffer of |X(f_band)|^2, clamped to >= 0.
# ================================================================
#must_use
fn band_energies(signal, sample_rate) {
    var out = alloc(NUM_BANDS * 8);
    var siglen = vec_len(signal);
    if (siglen == 0) {
        _fdtd_zero_bands(out);
        return out;
    }
    if (sample_rate == 0) {
        _fdtd_zero_bands(out);
        return out;
    }
    var inv_sr = f64_div(F64_ONE, f64_from(sample_rate));
    var band = 0;
    while (band < NUM_BANDS) {
        var f = frequency_band(band);
        var omega = f64_mul(f64_mul(F64_TAU, f), inv_sr);
        var coeff = f64_mul(F64_TWO, f64_cos(omega));
        var s_prev = 0;
        var s_prev2 = 0;
        var i = 0;
        while (i < siglen) {
            var x = vec_get(signal, i);
            var s = f64_sub(f64_add(x, f64_mul(coeff, s_prev)), s_prev2);
            s_prev2 = s_prev;
            s_prev = s;
            i = i + 1;
        }
        var sq = f64_add(f64_mul(s_prev, s_prev), f64_mul(s_prev2, s_prev2));
        var mag = f64_sub(sq, f64_mul(f64_mul(coeff, s_prev), s_prev2));
        store64(out + band * 8, f64_max(mag, 0));
        band = band + 1;
    }
    return out;
}

# --- outdoor.cyr ---

# outdoor.cyr -- ISO 9613-2 outdoor sound propagation: barrier
# diffraction, foliage attenuation, meteorological correction, and
# ground effect.
#
# Ports rust-old/src/outdoor.rs. f32 -> f64. Per-band returns
# ([f32; NUM_BANDS]) become an alloc(NUM_BANDS * 8) buffer of f64; the
# caller reads each band with load64(buf + band * 8). Frequency band
# centres come from material.frequency_band; the speed of sound comes
# from propagation.speed_of_sound.
#
# Self-contained: no `include` lines. Relies on the build/test unit
# providing material (NUM_BANDS, frequency_band), propagation
# (speed_of_sound), and stdlib math (F64_ONE, F64_TWO, F64_HALF,
# F64_LN10, f64_div/mul/add/sub/min/max/clamp/abs/neg/ln).

# log10(x) = ln(x) / ln(10)
fn _outdoor_log10(x) {
    return f64_div(f64_ln(x), F64_LN10);
}

# ================================================================
# Barrier diffraction (Maekawa, single edge)
# ================================================================

# Insertion loss (dB, positive = attenuation) of a thin barrier.
#   path_difference -- extra path over the barrier vs direct path (m)
#   frequency       -- Hz
# Maekawa: IL = 10 * log10(3 + 20*N), N = 2*delta/lambda (Fresnel number).
#must_use
fn barrier_insertion_loss(path_difference, frequency, temperature_celsius) {
    if (f64_le(path_difference, 0) == 1) { return 0; }
    if (f64_le(frequency, 0) == 1) { return 0; }

    var c = speed_of_sound(temperature_celsius);
    var wavelength = f64_div(c, frequency);

    # Fresnel number: N = 2*delta / lambda
    var fresnel_n = f64_div(f64_mul(F64_TWO, path_difference), wavelength);

    # Maekawa approximation (single edge)
    if (f64_lt(fresnel_n, 0) == 1) { return 0; }
    var inner = f64_add(f64_from(3), f64_mul(f64_from(20), fresnel_n));
    return f64_max(f64_mul(f64_from(10), _outdoor_log10(inner)), 0);
}

# Per-band barrier insertion loss. Returns an alloc(NUM_BANDS * 8)
# buffer; band i is at load64(buf + i * 8).
#must_use
fn barrier_insertion_loss_bands(path_difference, temperature_celsius) {
    var out = alloc(NUM_BANDS * 8);
    var band = 0;
    while (band < NUM_BANDS) {
        var il = barrier_insertion_loss(path_difference, frequency_band(band), temperature_celsius);
        store64(out + band * 8, il);
        band = band + 1;
    }
    return out;
}

# ================================================================
# Foliage attenuation (ISO 9613-2 Annex)
# ================================================================

# Attenuation (dB) of a foliage belt of given depth at a frequency.
# Rate ~0.01-0.12 dB/m, rising up to 8 kHz; capped at 10 dB total.
#must_use
fn foliage_attenuation(depth_m, frequency) {
    if (f64_le(depth_m, 0) == 1) { return 0; }
    if (f64_le(frequency, 0) == 1) { return 0; }

    var f_khz = f64_div(frequency, f64_from(1000));
    var clamped = f64_clamp(f_khz, 0, f64_from(8));
    # rate = 0.01 + 0.014 * clamp(f_khz, 0, 8)
    var base_rate = f64_div(F64_ONE, f64_from(100));            # 0.01
    var per_khz = f64_div(f64_from(14), f64_from(1000));        # 0.014
    var rate = f64_add(base_rate, f64_mul(per_khz, clamped));
    # Cap at 10 dB per ISO.
    return f64_min(f64_mul(rate, depth_m), f64_from(10));
}

# ================================================================
# Meteorological correction C_met (ISO 9613-2)
# ================================================================

# Correction (dB) for favourable propagation (downwind / inversion).
# 0 for short distances; positive for long distances.
#must_use
fn meteorological_correction(distance, source_height, receiver_height) {
    if (f64_le(distance, 0) == 1) { return 0; }

    # ISO 9613-2: uses the sum of heights h_s + h_r (not the average).
    var h_sum = f64_add(source_height, receiver_height);
    var dp = f64_sub(distance, f64_mul(f64_from(10), h_sum));
    if (f64_le(dp, 0) == 1) { return 0; }

    # C_0 depends on meteorological conditions (typically 0-3.5 dB).
    var half_seven = f64_div(f64_from(7), f64_from(2));         # 3.5
    var c0 = 0;
    if (f64_gt(distance, f64_from(1000)) == 1) {
        c0 = half_seven;
    } else {
        if (f64_gt(distance, f64_from(100)) == 1) {
            # (distance - 100) / 900 * 3.5
            c0 = f64_mul(f64_div(f64_sub(distance, f64_from(100)), f64_from(900)), half_seven);
        } else {
            c0 = 0;
        }
    }

    # C_met = C_0 * max(1 - 10*(h_s + h_r)/d, 0)
    var factor = f64_max(f64_sub(F64_ONE, f64_div(f64_mul(f64_from(10), h_sum), distance)), 0);
    return f64_mul(c0, factor);
}

# ================================================================
# Ground effect (ISO 9613-2 simplified)
# ================================================================

# Per-band ground attenuation (dB, in [-20, 0]). ground_factor G:
# 0 = hard ground, 1 = soft/porous. Returns an alloc(NUM_BANDS * 8)
# buffer; band i is at load64(buf + i * 8).
#must_use
fn ground_attenuation(distance, source_height, receiver_height, ground_factor) {
    var out = alloc(NUM_BANDS * 8);
    if (f64_le(distance, 0) == 1) {
        var z = 0;
        while (z < NUM_BANDS) {
            store64(out + z * 8, 0);
            z = z + 1;
        }
        return out;
    }

    var g = f64_clamp(ground_factor, 0, F64_ONE);
    var h_s = f64_max(source_height, 0);
    var h_r = f64_max(receiver_height, 0);
    var dp = f64_max(distance, F64_ONE);

    var neg_half = f64_neg(f64_div(f64_from(3), f64_from(2)));  # -1.5

    var band = 0;
    while (band < NUM_BANDS) {
        var f = frequency_band(band);

        # Soft-ground region term: -1.5 + g*(-1.5 + 3*min(f/500, 1))
        var fr = f64_min(f64_div(f, f64_from(500)), F64_ONE);
        var soft = f64_add(neg_half, f64_mul(g, f64_add(neg_half, f64_mul(f64_from(3), fr))));

        # Source region ground effect.
        var a_s = neg_half;
        if (f64_lt(h_s, F64_HALF) == 1) { a_s = soft; }

        # Receiver region ground effect.
        var a_r = neg_half;
        if (f64_lt(h_r, F64_HALF) == 1) { a_r = soft; }

        # Middle region: proportional to distance and G.
        var mid_factor = f64_max(f64_sub(F64_ONE,
        f64_div(f64_mul(f64_from(30), f64_add(h_s, h_r)), dp)), 0);
        var a_m = f64_mul(f64_mul(f64_neg(f64_from(3)), g), mid_factor);

        var total = f64_add(f64_add(a_s, a_m), a_r);
        store64(out + band * 8, f64_clamp(total, f64_neg(f64_from(20)), 0));
        band = band + 1;
    }
    return out;
}

# --- portal.cyr ---

# portal.cyr -- portal-based sound propagation through openings between
# rooms (doorways, windows, apertures). A portal connects two spaces and
# passes energy between them with frequency-dependent attenuation from
# aperture diffraction.
#
# Ports rust-old/src/portal.rs. f32 -> f64. Rust's `serde` derive is
# dropped (no serde in Cyrius); the serde round-trip test is omitted.
# The `[f32; NUM_BANDS]` return arrays become pointers to an inline
# 8xf64 block (alloc(NUM_BANDS * 8)); read a band with load64(buf + band * 8).
#
# Requires (from the build/test unit): hisab HVec3 (hvec3_*), error.cyr
# (GOONJ_EPSILON), material.cyr (NUM_BANDS, frequency_band),
# propagation.cyr (speed_of_sound), and stdlib math/ganita (F64_PI,
# F64_ONE, f64_sqrt/div/mul/min/abs/clamp).

# Portal opening: centre position + normal (both HVec3 ptrs; normal points
# into the destination room) and width/height in metres.
#derive(accessors)
struct Portal { position; normal; width; height; }

#must_use
fn portal_new(position, normal, width, height) {
    var p = alloc(sizeof(Portal));
    Portal_set_position(p, position);
    Portal_set_normal(p, normal);
    Portal_set_width(p, width);
    Portal_set_height(p, height);
    return p;
}

# Allocate an 8xf64 band buffer filled with 0.0 (0.0's bit pattern is 0).
#must_use
fn _portal_zeros() {
    var out = alloc(NUM_BANDS * 8);
    var i = 0;
    while (i < NUM_BANDS) {
        store64(out + i * 8, 0);
        i = i + 1;
    }
    return out;
}

# Area of the portal opening in m^2.
#must_use
fn portal_area(p) {
    return f64_mul(Portal_width(p), Portal_height(p));
}

# Frequency-dependent transmission factor (0..1) per octave band.
# Low freq (wavelength >> aperture) diffracts partially; high freq
# (wavelength << aperture) passes freely. Smooth sigmoid around ratio = 1:
# (ratio / (1 + ratio)).clamp(0, 1), ratio = characteristic_size / lambda.
# Returns a pointer to NUM_BANDS f64; all zero if the aperture is degenerate.
#must_use
fn portal_transmission_factor(p, temperature_celsius) {
    var characteristic_size = f64_sqrt(f64_mul(Portal_width(p), Portal_height(p)));
    if (f64_le(characteristic_size, 0) == 1) { return _portal_zeros(); }

    var c = speed_of_sound(temperature_celsius);
    var out = alloc(NUM_BANDS * 8);
    var band = 0;
    while (band < NUM_BANDS) {
        var freq = frequency_band(band);
        var wavelength = f64_div(c, freq);
        var ratio = f64_div(characteristic_size, wavelength);
        var factor = f64_clamp(f64_div(ratio, f64_add(F64_ONE, ratio)), 0, F64_ONE);
        store64(out + band * 8, factor);
        band = band + 1;
    }
    return out;
}

# Energy transmitted through a portal from source to listener (per band,
# 0..1). Combines aperture diffraction (transmission factor), directional
# coupling along source->portal->listener, and a two-stage inverse-square
# distance attenuation with area-weighted collection. Returns a pointer to
# NUM_BANDS f64; all zero if source or listener sits on the portal.
#must_use
fn portal_energy_transfer(source, portal, listener, temperature_celsius) {
    var to_portal = hvec3_sub(Portal_position(portal), source);
    var from_portal = hvec3_sub(listener, Portal_position(portal));
    var d_source = hvec3_length(to_portal);
    var d_listener = hvec3_length(from_portal);

    if (f64_lt(d_source, GOONJ_EPSILON) == 1) { return _portal_zeros(); }
    if (f64_lt(d_listener, GOONJ_EPSILON) == 1) { return _portal_zeros(); }

    # Directional coupling: alignment of source->portal->listener with normal.
    var src_dir = hvec3_scale(to_portal, f64_div(F64_ONE, d_source));
    var lis_dir = hvec3_scale(from_portal, f64_div(F64_ONE, d_listener));
    var cos_in = f64_abs(hvec3_dot(src_dir, Portal_normal(portal)));
    var cos_out = f64_abs(hvec3_dot(lis_dir, Portal_normal(portal)));
    var directional = f64_mul(cos_in, cos_out);

    # Two-stage inverse square: 4*pi * d_source^2 * d_listener^2, area-weighted.
    var pi4 = f64_mul(f64_from(4), F64_PI);
    var denom = f64_mul(f64_mul(pi4, f64_mul(d_source, d_source)), f64_mul(d_listener, d_listener));
    var distance_atten = f64_min(f64_div(portal_area(portal), denom), F64_ONE);

    var freq_factors = portal_transmission_factor(portal, temperature_celsius);
    var out = alloc(NUM_BANDS * 8);
    var band = 0;
    while (band < NUM_BANDS) {
        var ff = load64(freq_factors + band * 8);
        var e = f64_clamp(f64_mul(f64_mul(ff, directional), distance_atten), 0, F64_ONE);
        store64(out + band * 8, e);
        band = band + 1;
    }
    return out;
}

# --- udfa.cyr ---

# udfa.cyr -- Universal Diffraction Filter Approximation (UDFA).
#
# Filter-based diffraction model for real-time applications. Approximates
# diffraction effects as minimum-phase IIR filters, enabling efficient
# higher-order diffraction interactions around finite objects.
# Reference: Acta Acustica, 2024 -- "Universal Diffraction Filter Approximation."
#
# Ports rust-old/src/udfa.rs. f32 -> f64. Rust's `serde` derive is dropped
# (no serde in Cyrius); the serde round-trip test is therefore omitted.
# The `DiffractionFilter` struct (an `[f32; 8]` attenuation array plus two
# scalars) is an inline manual-layout block, mirroring material's
# AcousticMaterial. The Rust `&[DiffractionFilter]` slice argument of
# chain_diffraction_filters becomes a stdlib `vec` of filter pointers.
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON),
# material.cyr (NUM_BANDS, frequency_band), propagation.cyr
# (speed_of_sound), stdlib math/ganita (F64_ONE, F64_TWO, F64_LN10,
# f64_*) and vec (vec_len/vec_get).

# DiffractionFilter inline layout: 8xf64 attenuation | delay | quality.
enum DfLayout {
    DF_ATTEN = 0,    # offsets 0..64 (8 f64), per-band attenuation in dB
    DF_DELAY = 64,   # phase delay in seconds (extra path / speed of sound)
    DF_QUAL  = 72,   # filter quality (higher = sharper transition)
    DF_SIZE  = 80,
}

# Constants that aren't clean integers (f64 bit patterns; decimal in comment).
var UDFA_FRESNEL_MIN = 0x3F847AE147AE147B;   # 0.01  Fresnel-number cutoff
var UDFA_CLAMP_LO    = 0x3FB999999999999A;   # 0.1   quality clamp minimum
var UDFA_F64_MAX     = 0x7FEFFFFFFFFFFFFF;   # f64::MAX seed for min-quality

# log10(x) = ln(x) / ln(10)
fn _udfa_log10(x) { return f64_div(f64_ln(x), F64_LN10); }

# ================================================================
# DiffractionFilter accessors (manual layout)
# ================================================================
#must_use
fn df_delay_seconds(f) { return load64(f + DF_DELAY); }
#must_use
fn df_quality(f) { return load64(f + DF_QUAL); }
#must_use
fn df_attenuation_band(f, band) { return load64(f + DF_ATTEN + band * 8); }
fn _df_set_band(f, band, v) { store64(f + DF_ATTEN + band * 8, v); return 0; }

# Per-band attenuation (negative dB) for the UDFA spectral shape.
#   wavelength = c / freq;  fresnel_n = 2 * path_difference / wavelength
#   base_loss  = 0                         if fresnel_n < 0.01
#              = 10 * log10(3 + 20 N) * finite_correction   otherwise
#   atten      = -max(base_loss, 0)
fn _udfa_band_atten(c, path_difference, finite_correction, freq) {
    var wavelength = f64_div(c, freq);
    var fresnel_n = f64_div(f64_mul(F64_TWO, path_difference), wavelength);
    var base_loss = 0;
    if (f64_lt(fresnel_n, UDFA_FRESNEL_MIN) == 1) {
        # very low Fresnel number: no significant diffraction loss
        base_loss = 0;
    } else {
        # Maekawa IL ~ 10*log10(3 + 20 N), with finite-edge correction.
        var inner = f64_add(f64_from(3), f64_mul(f64_from(20), fresnel_n));
        base_loss = f64_mul(f64_mul(f64_from(10), _udfa_log10(inner)), finite_correction);
    }
    return f64_neg(f64_max(base_loss, 0));   # negative = attenuation
}

# Compute the UDFA diffraction filter for a single edge.
#   path_difference     -- extra path length around the edge vs direct (m)
#   edge_length         -- length of the diffracting edge (m)
#   temperature_celsius -- air temperature
#must_use
fn compute_diffraction_filter(path_difference, edge_length, temperature_celsius) {
    var f = alloc(DF_SIZE);

    if (f64_le(path_difference, 0) == 1) {
        var z = 0;
        while (z < NUM_BANDS) { _df_set_band(f, z, 0); z = z + 1; }
        store64(f + DF_DELAY, 0);
        store64(f + DF_QUAL, F64_ONE);
        return f;
    }

    var c = speed_of_sound(temperature_celsius);
    var delay = f64_div(path_difference, c);

    # Finite-edge correction: zero-length edge -> no diffraction,
    # long edge -> full diffraction.
    var finite_correction = 0;
    if (f64_gt(edge_length, GOONJ_EPSILON) == 1) {
        finite_correction = f64_sqrt(f64_div(edge_length, f64_add(edge_length, path_difference)));
    }

    var i = 0;
    while (i < NUM_BANDS) {
        var atten = _udfa_band_atten(c, path_difference, finite_correction, frequency_band(i));
        _df_set_band(f, i, atten);
        i = i + 1;
    }

    store64(f + DF_DELAY, delay);
    # Filter quality based on geometry: (path_difference * 10).clamp(0.1, 10).
    var quality = f64_clamp(f64_mul(path_difference, f64_from(10)), UDFA_CLAMP_LO, f64_from(10));
    store64(f + DF_QUAL, quality);
    return f;
}

# Apply a sequence of diffraction filters (higher-order diffraction).
# `filters` is a stdlib vec of DiffractionFilter pointers. Total
# attenuation is the per-band sum (dB), total delay the sum of delays,
# and quality the minimum quality across edges.
#must_use
fn chain_diffraction_filters(filters) {
    var result = alloc(DF_SIZE);
    var i = 0;
    while (i < NUM_BANDS) { _df_set_band(result, i, 0); i = i + 1; }

    var n = vec_len(filters);
    if (n == 0) {
        store64(result + DF_DELAY, 0);
        store64(result + DF_QUAL, F64_ONE);
        return result;
    }

    var total_delay = 0;
    var min_quality = UDFA_F64_MAX;

    var k = 0;
    while (k < n) {
        var filt = vec_get(filters, k);
        var b = 0;
        while (b < NUM_BANDS) {
            var sum = f64_add(df_attenuation_band(result, b), df_attenuation_band(filt, b));
            _df_set_band(result, b, sum);
            b = b + 1;
        }
        total_delay = f64_add(total_delay, df_delay_seconds(filt));
        min_quality = f64_min(min_quality, df_quality(filt));
        k = k + 1;
    }

    store64(result + DF_DELAY, total_delay);
    store64(result + DF_QUAL, min_quality);
    return result;
}

# --- underwater.cyr ---

# underwater.cyr -- underwater (ocean) acoustics: Mackenzie sound speed,
# Francois-Garrison absorption, Rayleigh bottom reflection, and Eckart
# sea-surface scattering loss.
#
# Ports rust-old/src/underwater.rs. f32 -> f64 throughout. Rust's `serde`
# derive is dropped (no serde in Cyrius); the serde round-trip test is
# omitted. The `[f32; NUM_BANDS]` band-absorption return becomes an inline
# 8xf64 buffer (alloc), matching material.cyr's fixed-array idiom.
#
# Self-contained: no `include` lines. Relies on error.cyr (GOONJ_EPSILON),
# material.cyr (NUM_BANDS, frequency_band) and stdlib math/ganita
# (F64_PI, F64_ONE, F64_TWO, F64_HALF, F64_LN10, f64_pow/exp/ln/sqrt/sin/cos)
# being present in the build/test unit.

# ================================================================
# Constants (f64 bit patterns; decimal in comments for traceability)
# ================================================================

# Mackenzie (1981) nine-term sound-speed coefficients.
var MACK_C0     = 0x4096A3D70A3D70A4;   # 1448.96
var MACK_C1     = 0x40125D2F1A9FBE77;   # 4.591
var MACK_C2     = 0x3FAB280F12C27A63;   # 0.05304
var MACK_C3     = 0x3F2F1DD278DE382F;   # 0.0002374
var MACK_C4     = 0x3FF570A3D70A3D71;   # 1.34
var MACK_C5     = 0x3F90B0F27BB2FEC5;   # 0.0163
var MACK_C6     = 0x3E867B4194CAD2CD;   # 1.675e-7
var MACK_C7     = 0x3F84FDF3B645A1CB;   # 0.01025
var MACK_C8     = 0x3D691E3D5303DC48;   # 7.139e-13

# Francois-Garrison (1982) absorption coefficients.
var UW_KELVIN   = 0x4071126666666666;   # 273.15  C -> K
var P_C1        = 0x3F21F4F50A02B841;   # 1.37e-4  pressure-factor linear term
var P_C2        = 0x3E3AA0F8DB08FFCD;   # 6.2e-9   pressure-factor quadratic term
var BORIC_886   = 0x4021B851EB851EB8;   # 8.86     boric-acid magnitude
var BORIC_078   = 0x3FE8F5C28F5C28F6;   # 0.78     boric-acid salinity exponent
var BORIC_28    = 0x4006666666666666;   # 2.8      boric relaxation magnitude
var MG_2144     = 0x403570A3D70A3D71;   # 21.44    MgSO4 magnitude
var MG_0025     = 0x3F9999999999999A;   # 0.025    MgSO4 temperature term
var MG_817      = 0x4020570A3D70A3D7;   # 8.17     MgSO4 relaxation magnitude
var MG_00018    = 0x3F5D7DBF487FCB92;   # 0.0018   MgSO4 salinity correction
var PW_LO_0     = 0x3F402D74AD510683;   # 4.937e-4 pure-water visc, T<=20 const
var PW_LO_1     = 0x3EFB287A728CE556;   # 2.59e-5  pure-water visc, T<=20 linear
var PW_LO_2     = 0x3EAE916E2F911ACE;   # 9.11e-7  pure-water visc, T<=20 quadratic
var PW_LO_3     = 0x3E501B2B29A4692B;   # 1.50e-8  pure-water visc, T<=20 cubic
var PW_HI_0     = 0x3F39FA7D09401AA2;   # 3.964e-4 pure-water visc, T>20 const
var PW_HI_1     = 0x3EE8088A682354EF;   # 1.146e-5 pure-water visc, T>20 linear
var PW_HI_2     = 0x3E8376297CFBFF14;   # 1.45e-7  pure-water visc, T>20 quadratic
var PW_HI_3     = 0x3E065575E0FF4A28;   # 6.5e-10  pure-water visc, T>20 cubic

# Eckart sea-surface scattering: coherent-energy floor before capping.
var E_NEG10     = 0x3DDB7CDFD9D7BDBB;   # 1e-10

# Hamilton (1980) sediment attenuation (dB per wavelength).
var SAND_ATTEN  = 0x3FEC28F5C28F5C29;   # 0.88
var SILT_ATTEN  = 0x3FF0CCCCCCCCCCCD;   # 1.05
var CLAY_ATTEN  = 0x3FC999999999999A;   # 0.20
var ROCK_ATTEN  = 0x3FB999999999999A;   # 0.10

# log10(x) = ln(x) / ln(10)
fn _uw_log10(x) { return f64_div(f64_ln(x), F64_LN10); }

# ================================================================
# OceanProfile -- ocean sound-speed profile parameters.
# ================================================================
#derive(accessors)
struct OceanProfile { temperature_celsius; salinity_ppt; depth_m; }

#must_use
fn ocean_profile_new(temperature_celsius, salinity_ppt, depth_m) {
    var p = alloc(sizeof(OceanProfile));
    OceanProfile_set_temperature_celsius(p, temperature_celsius);
    OceanProfile_set_salinity_ppt(p, salinity_ppt);
    OceanProfile_set_depth_m(p, depth_m);
    return p;
}

# Sound speed in seawater via the Mackenzie (1981) nine-term equation.
# Valid: T = 2-30 C, S = 25-40 ppt, D = 0-8000 m (+/-0.07 m/s).
#must_use
fn ocean_sound_speed(profile) {
    var t = OceanProfile_temperature_celsius(profile);
    var s = OceanProfile_salinity_ppt(profile);
    var d = OceanProfile_depth_m(profile);

    var t2 = f64_mul(t, t);
    var t3 = f64_mul(t2, t);
    var s_rel = f64_sub(s, f64_from(35));
    var d2 = f64_mul(d, d);
    var d3 = f64_mul(d2, d);

    # 1448.96 + 4.591*t - 0.05304*t^2 + 0.0002374*t^3 + 1.340*(s-35)
    #   + 0.01630*d + 1.675e-7*d^2 - 0.01025*t*(s-35) - 7.139e-13*t*d^3
    var c = MACK_C0;
    c = f64_add(c, f64_mul(MACK_C1, t));
    c = f64_sub(c, f64_mul(MACK_C2, t2));
    c = f64_add(c, f64_mul(MACK_C3, t3));
    c = f64_add(c, f64_mul(MACK_C4, s_rel));
    c = f64_add(c, f64_mul(MACK_C5, d));
    c = f64_add(c, f64_mul(MACK_C6, d2));
    c = f64_sub(c, f64_mul(MACK_C7, f64_mul(t, s_rel)));
    c = f64_sub(c, f64_mul(MACK_C8, f64_mul(t, d3)));
    return c;
}

# Sound speed at depth via a linear-thermocline model: a constant-temperature
# surface mixed layer transitioning to a linear gradient below it.
#must_use
fn ocean_speed_at_depth(surface, thermocline_gradient, mixed_layer_depth, depth) {
    var temp = OceanProfile_temperature_celsius(surface);
    if (f64_gt(depth, mixed_layer_depth) == 1) {
        temp = f64_add(temp, f64_mul(thermocline_gradient, f64_sub(depth, mixed_layer_depth)));
    }
    var clamped = f64_max(temp, f64_neg(F64_TWO));
    var p = ocean_profile_new(clamped, OceanProfile_salinity_ppt(surface), depth);
    return ocean_sound_speed(p);
}

# Acoustic absorption in seawater (dB/km) via the Francois-Garrison (1982)
# model: boric-acid + magnesium-sulphate relaxation + pure-water viscosity.
# Valid: 100 Hz-1 MHz, T = -6-35 C, S = 7.7-43 ppt, D = 0-7000 m.
#must_use
fn ocean_absorption_db_per_km(frequency_hz, profile) {
    if (f64_le(frequency_hz, 0) == 1) { return 0; }

    var t = OceanProfile_temperature_celsius(profile);
    var s = OceanProfile_salinity_ppt(profile);
    var d = OceanProfile_depth_m(profile);
    var f = f64_div(frequency_hz, f64_from(1000));   # kHz
    var f2 = f64_mul(f, f);

    var t_kelvin = f64_add(t, UW_KELVIN);
    var c = ocean_sound_speed(profile);

    # Pressure factor (depth dependent): 1 - 1.37e-4*d + 6.2e-9*d^2.
    var p_factor = f64_add(f64_sub(F64_ONE, f64_mul(P_C1, d)), f64_mul(P_C2, f64_mul(d, d)));

    # Boric acid contribution (low frequency, < 1 kHz).
    var s_ratio = f64_div(s, f64_from(35));
    var a1_exp = f64_sub(f64_mul(BORIC_078, _uw_log10(s_ratio)), f64_from(5));
    var a1 = f64_mul(f64_div(BORIC_886, c), f64_pow(f64_from(10), a1_exp));
    var f1_exp = f64_sub(f64_from(4), f64_div(f64_from(1245), t_kelvin));
    var f1 = f64_mul(f64_mul(BORIC_28, f64_sqrt(s_ratio)), f64_pow(f64_from(10), f1_exp));
    var boric_inner = f64_div(f64_mul(f64_mul(a1, f1), f2), f64_add(f64_mul(f1, f1), f2));
    var boric = f64_mul(boric_inner, p_factor);

    # Magnesium sulphate contribution (mid frequency, 1-100 kHz).
    var a2 = f64_mul(f64_div(f64_mul(MG_2144, s), c), f64_add(F64_ONE, f64_mul(MG_0025, t)));
    var f2r_exp = f64_sub(f64_from(8), f64_div(f64_from(1990), t_kelvin));
    var f2r_num = f64_mul(MG_817, f64_pow(f64_from(10), f2r_exp));
    var f2r_den = f64_add(F64_ONE, f64_mul(MG_00018, f64_sub(s, f64_from(35))));
    var f2_relax = f64_div(f2r_num, f2r_den);
    var mg_inner = f64_div(f64_mul(f64_mul(a2, f2_relax), f2), f64_add(f64_mul(f2_relax, f2_relax), f2));
    var mgso4 = f64_mul(mg_inner, p_factor);

    # Pure water viscous absorption (high frequency, > 100 kHz).
    var t2 = f64_mul(t, t);
    var t3 = f64_mul(t2, t);
    var a3 = 0;
    if (f64_le(t, f64_from(20)) == 1) {
        a3 = f64_sub(f64_add(f64_sub(PW_LO_0, f64_mul(PW_LO_1, t)),
        f64_mul(PW_LO_2, t2)), f64_mul(PW_LO_3, t3));
    } else {
        a3 = f64_sub(f64_add(f64_sub(PW_HI_0, f64_mul(PW_HI_1, t)),
        f64_mul(PW_HI_2, t2)), f64_mul(PW_HI_3, t3));
    }
    var pure_water = f64_mul(f64_mul(a3, f2), p_factor);

    return f64_max(f64_add(f64_add(boric, mgso4), pure_water), 0);
}

# Per-band ocean absorption (dB/km) -> inline 8xf64 buffer (NUM_BANDS slots),
# using material.cyr's octave-band centre frequencies.
#must_use
fn ocean_absorption_bands(profile) {
    var out = alloc(NUM_BANDS * 8);
    var band = 0;
    while (band < NUM_BANDS) {
        store64(out + band * 8, ocean_absorption_db_per_km(frequency_band(band), profile));
        band = band + 1;
    }
    return out;
}

# ================================================================
# SeabedSediment -- bottom sediment properties for reflection.
# ================================================================
#derive(accessors)
struct SeabedSediment { speed; density; attenuation_db_per_wavelength; }

#must_use
fn seabed_sediment_new(speed, density, attenuation_db_per_wavelength) {
    var sed = alloc(sizeof(SeabedSediment));
    SeabedSediment_set_speed(sed, speed);
    SeabedSediment_set_density(sed, density);
    SeabedSediment_set_attenuation_db_per_wavelength(sed, attenuation_db_per_wavelength);
    return sed;
}

# Hamilton (1980) presets.
#must_use
fn seabed_sand() { return seabed_sediment_new(f64_from(1749), f64_from(1941), SAND_ATTEN); }
#must_use
fn seabed_silt() { return seabed_sediment_new(f64_from(1575), f64_from(1740), SILT_ATTEN); }
#must_use
fn seabed_clay() { return seabed_sediment_new(f64_from(1500), f64_from(1500), CLAY_ATTEN); }
#must_use
fn seabed_rock() { return seabed_sediment_new(f64_from(5250), f64_from(2700), ROCK_ATTEN); }

# Bottom reflection coefficient magnitude (0..1) via the Rayleigh model.
#   R = (m*sin(theta) - n) / (m*sin(theta) + n)
# with m = rho_sed/rho_water and n = sqrt(1 - cos^2(theta) / (c_water/c_sed)^2).
#must_use
fn bottom_reflection_coefficient(grazing_angle_rad, water_speed, water_density, sediment) {
    if (f64_le(water_speed, 0) == 1) { return F64_ONE; }
    if (f64_le(water_density, 0) == 1) { return F64_ONE; }
    if (f64_le(SeabedSediment_speed(sediment), 0) == 1) { return F64_ONE; }
    if (f64_le(SeabedSediment_density(sediment), 0) == 1) { return F64_ONE; }

    var sin_theta = f64_sin(grazing_angle_rad);
    var cos_theta = f64_cos(grazing_angle_rad);

    var m = f64_div(SeabedSediment_density(sediment), water_density);
    var speed_ratio = f64_div(water_speed, SeabedSediment_speed(sediment));
    var speed_ratio2 = f64_mul(speed_ratio, speed_ratio);

    # n = sqrt(1 - (c_sed/c_water)^2 * cos^2(theta)) -- refracted-angle term.
    var inner = f64_sub(F64_ONE, f64_div(f64_mul(cos_theta, cos_theta), speed_ratio2));
    if (f64_lt(inner, 0) == 1) {
        # Total internal reflection (critical angle exceeded).
        return F64_ONE;
    }
    var n = f64_sqrt(inner);

    var num = f64_abs(f64_sub(f64_mul(m, sin_theta), n));
    var den = f64_add(f64_mul(m, sin_theta), n);
    if (f64_lt(f64_abs(den), GOONJ_EPSILON) == 1) { return F64_ONE; }

    return f64_clamp(f64_div(num, den), 0, F64_ONE);
}

# Sea-surface scattering loss (dB) due to wave roughness, via the Eckart model:
# loss grows with frequency and RMS wave height.
#must_use
fn surface_scattering_loss(frequency_hz, grazing_angle_rad, rms_wave_height, water_speed) {
    if (f64_le(frequency_hz, 0) == 1) { return 0; }
    if (f64_le(rms_wave_height, 0) == 1) { return 0; }
    if (f64_le(water_speed, 0) == 1) { return 0; }

    var wavelength = f64_div(water_speed, frequency_hz);
    var sin_theta = f64_abs(f64_sin(grazing_angle_rad));

    # Rayleigh roughness parameter: R = 4*pi*h_rms*sin(theta) / lambda.
    var roughness = f64_div(
    f64_mul(f64_mul(f64_mul(f64_from(4), F64_PI), rms_wave_height), sin_theta), wavelength);

    # Eckart model: scattering loss ~ exp(-R^2/2) -> dB.
    var coherent = f64_exp(f64_div(f64_neg(f64_mul(roughness, roughness)), F64_TWO));
    if (f64_lt(coherent, E_NEG10) == 1) {
        # Cap at 100 dB loss.
        return f64_from(100);
    }
    return f64_mul(f64_neg(f64_from(20)), _uw_log10(coherent));
}

# --- vibroacoustics.cyr ---

# vibroacoustics.cyr -- coupling between structural vibration and acoustic
# radiation. Estimates sound radiated by vibrating surfaces from surface
# velocity distributions using radiation-impedance models.
#
# Ports rust-old/src/vibroacoustics.rs. f32 → f64. Rust's `serde` derive is
# dropped (no serde in Cyrius); the serde round-trip test is therefore
# omitted. `&[VibratingSurface]`, `&[Vec3]`, `&[f32]`, `&[VibrationMode]`
# and `Vec<f32>` mode shapes all become stdlib `vec` handles (pointers /
# f64 stored directly in the 8-byte slots). RadiationResult's
# `[f32; NUM_BANDS]` array uses a manual inline layout.
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON,
# F64_NEG_INF), material.cyr (NUM_BANDS, frequency_band), propagation.cyr
# (speed_of_sound), hisab HVec3 (hvec3_unit_y), and stdlib math/ganita
# (F64_*, f64_*) + vec (vec_new/push/len/get) with alloc_init() run.

# RadiationResult inline layout: watts | level_db | 8×f64 power_per_band.
enum RrLayout {
    RR_WATTS = 0,
    RR_DB    = 8,
    RR_BANDS = 16,   # offsets 16..80 (8 f64)
    RR_SIZE  = 80,
}

# Physics constants that aren't clean integers (f64 bit patterns).
var VIBRO_RHO_AIR  = 0x3FF35C28F5C28F5C;   # 1.21   air density kg/m³
var INV_PICO = 0x3D719799812DEA11;   # 1e-12  reference power (1 pW)
var V_0_01   = 0x3F847AE147AE147B;   # 0.01

# log10(x) = ln(x) / ln(10)
fn _vib_log10(x) { return f64_div(f64_ln(x), F64_LN10); }

# ================================================================
# VibratingSurface — a vibrating surface element.
#   position/normal : HVec3 pointers; area/velocity/frequency : f64.
# ================================================================
#derive(accessors)
struct VibratingSurface { position; normal; area; velocity; frequency; }

#must_use
fn vibrating_surface_new(position, normal, area, velocity, frequency) {
    var s = alloc(sizeof(VibratingSurface));
    VibratingSurface_set_position(s, position);
    VibratingSurface_set_normal(s, normal);
    VibratingSurface_set_area(s, area);
    VibratingSurface_set_velocity(s, velocity);
    VibratingSurface_set_frequency(s, frequency);
    return s;
}

# ================================================================
# VibrationMode — a structural mode shape for modal radiation.
#   mode_shape : a `vec` of per-element f64 normal-velocity amplitudes.
# ================================================================
#derive(accessors)
struct VibrationMode { frequency; damping; mode_shape; }

#must_use
fn vibration_mode_new(frequency, damping, mode_shape) {
    var m = alloc(sizeof(VibrationMode));
    VibrationMode_set_frequency(m, frequency);
    VibrationMode_set_damping(m, damping);
    VibrationMode_set_mode_shape(m, mode_shape);
    return m;
}

# ================================================================
# RadiationResult — radiated power, level, and per-band breakdown.
# ================================================================
#must_use
fn radiation_result_sound_power_watts(r)    { return load64(r + RR_WATTS); }
#must_use
fn radiation_result_sound_power_level_db(r) { return load64(r + RR_DB); }
#must_use
fn radiation_result_power_per_band(r, band) { return load64(r + RR_BANDS + band * 8); }

# Build a RadiationResult with all per-band powers zeroed.
fn _rr_make(watts, db) {
    var r = alloc(RR_SIZE);
    store64(r + RR_WATTS, watts);
    store64(r + RR_DB, db);
    var i = 0;
    while (i < NUM_BANDS) {
        store64(r + RR_BANDS + i * 8, 0);
        i = i + 1;
    }
    return r;
}

# ================================================================
# Radiation efficiency of a baffled rectangular plate.
# Below critical: edge/corner radiation (σ << 1). At critical: σ peaks.
# Above: σ → 1.
# ================================================================
#must_use
fn radiation_efficiency(frequency, critical_frequency, plate_area, plate_perimeter, temperature_celsius) {
    if (f64_le(frequency, 0) == 1) { return 0; }
    if (f64_le(critical_frequency, 0) == 1) { return 0; }
    if (f64_le(plate_area, 0) == 1) { return 0; }

    var c = speed_of_sound(temperature_celsius);
    var wavelength = f64_div(c, frequency);
    var f_ratio = f64_div(frequency, critical_frequency);

    if (f64_lt(f_ratio, F64_HALF) == 1) {
        # σ ≈ (perimeter · wavelength) / (4π · area) (edge radiation)
        var denom = f64_mul(f64_mul(f64_from(4), F64_PI), plate_area);
        var sigma = f64_div(f64_mul(plate_perimeter, wavelength), denom);
        return f64_clamp(sigma, 0, F64_ONE);
    }
    if (f64_lt(f_ratio, F64_ONE) == 1) {
        # Approaching critical: rapid increase.
        var one_minus = f64_sub(F64_ONE, f_ratio);
        var sigma = f64_sqrt(f64_div(F64_ONE, one_minus));
        var a = f64_clamp(sigma, 0, f64_from(10));
        var b = f64_div(F64_ONE, f64_sqrt(f64_add(one_minus, V_0_01)));
        return f64_clamp(f64_min(a, b), 0, F64_ONE);
    }
    # At or above critical: σ → 1.
    var inner = f64_sub(F64_ONE, f64_div(F64_ONE, f64_mul(f_ratio, f_ratio)));
    var t = f64_max(f64_sqrt(f64_abs(inner)), V_0_01);
    var sigma = f64_div(F64_ONE, t);
    return f64_clamp(sigma, 0, F64_ONE);
}

# ================================================================
# Sound power radiated by a set of vibrating surfaces.
# Rayleigh-integral baffled-piston approximation:
#   W = ρ₀c₀ · σ · A · <v²>.
#   surfaces : a `vec` of VibratingSurface pointers.
# ================================================================
#must_use
fn radiated_sound_power(surfaces, critical_frequency, temperature_celsius) {
    var n = vec_len(surfaces);
    if (n == 0) { return _rr_make(0, F64_NEG_INF); }

    var c = speed_of_sound(temperature_celsius);
    var rho = VIBRO_RHO_AIR;

    var total_area = 0;
    var i = 0;
    while (i < n) {
        total_area = f64_add(total_area, VibratingSurface_area(vec_get(surfaces, i)));
        i = i + 1;
    }
    # Approximate perimeter for a square plate.
    var perimeter = f64_mul(f64_from(4), f64_sqrt(total_area));

    var r = _rr_make(0, F64_NEG_INF);
    var total_power = 0;
    i = 0;
    while (i < n) {
        var s = vec_get(surfaces, i);
        var freq = VibratingSurface_frequency(s);
        var sigma = radiation_efficiency(freq, critical_frequency, total_area, perimeter, temperature_celsius);
        var vel = VibratingSurface_velocity(s);

        # W = ρ₀c · σ · A · v² (left-associative, matching the Rust order).
        var power = f64_mul(rho, c);
        power = f64_mul(power, sigma);
        power = f64_mul(power, VibratingSurface_area(s));
        power = f64_mul(power, vel);
        power = f64_mul(power, vel);
        total_power = f64_add(total_power, power);

        var band = nearest_band(freq);
        var cur = load64(r + RR_BANDS + band * 8);
        store64(r + RR_BANDS + band * 8, f64_add(cur, power));
        i = i + 1;
    }

    var swl = F64_NEG_INF;
    if (f64_gt(total_power, 0) == 1) {
        # dB re 1 pW.
        swl = f64_mul(f64_from(10), _vib_log10(f64_div(total_power, INV_PICO)));
    }
    store64(r + RR_WATTS, total_power);
    store64(r + RR_DB, swl);
    return r;
}

# ================================================================
# Radiated power from a set of vibration modes (modal superposition).
#   positions : `vec` of HVec3 pointers; areas : `vec` of f64;
#   modes     : `vec` of VibrationMode pointers.
# ================================================================
#must_use
fn modal_radiation(positions, areas, modes, excitation_amplitude, critical_frequency, temperature_celsius) {
    var np = vec_len(positions);
    var na = vec_len(areas);
    var nm = vec_len(modes);
    if (np == 0) { return _rr_make(0, F64_NEG_INF); }
    if (na == 0) { return _rr_make(0, F64_NEG_INF); }
    if (nm == 0) { return _rr_make(0, F64_NEG_INF); }

    var n = np;
    if (na < n) { n = na; }

    var surfaces = vec_new();
    var mi = 0;
    while (mi < nm) {
        var mode = vec_get(modes, mi);
        var shape = VibrationMode_mode_shape(mode);
        if (vec_len(shape) < n) {
            mi = mi + 1;
        } else {
            var freq = VibrationMode_frequency(mode);
            var damping = VibrationMode_damping(mode);
            # Modal response amplitude: A / (2ζω) at resonance.
            var omega = f64_mul(F64_TAU, freq);
            var modal_amp = 0;
            if (f64_gt(omega, 0) == 1) {
                if (f64_gt(damping, 0) == 1) {
                    modal_amp = f64_div(excitation_amplitude, f64_mul(f64_mul(F64_TWO, damping), omega));
                }
            }

            var i = 0;
            while (i < n) {
                var velocity = f64_mul(modal_amp, vec_get(shape, i));
                var vabs = f64_abs(velocity);
                if (f64_gt(vabs, GOONJ_EPSILON) == 1) {
                    # Default normal up — caller should set correctly.
                    var pos = vec_get(positions, i);
                    var surf = vibrating_surface_new(pos, hvec3_unit_y(), vec_get(areas, i), vabs, freq);
                    vec_push(surfaces, surf);
                }
                i = i + 1;
            }
            mi = mi + 1;
        }
    }

    return radiated_sound_power(surfaces, critical_frequency, temperature_celsius);
}

# ================================================================
# Nearest octave-band index for a frequency (Hz).
# ================================================================
#must_use
fn nearest_band(frequency) {
    var best = 0;
    var best_dist = f64_abs(f64_sub(frequency, frequency_band(0)));
    var i = 1;
    while (i < NUM_BANDS) {
        var dist = f64_abs(f64_sub(frequency, frequency_band(i)));
        if (f64_lt(dist, best_dist) == 1) {
            best = i;
            best_dist = dist;
        }
        i = i + 1;
    }
    return best;
}

# --- bridge.cyr ---

# bridge.cyr -- cross-crate bridges: convert primitive values from other
# AGNOS science crates (pavan/badal/ushma/bijli) into goonj acoustic
# parameters. Always available — takes primitive f64 values, no science
# crate deps.
#
# Ports rust-old/src/bridge.rs. f32 → f64 throughout. The Rust `bool`
# `approaching` flag becomes an integer 1/0. The `[f32; NUM_BANDS]` return
# of air_absorption_from_weather becomes a pointer to an 8×f64 buffer
# (alloc 64 bytes; caller reads load64(buf + i*8)).
#
# Requires (from the build/test unit): propagation.cyr (speed_of_sound,
# atmospheric_absorption), material.cyr (frequency_band, NUM_BANDS), stdlib
# math/ganita (F64_ONE/F64_TWO/F64_HALF/F64_PI, f64_*). alloc_init() must
# have run before air_absorption_from_weather (it allocs a buffer).

# ================================================================
# Constants (f64 bit patterns; decimal in comments for traceability).
# Bridge-local names avoid colliding with propagation.cyr's globals.
# ================================================================
var WIND_TURB_COEFF  = 0x3F8A9FBE76C8B439;   # 0.013   turbulent-scatter coeff
var MACH_CLAMP       = 0x3FEFAE147AE147AE;   # 0.99    sub-sonic Mach clamp
var STD_PRESSURE_HPA = 0x408FAA0000000000;   # 1013.25 standard pressure (hPa)
var BR_KELVIN        = 0x4071126666666666;   # 273.15  °C → K offset
var BR_T_REF         = 0x4072526666666666;   # 293.15  K (20 °C reference)
var BR_SOUND_TCOEFF  = 0x3FE3645A1CAC0831;   # 0.606   m/s per °C
var ZETA_MIN         = 0x3F50624DD2F1A9FC;   # 0.001   min damping ratio
var DENOM_THRESH     = 0x3DDB7CDFD9D7BDBB;   # 1e-10   transfer-fn denom floor
var RHO_AIR          = 0x3FF399999999999A;   # 1.225   air density kg/m³

# ── Pavan bridges (aerodynamics) ──

# Wind speed (m/s) → outdoor propagation attenuation (dB/m, always ≥ 0).
# Turbulent scattering grows ~ with wind speed squared (ISO 9613-2 approx):
# (speed² · 0.013).min(5.0) / 1000.0.
#must_use
fn wind_attenuation_factor(wind_speed_ms) {
    var speed = f64_max(wind_speed_ms, 0);
    var scaled = f64_mul(f64_mul(speed, speed), WIND_TURB_COEFF);
    return f64_div(f64_min(scaled, f64_from(5)), f64_from(1000));
}

# Mach number → Doppler frequency-shift ratio. `approaching` is 1 if the
# source moves toward the listener, else 0. m = |Mach|.min(0.99):
#   approaching: 1 / (1 - m);  receding: 1 / (1 + m).
#must_use
fn doppler_ratio_from_mach(mach_number, approaching) {
    var m = f64_min(f64_abs(mach_number), MACH_CLAMP);
    if (approaching == 1) {
        return f64_div(F64_ONE, f64_sub(F64_ONE, m));
    }
    return f64_div(F64_ONE, f64_add(F64_ONE, m));
}

# Temperature (°C) + wind component (m/s) → effective speed of sound.
# Downwind (positive component) speeds sound up; upwind slows it.
#must_use
fn effective_speed_of_sound(temperature_celsius, wind_component_ms) {
    return f64_add(speed_of_sound(temperature_celsius), wind_component_ms);
}

# ── Badal bridges (weather/atmosphere) ──

# Humidity (%) + temperature (°C) → per-band air absorption (dB/m) at the 8
# standard octave-band centre frequencies (ISO 9613-1). Returns a pointer
# to an 8×f64 buffer; caller reads load64(buf + band*8).
#must_use
fn air_absorption_from_weather(humidity_percent, temperature_celsius) {
    var h = f64_clamp(humidity_percent, 0, f64_from(100));
    var t = temperature_celsius;
    var buf = alloc(NUM_BANDS * 8);
    var band = 0;
    while (band < NUM_BANDS) {
        var a = atmospheric_absorption(frequency_band(band), h, t, F64_ONE);
        store64(buf + band * 8, a);
        band = band + 1;
    }
    return buf;
}

# Temperature (°C) → speed of sound (m/s). Thin wrapper over speed_of_sound.
#must_use
fn speed_of_sound_from_temperature(temperature_celsius) {
    return speed_of_sound(temperature_celsius);
}

# Atmospheric pressure (hPa) → pressure ratio (atm). 1013.25 hPa = 1.0 atm.
#must_use
fn pressure_to_atm(pressure_hpa) {
    return f64_div(pressure_hpa, STD_PRESSURE_HPA);
}

# ── Ushma bridges (thermodynamics) ──

# Temperature (°C) → porous-absorber absorption scaling factor (1.0 at
# 20 °C). Scales ~ sqrt(T/T_ref): sqrt(max(T_K, 1) / 293.15).
#must_use
fn absorption_temperature_scale(temperature_celsius) {
    var t_kelvin = f64_max(f64_add(temperature_celsius, BR_KELVIN), F64_ONE);
    return f64_sqrt(f64_div(t_kelvin, BR_T_REF));
}

# Thermal gradient (°C/m) → sound-speed gradient (m/s per m). Since
# c = 331.3 + 0.606·T, dc/dz = 0.606 · dT/dz.
#must_use
fn sound_speed_gradient(thermal_gradient_c_per_m) {
    return f64_mul(BR_SOUND_TCOEFF, thermal_gradient_c_per_m);
}

# ── Bijli bridges (electromagnetism) ──

# EM drive frequency vs structural natural frequency → resonance
# amplification factor (single-DOF transfer-function magnitude). Returns
# 1.0 for a non-positive structural frequency, caps at 1000.0.
#must_use
fn em_resonance_coupling(em_frequency_hz, structural_freq_hz, damping_ratio) {
    if (f64_le(structural_freq_hz, 0) == 1) { return F64_ONE; }
    var r = f64_div(em_frequency_hz, structural_freq_hz);
    var zeta = f64_max(damping_ratio, ZETA_MIN);
    # denom = sqrt((1 - r²)² + (2·zeta·r)²)
    var one_minus_r2 = f64_sub(F64_ONE, f64_mul(r, r));
    var two_zeta_r = f64_mul(f64_mul(F64_TWO, zeta), r);
    var denom = f64_sqrt(f64_add(f64_mul(one_minus_r2, one_minus_r2),
    f64_mul(two_zeta_r, two_zeta_r)));
    if (f64_lt(denom, DENOM_THRESH) == 1) { return f64_from(1000); }
    return f64_min(f64_div(F64_ONE, denom), f64_from(1000));
}

# EM field amplitude (V/m) + frequency → radiated acoustic power (W) from a
# piezoelectric transducer. Simplified: P = 0.5·ρ·c·A·v², with
# v = d·E·2π·f and ρ = 1.225 kg/m³, c = 343 m/s. Clamped at 0.
#must_use
fn piezo_acoustic_power(e_field_v_per_m, frequency_hz, piezo_coefficient_m_per_v, transducer_area_m2) {
    var c = f64_from(343);
    var displacement = f64_mul(piezo_coefficient_m_per_v, e_field_v_per_m);
    var velocity = f64_mul(f64_mul(f64_mul(displacement, F64_TWO), F64_PI), frequency_hz);
    var power = f64_mul(f64_mul(f64_mul(f64_mul(F64_HALF, RHO_AIR), c),
    transducer_area_m2), f64_mul(velocity, velocity));
    return f64_max(power, 0);
}

# --- ray.cyr ---

# ray.cyr -- acoustic ray tracing: single-band (AcousticRay) and
# multiband (MultibandRay) rays, planar wall intersection, specular +
# scattering reflection, and linear / BVH-accelerated path tracing.
#
# Ports rust-old/src/ray.rs. f32 -> f64. Rust's `serde` derive is dropped.
# Option<f32> from ray_wall_intersection becomes a negative sentinel
# (RAY_NONE); Option<(f32,usize)> from find_nearest_wall* becomes a
# NearestWall struct pointer (0 == None). The `[f32; NUM_BANDS]` energy
# arrays (MultibandRay, RayBounce, RayPath) use manual inline layout.
# Uses hisab geo (geo_ray_new, bvh_query_ray) for BVH broadphase and
# room.cyr's Wall / AcceleratedRoom types.
#
# Requires (build/test unit): error.cyr (GOONJ_EPSILON), material.cyr
# (NUM_BANDS, am_scattering, AM_ABS, frequency_band), room.cyr (Wall_*,
# AcceleratedRoom_*, AcousticRoom_*, RoomGeometry_walls), hisab, stdlib
# math/vec. alloc_init() must have run.

var ENERGY_THRESHOLD = 0x3F50624DD2F1A9FC;   # 0.001 — dead below this
var RAY_NONE         = 0xBFF0000000000000;   # -1.0 — "no intersection" sentinel

# ================================================================
# Structs
# ================================================================
#derive(accessors)
struct AcousticRay { origin; direction; energy; frequency_hz; distance_traveled; }

#derive(accessors)
struct RayHit { point; normal; distance; wall_index; }

#derive(accessors)
struct NearestWall { distance; index; }

# MultibandRay: origin | direction | energy[8] | distance  (manual layout).
enum MbrLayout { MBR_ORIGIN = 0, MBR_DIR = 8, MBR_ENERGY = 16, MBR_DIST = 80, MBR_SIZE = 88 }

# RayBounce: point | normal | wall_index | dist_from_prev | energy_after[8].
enum RbLayout { RB_POINT = 0, RB_NORMAL = 8, RB_WIDX = 16, RB_DIST = 24, RB_ENERGY = 32, RB_SIZE = 96 }

# RayPath: bounces (vec) | total_distance | final_energy[8].
enum RpLayout { RP_BOUNCES = 0, RP_TOTAL = 8, RP_FINAL = 16, RP_SIZE = 80 }

fn mbr_origin(r)            { return load64(r + MBR_ORIGIN); }
fn mbr_direction(r)         { return load64(r + MBR_DIR); }
fn mbr_energy_band(r, i)    { return load64(r + MBR_ENERGY + i * 8); }
fn mbr_set_energy_band(r, i, v) { store64(r + MBR_ENERGY + i * 8, v); return 0; }
fn mbr_distance(r)          { return load64(r + MBR_DIST); }

fn ray_path_bounces(p)      { return load64(p + RP_BOUNCES); }
fn ray_path_total_distance(p) { return load64(p + RP_TOTAL); }
fn ray_path_final_energy(p, i) { return load64(p + RP_FINAL + i * 8); }

fn ray_bounce_point(b)      { return load64(b + RB_POINT); }
fn ray_bounce_normal(b)     { return load64(b + RB_NORMAL); }
fn ray_bounce_wall_index(b) { return load64(b + RB_WIDX); }
fn ray_bounce_distance(b)   { return load64(b + RB_DIST); }
fn ray_bounce_energy_after(b, i) { return load64(b + RB_ENERGY + i * 8); }

# ================================================================
# AcousticRay
# ================================================================
# Normalize direction; zero-length falls back to +Z.
#must_use
fn _ray_norm_dir(direction) {
    var len = hvec3_length(direction);
    if (f64_gt(len, GOONJ_EPSILON) == 1) { return hvec3_scale(direction, f64_div(F64_ONE, len)); }
    return hvec3_unit_z();
}

#must_use
fn acoustic_ray_new(origin, direction, frequency_hz) {
    var r = alloc(sizeof(AcousticRay));
    AcousticRay_set_origin(r, origin);
    AcousticRay_set_direction(r, _ray_norm_dir(direction));
    AcousticRay_set_energy(r, F64_ONE);
    AcousticRay_set_frequency_hz(r, frequency_hz);
    AcousticRay_set_distance_traveled(r, 0);
    return r;
}

# Probe ray with the direction used as-is (caller already normalized).
#must_use
fn _acoustic_ray_raw(origin, direction) {
    var r = alloc(sizeof(AcousticRay));
    AcousticRay_set_origin(r, origin);
    AcousticRay_set_direction(r, direction);
    AcousticRay_set_energy(r, F64_ONE);
    AcousticRay_set_frequency_hz(r, f64_from(1000));
    AcousticRay_set_distance_traveled(r, 0);
    return r;
}

#must_use
fn acoustic_ray_is_alive(r) {
    if (f64_gt(AcousticRay_energy(r), ENERGY_THRESHOLD) == 1) { return 1; }
    return 0;
}

# ================================================================
# MultibandRay
# ================================================================
#must_use
fn multiband_ray_new(origin, direction) {
    var r = alloc(MBR_SIZE);
    store64(r + MBR_ORIGIN, origin);
    store64(r + MBR_DIR, _ray_norm_dir(direction));
    var i = 0;
    while (i < NUM_BANDS) {
        store64(r + MBR_ENERGY + i * 8, F64_ONE);
        i = i + 1;
    }
    store64(r + MBR_DIST, 0);
    return r;
}

# Deep copy (Rust clone) — trace mutates a working copy, not the input.
#must_use
fn _multiband_ray_clone(src) {
    var r = alloc(MBR_SIZE);
    store64(r + MBR_ORIGIN, mbr_origin(src));
    store64(r + MBR_DIR, mbr_direction(src));
    var i = 0;
    while (i < NUM_BANDS) {
        store64(r + MBR_ENERGY + i * 8, mbr_energy_band(src, i));
        i = i + 1;
    }
    store64(r + MBR_DIST, mbr_distance(src));
    return r;
}

#must_use
fn multiband_ray_is_alive(r) {
    var i = 0;
    while (i < NUM_BANDS) {
        if (f64_gt(mbr_energy_band(r, i), ENERGY_THRESHOLD) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

#must_use
fn multiband_ray_max_energy(r) {
    var m = 0;
    var i = 0;
    while (i < NUM_BANDS) {
        m = f64_max(m, mbr_energy_band(r, i));
        i = i + 1;
    }
    return m;
}

# ================================================================
# Geometry: planar wall intersection + point-in-polygon
# ================================================================
# Inside test for a convex polygon (vertices is a vec of HVec3).
#must_use
fn point_in_convex_polygon(point, vertices, normal) {
    var n = vec_len(vertices);
    if (n < 3) { return 0; }
    var i = 0;
    while (i < n) {
        var v0 = vec_get(vertices, i);
        var v1 = vec_get(vertices, (i + 1) % n);
        var edge = hvec3_sub(v1, v0);
        var to_point = hvec3_sub(point, v0);
        var c = hvec3_cross(edge, to_point);
        if (f64_lt(hvec3_dot(c, normal), f64_neg(GOONJ_EPSILON)) == 1) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Ray-wall intersection distance, or RAY_NONE (negative) if no hit.
#must_use
fn ray_wall_intersection(ray, wall) {
    var verts = Wall_vertices(wall);
    if (vec_len(verts) < 3) { return RAY_NONE; }

    var n = Wall_normal(wall);
    var d_dot_n = hvec3_dot(AcousticRay_direction(ray), n);
    if (f64_lt(f64_abs(d_dot_n), GOONJ_EPSILON) == 1) { return RAY_NONE; }

    var p0 = vec_get(verts, 0);
    var diff = hvec3_sub(p0, AcousticRay_origin(ray));
    var t = f64_div(hvec3_dot(diff, n), d_dot_n);
    if (f64_lt(t, GOONJ_EPSILON) == 1) { return RAY_NONE; }

    var hit = hvec3_add(AcousticRay_origin(ray), hvec3_scale(AcousticRay_direction(ray), t));
    if (point_in_convex_polygon(hit, verts, n) == 1) { return t; }
    return RAY_NONE;
}

# ================================================================
# Reflection
# ================================================================
# Reflection direction: specular r = d - 2(d·n)n, blended toward the
# normal by `scattering`.
#must_use
fn _reflect_direction(d, n, scattering) {
    var specular = hvec3_sub(d, hvec3_scale(n, f64_mul(F64_TWO, hvec3_dot(d, n))));
    if (f64_gt(scattering, GOONJ_EPSILON) == 1) {
        var blended = hvec3_add(hvec3_scale(specular, f64_sub(F64_ONE, scattering)),
        hvec3_scale(n, scattering));
        var len = hvec3_length(blended);
        if (f64_gt(len, GOONJ_EPSILON) == 1) { return hvec3_scale(blended, f64_div(F64_ONE, len)); }
        return specular;
    }
    return specular;
}

#must_use
fn reflect_ray(ray, hit, absorption, scattering) {
    var dir = _reflect_direction(AcousticRay_direction(ray), RayHit_normal(hit), scattering);
    var r = alloc(sizeof(AcousticRay));
    AcousticRay_set_origin(r, RayHit_point(hit));
    AcousticRay_set_direction(r, dir);
    AcousticRay_set_energy(r, f64_mul(AcousticRay_energy(ray), f64_sub(F64_ONE, absorption)));
    AcousticRay_set_frequency_hz(r, AcousticRay_frequency_hz(ray));
    AcousticRay_set_distance_traveled(r, f64_add(AcousticRay_distance_traveled(ray), RayHit_distance(hit)));
    return r;
}

# `absorption` is a pointer to 8 consecutive f64 (per-band coefficients).
#must_use
fn reflect_ray_multiband(ray, hit, absorption, scattering) {
    var dir = _reflect_direction(mbr_direction(ray), RayHit_normal(hit), scattering);
    var r = alloc(MBR_SIZE);
    store64(r + MBR_ORIGIN, RayHit_point(hit));
    store64(r + MBR_DIR, dir);
    var i = 0;
    while (i < NUM_BANDS) {
        var e = f64_mul(mbr_energy_band(ray, i), f64_sub(F64_ONE, load64(absorption + i * 8)));
        store64(r + MBR_ENERGY + i * 8, e);
        i = i + 1;
    }
    store64(r + MBR_DIST, f64_add(mbr_distance(ray), RayHit_distance(hit)));
    return r;
}

# Pointer to a wall's material absorption block (8 f64). AM_ABS is the
# absorption offset inside AcousticMaterial (material.cyr).
#must_use
fn _wall_absorption_ptr(wall) { return Wall_material(wall) + AM_ABS; }

# ================================================================
# Nearest-wall search (linear + BVH) and path tracing
# ================================================================
# Returns a NearestWall (distance,index) or 0 (None). skip_wall = -1 for none.
#must_use
fn find_nearest_wall(origin, direction, walls, skip_wall) {
    var probe = _acoustic_ray_raw(origin, direction);
    var found = 0;
    var best_t = 0;
    var best_idx = 0;
    var n = vec_len(walls);
    var i = 0;
    while (i < n) {
        if (i != skip_wall) {
            var t = ray_wall_intersection(probe, vec_get(walls, i));
            if (f64_ge(t, 0) == 1) {
                if (found == 0) {
                    found = 1; best_t = t; best_idx = i;
                } else {
                    if (f64_lt(t, best_t) == 1) { best_t = t; best_idx = i; }
                }
            }
        }
        i = i + 1;
    }
    if (found == 0) { return 0; }
    var nw = alloc(sizeof(NearestWall));
    NearestWall_set_distance(nw, best_t);
    NearestWall_set_index(nw, best_idx);
    return nw;
}

# BVH broadphase variant. Zero-direction -> None (matches Rust Ray::new Err).
#must_use
fn find_nearest_wall_bvh(origin, direction, walls, bvh, skip_wall) {
    if (f64_lt(hvec3_length(direction), GOONJ_EPSILON) == 1) { return 0; }
    var hray = geo_ray_new(origin, direction);
    var candidates = bvh_query_ray(bvh, hray);
    var probe = _acoustic_ray_raw(origin, direction);

    var found = 0;
    var best_t = 0;
    var best_idx = 0;
    var m = vec_len(candidates);
    var j = 0;
    while (j < m) {
        var idx = vec_get(candidates, j);
        if (idx != skip_wall) {
            var t = ray_wall_intersection(probe, vec_get(walls, idx));
            if (f64_ge(t, 0) == 1) {
                if (found == 0) {
                    found = 1; best_t = t; best_idx = idx;
                } else {
                    if (f64_lt(t, best_t) == 1) { best_t = t; best_idx = idx; }
                }
            }
        }
        j = j + 1;
    }
    if (found == 0) { return 0; }
    var nw = alloc(sizeof(NearestWall));
    NearestWall_set_distance(nw, best_t);
    NearestWall_set_index(nw, best_idx);
    return nw;
}

# Record one bounce into a freshly-alloc'd RayBounce.
#must_use
fn _make_bounce(point, normal, wall_index, distance, ray_after) {
    var b = alloc(RB_SIZE);
    store64(b + RB_POINT, point);
    store64(b + RB_NORMAL, normal);
    store64(b + RB_WIDX, wall_index);
    store64(b + RB_DIST, distance);
    var k = 0;
    while (k < NUM_BANDS) {
        store64(b + RB_ENERGY + k * 8, mbr_energy_band(ray_after, k));
        k = k + 1;
    }
    return b;
}

# Assemble a RayPath from accumulated bounces + the final ray state.
#must_use
fn _make_path(bounces, current) {
    var path = alloc(RP_SIZE);
    store64(path + RP_BOUNCES, bounces);
    store64(path + RP_TOTAL, mbr_distance(current));
    var k = 0;
    while (k < NUM_BANDS) {
        store64(path + RP_FINAL + k * 8, mbr_energy_band(current, k));
        k = k + 1;
    }
    return path;
}

# Trace a multiband ray through a vec of walls, recording each bounce.
#must_use
fn trace_ray(ray, walls, max_bounces) {
    var current = _multiband_ray_clone(ray);
    var bounces = vec_new();
    var last_wall = 0 - 1;
    var b = 0;
    var go = 1;
    while (go == 1) {
        if (b >= max_bounces) { go = 0; }
        if (go == 1) {
            if (multiband_ray_is_alive(current) == 0) { go = 0; }
        }
        if (go == 1) {
            var nw = find_nearest_wall(mbr_origin(current), mbr_direction(current), walls, last_wall);
            if (nw == 0) {
                go = 0;
            } else {
                var idx = NearestWall_index(nw);
                var t = NearestWall_distance(nw);
                var wall = vec_get(walls, idx);
                var point = hvec3_add(mbr_origin(current), hvec3_scale(mbr_direction(current), t));
                var hit = alloc(sizeof(RayHit));
                RayHit_set_point(hit, point);
                RayHit_set_normal(hit, Wall_normal(wall));
                RayHit_set_distance(hit, t);
                RayHit_set_wall_index(hit, idx);
                current = reflect_ray_multiband(current, hit, _wall_absorption_ptr(wall),
                am_scattering(Wall_material(wall)));
                vec_push(bounces, _make_bounce(point, Wall_normal(wall), idx, t, current));
                last_wall = idx;
                b = b + 1;
            }
        }
    }
    return _make_path(bounces, current);
}

# BVH-accelerated trace through an AcceleratedRoom.
#must_use
fn trace_ray_bvh(ray, accel_room, max_bounces) {
    var room = AcceleratedRoom_room(accel_room);
    var walls = RoomGeometry_walls(AcousticRoom_geometry(room));
    var bvh = AcceleratedRoom_bvh(accel_room);

    var current = _multiband_ray_clone(ray);
    var bounces = vec_new();
    var last_wall = 0 - 1;
    var b = 0;
    var go = 1;
    while (go == 1) {
        if (b >= max_bounces) { go = 0; }
        if (go == 1) {
            if (multiband_ray_is_alive(current) == 0) { go = 0; }
        }
        if (go == 1) {
            var nw = find_nearest_wall_bvh(mbr_origin(current), mbr_direction(current), walls, bvh, last_wall);
            if (nw == 0) {
                go = 0;
            } else {
                var idx = NearestWall_index(nw);
                var t = NearestWall_distance(nw);
                var wall = vec_get(walls, idx);
                var point = hvec3_add(mbr_origin(current), hvec3_scale(mbr_direction(current), t));
                var hit = alloc(sizeof(RayHit));
                RayHit_set_point(hit, point);
                RayHit_set_normal(hit, Wall_normal(wall));
                RayHit_set_distance(hit, t);
                RayHit_set_wall_index(hit, idx);
                current = reflect_ray_multiband(current, hit, _wall_absorption_ptr(wall),
                am_scattering(Wall_material(wall)));
                vec_push(bounces, _make_bounce(point, Wall_normal(wall), idx, t, current));
                last_wall = idx;
                b = b + 1;
            }
        }
    }
    return _make_path(bounces, current);
}

# --- radiosity.cyr ---

# radiosity.cyr -- acoustic radiosity: diffuse energy exchange between
# surface patches. View factors between wall patches drive an iterative
# energy-exchange solve until convergence. Source/receiver-independent:
# once patch-to-patch coupling is computed, moving sources/listeners is
# nearly free.
#
# Ports rust-old/src/radiosity.rs. f32 -> f64 throughout (hisab is
# f64-only). Rust's `serde` derive is dropped (no serde in Cyrius); the
# oracle has no serde round-trip test to port. The `Patch` struct carries
# two inline `[f32; 8]` arrays (reflectance, energy), so it uses the
# manual struct layout (PatchLayout offsets + store64/load64) the way
# material.cyr lays out AcousticMaterial. `Vec<Patch>` becomes a stdlib
# `vec` of Patch pointers; the `(Vec<Patch>, u32, bool)` result becomes a
# `#derive(accessors)` RadiosityResult struct (converged as 0/1).
#
# Requires (from the build/test unit): stdlib math/ganita (F64_*, f64_*),
# vec (vec_new/push/len/get/set), hisab (hvec3_*), error.cyr
# (GOONJ_EPSILON), material.cyr (NUM_BANDS, am_absorption_band), and
# room.cyr (Wall_vertices/material/normal, wall_area). alloc_init() must
# have run.

# Patch inline layout: centre ptr | normal ptr | area | 8xf64 reflectance
# | 8xf64 energy.
enum PatchLayout {
    PA_CENTRE = 0,
    PA_NORMAL = 8,
    PA_AREA   = 16,
    PA_REFL   = 24,    # offsets 24..88  (8 f64, per-band reflectance)
    PA_ENERGY = 88,    # offsets 88..152 (8 f64, per-band radiosity energy)
    PA_SIZE   = 152,
}

# ================================================================
# Patch
# ================================================================
fn patch_centre(p) { return load64(p + PA_CENTRE); }
fn patch_normal(p) { return load64(p + PA_NORMAL); }
fn patch_area(p) { return load64(p + PA_AREA); }
fn patch_reflectance_band(p, band) { return load64(p + PA_REFL + band * 8); }
fn patch_energy_band(p, band) { return load64(p + PA_ENERGY + band * 8); }

fn _patch_set_centre(p, v) { store64(p + PA_CENTRE, v); return 0; }
fn _patch_set_normal(p, v) { store64(p + PA_NORMAL, v); return 0; }
fn _patch_set_area(p, v) { store64(p + PA_AREA, v); return 0; }
fn _patch_set_reflectance(p, band, v) { store64(p + PA_REFL + band * 8, v); return 0; }
fn _patch_set_energy(p, band, v) { store64(p + PA_ENERGY + band * 8, v); return 0; }

# Build a patch from centre/normal (HVec3 ptrs), area, and a reflectance
# buffer (8 f64). Per-band energy is initialised to zero.
#must_use
fn patch_new(centre, normal, area, reflectance) {
    var p = alloc(PA_SIZE);
    _patch_set_centre(p, centre);
    _patch_set_normal(p, normal);
    _patch_set_area(p, area);
    var b = 0;
    while (b < NUM_BANDS) {
        _patch_set_reflectance(p, b, load64(reflectance + b * 8));
        _patch_set_energy(p, b, 0);
        b = b + 1;
    }
    return p;
}

# ================================================================
# Patch generation
# ================================================================
# Subdivide room walls into patches for radiosity. Each wall becomes a
# grid of approximately `patches_per_wall` patches (capped at 100/wall).
# `walls` is a vec of Wall pointers; returns a vec of Patch pointers.
#must_use
fn create_patches(walls, patches_per_wall) {
    var ppw = patches_per_wall;
    if (ppw > 100) { ppw = 100; }
    var patches = vec_new();

    var nw = vec_len(walls);
    var wi = 0;
    while (wi < nw) {
        var wall = vec_get(walls, wi);
        var area = wall_area(wall);
        var verts = Wall_vertices(wall);
        var nverts = vec_len(verts);

        var skip = 0;
        if (f64_lt(area, GOONJ_EPSILON) == 1) { skip = 1; }
        if (nverts < 3) { skip = 1; }

        if (skip == 0) {
            # Grid side n = ceil(sqrt(patches_per_wall)), at least 1.
            var n = f64_to(f64_ceil(f64_sqrt(f64_from(ppw))));
            if (n < 1) { n = 1; }
            var patch_area = f64_div(area, f64_from(n * n));

            # Quad corners (degenerate walls clamp toward v0 / v2).
            var v0 = vec_get(verts, 0);
            var v1 = v0;
            if (nverts > 1) { v1 = vec_get(verts, 1); }
            var v2 = v0;
            if (nverts > 2) { v2 = vec_get(verts, 2); }
            var v3 = v2;
            if (nverts > 3) { v3 = vec_get(verts, 3); }

            # Per-band reflectance = 1 - absorption.
            var material = Wall_material(wall);
            var refl = alloc(NUM_BANDS * 8);
            var band = 0;
            while (band < NUM_BANDS) {
                store64(refl + band * 8, f64_sub(F64_ONE, am_absorption_band(material, band)));
                band = band + 1;
            }

            var normal = Wall_normal(wall);
            var iy = 0;
            while (iy < n) {
                var ix = 0;
                while (ix < n) {
                    # Bilinear patch centre on the quad.
                    var u = f64_div(f64_add(f64_from(ix), F64_HALF), f64_from(n));
                    var v = f64_div(f64_add(f64_from(iy), F64_HALF), f64_from(n));
                    var w0 = f64_mul(f64_sub(F64_ONE, u), f64_sub(F64_ONE, v));
                    var w1 = f64_mul(u, f64_sub(F64_ONE, v));
                    var w2 = f64_mul(u, v);
                    var w3 = f64_mul(f64_sub(F64_ONE, u), v);
                    var centre = hvec3_add(
                    hvec3_add(hvec3_scale(v0, w0), hvec3_scale(v1, w1)),
                    hvec3_add(hvec3_scale(v2, w2), hvec3_scale(v3, w3)));
                    vec_push(patches, patch_new(centre, normal, patch_area, refl));
                    ix = ix + 1;
                }
                iy = iy + 1;
            }
        }
        wi = wi + 1;
    }
    return patches;
}

# ================================================================
# Form factor
# ================================================================
# Form factor between two patches:
#   F_ij = (cos t_i * cos t_j) / (pi * r^2) * A_j
# where t_i/t_j are the angles from the patch normals to the connecting
# line and r is the centre-to-centre distance.
#must_use
fn _form_factor(p_i, p_j) {
    var diff = hvec3_sub(patch_centre(p_j), patch_centre(p_i));
    var r2 = hvec3_dot(diff, diff);
    if (f64_lt(r2, GOONJ_EPSILON) == 1) { return 0; }
    var r = f64_sqrt(r2);
    var dir = hvec3_scale(diff, f64_div(F64_ONE, r));

    var cos_i = f64_max(hvec3_dot(dir, patch_normal(p_i)), 0);
    var cos_j = f64_max(hvec3_dot(hvec3_neg(dir), patch_normal(p_j)), 0);

    return f64_div(f64_mul(f64_mul(cos_i, cos_j), patch_area(p_j)), f64_mul(F64_PI, r2));
}

# ================================================================
# RadiosityResult
# ================================================================
# Final per-patch energy distribution, iteration count, and convergence
# flag (1 = converged within tolerance, 0 = hit max_iterations).
#derive(accessors)
struct RadiosityResult { patches; iterations; converged; }

#must_use
fn _radiosity_result(patches, iterations, converged) {
    var r = alloc(sizeof(RadiosityResult));
    RadiosityResult_set_patches(r, patches);
    RadiosityResult_set_iterations(r, iterations);
    RadiosityResult_set_converged(r, converged);
    return r;
}

# ================================================================
# Solver
# ================================================================
# Solve acoustic radiosity for `patches` (vec of Patch ptrs) with a
# source patch emitting `source_energy` (a buffer of 8 f64). Iterates
# energy exchange until max_change < tolerance or `max_iterations`.
#must_use
fn solve_radiosity(patches, source_patch, source_energy, max_iterations, tolerance) {
    var n = vec_len(patches);
    if (n == 0) { return _radiosity_result(patches, 0, 1); }
    if (source_patch >= n) { return _radiosity_result(patches, 0, 1); }

    # Initialise source patch energy.
    var src = vec_get(patches, source_patch);
    var sb = 0;
    while (sb < NUM_BANDS) {
        _patch_set_energy(src, sb, load64(source_energy + sb * 8));
        sb = sb + 1;
    }

    # Pre-allocate the incoming buffer (n x NUM_BANDS f64) once.
    var incoming = alloc(n * NUM_BANDS * 8);

    var iteration = 0;
    while (iteration < max_iterations) {
        var max_change = 0;

        # Clear the incoming buffer.
        var ci = 0;
        while (ci < n * NUM_BANDS) {
            store64(incoming + ci * 8, 0);
            ci = ci + 1;
        }

        # Gather: accumulate incoming energy through form factors.
        var i = 0;
        while (i < n) {
            var j = 0;
            while (j < n) {
                if (i != j) {
                    var ff = _form_factor(vec_get(patches, i), vec_get(patches, j));
                    if (f64_ge(ff, GOONJ_EPSILON) == 1) {
                        var pj = vec_get(patches, j);
                        var bg = 0;
                        while (bg < NUM_BANDS) {
                            var slot = incoming + (i * NUM_BANDS + bg) * 8;
                            var contrib = f64_mul(load64(pj + PA_ENERGY + bg * 8), ff);
                            store64(slot, f64_add(load64(slot), contrib));
                            bg = bg + 1;
                        }
                    }
                }
                j = j + 1;
            }
            i = i + 1;
        }

        # Scatter: update patch energies (source re-emits each iteration).
        i = 0;
        while (i < n) {
            var pi = vec_get(patches, i);
            var bs = 0;
            while (bs < NUM_BANDS) {
                var base = 0;
                if (i == source_patch) { base = load64(source_energy + bs * 8); }
                var inc = load64(incoming + (i * NUM_BANDS + bs) * 8);
                var new_energy = f64_add(base, f64_mul(inc, patch_reflectance_band(pi, bs)));
                var change = f64_abs(f64_sub(new_energy, patch_energy_band(pi, bs)));
                max_change = f64_max(max_change, change);
                _patch_set_energy(pi, bs, new_energy);
                bs = bs + 1;
            }
            i = i + 1;
        }

        if (f64_lt(max_change, tolerance) == 1) {
            return _radiosity_result(patches, iteration + 1, 1);
        }
        iteration = iteration + 1;
    }

    return _radiosity_result(patches, max_iterations, 0);
}

# --- image_source.cyr ---

# image_source.cyr -- image-source method for exact early specular
# reflections. Allen & Berkeley analytic mirror method for shoebox rooms
# plus a general recursive wall-reflection method for convex rooms; then
# arrival time + per-band amplitude for each image source.
#
# Ports rust-old/src/image_source.rs. f32 → f64 throughout (hisab is
# f64-only). Rust's `serde` derive is dropped (no serde in Cyrius); it has
# no test to port here. The `[f32; NUM_BANDS]` attenuation / amplitude
# arrays become inline 8×f64 blocks via manual struct layout (enum offsets
# + store64/load64). `Vec3` → hisab HVec3; `Vec<ImageSource>` /
# `Vec<EarlyReflection>` → stdlib `vec` holding struct pointers. The
# `[AcousticMaterial; 6]` materials array is a 6-slot pointer block.
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON), material.cyr
# (NUM_BANDS, am_absorption_band), room.cyr (Wall_*, RoomGeometry_*,
# AcousticRoom_*), stdlib math/ganita (F64_ONE, f64_*), vec, and hisab
# (hvec3_*). alloc_init() must have run.

# +inf / -inf sentinels for the bounding-box scan (f64 bit patterns).
var IS_POS_INF = 0x7FF0000000000000;   # +inf
var IS_NEG_INF = 0xFFF0000000000000;   # -inf

# ImageSource inline layout: position ptr | order | 8×f64 attenuation.
enum IsLayout {
    IS_POS   = 0,
    IS_ORDER = 8,
    IS_ATTEN = 16,    # offsets 16..80 (8 f64)
    IS_SIZE  = 80,
}

# EarlyReflection inline layout: delay | 8×f64 amplitude | dir | order | dist.
enum ErLayout {
    ER_DELAY = 0,
    ER_AMP   = 8,     # offsets 8..72 (8 f64)
    ER_DIR   = 72,
    ER_ORDER = 80,
    ER_DIST  = 88,
    ER_SIZE  = 96,
}

# ================================================================
# Small integer helpers
# ================================================================
# Absolute value of an integer (Rust's `i32::unsigned_abs`).
#must_use
fn _is_uabs(n) {
    if (n < 0) { return 0 - n; }
    return n;
}

# base^k for integer k >= 0 (Rust's `f32::powi`; powi(0) = 1).
#must_use
fn _is_ipow(base, k) {
    var result = F64_ONE;
    var i = 0;
    while (i < k) {
        result = f64_mul(result, base);
        i = i + 1;
    }
    return result;
}

# ================================================================
# ImageSource accessors + constructor
# ================================================================
fn image_source_position(s)        { return load64(s + IS_POS); }
fn image_source_order(s)           { return load64(s + IS_ORDER); }
fn image_source_atten_band(s, band) { return load64(s + IS_ATTEN + band * 8); }

# Allocate an image source at `position`/`order` with all-1.0 attenuation.
#must_use
fn _image_source_new(position, order) {
    var s = alloc(IS_SIZE);
    store64(s + IS_POS, position);
    store64(s + IS_ORDER, order);
    var i = 0;
    while (i < NUM_BANDS) {
        store64(s + IS_ATTEN + i * 8, F64_ONE);
        i = i + 1;
    }
    return s;
}

# ================================================================
# EarlyReflection accessors + constructor
# ================================================================
fn early_reflection_delay_seconds(r)    { return load64(r + ER_DELAY); }
fn early_reflection_amplitude_band(r, b) { return load64(r + ER_AMP + b * 8); }
fn early_reflection_direction(r)        { return load64(r + ER_DIR); }
fn early_reflection_order(r)            { return load64(r + ER_ORDER); }
fn early_reflection_distance(r)         { return load64(r + ER_DIST); }

# Allocate an early reflection; amplitude bands are filled by the caller.
#must_use
fn _early_reflection_new(delay, direction, order, distance) {
    var r = alloc(ER_SIZE);
    store64(r + ER_DELAY, delay);
    store64(r + ER_DIR, direction);
    store64(r + ER_ORDER, order);
    store64(r + ER_DIST, distance);
    return r;
}

# ================================================================
# Geometry helpers
# ================================================================
# Reflect a point across a plane (point on plane + normal).
# d = (point - plane_point)·normal ; result = point - 2·d·normal.
#must_use
fn reflect_point(point, plane_point, plane_normal) {
    var d = hvec3_dot(hvec3_sub(point, plane_point), plane_normal);
    return hvec3_sub(point, hvec3_scale(plane_normal, f64_mul(f64_from(2), d)));
}

# Image coordinate along one axis for reflection count `n`.
# Even n: n·dim + source (same-parity). Odd n>0: n·dim + (dim - source).
# Odd n<0: n·dim - (dim - source).
#must_use
fn image_coordinate(source_coord, dimension, n) {
    var nd = f64_mul(f64_from(n), dimension);
    if (n % 2 == 0) { return f64_add(nd, source_coord); }
    if (n > 0) { return f64_add(nd, f64_sub(dimension, source_coord)); }
    return f64_sub(nd, f64_sub(dimension, source_coord));
}

# Apply per-band attenuation for reflections along one axis, multiplying
# into `atten` (pointer to 8 f64). `neg_wall` sits at coordinate 0,
# `pos_wall` at coordinate = dimension; bounces alternate between them.
fn apply_axis_attenuation(atten, materials, neg_wall, pos_wall, n) {
    if (n == 0) { return 0; }
    var abs_n = _is_uabs(n);
    var neg_hits = 0;
    var pos_hits = 0;
    if (n > 0) {
        # Positive: pos wall ceil(n/2) times, neg wall floor(n/2) times.
        neg_hits = abs_n / 2;
        pos_hits = (abs_n + 1) / 2;
    } else {
        # Negative: neg wall ceil(|n|/2) times, pos wall floor(|n|/2) times.
        neg_hits = (abs_n + 1) / 2;
        pos_hits = abs_n / 2;
    }
    var neg_mat = load64(materials + neg_wall * 8);
    var pos_mat = load64(materials + pos_wall * 8);
    var band = 0;
    while (band < NUM_BANDS) {
        var neg_factor = _is_ipow(f64_sub(F64_ONE, am_absorption_band(neg_mat, band)), neg_hits);
        var pos_factor = _is_ipow(f64_sub(F64_ONE, am_absorption_band(pos_mat, band)), pos_hits);
        var cur = load64(atten + band * 8);
        store64(atten + band * 8, f64_mul(cur, f64_mul(neg_factor, pos_factor)));
        band = band + 1;
    }
    return 0;
}

# ================================================================
# Shoebox analytic mirror method
# ================================================================
# Image sources for a shoebox room (length=x, width=z, height=y). The
# `materials` block is [floor, ceiling, front, back, left, right]. Caps
# max_order at 20 to bound the O(n³) source count.
#must_use
fn compute_image_sources_shoebox(source, length, width, height, materials, max_order) {
    var mo = max_order;
    if (mo > 20) { mo = 20; }
    var max_n = mo;
    var sources = vec_new();

    # Order 0 = direct path (the source itself), unit attenuation.
    vec_push(sources, _image_source_new(source, 0));

    var nx = 0 - max_n;
    while (nx <= max_n) {
        var ny = 0 - max_n;
        while (ny <= max_n) {
            var nz = 0 - max_n;
            while (nz <= max_n) {
                var order = _is_uabs(nx) + _is_uabs(ny) + _is_uabs(nz);
                var skip = 0;
                if (order == 0) { skip = 1; }
                if (order > mo) { skip = 1; }
                if (skip == 0) {
                    var x = image_coordinate(HVec3_x(source), length, nx);
                    var y = image_coordinate(HVec3_y(source), height, ny);
                    var z = image_coordinate(HVec3_z(source), width, nz);
                    var img = _image_source_new(hvec3_new(x, y, z), order);
                    # left(4)/right(5) = x, floor(0)/ceiling(1) = y, front(2)/back(3) = z.
                    apply_axis_attenuation(img + IS_ATTEN, materials, 4, 5, nx);
                    apply_axis_attenuation(img + IS_ATTEN, materials, 0, 1, ny);
                    apply_axis_attenuation(img + IS_ATTEN, materials, 2, 3, nz);
                    vec_push(sources, img);
                }
                nz = nz + 1;
            }
            ny = ny + 1;
        }
        nx = nx + 1;
    }
    return sources;
}

# ================================================================
# General recursive method (arbitrary convex room)
# ================================================================
# Image sources by recursive reflection across each wall. Caps max_order
# at 6 to bound the O(W^N) growth.
#must_use
fn compute_image_sources_general(source, walls, max_order) {
    var mo = max_order;
    if (mo > 6) { mo = 6; }
    var sources = vec_new();
    var direct = _image_source_new(source, 0);
    vec_push(sources, direct);

    # Working set: sources at the current order to be reflected.
    var current_order = vec_new();
    vec_push(current_order, direct);

    var nw = vec_len(walls);
    var order = 1;
    while (order <= mo) {
        var next_order = vec_new();
        var pi = 0;
        var ncur = vec_len(current_order);
        while (pi < ncur) {
            var parent = vec_get(current_order, pi);
            var wi = 0;
            while (wi < nw) {
                var wall = vec_get(walls, wi);
                var v0 = vec_get(Wall_vertices(wall), 0);
                var reflected_pos = reflect_point(image_source_position(parent), v0, Wall_normal(wall));
                var img = _image_source_new(reflected_pos, image_source_order(parent) + 1);
                var mat = Wall_material(wall);
                var band = 0;
                while (band < NUM_BANDS) {
                    var pa = image_source_atten_band(parent, band);
                    var factor = f64_sub(F64_ONE, am_absorption_band(mat, band));
                    store64(img + IS_ATTEN + band * 8, f64_mul(pa, factor));
                    band = band + 1;
                }
                vec_push(next_order, img);
                wi = wi + 1;
            }
            pi = pi + 1;
        }
        var ei = 0;
        var nnext = vec_len(next_order);
        while (ei < nnext) {
            vec_push(sources, vec_get(next_order, ei));
            ei = ei + 1;
        }
        current_order = next_order;
        order = order + 1;
    }
    return sources;
}

# ================================================================
# Early reflections
# ================================================================
# Ascending insertion sort of an EarlyReflection vec by delay (Rust's
# `sort_by` on partial_cmp, NaN treated as Equal).
fn _er_sort_by_delay(v) {
    var n = vec_len(v);
    var i = 1;
    while (i < n) {
        var key = vec_get(v, i);
        var key_delay = early_reflection_delay_seconds(key);
        var j = i - 1;
        var go = 1;
        while (go == 1) {
            if (j < 0) { go = 0; }
            if (go == 1) {
                if (f64_gt(early_reflection_delay_seconds(vec_get(v, j)), key_delay) == 1) {
                    vec_set(v, j + 1, vec_get(v, j));
                    j = j - 1;
                } else {
                    go = 0;
                }
            }
        }
        vec_set(v, j + 1, key);
        i = i + 1;
    }
    return 0;
}

# Early reflections for a shoebox room: image sources up to max_order, each
# with arrival time and per-band amplitude (attenuation × inverse distance),
# returned sorted by arrival time. Empty geometry or non-positive speed → [].
#must_use
fn compute_early_reflections(source, listener, room, max_order, c_sound) {
    var geom = AcousticRoom_geometry(room);
    var walls = RoomGeometry_walls(geom);
    var reflections = vec_new();
    if (vec_len(walls) == 0) { return reflections; }
    if (f64_le(c_sound, 0) == 1) { return reflections; }

    # Room dimensions from the bounding box of all wall vertices.
    var mn = hvec3_splat(IS_POS_INF);
    var mx = hvec3_splat(IS_NEG_INF);
    var nw = vec_len(walls);
    var i = 0;
    while (i < nw) {
        var verts = Wall_vertices(vec_get(walls, i));
        var nv = vec_len(verts);
        var j = 0;
        while (j < nv) {
            var vtx = vec_get(verts, j);
            mn = hvec3_min(mn, vtx);
            mx = hvec3_max(mx, vtx);
            j = j + 1;
        }
        i = i + 1;
    }
    var dims = hvec3_sub(mx, mn);

    # Materials [floor, ceiling, front, back, left, right]; fall back to the
    # first wall's material if there are fewer than six walls.
    var materials = alloc(6 * 8);
    var k = 0;
    while (k < 6) {
        var src_idx = 0;
        if (nw >= 6) { src_idx = k; }
        store64(materials + k * 8, Wall_material(vec_get(walls, src_idx)));
        k = k + 1;
    }

    var image_sources = compute_image_sources_shoebox(
    source, HVec3_x(dims), HVec3_z(dims), HVec3_y(dims), materials, max_order);

    var ns = vec_len(image_sources);
    var s = 0;
    while (s < ns) {
        var img = vec_get(image_sources, s);
        var diff = hvec3_sub(listener, image_source_position(img));
        var distance = hvec3_length(diff);
        if (f64_ge(distance, GOONJ_EPSILON) == 1) {
            var delay = f64_div(distance, c_sound);
            var inv_dist = f64_div(F64_ONE, distance);
            var direction = hvec3_scale(diff, inv_dist);
            var r = _early_reflection_new(delay, direction, image_source_order(img), distance);
            var band = 0;
            while (band < NUM_BANDS) {
                store64(r + ER_AMP + band * 8,
                f64_mul(image_source_atten_band(img, band), inv_dist));
                band = band + 1;
            }
            vec_push(reflections, r);
        }
        s = s + 1;
    }
    _er_sort_by_delay(reflections);
    return reflections;
}

# --- dwm.cyr ---

# dwm.cyr -- 3D rectilinear Digital Waveguide Mesh (Smith / Van Duyne):
# wave-based room acoustics on a regular lattice with per-face IIR
# boundary reflection filters, plus dispersion characterization/correction.
#
# Ports rust-old/src/dwm.rs. f32 -> f64. serde dropped. Flat-namespace
# care: the co-compiled `fdtd` already defines MAX_GRID_CELLS,
# MAX_TIME_STEPS and band_energies, so this module uses DWM_-prefixed grid
# constants, `dwm_band_energies` (delegates to fdtd's `band_energies`), and
# `_dwm_`-prefixed private helpers.
#
# Requires (build/test unit): error.cyr, material.cyr (NUM_BANDS, am_*,
# _am_make), hybrid.cyr, fdtd.cyr (band_energies), stdlib math/ganita/vec.
# alloc_init() first. The solve_dwm_3d grid solver uses raw load64/store64
# buffers for the hot triple-loop (pressure is copied to a vec only for the
# result); receiver signals accumulate as vecs.

var DWM_SQRT_3         = 0x3FFBB67AE6502B91;   # 1.7320508  (√3)
var DWM_K              = 6;                     # waveguide ports per node
var DWM_SCATTER        = 0x3FD5555555555555;   # 2/K = 0.33333…
var DWM_MAX_GRID_CELLS = 4000000;
var DWM_MAX_TIME_STEPS = 1000000;
var DWM_DX_WARN_TOL    = 0x3F847AE147AE147B;   # 0.01
var DWM_DX_FAIL_TOL    = 0x3FB999999999999A;   # 0.10
var DWM_DEFAULT_BOOST  = 0x3FF0CCCCCCCCCCCD;   # 1.05
var DWM_DX_DEFAULT     = 0x3F9B9628CBD1244A;   # 0.02694
var DWM_DUR_DEFAULT    = 0x3FA999999999999A;   # 0.05
var DWM_POS_099        = 0x3FEFAE147AE147AE;   # 0.99
var DWM_NEG_099        = 0xBFEFAE147AE147AE;   # -0.99

# ================================================================
# WallMaterials — per-face materials (each an AcousticMaterial ptr).
# ================================================================
#derive(accessors)
struct WallMaterials { x_neg; x_pos; y_neg; y_pos; z_neg; z_pos; }

#must_use
fn wall_materials_new(x_neg, x_pos, y_neg, y_pos, z_neg, z_pos) {
    var w = alloc(sizeof(WallMaterials));
    WallMaterials_set_x_neg(w, x_neg);
    WallMaterials_set_x_pos(w, x_pos);
    WallMaterials_set_y_neg(w, y_neg);
    WallMaterials_set_y_pos(w, y_pos);
    WallMaterials_set_z_neg(w, z_neg);
    WallMaterials_set_z_pos(w, z_pos);
    return w;
}

# All six faces share one material (read-only sharing; Rust cloned).
#must_use
fn wall_materials_uniform(material) {
    return wall_materials_new(material, material, material, material, material, material);
}

# Fully rigid walls: zero absorption everywhere (R = 1).
#must_use
fn wall_materials_rigid() {
    return wall_materials_uniform(_am_make("rigid", 0, 0, 0, 0, 0, 0, 0, 0, 0));
}

# ================================================================
# DwmConfig
# ================================================================
#derive(accessors)
struct DwmConfig { sample_rate; dx; speed_of_sound; nx; ny; nz; duration_seconds; wall_materials; }

#must_use
fn dwm_config_new(sample_rate, dx, speed_of_sound, nx, ny, nz, duration_seconds, wall_materials) {
    var c = alloc(sizeof(DwmConfig));
    DwmConfig_set_sample_rate(c, sample_rate);
    DwmConfig_set_dx(c, dx);
    DwmConfig_set_speed_of_sound(c, speed_of_sound);
    DwmConfig_set_nx(c, nx);
    DwmConfig_set_ny(c, ny);
    DwmConfig_set_nz(c, nz);
    DwmConfig_set_duration_seconds(c, duration_seconds);
    DwmConfig_set_wall_materials(c, wall_materials);
    return c;
}

# Default: 22050 Hz, dx≈0.02694, c=343, 30×25×20, 0.05 s, rigid walls.
#must_use
fn dwm_config_default() {
    return dwm_config_new(22050, DWM_DX_DEFAULT, f64_from(343), 30, 25, 20,
    DWM_DUR_DEFAULT, wall_materials_rigid());
}

# Builder: set all faces to one material; mutate + return the config.
#must_use
fn dwm_config_with_acoustic_material(config, material) {
    DwmConfig_set_wall_materials(config, wall_materials_uniform(material));
    return config;
}
#must_use
fn dwm_config_with_wall_materials(config, walls) {
    DwmConfig_set_wall_materials(config, walls);
    return config;
}

# ================================================================
# BoundaryFilter — 1-pole IIR reflection filter H(z)=b0/(1-a1 z^-1),
# fitted to a material's 63 Hz and 8 kHz absorption.
# ================================================================
#derive(accessors)
struct BoundaryFilter { b0; a1; }

#must_use
fn boundary_filter_from_material(material) {
    var alpha_low = f64_clamp(am_absorption_band(material, 0), 0, F64_ONE);
    var alpha_high = f64_clamp(am_absorption_band(material, NUM_BANDS - 1), 0, F64_ONE);
    var r_low = f64_sqrt(f64_max(f64_sub(F64_ONE, alpha_low), 0));
    var r_high = f64_sqrt(f64_max(f64_sub(F64_ONE, alpha_high), 0));
    var denom = f64_add(r_low, r_high);
    var a1 = 0;
    if (f64_gt(denom, GOONJ_EPSILON) == 1) {
        a1 = f64_clamp(f64_div(f64_sub(r_low, r_high), denom), DWM_NEG_099, DWM_POS_099);
    }
    var b0 = f64_mul(r_low, f64_sub(F64_ONE, a1));
    var f = alloc(sizeof(BoundaryFilter));
    BoundaryFilter_set_b0(f, b0);
    BoundaryFilter_set_a1(f, a1);
    return f;
}

# y[n] = b0·x + a1·prev_y
#must_use
fn boundary_filter_process(filter, x, prev_y) {
    return f64_add(f64_mul(BoundaryFilter_b0(filter), x), f64_mul(BoundaryFilter_a1(filter), prev_y));
}

# ================================================================
# DwmSource / DwmReceiver / DwmResult
# ================================================================
#derive(accessors)
struct DwmSource { ix; iy; iz; signal; }

# Gaussian pulse centred at peak_step, width sigma_steps; ~6σ long.
#must_use
fn dwm_source_gaussian_pulse(ix, iy, iz, peak_step, sigma_steps, amplitude) {
    var n = f64_to(f64_ceil(f64_add(f64_from(peak_step), f64_mul(f64_from(6), sigma_steps))));
    if (n < 1) { n = 1; }
    var inv_sigma = f64_div(F64_ONE, f64_max(sigma_steps, F64_ONE));
    var signal = vec_new();
    var i = 0;
    while (i < n) {
        var arg = f64_mul(f64_sub(f64_from(i), f64_from(peak_step)), inv_sigma);
        var val = f64_mul(amplitude, f64_exp(f64_mul(f64_neg(F64_HALF), f64_mul(arg, arg))));
        vec_push(signal, val);
        i = i + 1;
    }
    var s = alloc(sizeof(DwmSource));
    DwmSource_set_ix(s, ix);
    DwmSource_set_iy(s, iy);
    DwmSource_set_iz(s, iz);
    DwmSource_set_signal(s, signal);
    return s;
}

#derive(accessors)
struct DwmReceiver { ix; iy; iz; }

#must_use
fn dwm_receiver_new(ix, iy, iz) {
    var r = alloc(sizeof(DwmReceiver));
    DwmReceiver_set_ix(r, ix);
    DwmReceiver_set_iy(r, iy);
    DwmReceiver_set_iz(r, iz);
    return r;
}

#derive(accessors)
struct DwmResult { receiver_signals; final_pressure; time_steps; dt; }

#must_use
fn _dwm_empty_result() {
    var r = alloc(sizeof(DwmResult));
    DwmResult_set_receiver_signals(r, vec_new());
    DwmResult_set_final_pressure(r, vec_new());
    DwmResult_set_time_steps(r, 0);
    DwmResult_set_dt(r, 0);
    return r;
}

# Row-major flat index (z*ny + y)*nx + x.
#must_use
fn _dwm_idx(x, y, z, nx, ny) {
    return (z * ny + y) * nx + x;
}

# ================================================================
# Convenience / characterization functions
# ================================================================
# Grid spacing required for a sample rate + sound speed: Δx = c·√3 / fs.
#must_use
fn required_dx(sample_rate, speed_of_sound) {
    if (sample_rate == 0) { return 0; }
    return f64_div(f64_mul(speed_of_sound, DWM_SQRT_3), f64_from(sample_rate));
}

# Per-band energies (delegates to fdtd's Goertzel helper).
#must_use
fn dwm_band_energies(signal, sample_rate) {
    return band_energies(signal, sample_rate);
}

# Mesh frequency f_mesh = c / (2·Δx); 0 if dx ≤ 0.
#must_use
fn mesh_frequency(config) {
    var dx = DwmConfig_dx(config);
    if (f64_le(dx, 0) == 1) { return 0; }
    return f64_div(DwmConfig_speed_of_sound(config), f64_mul(F64_TWO, dx));
}

# Dispersion factor f_sim/f_true for axis-aligned propagation (1 at DC,
# → 0 at the mesh limit, 0 above it, 1 for invalid input).
#must_use
fn dispersion_factor(config, frequency_hz) {
    if (f64_le(frequency_hz, 0) == 1) { return F64_ONE; }
    if (DwmConfig_sample_rate(config) == 0) { return F64_ONE; }
    if (f64_le(DwmConfig_speed_of_sound(config), 0) == 1) { return F64_ONE; }
    if (f64_ge(frequency_hz, mesh_frequency(config)) == 1) { return 0; }

    var dt = f64_div(F64_ONE, f64_from(DwmConfig_sample_rate(config)));
    var omega_true = f64_mul(F64_TAU, frequency_hz);
    var arg = f64_div(f64_mul(f64_mul(omega_true, dt), DWM_SQRT_3), F64_TWO);
    var sin_arg = f64_clamp(f64_div(f64_sin(arg), DWM_SQRT_3), f64_neg(F64_ONE), F64_ONE);
    var omega_sim = f64_div(f64_mul(F64_TWO, f64_asin(sin_arg)), dt);
    if (f64_lt(f64_abs(omega_true), GOONJ_EPSILON) == 1) { return F64_ONE; }
    return f64_div(omega_sim, omega_true);
}

# ================================================================
# DispersionCorrection — 2-tap FIR y[n] = b0·x[n] + b1·x[n-1].
# ================================================================
#derive(accessors)
struct DispersionCorrection { b0; b1; }

#must_use
fn dispersion_correction_new(b0, b1) {
    var d = alloc(sizeof(DispersionCorrection));
    DispersionCorrection_set_b0(d, b0);
    DispersionCorrection_set_b1(d, b1);
    return d;
}

#must_use
fn dispersion_correction_passthrough() {
    return dispersion_correction_new(F64_ONE, 0);
}

# Calibrate so the boost at f_mesh/2 matches `boost` with unity DC gain.
#must_use
fn dispersion_correction_calibrated(config, boost) {
    var f_mesh = mesh_frequency(config);
    if (f64_le(f_mesh, 0) == 1) { return dispersion_correction_passthrough(); }
    if (DwmConfig_sample_rate(config) == 0) { return dispersion_correction_passthrough(); }

    var omega_target = f64_div(f64_mul(F64_TAU, f64_mul(F64_HALF, f_mesh)),
    f64_from(DwmConfig_sample_rate(config)));
    var cos_t = f64_cos(omega_target);
    var denom = f64_mul(F64_TWO, f64_sub(cos_t, F64_ONE));
    if (f64_lt(f64_abs(denom), GOONJ_EPSILON) == 1) { return dispersion_correction_passthrough(); }

    var target_sq = f64_mul(boost, boost);
    var rhs = f64_div(f64_sub(target_sq, F64_ONE), denom);
    var disc = f64_sub(F64_ONE, f64_mul(f64_from(4), rhs));
    if (f64_lt(disc, 0) == 1) { return dispersion_correction_passthrough(); }
    var root = f64_sqrt(disc);
    var b0 = f64_mul(f64_add(F64_ONE, root), F64_HALF);
    return dispersion_correction_new(b0, f64_sub(F64_ONE, b0));
}

#must_use
fn dispersion_correction_for_config(config) {
    return dispersion_correction_calibrated(config, DWM_DEFAULT_BOOST);
}

# Apply the FIR in place to a vec signal (backwards so x[i-1] survives).
fn dispersion_correction_apply(dc, signal) {
    var n = vec_len(signal);
    if (n == 0) { return 0; }
    var b0 = DispersionCorrection_b0(dc);
    var b1 = DispersionCorrection_b1(dc);
    var i = n - 1;
    while (i >= 1) {
        vec_set(signal, i, f64_add(f64_mul(b0, vec_get(signal, i)), f64_mul(b1, vec_get(signal, i - 1))));
        i = i - 1;
    }
    vec_set(signal, 0, f64_mul(b0, vec_get(signal, 0)));
    return 0;
}

# ================================================================
# solve_dwm_3d — 3D acoustic wave equation on a box via the DWM.
# ================================================================
# Alloc a zeroed f64 buffer of `count` elements.
#must_use
fn _dwm_zeros(count) {
    var buf = alloc(count * 8);
    var i = 0;
    while (i < count) {
        store64(buf + i * 8, 0);
        i = i + 1;
    }
    return buf;
}

# Returns a DwmResult. Empty result on degenerate input (tiny grid, source
# out of range, dx deviating from c·Δt·√3 by >10%, etc.). `receivers` is a
# vec of DwmReceiver; each in-range receiver gets a pressure trace.
#must_use
fn solve_dwm_3d(config, source, receivers) {
    if (DwmConfig_sample_rate(config) == 0) { return _dwm_empty_result(); }
    if (f64_le(DwmConfig_dx(config), 0) == 1) { return _dwm_empty_result(); }
    if (f64_le(DwmConfig_speed_of_sound(config), 0) == 1) { return _dwm_empty_result(); }
    var nx = DwmConfig_nx(config);
    var ny = DwmConfig_ny(config);
    var nz = DwmConfig_nz(config);
    if (nx < 3) { return _dwm_empty_result(); }
    if (ny < 3) { return _dwm_empty_result(); }
    if (nz < 3) { return _dwm_empty_result(); }
    if (f64_le(DwmConfig_duration_seconds(config), 0) == 1) { return _dwm_empty_result(); }

    var n = nx * ny * nz;
    if (n == 0) { return _dwm_empty_result(); }
    if (n > DWM_MAX_GRID_CELLS) { return _dwm_empty_result(); }
    if (DwmSource_ix(source) >= nx) { return _dwm_empty_result(); }
    if (DwmSource_iy(source) >= ny) { return _dwm_empty_result(); }
    if (DwmSource_iz(source) >= nz) { return _dwm_empty_result(); }

    var dt = f64_div(F64_ONE, f64_from(DwmConfig_sample_rate(config)));
    var dx_expected = f64_mul(f64_mul(DwmConfig_speed_of_sound(config), dt), DWM_SQRT_3);
    var dx_dev = f64_div(f64_abs(f64_sub(DwmConfig_dx(config), dx_expected)),
    f64_max(dx_expected, GOONJ_EPSILON));
    if (f64_gt(dx_dev, DWM_DX_FAIL_TOL) == 1) {
        # Ports the Rust tracing::warn! — surfaced via goonj_log (verbose diag).
        goonj_log_warn("dwm: dx deviates from c*dt*sqrt(3) by >10%; refusing to run");
        return _dwm_empty_result();
    }
    if (f64_gt(dx_dev, DWM_DX_WARN_TOL) == 1) {
        goonj_log_warn("dwm: dx deviates from c*dt*sqrt(3) by >1%; sound speed will be off");
    }

    var num_steps = f64_to(f64_div(DwmConfig_duration_seconds(config), dt));
    if (num_steps > DWM_MAX_TIME_STEPS) { num_steps = DWM_MAX_TIME_STEPS; }
    if (num_steps == 0) { return _dwm_empty_result(); }

    var walls = DwmConfig_wall_materials(config);
    var f_xneg = boundary_filter_from_material(WallMaterials_x_neg(walls));
    var f_xpos = boundary_filter_from_material(WallMaterials_x_pos(walls));
    var f_yneg = boundary_filter_from_material(WallMaterials_y_neg(walls));
    var f_ypos = boundary_filter_from_material(WallMaterials_y_pos(walls));
    var f_zneg = boundary_filter_from_material(WallMaterials_z_neg(walls));
    var f_zpos = boundary_filter_from_material(WallMaterials_z_pos(walls));

    # Per-face IIR filter state (one f64 per boundary cell).
    var s_xneg = _dwm_zeros(ny * nz);
    var s_xpos = _dwm_zeros(ny * nz);
    var s_yneg = _dwm_zeros(nx * nz);
    var s_ypos = _dwm_zeros(nx * nz);
    var s_zneg = _dwm_zeros(nx * ny);
    var s_zpos = _dwm_zeros(nx * ny);

    # Outgoing-wave buffers (K per node), pressure scratch.
    var out_curr = _dwm_zeros(n * DWM_K);
    var out_next = _dwm_zeros(n * DWM_K);
    var pressure = _dwm_zeros(n);

    # One accumulator vec per receiver (out-of-range ones stay empty).
    var receiver_signals = vec_new();
    var ri = 0;
    while (ri < vec_len(receivers)) {
        vec_push(receiver_signals, vec_new());
        ri = ri + 1;
    }

    var source_signal = DwmSource_signal(source);
    var source_node = _dwm_idx(DwmSource_ix(source), DwmSource_iy(source), DwmSource_iz(source), nx, ny);

    for (var step = 0; step < num_steps; step = step + 1) {
        for (var z = 0; z < nz; z = z + 1) {
            for (var y = 0; y < ny; y = y + 1) {
                for (var x = 0; x < nx; x = x + 1) {
                    var node = _dwm_idx(x, y, z, nx, ny);
                    var base = node * DWM_K;

                    # Incoming waves; at a boundary the outgoing wave reflects
                    # back through that face's 1-pole IIR (per-cell state).
                    var in_xpos = 0;
                    if (x + 1 < nx) {
                        in_xpos = load64(out_curr + (_dwm_idx(x + 1, y, z, nx, ny) * DWM_K + 1) * 8);
                    } else {
                        var si = z * ny + y;
                        in_xpos = boundary_filter_process(f_xpos, load64(out_curr + base * 8), load64(s_xpos + si * 8));
                        store64(s_xpos + si * 8, in_xpos);
                    }
                    var in_xneg = 0;
                    if (x > 0) {
                        in_xneg = load64(out_curr + (_dwm_idx(x - 1, y, z, nx, ny) * DWM_K) * 8);
                    } else {
                        var si = z * ny + y;
                        in_xneg = boundary_filter_process(f_xneg, load64(out_curr + (base + 1) * 8),
                        load64(s_xneg + si * 8));
                        store64(s_xneg + si * 8, in_xneg);
                    }
                    var in_ypos = 0;
                    if (y + 1 < ny) {
                        in_ypos = load64(out_curr + (_dwm_idx(x, y + 1, z, nx, ny) * DWM_K + 3) * 8);
                    } else {
                        var si = z * nx + x;
                        in_ypos = boundary_filter_process(f_ypos, load64(out_curr + (base + 2) * 8),
                        load64(s_ypos + si * 8));
                        store64(s_ypos + si * 8, in_ypos);
                    }
                    var in_yneg = 0;
                    if (y > 0) {
                        in_yneg = load64(out_curr + (_dwm_idx(x, y - 1, z, nx, ny) * DWM_K + 2) * 8);
                    } else {
                        var si = z * nx + x;
                        in_yneg = boundary_filter_process(f_yneg, load64(out_curr + (base + 3) * 8),
                        load64(s_yneg + si * 8));
                        store64(s_yneg + si * 8, in_yneg);
                    }
                    var in_zpos = 0;
                    if (z + 1 < nz) {
                        in_zpos = load64(out_curr + (_dwm_idx(x, y, z + 1, nx, ny) * DWM_K + 5) * 8);
                    } else {
                        var si = y * nx + x;
                        in_zpos = boundary_filter_process(f_zpos, load64(out_curr + (base + 4) * 8),
                        load64(s_zpos + si * 8));
                        store64(s_zpos + si * 8, in_zpos);
                    }
                    var in_zneg = 0;
                    if (z > 0) {
                        in_zneg = load64(out_curr + (_dwm_idx(x, y, z - 1, nx, ny) * DWM_K + 4) * 8);
                    } else {
                        var si = y * nx + x;
                        in_zneg = boundary_filter_process(f_zneg, load64(out_curr + (base + 5) * 8),
                        load64(s_zneg + si * 8));
                        store64(s_zneg + si * 8, in_zneg);
                    }

                    # Junction pressure p = (2/K)·Σ incoming.
                    var sum = f64_add(f64_add(f64_add(in_xpos, in_xneg), f64_add(in_ypos, in_yneg)),
                    f64_add(in_zpos, in_zneg));
                    var p = f64_mul(DWM_SCATTER, sum);

                    # Transparent (additive) source injection.
                    if (node == source_node) {
                        if (step < vec_len(source_signal)) {
                            p = f64_add(p, vec_get(source_signal, step));
                        }
                    }
                    store64(pressure + node * 8, p);

                    # Outgoing: out_i = p − in_i.
                    store64(out_next + base * 8, f64_sub(p, in_xpos));
                    store64(out_next + (base + 1) * 8, f64_sub(p, in_xneg));
                    store64(out_next + (base + 2) * 8, f64_sub(p, in_ypos));
                    store64(out_next + (base + 3) * 8, f64_sub(p, in_yneg));
                    store64(out_next + (base + 4) * 8, f64_sub(p, in_zpos));
                    store64(out_next + (base + 5) * 8, f64_sub(p, in_zneg));
                }
            }
        }

        # Sample receivers.
        for (var rj = 0; rj < vec_len(receivers); rj = rj + 1) {
            var rx = vec_get(receivers, rj);
            if (DwmReceiver_ix(rx) < nx) {
                if (DwmReceiver_iy(rx) < ny) {
                    if (DwmReceiver_iz(rx) < nz) {
                        var pidx = _dwm_idx(DwmReceiver_ix(rx), DwmReceiver_iy(rx), DwmReceiver_iz(rx), nx, ny);
                        vec_push(vec_get(receiver_signals, rj), load64(pressure + pidx * 8));
                    }
                }
            }
        }

        # Rotate buffers.
        var tmp = out_curr;
        out_curr = out_next;
        out_next = tmp;
    }

    # Copy final pressure field into a vec.
    var final_pressure = vec_new();
    var fi = 0;
    while (fi < n) {
        vec_push(final_pressure, load64(pressure + fi * 8));
        fi = fi + 1;
    }

    var result = alloc(sizeof(DwmResult));
    DwmResult_set_receiver_signals(result, receiver_signals);
    DwmResult_set_final_pressure(result, final_pressure);
    DwmResult_set_time_steps(result, num_steps);
    DwmResult_set_dt(result, dt);
    return result;
}

# --- diffuse.cyr ---

# diffuse.cyr -- diffuse rain: stochastic ray tracing for late
# reverberation tails.
#
# Launches many rays from a source in uniformly distributed directions
# (Fibonacci sphere + inline xorshift64 jitter), traces each through the
# room geometry, and collects per-band energy at every bounce point that
# falls within a collection sphere around the listener. The result is a
# time-energy set of late-reverb contributions, sorted by arrival time.
#
# Ports rust-old/src/diffuse.rs. f32 -> f64 throughout. Rust's `serde`
# derive on DiffuseRainConfig/LateReverbContribution/DiffuseRainResult is
# dropped (no serde in Cyrius); there is no serde round-trip test to port.
# The `[f32; NUM_BANDS]` energy array on LateReverbContribution uses manual
# inline layout (like ray.cyr's RayBounce). The private Xorshift64 PRNG is
# prefixed `_diffuse_` / `DiffuseRng` to avoid clashing with the xorshift in
# dark_velvet_noise.cyr when the whole library is bundled.
#
# Requires (from the build/test unit): stdlib alloc/vec (alloc_init, vec_*),
# math/ganita (F64_ONE/TWO/HALF/TAU, f64_*, f64_sin/cos/acos/pow/sqrt),
# hisab (hvec3_*, HVec3_*), error.cyr (GOONJ_EPSILON), material.cyr
# (NUM_BANDS), room.cyr (AcousticRoom_*, RoomGeometry_walls,
# room_geometry_volume_shoebox), and ray.cyr (multiband_ray_new, trace_ray,
# ray_path_bounces, ray_bounce_point/distance/energy_after). alloc_init()
# must have run.

# LateReverbContribution inline layout: time | direction | energy[8].
enum LrcLayout { LRC_TIME = 0, LRC_DIR = 8, LRC_ENERGY = 16, LRC_SIZE = 80 }

# ================================================================
# DiffuseRainConfig -- configuration for a diffuse-rain computation.
#   num_rays          : rays launched from the source
#   max_bounces       : maximum bounces per ray
#   max_time_seconds  : maximum simulation time (s)
#   collection_radius : listener collection-sphere radius; if <= f32::EPSILON
#                       it is auto-computed from room volume and ray count
#   speed_of_sound    : speed of sound (m/s)
#   seed              : xorshift64 seed for reproducibility
# ================================================================
#derive(accessors)
struct DiffuseRainConfig {
    num_rays;
    max_bounces;
    max_time_seconds;
    collection_radius;
    speed_of_sound;
    seed;
}

#must_use
fn diffuse_rain_config_new(num_rays, max_bounces, max_time_seconds, collection_radius, speed_of_sound, seed) {
    var c = alloc(sizeof(DiffuseRainConfig));
    DiffuseRainConfig_set_num_rays(c, num_rays);
    DiffuseRainConfig_set_max_bounces(c, max_bounces);
    DiffuseRainConfig_set_max_time_seconds(c, max_time_seconds);
    DiffuseRainConfig_set_collection_radius(c, collection_radius);
    DiffuseRainConfig_set_speed_of_sound(c, speed_of_sound);
    DiffuseRainConfig_set_seed(c, seed);
    return c;
}

# ================================================================
# LateReverbContribution -- one late-reverb energy arrival (manual layout).
# ================================================================
#must_use
fn lrc_time(c) { return load64(c + LRC_TIME); }
#must_use
fn lrc_direction(c) { return load64(c + LRC_DIR); }
#must_use
fn lrc_energy_band(c, i) { return load64(c + LRC_ENERGY + i * 8); }

# Build a contribution, copying the 8-band energy from a RayBounce.
#must_use
fn _make_contribution(time, direction, bounce) {
    var c = alloc(LRC_SIZE);
    store64(c + LRC_TIME, time);
    store64(c + LRC_DIR, direction);
    var i = 0;
    while (i < NUM_BANDS) {
        store64(c + LRC_ENERGY + i * 8, ray_bounce_energy_after(bounce, i));
        i = i + 1;
    }
    return c;
}

# ================================================================
# DiffuseRainResult -- contributions (sorted by time) + ray/bounce counts.
# ================================================================
#derive(accessors)
struct DiffuseRainResult { contributions; rays_traced; total_bounces; }

#must_use
fn _diffuse_empty_result() {
    var r = alloc(sizeof(DiffuseRainResult));
    DiffuseRainResult_set_contributions(r, vec_new());
    DiffuseRainResult_set_rays_traced(r, 0);
    DiffuseRainResult_set_total_bounces(r, 0);
    return r;
}

# ================================================================
# DiffuseRng -- private xorshift64 PRNG (prefixed to avoid the
# dark_velvet_noise.cyr xorshift symbol in the bundled namespace).
# ================================================================
#derive(accessors)
struct DiffuseRng { state; }

#must_use
fn _diffuse_xorshift_new(seed) {
    var r = alloc(sizeof(DiffuseRng));
    if (seed == 0) {
        DiffuseRng_set_state(r, 0x5555555555555555);
    } else {
        DiffuseRng_set_state(r, seed);
    }
    return r;
}

# One xorshift64 step (C-style bit ops; shift semantics only need internal
# consistency for determinism).
fn _diffuse_xorshift_next_u64(rng) {
    var x = DiffuseRng_state(rng);
    x = x ^ (x << 13);
    x = x ^ (x >> 7);
    x = x ^ (x << 17);
    DiffuseRng_set_state(rng, x);
    return x;
}

# Float in [0, 1): top 24 bits / 2^24. Masking with 0xFFFFFF makes the
# result independent of the shift's sign behaviour, keeping it in range.
fn _diffuse_xorshift_next_f64(rng) {
    var r = _diffuse_xorshift_next_u64(rng);
    var bits = (r >> 40) & 0xFFFFFF;
    return f64_div(f64_from(bits), f64_from(16777216));
}

# ================================================================
# Fibonacci sphere
# ================================================================
# Uniformly distributed directions on a sphere via the Fibonacci spiral.
#must_use
fn fibonacci_sphere(n) {
    var golden_ratio = f64_div(f64_add(F64_ONE, f64_sqrt(f64_from(5))), F64_TWO);
    var angle_increment = f64_div(F64_TAU, golden_ratio);
    var dirs = vec_new();
    var i = 0;
    while (i < n) {
        var t = f64_div(f64_add(f64_from(i), F64_HALF), f64_from(n));
        var phi = f64_acos(f64_sub(F64_ONE, f64_mul(F64_TWO, t)));
        var theta = f64_mul(angle_increment, f64_from(i));
        var sp = f64_sin(phi);
        var x = f64_mul(sp, f64_cos(theta));
        var y = f64_mul(sp, f64_sin(theta));
        var z = f64_cos(phi);
        vec_push(dirs, hvec3_new(x, y, z));
        i = i + 1;
    }
    return dirs;
}

# Auto collection radius: r = 2 * (volume / num_rays)^(1/3). cbrt via pow;
# the ratio is positive so pow(x, 1/3) == cbrt(x).
#must_use
fn auto_collection_radius(volume, num_rays) {
    var ratio = f64_div(volume, f64_from(num_rays));
    var cube_root = f64_pow(ratio, f64_div(F64_ONE, f64_from(3)));
    return f64_mul(F64_TWO, cube_root);
}

# ================================================================
# Sorting
# ================================================================
# Ascending insertion sort of a contribution vec by arrival time.
fn _diffuse_sort_contributions(v) {
    var n = vec_len(v);
    var i = 1;
    while (i < n) {
        var key = vec_get(v, i);
        var key_t = lrc_time(key);
        var j = i - 1;
        var go = 1;
        while (go == 1) {
            if (j < 0) { go = 0; }
            if (go == 1) {
                if (f64_gt(lrc_time(vec_get(v, j)), key_t) == 1) {
                    vec_set(v, j + 1, vec_get(v, j));
                    j = j - 1;
                } else {
                    go = 0;
                }
            }
        }
        vec_set(v, j + 1, key);
        i = i + 1;
    }
    return 0;
}

# ================================================================
# generate_diffuse_rain
# ================================================================
# Launch config.num_rays from source, trace each through the room, and
# collect per-band energy at bounce points inside the collection sphere
# around listener. Returns a DiffuseRainResult (contributions sorted by
# time). Degenerate configs (num_rays == 0 or speed_of_sound <= 0) return
# an empty result.
#must_use
fn generate_diffuse_rain(source, listener, room, config) {
    if (DiffuseRainConfig_num_rays(config) == 0) { return _diffuse_empty_result(); }
    if (f64_le(DiffuseRainConfig_speed_of_sound(config), 0) == 1) { return _diffuse_empty_result(); }

    var geom = AcousticRoom_geometry(room);
    var volume = room_geometry_volume_shoebox(geom);
    var collection_r = auto_collection_radius(volume, DiffuseRainConfig_num_rays(config));
    if (f64_gt(DiffuseRainConfig_collection_radius(config), GOONJ_EPSILON) == 1) {
        collection_r = DiffuseRainConfig_collection_radius(config);
    }
    var collection_r2 = f64_mul(collection_r, collection_r);

    var directions = fibonacci_sphere(DiffuseRainConfig_num_rays(config));
    var rng = _diffuse_xorshift_new(DiffuseRainConfig_seed(config));
    var max_time = DiffuseRainConfig_max_time_seconds(config);
    var jitter_scale = f64_div(F64_ONE, f64_from(20));

    var walls = RoomGeometry_walls(geom);
    var contributions = vec_new();
    var total_bounces = 0;

    var num_dirs = vec_len(directions);
    var di = 0;
    while (di < num_dirs) {
        var base_dir = vec_get(directions, di);

        # Slight random perturbation for stochastic diversity.
        var jx = f64_mul(f64_sub(_diffuse_xorshift_next_f64(rng), F64_HALF), jitter_scale);
        var jy = f64_mul(f64_sub(_diffuse_xorshift_next_f64(rng), F64_HALF), jitter_scale);
        var jz = f64_mul(f64_sub(_diffuse_xorshift_next_f64(rng), F64_HALF), jitter_scale);
        var dir_raw = hvec3_add(base_dir, hvec3_new(jx, jy, jz));
        var len = hvec3_length(dir_raw);
        var dir = base_dir;
        if (f64_gt(len, GOONJ_EPSILON) == 1) {
            dir = hvec3_scale(dir_raw, f64_div(F64_ONE, len));
        }

        var ray = multiband_ray_new(source, dir);
        var path = trace_ray(ray, walls, DiffuseRainConfig_max_bounces(config));
        var bounces = ray_path_bounces(path);
        total_bounces = total_bounces + vec_len(bounces);

        # Walk bounce points, accumulating distance for time; stop once the
        # arrival time exceeds max_time (distance is monotonic).
        var cumulative_distance = 0;
        var nb = vec_len(bounces);
        var bi = 0;
        var stop = 0;
        while (bi < nb) {
            if (stop == 0) {
                var bounce = vec_get(bounces, bi);
                cumulative_distance = f64_add(cumulative_distance, ray_bounce_distance(bounce));
                var time = f64_div(cumulative_distance, DiffuseRainConfig_speed_of_sound(config));
                if (f64_gt(time, max_time) == 1) {
                    stop = 1;
                } else {
                    var diff = hvec3_sub(ray_bounce_point(bounce), listener);
                    var dist2 = hvec3_dot(diff, diff);
                    if (f64_le(dist2, collection_r2) == 1) {
                        var dist = f64_sqrt(dist2);
                        var direction = dir;
                        if (f64_gt(dist, GOONJ_EPSILON) == 1) {
                            direction = hvec3_scale(diff, f64_div(F64_ONE, dist));
                        }
                        vec_push(contributions, _make_contribution(time, direction, bounce));
                    }
                }
            }
            bi = bi + 1;
        }
        di = di + 1;
    }

    _diffuse_sort_contributions(contributions);

    var result = alloc(sizeof(DiffuseRainResult));
    DiffuseRainResult_set_contributions(result, contributions);
    DiffuseRainResult_set_rays_traced(result, DiffuseRainConfig_num_rays(config));
    DiffuseRainResult_set_total_bounces(result, total_bounces);
    return result;
}

# --- diffraction.cyr ---

# diffraction.cyr -- edge diffraction loss + occlusion.
#
# Ports rust-old/src/diffraction.rs. f32 -> f64 throughout (hisab is
# f64-only). Two loss models: a UTD-inspired half-plane approximation
# (edge_diffraction_loss) and a Kouyoumjian-Pathak wedge model
# (utd_wedge_diffraction). Plus line-of-sight occlusion (is_occluded)
# and the extra diffraction path length (diffraction_path_extra).
#
# Rust's `cot_term` closure (captures inv_n / wedge_n / k / l) becomes the
# free helper `_diff_cot_term` taking those as explicit params. `.powi(2)`
# is a self-multiply; `.round()` uses the stdlib `f64_round` builtin.
# `Option<f32>` from ray_wall_intersection is a negative sentinel
# (RAY_NONE), so the `t > EPSILON` guard already rejects the no-hit case.
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON), stdlib
# math/ganita (F64_PI, F64_TAU, F64_ONE, F64_TWO, F64_HALF, f64_sin/cos/
# sqrt/round/ln/…), hisab (hvec3_sub/length/distance), propagation.cyr
# (speed_of_sound), ray.cyr (acoustic_ray_new, ray_wall_intersection),
# room.cyr (Wall via ray_wall_intersection). alloc_init() must have run.

# Non-integer f64 bit patterns (decimal in comments for traceability).
var DIFF_001  = 0x3F847AE147AE147B;   # 0.01   Fresnel-arg / a rolloff threshold
var DIFF_1E6  = 0x3EB0C6F7A0B5ED8D;   # 1e-6   coefficient clamp floor / sin guard
var DIFF_1E10 = 0x3DDB7CDFD9D7BDBB;   # 1e-10  UTD total clamp floor

# log10(x) = ln(x) / ln(10)
#must_use
fn _diff_log10(x) {
    return f64_div(f64_ln(x), F64_LN10);
}

# ================================================================
# Edge diffraction attenuation (UTD-inspired half-plane approximation).
# Returns attenuation in dB (negative = signal loss).
# ================================================================
#must_use
fn edge_diffraction_loss(frequency, angle_rad, temperature_celsius) {
    if (f64_le(frequency, 0) == 1) { return 0; }

    var c = speed_of_sound(temperature_celsius);
    var wavelength = f64_div(c, frequency);
    var k = f64_div(F64_TAU, wavelength);

    var shadow_factor = f64_clamp(f64_div(angle_rad, F64_PI), 0, F64_ONE);

    var fresnel_arg = f64_mul(f64_mul(f64_mul(F64_TWO, k), shadow_factor), shadow_factor);
    var transition = 0;
    if (f64_lt(fresnel_arg, DIFF_001) == 1) {
        transition = f64_sub(F64_ONE, f64_mul(shadow_factor, F64_HALF));
    } else {
        transition = f64_sqrt(f64_div(F64_ONE, f64_add(F64_ONE, fresnel_arg)));
    }

    var coefficient = f64_clamp(transition, DIFF_1E6, F64_ONE);
    return f64_mul(f64_from(20), _diff_log10(coefficient));
}

# ================================================================
# Kouyoumjian-Pathak UTD wedge diffraction.
# ================================================================
# One cotangent + transition-function term (the ported `cot_term` closure).
#   sign is +1.0 or -1.0 (as f64); beta is beta_plus or beta_minus.
#must_use
fn _diff_cot_term(beta, sign, inv_n, wedge_n, k, l) {
    var phi_arg = f64_add(F64_PI, f64_mul(sign, beta));
    var cot_arg = f64_mul(f64_mul(phi_arg, inv_n), F64_HALF);
    var sin_val = f64_sin(cot_arg);
    if (f64_lt(f64_abs(sin_val), DIFF_1E6) == 1) { return 0; }
    var cot = f64_div(f64_cos(cot_arg), sin_val);

    # a±(β) = 2kL cos²((2πnN± − β)/2), N± nearest integer to (π±β)/(2πn).
    var n_int = f64_round(f64_div(phi_arg, f64_mul(F64_TAU, wedge_n)));
    var a_arg = f64_sub(f64_mul(f64_mul(F64_TAU, wedge_n), n_int), beta);
    var cval = f64_cos(f64_mul(a_arg, F64_HALF));
    var a = f64_mul(f64_mul(f64_mul(F64_TWO, k), l), f64_mul(cval, cval));

    # Approximate Fresnel transition F(x) ≈ √(x/(1+x)); √x near zero.
    var f_val = 0;
    if (f64_lt(a, DIFF_001) == 1) {
        f_val = f64_sqrt(a);
    } else {
        f_val = f64_sqrt(f64_div(a, f64_add(F64_ONE, a)));
    }
    return f64_mul(cot, f_val);
}

# Wedge diffraction loss (dB, negative = loss). exterior angle = n × π.
#must_use
fn utd_wedge_diffraction(frequency, wedge_n, source_angle, receiver_angle,
distance_source, distance_receiver, temperature_celsius) {
    if (f64_le(frequency, 0) == 1) { return 0; }
    if (f64_le(wedge_n, 0) == 1) { return 0; }
    if (f64_le(distance_source, 0) == 1) { return 0; }
    if (f64_le(distance_receiver, 0) == 1) { return 0; }

    var c = speed_of_sound(temperature_celsius);
    var k = f64_div(f64_mul(F64_TAU, frequency), c);

    # UTD distance factor: L = (rs × rr) / (rs + rr).
    var sum_dist = f64_add(distance_source, distance_receiver);
    var l = f64_div(f64_mul(distance_source, distance_receiver), sum_dist);

    var inv_n = f64_div(F64_ONE, wedge_n);
    var beta_plus = f64_add(source_angle, receiver_angle);
    var beta_minus = f64_sub(source_angle, receiver_angle);

    var neg_one = f64_neg(F64_ONE);
    var t1 = f64_abs(_diff_cot_term(beta_plus, F64_ONE, inv_n, wedge_n, k, l));
    var t2 = f64_abs(_diff_cot_term(beta_minus, F64_ONE, inv_n, wedge_n, k, l));
    var t3 = f64_abs(_diff_cot_term(beta_plus, neg_one, inv_n, wedge_n, k, l));
    var t4 = f64_abs(_diff_cot_term(beta_minus, neg_one, inv_n, wedge_n, k, l));
    var cot_sum = f64_add(f64_add(t1, t2), f64_add(t3, t4));
    var d_magnitude = f64_div(cot_sum, f64_mul(wedge_n, f64_sqrt(f64_mul(F64_TAU, k))));

    # Distance spreading factor.
    var spread = f64_sqrt(f64_div(l, sum_dist));
    var total = f64_clamp(f64_mul(d_magnitude, spread), DIFF_1E10, F64_ONE);
    return f64_mul(f64_from(20), _diff_log10(total));
}

# ================================================================
# Occlusion + diffraction path length.
# ================================================================
# 1 if the source→listener path is blocked by at least one wall, else 0.
# `walls` is a stdlib vec of Wall pointers.
#must_use
fn is_occluded(source, listener, walls) {
    var direction = hvec3_sub(listener, source);
    var max_dist = hvec3_length(direction);
    if (f64_lt(max_dist, GOONJ_EPSILON) == 1) { return 0; }

    var ray = acoustic_ray_new(source, direction, 0);
    var limit = f64_sub(max_dist, GOONJ_EPSILON);
    var n = vec_len(walls);
    var i = 0;
    while (i < n) {
        var t = ray_wall_intersection(ray, vec_get(walls, i));
        if (f64_gt(t, GOONJ_EPSILON) == 1) {
            if (f64_lt(t, limit) == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# Extra path length (m) sound travels diffracting around an edge vs direct.
#must_use
fn diffraction_path_extra(source, edge_point, listener) {
    var d_source_edge = hvec3_distance(source, edge_point);
    var d_edge_listener = hvec3_distance(edge_point, listener);
    var d_direct = hvec3_distance(source, listener);
    return f64_sub(f64_add(d_source_edge, d_edge_listener), d_direct);
}

# --- impulse.cyr ---

# impulse.cyr -- impulse-response generation + reverberation time (RT60).
#
# Scalar RT60 estimators (Sabine, Eyring, shoebox, Fitzroy, Kuttruff),
# the ImpulseResponse type (samples + Schroeder energy-decay curve), the
# MultibandIr type (one IR buffer per octave band + broadband collapse),
# and generate_ir, which combines image-source early reflections with
# diffuse-rain late reverb into a per-band impulse response.
#
# Ports rust-old/src/impulse.rs. f32 -> f64 throughout (hisab is f64-only).
# Rust's `serde` derive on the config/IR structs is dropped (no serde in
# Cyrius); no serde round-trip test exists in the oracle to port. The
# `Vec<f32>` sample buffers become stdlib `vec` (f64 stored directly). The
# `[Vec<f32>; NUM_BANDS]` band array on MultibandIr uses manual inline
# layout (8 vec handles, like ray.cyr's RayBounce block). f32::INFINITY on
# the degenerate RT60 paths becomes the +inf bit pattern (IMP_POS_INF).
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON),
# material.cyr (NUM_BANDS, pct/milli), propagation.cyr (speed_of_sound),
# room.cyr (AcousticRoom_*, RoomGeometry queries), image_source.cyr
# (compute_early_reflections, early_reflection_*), diffuse.cyr
# (diffuse_rain_config_new, generate_diffuse_rain, DiffuseRainResult_*,
# lrc_time/lrc_energy_band), stdlib math/ganita + vec + hisab.
# alloc_init() must have run.

# Non-integer f64 bit patterns (decimals in comments).
var IMP_SABINE  = 0x3FC49BA5E353F7CF;   # 0.161  Sabine constant (0.161·V/A)
var IMP_POS_INF = 0x7FF0000000000000;   # +inf   degenerate RT60 (f32::INFINITY)

# MultibandIr inline layout: 8 band-vec handles | sample_rate | rt60.
enum MiLayout { MI_BANDS = 0, MI_RATE = 64, MI_RT60 = 72, MI_SIZE = 80 }

# log10(x) = ln(x) / ln(10).
#must_use
fn _impulse_log10(x) { return f64_div(f64_ln(x), F64_LN10); }

# ================================================================
# RT60 estimators
# ================================================================
# Sabine reverberation time: T = 0.161·V / A. Non-positive absorption
# (anechoic / nonsensical) returns +inf.
#must_use
fn sabine_rt60(volume, total_absorption) {
    if (f64_le(total_absorption, 0) == 1) { return IMP_POS_INF; }
    return f64_div(f64_mul(IMP_SABINE, volume), total_absorption);
}

# Eyring reverberation time: T = 0.161·V / (-S·ln(1 - a)). More accurate
# than Sabine at high absorption. Non-positive absorption / surface → +inf;
# total absorption (a >= 1) → 0 (anechoic).
#must_use
fn eyring_rt60(volume, surface_area, average_absorption) {
    if (f64_le(average_absorption, 0) == 1) { return IMP_POS_INF; }
    if (f64_le(surface_area, 0) == 1) { return IMP_POS_INF; }
    if (f64_ge(average_absorption, F64_ONE) == 1) { return 0; }
    var denominator = f64_mul(f64_neg(surface_area), f64_ln(f64_sub(F64_ONE, average_absorption)));
    if (f64_le(denominator, 0) == 1) { return IMP_POS_INF; }
    return f64_div(f64_mul(IMP_SABINE, volume), denominator);
}

# Estimate shoebox RT60 (Sabine) from dimensions and a uniform absorption.
#must_use
fn estimate_rt60_shoebox(length, width, height, avg_absorption) {
    var volume = f64_mul(f64_mul(length, width), height);
    var surface_area = f64_mul(F64_TWO,
    f64_add(f64_add(f64_mul(length, width), f64_mul(length, height)), f64_mul(width, height)));
    var total_absorption = f64_mul(surface_area, avg_absorption);
    return sabine_rt60(volume, total_absorption);
}

# ================================================================
# AxisAbsorption -- absorption + combined area for one axis pair (Fitzroy).
# ================================================================
#derive(accessors)
struct AxisAbsorption { alpha; area; }

#must_use
fn axis_absorption_new(alpha, area) {
    var a = alloc(sizeof(AxisAbsorption));
    AxisAbsorption_set_alpha(a, alpha);
    AxisAbsorption_set_area(a, area);
    return a;
}

# Per-axis Fitzroy term: (Sj/S) / (-ln(1 - aj)); 0 for degenerate / fully
# absorptive pairs.
#must_use
fn _impulse_fitzroy_term(alpha, area, surface_area) {
    if (f64_le(alpha, 0) == 1) { return 0; }
    if (f64_le(area, 0) == 1) { return 0; }
    if (f64_ge(alpha, F64_ONE) == 1) { return 0; }
    var neg_ln = f64_neg(f64_ln(f64_sub(F64_ONE, alpha)));
    if (f64_lt(neg_ln, GOONJ_EPSILON) == 1) { return 0; }
    return f64_div(f64_div(area, surface_area), neg_ln);
}

# Fitzroy reverberation time for non-uniform absorption. `axes` is a
# pointer to three AxisAbsorption pointers. Non-positive volume / surface
# or a zero sum → +inf.
#must_use
fn fitzroy_rt60(volume, surface_area, axes) {
    if (f64_le(volume, 0) == 1) { return IMP_POS_INF; }
    if (f64_le(surface_area, 0) == 1) { return IMP_POS_INF; }
    var sum = 0;
    var i = 0;
    while (i < 3) {
        var ax = load64(axes + i * 8);
        sum = f64_add(sum,
        _impulse_fitzroy_term(AxisAbsorption_alpha(ax), AxisAbsorption_area(ax), surface_area));
        i = i + 1;
    }
    if (f64_le(sum, 0) == 1) { return IMP_POS_INF; }
    return f64_mul(f64_div(f64_mul(IMP_SABINE, volume), surface_area), sum);
}

# Kuttruff correction to an Eyring RT60 for absorption variance:
# T_corrected = T · (1 + variance / (2·mean_alpha²)). Near-zero mean → no
# change.
#must_use
fn kuttruff_correction(eyring_time, mean_alpha, alpha_variance) {
    if (f64_lt(f64_abs(mean_alpha), GOONJ_EPSILON) == 1) { return eyring_time; }
    var denom = f64_mul(f64_mul(F64_TWO, mean_alpha), mean_alpha);
    return f64_mul(eyring_time, f64_add(F64_ONE, f64_div(alpha_variance, denom)));
}

# ================================================================
# ImpulseResponse
# ================================================================
#derive(accessors)
struct ImpulseResponse { samples; sample_rate; rt60; }

#must_use
fn impulse_response_new(samples, sample_rate, rt60) {
    var ir = alloc(sizeof(ImpulseResponse));
    ImpulseResponse_set_samples(ir, samples);
    ImpulseResponse_set_sample_rate(ir, sample_rate);
    ImpulseResponse_set_rt60(ir, rt60);
    return ir;
}

# Energy decay curve (Schroeder backward integration), in dB, normalized
# to 0 dB at the start. Empty samples → empty curve.
#must_use
fn impulse_response_energy_decay_curve(ir) {
    var samples = ImpulseResponse_samples(ir);
    var n = vec_len(samples);
    var edc = vec_new();
    var i = 0;
    while (i < n) {
        vec_push(edc, 0);
        i = i + 1;
    }
    var cumulative = 0;
    var k = n - 1;
    while (k >= 0) {
        var s = vec_get(samples, k);
        cumulative = f64_add(cumulative, f64_mul(s, s));
        vec_set(edc, k, cumulative);
        k = k - 1;
    }
    if (n == 0) { return edc; }
    var mx = f64_max(vec_get(edc, 0), GOONJ_EPSILON);
    var j = 0;
    while (j < n) {
        vec_set(edc, j, f64_mul(f64_from(10), _impulse_log10(f64_div(vec_get(edc, j), mx))));
        j = j + 1;
    }
    return edc;
}

# Duration in seconds; zero sample rate → 0.
#must_use
fn impulse_response_duration_seconds(ir) {
    var rate = ImpulseResponse_sample_rate(ir);
    if (rate == 0) { return 0; }
    return f64_div(f64_from(vec_len(ImpulseResponse_samples(ir))), f64_from(rate));
}

# ================================================================
# IrConfig -- full impulse-response generation parameters.
# ================================================================
#derive(accessors)
struct IrConfig {
    sample_rate;
    max_order;
    num_diffuse_rays;
    max_bounces;
    max_time_seconds;
    seed;
}

#must_use
fn ir_config_new(sample_rate, max_order, num_diffuse_rays, max_bounces, max_time_seconds, seed) {
    var c = alloc(sizeof(IrConfig));
    IrConfig_set_sample_rate(c, sample_rate);
    IrConfig_set_max_order(c, max_order);
    IrConfig_set_num_diffuse_rays(c, num_diffuse_rays);
    IrConfig_set_max_bounces(c, max_bounces);
    IrConfig_set_max_time_seconds(c, max_time_seconds);
    IrConfig_set_seed(c, seed);
    return c;
}

# Defaults: 48 kHz, order 3, 5000 diffuse rays, 50 bounces, 2 s, seed 42.
#must_use
fn ir_config_default() {
    return ir_config_new(48000, 3, 5000, 50, F64_TWO, 42);
}

# ================================================================
# MultibandIr -- one IR buffer per octave band (manual inline layout).
# ================================================================
#must_use
fn multiband_ir_band(m, i) { return load64(m + MI_BANDS + i * 8); }
#must_use
fn multiband_ir_sample_rate(m) { return load64(m + MI_RATE); }
#must_use
fn multiband_ir_rt60(m) { return load64(m + MI_RT60); }

# Allocate a MultibandIr with NUM_BANDS empty band vecs.
#must_use
fn multiband_ir_new(sample_rate, rt60) {
    var m = alloc(MI_SIZE);
    var b = 0;
    while (b < NUM_BANDS) {
        store64(m + MI_BANDS + b * 8, vec_new());
        b = b + 1;
    }
    store64(m + MI_RATE, sample_rate);
    store64(m + MI_RT60, rt60);
    return m;
}

# Collapse to a broadband (mono) impulse response by summing all bands,
# then peak-normalizing.
#must_use
fn multiband_ir_to_broadband(m) {
    var len = vec_len(multiband_ir_band(m, 0));
    var samples = vec_new();
    var i = 0;
    while (i < len) {
        vec_push(samples, 0);
        i = i + 1;
    }
    var band = 0;
    while (band < NUM_BANDS) {
        var buf = multiband_ir_band(m, band);
        var bl = vec_len(buf);
        var k = 0;
        while (k < bl) {
            if (k < len) {
                vec_set(samples, k, f64_add(vec_get(samples, k), vec_get(buf, k)));
            }
            k = k + 1;
        }
        band = band + 1;
    }
    var max_abs = 0;
    var mi = 0;
    while (mi < len) {
        max_abs = f64_max(max_abs, f64_abs(vec_get(samples, mi)));
        mi = mi + 1;
    }
    if (f64_gt(max_abs, GOONJ_EPSILON) == 1) {
        var n = 0;
        while (n < len) {
            vec_set(samples, n, f64_div(vec_get(samples, n), max_abs));
            n = n + 1;
        }
    }
    return impulse_response_new(samples, multiband_ir_sample_rate(m), multiband_ir_rt60(m));
}

# ================================================================
# generate_ir
# ================================================================
# Combine image-source early reflections and diffuse-rain late reverb into
# a per-band impulse response. RT60 is estimated (Sabine) from the room's
# broadband volume and total absorption.
#must_use
fn generate_ir(source, listener, room, config) {
    var c = speed_of_sound(AcousticRoom_temperature_celsius(room));
    var rate = IrConfig_sample_rate(config);
    # Cap to 10 minutes at 192 kHz (~115M samples) to prevent OOM.
    var max_samples = 115200000;
    var num_samples = f64_to(f64_mul(IrConfig_max_time_seconds(config), f64_from(rate)));
    if (num_samples > max_samples) { num_samples = max_samples; }

    var mi = multiband_ir_new(rate, 0);
    var b = 0;
    while (b < NUM_BANDS) {
        var buf = multiband_ir_band(mi, b);
        var s = 0;
        while (s < num_samples) {
            vec_push(buf, 0);
            s = s + 1;
        }
        b = b + 1;
    }

    # Early reflections (image-source method).
    var early = compute_early_reflections(source, listener, room, IrConfig_max_order(config), c);
    var ne = vec_len(early);
    var ei = 0;
    while (ei < ne) {
        var refl = vec_get(early, ei);
        var sidx = f64_to(f64_mul(early_reflection_delay_seconds(refl), f64_from(rate)));
        if (sidx < num_samples) {
            var eband = 0;
            while (eband < NUM_BANDS) {
                var ebuf = multiband_ir_band(mi, eband);
                vec_set(ebuf, sidx,
                f64_add(vec_get(ebuf, sidx), early_reflection_amplitude_band(refl, eband)));
                eband = eband + 1;
            }
        }
        ei = ei + 1;
    }

    # Late reverb (diffuse rain). collection_radius 0 => auto.
    var dconf = diffuse_rain_config_new(
    IrConfig_num_diffuse_rays(config),
    IrConfig_max_bounces(config),
    IrConfig_max_time_seconds(config),
    0,
    c,
    IrConfig_seed(config));
    var diffuse = generate_diffuse_rain(source, listener, room, dconf);
    var contribs = DiffuseRainResult_contributions(diffuse);
    var nc = vec_len(contribs);
    var ci = 0;
    while (ci < nc) {
        var contrib = vec_get(contribs, ci);
        var didx = f64_to(f64_mul(lrc_time(contrib), f64_from(rate)));
        if (didx < num_samples) {
            var dband = 0;
            while (dband < NUM_BANDS) {
                var dbuf = multiband_ir_band(mi, dband);
                vec_set(dbuf, didx, f64_add(vec_get(dbuf, didx), lrc_energy_band(contrib, dband)));
                dband = dband + 1;
            }
        }
        ci = ci + 1;
    }

    # RT60 from broadband energy.
    var geom = AcousticRoom_geometry(room);
    var rt60 = sabine_rt60(room_geometry_volume_shoebox(geom), room_geometry_total_absorption(geom));
    store64(mi + MI_RT60, rt60);
    return mi;
}

# --- analysis.cyr ---

# analysis.cyr -- room-acoustics metrics per ISO 3382-1 and IEC 60268-16.
#
# Scalar/vector math over an ImpulseResponse and its sample vec: clarity
# (C50/C80), definition (D50), Speech Transmission Index (STI), early decay
# time (EDT), sound strength (G), centre time (ts), a 4th-order octave-band
# filter, lateral energy fraction (LF), interaural cross-correlation (IACC),
# and absorption-placement suggestions.
#
# Ports rust-old/src/analysis.rs. f32 -> f64 throughout (hisab is f64-only).
# Rust's `serde` derive on AbsorptionSuggestion is dropped (no serde in
# Cyrius); no serde round-trip test exists in the oracle to port. The
# `Vec<f32>` sample buffers are stdlib `vec` (f64 stored directly). Non-
# integer literals reuse material.cyr's pct(n)/milli(n) exact-hundredth/
# thousandth helpers; f32::INFINITY on the degenerate clarity/EDT paths
# becomes the +inf bit pattern (ANL_POS_INF), f32::NEG_INFINITY the shared
# F64_NEG_INF from error.cyr.
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON,
# F64_NEG_INF), material.cyr (average_absorption, pct, milli), room.cyr
# (AcousticRoom_geometry, RoomGeometry_walls, Wall_material, wall_area,
# room_geometry_volume_shoebox, room_geometry_total_absorption),
# impulse.cyr (ImpulseResponse accessors, impulse_response_energy_decay_curve,
# sabine_rt60), stdlib math/ganita (F64_*, f64_*) + vec. alloc_init() must
# have run.

# +inf bit pattern (f32::INFINITY on the degenerate clarity / EDT paths).
var ANL_POS_INF = 0x7FF0000000000000;   # +inf

# log10(x) = ln(x) / ln(10).
#must_use
fn _analysis_log10(x) { return f64_div(f64_ln(x), F64_LN10); }

# STI modulation frequency (Hz) by index 0..13 (IEC 60268-16:2020).
#must_use
fn _analysis_mod_freq(i) {
    if (i == 0) { return pct(63); }
    if (i == 1) { return pct(80); }
    if (i == 2) { return F64_ONE; }
    if (i == 3) { return pct(125); }
    if (i == 4) { return pct(160); }
    if (i == 5) { return F64_TWO; }
    if (i == 6) { return pct(250); }
    if (i == 7) { return pct(315); }
    if (i == 8) { return f64_from(4); }
    if (i == 9) { return f64_from(5); }
    if (i == 10) { return pct(630); }
    if (i == 11) { return f64_from(8); }
    if (i == 12) { return f64_from(10); }
    if (i == 13) { return pct(1250); }
    return 0;
}

# STI alpha_k per-band weights (IEC 60268-16:2020 Table 2), index 0..6.
#must_use
fn _analysis_alpha_k(k) {
    if (k == 0) { return milli(85); }
    if (k == 1) { return milli(127); }
    if (k == 2) { return milli(230); }
    if (k == 3) { return milli(233); }
    if (k == 4) { return milli(309); }
    if (k == 5) { return milli(224); }
    if (k == 6) { return milli(173); }
    return 0;
}

# STI beta_k redundancy weights (IEC 60268-16:2020 Table 3), index 0..5.
#must_use
fn _analysis_beta_k(k) {
    if (k == 0) { return milli(85); }
    if (k == 1) { return milli(78); }
    if (k == 2) { return milli(65); }
    if (k == 3) { return milli(11); }
    if (k == 4) { return milli(47); }
    if (k == 5) { return milli(95); }
    return 0;
}

# ================================================================
# Clarity / definition
# ================================================================
# Generic clarity: 10·log10(E_early / E_late) in dB at a time boundary.
# Empty samples or zero rate -> 0; near-zero late energy -> +inf.
#must_use
fn _analysis_clarity(ir, boundary_seconds) {
    var samples = ImpulseResponse_samples(ir);
    var n = vec_len(samples);
    var rate = ImpulseResponse_sample_rate(ir);
    if (n == 0) { return 0; }
    if (rate == 0) { return 0; }
    var bs = f64_to(f64_mul(boundary_seconds, f64_from(rate)));
    if (bs > n) { bs = n; }
    var early = 0;
    var i = 0;
    while (i < bs) {
        var s = vec_get(samples, i);
        early = f64_add(early, f64_mul(s, s));
        i = i + 1;
    }
    var late = 0;
    i = bs;
    while (i < n) {
        var s = vec_get(samples, i);
        late = f64_add(late, f64_mul(s, s));
        i = i + 1;
    }
    if (f64_lt(late, GOONJ_EPSILON) == 1) { return ANL_POS_INF; }
    return f64_mul(f64_from(10), _analysis_log10(f64_div(early, late)));
}

# Clarity C50 -- early (0-50 ms) vs late energy, dB.
#must_use
fn clarity_c50(ir) { return _analysis_clarity(ir, milli(50)); }

# Clarity C80 -- early (0-80 ms) vs late energy, dB.
#must_use
fn clarity_c80(ir) { return _analysis_clarity(ir, milli(80)); }

# Definition D50 -- early (0-50 ms) to total energy ratio (0..1).
#must_use
fn definition_d50(ir) {
    var samples = ImpulseResponse_samples(ir);
    var n = vec_len(samples);
    var rate = ImpulseResponse_sample_rate(ir);
    if (n == 0) { return 0; }
    if (rate == 0) { return 0; }
    var bs = f64_to(f64_mul(milli(50), f64_from(rate)));
    if (bs > n) { bs = n; }
    var early = 0;
    var i = 0;
    while (i < bs) {
        var s = vec_get(samples, i);
        early = f64_add(early, f64_mul(s, s));
        i = i + 1;
    }
    var total = 0;
    i = 0;
    while (i < n) {
        var s = vec_get(samples, i);
        total = f64_add(total, f64_mul(s, s));
        i = i + 1;
    }
    if (f64_lt(total, GOONJ_EPSILON) == 1) { return 0; }
    return f64_div(early, total);
}

# ================================================================
# Speech Transmission Index (STI) -- IEC 60268-16:2020
# ================================================================
# 7-band x 14-modulation-frequency framework applied to the broadband IR
# (identical MTF broadcast to every band -- comparative approximation).
# Empty samples, zero rate, or silent IR -> 0. Result clamped to 0..1.
#must_use
fn sti_estimate(ir) {
    var samples = ImpulseResponse_samples(ir);
    var n = vec_len(samples);
    var rate = ImpulseResponse_sample_rate(ir);
    if (n == 0) { return 0; }
    if (rate == 0) { return 0; }
    var total_energy = 0;
    var ei = 0;
    while (ei < n) {
        var s = vec_get(samples, ei);
        total_energy = f64_add(total_energy, f64_mul(s, s));
        ei = ei + 1;
    }
    if (f64_lt(total_energy, GOONJ_EPSILON) == 1) { return 0; }

    var dt = f64_div(F64_ONE, f64_from(rate));
    var ti_sum = 0;
    var m = 0;
    while (m < 14) {
        var omega = f64_mul(F64_TAU, _analysis_mod_freq(m));
        var real = 0;
        var imag = 0;
        var i = 0;
        while (i < n) {
            var s = vec_get(samples, i);
            var h2 = f64_mul(s, s);
            var angle = f64_mul(omega, f64_mul(f64_from(i), dt));
            real = f64_add(real, f64_mul(h2, f64_cos(angle)));
            imag = f64_add(imag, f64_mul(h2, f64_sin(angle)));
            i = i + 1;
        }
        var mag = f64_sqrt(f64_add(f64_mul(real, real), f64_mul(imag, imag)));
        var mtf = f64_clamp(f64_div(mag, total_energy), 0, F64_ONE);
        var snr = 0;
        if (f64_ge(mtf, F64_ONE) == 1) {
            snr = f64_from(15);
        } else {
            if (f64_le(mtf, GOONJ_EPSILON) == 1) {
                snr = f64_neg(f64_from(15));
            } else {
                snr = f64_mul(_analysis_log10(f64_div(mtf, f64_sub(F64_ONE, mtf))), f64_from(10));
            }
        }
        var snr_c = f64_clamp(snr, f64_neg(f64_from(15)), f64_from(15));
        ti_sum = f64_add(ti_sum, f64_div(f64_add(snr_c, f64_from(15)), f64_from(30)));
        m = m + 1;
    }
    var mti = f64_div(ti_sum, f64_from(14));

    # STI = Sum(alpha_k * MTI_k) - Sum(beta_k * sqrt(MTI_k * MTI_{k+1})).
    # All bands share the same MTI, so band_mti[k] = mti for every k.
    var sti = 0;
    var k = 0;
    while (k < 7) {
        sti = f64_add(sti, f64_mul(_analysis_alpha_k(k), mti));
        k = k + 1;
    }
    k = 0;
    while (k < 6) {
        sti = f64_sub(sti, f64_mul(_analysis_beta_k(k), f64_sqrt(f64_mul(mti, mti))));
        k = k + 1;
    }
    return f64_clamp(sti, 0, F64_ONE);
}

# ================================================================
# ISO 3382-1 decay / energy parameters
# ================================================================
# Early Decay Time -- 6 x T10 from the Schroeder energy-decay curve.
# No -10 dB crossing -> +inf; empty samples / zero rate / empty EDC -> 0.
#must_use
fn early_decay_time(ir) {
    var samples = ImpulseResponse_samples(ir);
    var n = vec_len(samples);
    var rate = ImpulseResponse_sample_rate(ir);
    if (n == 0) { return 0; }
    if (rate == 0) { return 0; }
    var edc = impulse_response_energy_decay_curve(ir);
    var m = vec_len(edc);
    if (m == 0) { return 0; }
    var t10 = m;
    var found = 0;
    var i = 0;
    while (i < m) {
        if (found == 0) {
            if (f64_le(vec_get(edc, i), f64_neg(f64_from(10))) == 1) {
                t10 = i;
                found = 1;
            }
        }
        i = i + 1;
    }
    if (t10 == 0) { return 0; }
    if (t10 >= m) { return ANL_POS_INF; }
    return f64_div(f64_mul(f64_from(6), f64_from(t10)), f64_from(rate));
}

# Sound Strength G -- total energy in dB relative to a 10 m free-field
# reference. Empty samples / zero rate -> 0; near-zero energy -> -inf.
#must_use
fn sound_strength_g(ir) {
    var samples = ImpulseResponse_samples(ir);
    var n = vec_len(samples);
    var rate = ImpulseResponse_sample_rate(ir);
    if (n == 0) { return 0; }
    if (rate == 0) { return 0; }
    var total_energy = 0;
    var i = 0;
    while (i < n) {
        var s = vec_get(samples, i);
        total_energy = f64_add(total_energy, f64_mul(s, s));
        i = i + 1;
    }
    var dt = f64_div(F64_ONE, f64_from(rate));
    var integrated = f64_mul(total_energy, dt);
    if (f64_lt(integrated, GOONJ_EPSILON) == 1) { return F64_NEG_INF; }
    var ref_energy = f64_mul(
    f64_div(F64_ONE, f64_mul(f64_mul(f64_from(4), F64_PI), f64_from(100))), dt);
    return f64_mul(f64_from(10), _analysis_log10(f64_div(integrated, ref_energy)));
}

# Centre Time ts -- first moment of the squared IR, in seconds.
# Empty samples / zero rate / near-zero energy -> 0.
#must_use
fn centre_time_ts(ir) {
    var samples = ImpulseResponse_samples(ir);
    var n = vec_len(samples);
    var rate = ImpulseResponse_sample_rate(ir);
    if (n == 0) { return 0; }
    if (rate == 0) { return 0; }
    var dt = f64_div(F64_ONE, f64_from(rate));
    var numerator = 0;
    var denominator = 0;
    var i = 0;
    while (i < n) {
        var s = vec_get(samples, i);
        var h2 = f64_mul(s, s);
        var t = f64_mul(f64_from(i), dt);
        numerator = f64_add(numerator, f64_mul(t, h2));
        denominator = f64_add(denominator, h2);
        i = i + 1;
    }
    if (f64_lt(denominator, GOONJ_EPSILON) == 1) { return 0; }
    return f64_div(numerator, denominator);
}

# ================================================================
# Octave-band filter (4th-order bandpass, Direct Form II transposed)
# ================================================================
# Bilinear-transformed 2nd-order bandpass, cascaded to 4th order, centred
# on `centre_freq` with a one-octave bandwidth. Returns the filtered
# samples. Empty / zero-rate / non-positive frequency -> empty vec; a
# degenerate a0 -> all-zero vec of the input length.
#must_use
fn octave_band_filter(ir, centre_freq) {
    var samples = ImpulseResponse_samples(ir);
    var n = vec_len(samples);
    var rate = ImpulseResponse_sample_rate(ir);
    if (n == 0) { return vec_new(); }
    if (rate == 0) { return vec_new(); }
    if (f64_le(centre_freq, 0) == 1) { return vec_new(); }

    var fs = f64_from(rate);
    var sqrt2 = F64_SQRT2;
    var f_low = f64_div(centre_freq, sqrt2);
    var f_high = f64_mul(centre_freq, sqrt2);

    var w_low = f64_tan(f64_div(f64_mul(F64_PI, f_low), fs));
    var w_high = f64_tan(f64_div(f64_mul(F64_PI, f_high), fs));
    var bw = f64_sub(w_high, w_low);
    var ww = f64_mul(w_low, w_high);

    # a0 = 1 + sqrt2*bw + bw*bw + ww*(2 + sqrt2*bw)
    var a0 = f64_add(f64_add(f64_add(F64_ONE, f64_mul(sqrt2, bw)), f64_mul(bw, bw)),
    f64_mul(ww, f64_add(F64_TWO, f64_mul(sqrt2, bw))));
    if (f64_lt(f64_abs(a0), GOONJ_EPSILON) == 1) {
        var zeros = vec_new();
        var zi = 0;
        while (zi < n) {
            vec_push(zeros, 0);
            zi = zi + 1;
        }
        return zeros;
    }
    var inv_a0 = f64_div(F64_ONE, a0);

    # b1 = 0, b3 = 0 (omitted); b0, b2 = -2*b0, b4 = b0.
    var b0 = f64_mul(f64_mul(bw, bw), inv_a0);
    var b2 = f64_mul(f64_neg(F64_TWO), b0);
    var b4 = b0;

    # a1 = (2*(ww*(2 + sqrt2*bw) - 1 - sqrt2*bw)) * inv_a0
    var a1 = f64_mul(f64_mul(F64_TWO,
    f64_sub(f64_sub(f64_mul(ww, f64_add(F64_TWO, f64_mul(sqrt2, bw))), F64_ONE),
    f64_mul(sqrt2, bw))), inv_a0);
    # a2 = (2*(1 - bw*bw + ww*(2*ww - 2))) * inv_a0
    var a2 = f64_mul(f64_mul(F64_TWO,
    f64_add(f64_sub(F64_ONE, f64_mul(bw, bw)),
    f64_mul(ww, f64_sub(f64_mul(F64_TWO, ww), F64_TWO)))), inv_a0);
    # a3 = (2*(ww*(2 - sqrt2*bw) - 1 + sqrt2*bw)) * inv_a0
    var a3 = f64_mul(f64_mul(F64_TWO,
    f64_add(f64_sub(f64_mul(ww, f64_sub(F64_TWO, f64_mul(sqrt2, bw))), F64_ONE),
    f64_mul(sqrt2, bw))), inv_a0);
    # a4 = (1 - sqrt2*bw + bw*bw + ww*(2 - sqrt2*bw)) * inv_a0
    var a4 = f64_mul(
    f64_add(f64_add(f64_sub(F64_ONE, f64_mul(sqrt2, bw)), f64_mul(bw, bw)),
    f64_mul(ww, f64_sub(F64_TWO, f64_mul(sqrt2, bw)))), inv_a0);

    var out = vec_new();
    var oi = 0;
    while (oi < n) {
        vec_push(out, 0);
        oi = oi + 1;
    }
    var x1 = 0;
    var x2 = 0;
    var x3 = 0;
    var x4 = 0;
    var y1 = 0;
    var y2 = 0;
    var y3 = 0;
    var y4 = 0;
    var i = 0;
    while (i < n) {
        var x = vec_get(samples, i);
        var y = f64_add(f64_mul(b0, x), f64_add(f64_mul(b2, x2), f64_mul(b4, x4)));
        y = f64_sub(y, f64_mul(a1, y1));
        y = f64_sub(y, f64_mul(a2, y2));
        y = f64_sub(y, f64_mul(a3, y3));
        y = f64_sub(y, f64_mul(a4, y4));
        vec_set(out, i, y);
        x4 = x3;
        x3 = x2;
        x2 = x1;
        x1 = x;
        y4 = y3;
        y3 = y2;
        y2 = y1;
        y1 = y;
        i = i + 1;
    }
    return out;
}

# ================================================================
# Spatial metrics (binaural)
# ================================================================
# Lateral Energy Fraction (LF/JLF) -- early lateral to early total energy
# (0-80 ms). Lateral component from the L-R figure-8, omni from (L+R)/2.
# Empty channels / zero rate / near-zero energy -> 0. Clamped to 0..1.
#must_use
fn lateral_fraction_lf(left, right, sample_rate) {
    var nl = vec_len(left);
    var nr = vec_len(right);
    if (nl == 0) { return 0; }
    if (nr == 0) { return 0; }
    if (sample_rate == 0) { return 0; }
    var boundary = f64_to(f64_mul(milli(80), f64_from(sample_rate)));
    var n = nl;
    if (nr < n) { n = nr; }
    if (boundary < n) { n = boundary; }
    var lateral_energy = 0;
    var total_energy = 0;
    var i = 0;
    while (i < n) {
        var l = vec_get(left, i);
        var r = vec_get(right, i);
        var omni = f64_mul(f64_add(l, r), F64_HALF);
        var figure8 = f64_mul(f64_sub(l, r), F64_HALF);
        total_energy = f64_add(total_energy, f64_mul(omni, omni));
        lateral_energy = f64_add(lateral_energy, f64_mul(figure8, figure8));
        i = i + 1;
    }
    if (f64_lt(total_energy, GOONJ_EPSILON) == 1) { return 0; }
    return f64_clamp(f64_div(lateral_energy, total_energy), 0, F64_ONE);
}

# Interaural Cross-Correlation (IACC) -- max normalized |cross-correlation|
# of the early L/R signals (0-80 ms) over a +-1 ms lag range. Empty
# channels / zero rate / near-zero norm -> 0. Clamped to 0..1.
#must_use
fn iacc(left, right, sample_rate) {
    var nl = vec_len(left);
    var nr = vec_len(right);
    if (nl == 0) { return 0; }
    if (nr == 0) { return 0; }
    if (sample_rate == 0) { return 0; }
    var boundary = f64_to(f64_mul(milli(80), f64_from(sample_rate)));
    var n = nl;
    if (nr < n) { n = nr; }
    if (boundary < n) { n = boundary; }
    if (n == 0) { return 0; }
    var energy_l = 0;
    var energy_r = 0;
    var i = 0;
    while (i < n) {
        var l = vec_get(left, i);
        var r = vec_get(right, i);
        energy_l = f64_add(energy_l, f64_mul(l, l));
        energy_r = f64_add(energy_r, f64_mul(r, r));
        i = i + 1;
    }
    var norm = f64_sqrt(f64_mul(energy_l, energy_r));
    if (f64_lt(norm, GOONJ_EPSILON) == 1) { return 0; }
    var max_lag = f64_to(f64_mul(milli(1), f64_from(sample_rate)));
    if (max_lag < 1) { max_lag = 1; }
    var max_xcorr = 0;
    var lag = 0;
    while (lag <= max_lag) {
        var xcorr_pos = 0;
        var xcorr_neg = 0;
        var j = 0;
        while (j < n) {
            if (j + lag < n) {
                xcorr_pos = f64_add(xcorr_pos, f64_mul(vec_get(left, j), vec_get(right, j + lag)));
            }
            if (j >= lag) {
                xcorr_neg = f64_add(xcorr_neg, f64_mul(vec_get(left, j), vec_get(right, j - lag)));
            }
            j = j + 1;
        }
        max_xcorr = f64_max(max_xcorr, f64_max(f64_abs(xcorr_pos), f64_abs(xcorr_neg)));
        lag = lag + 1;
    }
    return f64_clamp(f64_div(max_xcorr, norm), 0, F64_ONE);
}

# ================================================================
# Absorption-placement suggestions
# ================================================================
# A single wall's treatment suggestion: index, RT60 sensitivity (seconds,
# negative reduces reverb), and the wall's current average absorption.
#derive(accessors)
struct AbsorptionSuggestion { wall_index; rt60_sensitivity; current_absorption; }

#must_use
fn absorption_suggestion_new(wall_index, rt60_sensitivity, current_absorption) {
    var a = alloc(sizeof(AbsorptionSuggestion));
    AbsorptionSuggestion_set_wall_index(a, wall_index);
    AbsorptionSuggestion_set_rt60_sensitivity(a, rt60_sensitivity);
    AbsorptionSuggestion_set_current_absorption(a, current_absorption);
    return a;
}

# Ascending insertion sort of a suggestion vec by rt60_sensitivity
# (mutates in place; stable, matching Rust's sort_by partial_cmp).
fn _analysis_sort_suggestions(v) {
    var n = vec_len(v);
    var i = 1;
    while (i < n) {
        var key = vec_get(v, i);
        var key_val = AbsorptionSuggestion_rt60_sensitivity(key);
        var j = i - 1;
        var go = 1;
        while (go == 1) {
            if (j < 0) { go = 0; }
            if (go == 1) {
                if (f64_gt(AbsorptionSuggestion_rt60_sensitivity(vec_get(v, j)), key_val) == 1) {
                    vec_set(v, j + 1, vec_get(v, j));
                    j = j - 1;
                } else {
                    go = 0;
                }
            }
        }
        vec_set(v, j + 1, key);
        i = i + 1;
    }
    return 0;
}

# Suggest which walls most affect RT60 if treated. Bumps each wall's
# absorption (bump scaled by the current/target RT60 ratio), measures the
# Sabine RT60 delta, and returns suggestions sorted most-impactful first.
#must_use
fn suggest_absorption_placement(room, target_rt60) {
    var geom = AcousticRoom_geometry(room);
    var volume = room_geometry_volume_shoebox(geom);
    var current_total_abs = room_geometry_total_absorption(geom);
    var current_rt60 = sabine_rt60(volume, current_total_abs);

    var rt60_ratio = F64_ONE;
    if (f64_gt(target_rt60, GOONJ_EPSILON) == 1) {
        if (f64_gt(current_rt60, GOONJ_EPSILON) == 1) {
            rt60_ratio = f64_clamp(f64_div(current_rt60, target_rt60), pct(10), f64_from(10));
        }
    }
    var bump = f64_min(f64_mul(pct(20), rt60_ratio), F64_HALF);

    var suggestions = vec_new();
    var walls = RoomGeometry_walls(geom);
    var nw = vec_len(walls);
    var i = 0;
    while (i < nw) {
        var wall = vec_get(walls, i);
        var area = wall_area(wall);
        var current_abs = average_absorption(Wall_material(wall));
        var new_abs = f64_min(f64_add(current_abs, bump), F64_ONE);
        var delta_abs = f64_mul(f64_sub(new_abs, current_abs), area);
        var new_total_abs = f64_add(current_total_abs, delta_abs);
        var new_rt60 = sabine_rt60(volume, new_total_abs);
        var sensitivity = f64_sub(new_rt60, current_rt60);
        vec_push(suggestions, absorption_suggestion_new(i, sensitivity, current_abs));
        i = i + 1;
    }
    _analysis_sort_suggestions(suggestions);
    return suggestions;
}

# --- beam.cyr ---

# beam.cyr -- beam tracing: volumetric sound propagation without the
# per-ray sampling artifacts of discrete ray tracing.
#
# A beam is a pyramidal frustum originating at a source (AcousticBeam).
# When its axis intersects a wall, the beam is reflected specularly and a
# child beam continues up to `max_order` reflections, losing per-band
# energy at each bounce. Ports rust-old/src/beam.rs. f32 -> f64. Rust's
# `serde` derive is dropped (no serde in Cyrius); the serde round-trip
# test is therefore omitted.
#
# Reference: Funkhouser et al., "A Beam Tracing Method for Interactive
# Architectural Acoustics," JASA 115(2), 2004.
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON),
# material.cyr (NUM_BANDS, am_absorption_band), room.cyr (Wall_*,
# wall_area, RoomGeometry_walls), diffuse.cyr (fibonacci_sphere), stdlib
# math/ganita (F64_*, f64_tan/f64_sqrt/f64_clamp) and hisab (hvec3_*).
# alloc_init() must have run.

var BEAM_DEAD = 0x3F50624DD2F1A9FC;   # 0.001 — beam dead below this max band energy
var BEAM_NONE = 0xBFF0000000000000;   # -1.0 — "no intersection" sentinel

# AcousticBeam inline layout:
# apex | direction | half_angle | energy[8] | path_length | order.
enum BeamLayout {
    BEAM_APEX   = 0,
    BEAM_DIR    = 8,
    BEAM_HALF   = 16,
    BEAM_ENERGY = 24,   # offsets 24..88 (8 f64)
    BEAM_PATH   = 88,
    BEAM_ORDER  = 96,
    BEAM_SIZE   = 104,
}

# BeamPath inline layout: hits (vec) | final_energy[8] | total | order.
enum BeamPathLayout {
    BP_HITS  = 0,
    BP_FINAL = 8,       # offsets 8..72 (8 f64)
    BP_TOTAL = 72,
    BP_ORDER = 80,
    BP_SIZE  = 88,
}

# ================================================================
# AcousticBeam accessors (manual inline layout)
# ================================================================
fn beam_apex(b)             { return load64(b + BEAM_APEX); }
fn beam_direction(b)        { return load64(b + BEAM_DIR); }
fn beam_half_angle(b)       { return load64(b + BEAM_HALF); }
fn beam_energy_band(b, i)   { return load64(b + BEAM_ENERGY + i * 8); }
fn beam_path_length(b)      { return load64(b + BEAM_PATH); }
fn beam_order(b)            { return load64(b + BEAM_ORDER); }

# A beam with all-1.0 per-band energy, zero path length, order 0.
#must_use
fn acoustic_beam_new(apex, direction, half_angle) {
    var b = alloc(BEAM_SIZE);
    store64(b + BEAM_APEX, apex);
    store64(b + BEAM_DIR, direction);
    store64(b + BEAM_HALF, half_angle);
    var i = 0;
    while (i < NUM_BANDS) {
        store64(b + BEAM_ENERGY + i * 8, F64_ONE);
        i = i + 1;
    }
    store64(b + BEAM_PATH, 0);
    store64(b + BEAM_ORDER, 0);
    return b;
}

# Deep copy (Rust clone) — trace mutates a working copy, not the input.
#must_use
fn _beam_clone(src) {
    var b = alloc(BEAM_SIZE);
    store64(b + BEAM_APEX, beam_apex(src));
    store64(b + BEAM_DIR, beam_direction(src));
    store64(b + BEAM_HALF, beam_half_angle(src));
    var i = 0;
    while (i < NUM_BANDS) {
        store64(b + BEAM_ENERGY + i * 8, beam_energy_band(src, i));
        i = i + 1;
    }
    store64(b + BEAM_PATH, beam_path_length(src));
    store64(b + BEAM_ORDER, beam_order(src));
    return b;
}

# ================================================================
# BeamWallHit
# ================================================================
#derive(accessors)
struct BeamWallHit { centre; distance; wall_index; coverage; }

#must_use
fn beam_wall_hit_new(centre, distance, wall_index, coverage) {
    var h = alloc(sizeof(BeamWallHit));
    BeamWallHit_set_centre(h, centre);
    BeamWallHit_set_distance(h, distance);
    BeamWallHit_set_wall_index(h, wall_index);
    BeamWallHit_set_coverage(h, coverage);
    return h;
}

# ================================================================
# BeamPath accessors (manual inline layout)
# ================================================================
fn beam_path_hits(p)           { return load64(p + BP_HITS); }
fn beam_path_final_energy(p, i) { return load64(p + BP_FINAL + i * 8); }
fn beam_path_total_distance(p) { return load64(p + BP_TOTAL); }
fn beam_path_order(p)          { return load64(p + BP_ORDER); }

# ================================================================
# Beam / wall geometry
# ================================================================
# Distance along the beam axis to a wall plane, or BEAM_NONE if the beam
# does not intersect it in front (fewer than 3 vertices, axis parallel to
# the wall, or the plane behind the apex).
#must_use
fn _beam_wall_distance(beam, wall) {
    var verts = Wall_vertices(wall);
    if (vec_len(verts) < 3) { return BEAM_NONE; }
    var n = Wall_normal(wall);
    var d_dot_n = hvec3_dot(beam_direction(beam), n);
    if (f64_lt(f64_abs(d_dot_n), GOONJ_EPSILON) == 1) { return BEAM_NONE; }
    var p0 = vec_get(verts, 0);
    var t = f64_div(hvec3_dot(hvec3_sub(p0, beam_apex(beam)), n), d_dot_n);
    if (f64_lt(t, GOONJ_EPSILON) == 1) { return BEAM_NONE; }
    return t;
}

# ================================================================
# Beam tracing
# ================================================================
# Trace a beam through a wall list, recording wall intersections. At the
# nearest wall the beam is reflected and tracing continues up to
# `max_order` reflections; the beam's energy is reduced per-band at each
# reflection and tracing stops once the strongest band falls below 0.001.
#must_use
fn trace_beam(beam, walls, max_order) {
    var current = _beam_clone(beam);
    var hits = vec_new();
    var last_wall = (0 - 1);
    var nwalls = vec_len(walls);

    var iter = 0;
    var running = 1;
    while (running == 1) {
        if (iter >= max_order) {
            running = 0;
        } else {
            # Find nearest wall intersection along the beam axis.
            var found = 0;
            var best_t = 0;
            var best_idx = 0;
            var i = 0;
            while (i < nwalls) {
                var skip = 0;
                if (last_wall == i) { skip = 1; }
                if (skip == 0) {
                    var t = _beam_wall_distance(current, vec_get(walls, i));
                    if (f64_ge(t, 0) == 1) {
                        if (found == 0) {
                            found = 1;
                            best_t = t;
                            best_idx = i;
                        } else {
                            if (f64_lt(t, best_t) == 1) {
                                best_t = t;
                                best_idx = i;
                            }
                        }
                    }
                }
                i = i + 1;
            }

            if (found == 0) {
                running = 0;
            } else {
                var wall = vec_get(walls, best_idx);
                var t2 = best_t;

                # Coverage = fraction of the beam solid angle intercepted.
                # Wall larger than the footprint -> ~1.0; smaller ->
                # wall_area / beam_footprint_area.
                var footprint_radius = f64_mul(t2, f64_tan(beam_half_angle(current)));
                var warea = wall_area(wall);
                var beam_area = f64_mul(f64_mul(F64_PI, footprint_radius), footprint_radius);
                var coverage = F64_ONE;
                if (f64_gt(beam_area, GOONJ_EPSILON) == 1) {
                    coverage = f64_clamp(f64_div(warea, beam_area), 0, F64_ONE);
                }

                var hit_point = hvec3_add(beam_apex(current),
                hvec3_scale(beam_direction(current), t2));
                vec_push(hits, beam_wall_hit_new(hit_point, t2, best_idx, coverage));

                # Reflect the axis direction specularly about the wall normal.
                var n = Wall_normal(wall);
                var d_dot_n = hvec3_dot(beam_direction(current), n);
                var reflected_dir = hvec3_sub(beam_direction(current),
                hvec3_scale(n, f64_mul(F64_TWO, d_dot_n)));
                var len = hvec3_length(reflected_dir);
                if (f64_gt(len, GOONJ_EPSILON) == 1) {
                    reflected_dir = hvec3_scale(reflected_dir, f64_div(F64_ONE, len));
                } else {
                    reflected_dir = beam_direction(current);
                }

                # Apply per-band absorption; track the strongest band.
                var next = alloc(BEAM_SIZE);
                var mat = Wall_material(wall);
                var max_e = 0;
                var band = 0;
                while (band < NUM_BANDS) {
                    var ne = f64_mul(beam_energy_band(current, band),
                    f64_sub(F64_ONE, am_absorption_band(mat, band)));
                    store64(next + BEAM_ENERGY + band * 8, ne);
                    max_e = f64_max(max_e, ne);
                    band = band + 1;
                }

                if (f64_lt(max_e, BEAM_DEAD) == 1) {
                    running = 0;
                } else {
                    store64(next + BEAM_APEX, hit_point);
                    store64(next + BEAM_DIR, reflected_dir);
                    store64(next + BEAM_HALF, beam_half_angle(current));
                    store64(next + BEAM_PATH, f64_add(beam_path_length(current), t2));
                    store64(next + BEAM_ORDER, beam_order(current) + 1);
                    current = next;
                    last_wall = best_idx;
                }
            }
            iter = iter + 1;
        }
    }

    var path = alloc(BP_SIZE);
    store64(path + BP_HITS, hits);
    store64(path + BP_TOTAL, beam_path_length(current));
    store64(path + BP_ORDER, beam_order(current));
    var fb = 0;
    while (fb < NUM_BANDS) {
        store64(path + BP_FINAL + fb * 8, beam_energy_band(current, fb));
        fb = fb + 1;
    }
    return path;
}

# ================================================================
# Beam set generation
# ================================================================
# A set of beams covering the full sphere from a source, via a Fibonacci
# sphere. `subdivisions` sets resolution: 0 -> 20 beams, 1 -> 80, 2 ->
# 320, capped at 3. Half-angle = pi / sqrt(n).
#must_use
fn generate_beam_set(source, subdivisions) {
    var s = subdivisions;
    if (s > 3) { s = 3; }
    var p = 1;
    var k = 0;
    while (k < s) {
        p = p * 4;
        k = k + 1;
    }
    var n = 20 * p;
    var half_angle = f64_div(F64_PI, f64_sqrt(f64_from(n)));

    var dirs = fibonacci_sphere(n);
    var beams = vec_new();
    var i = 0;
    while (i < n) {
        vec_push(beams, acoustic_beam_new(source, vec_get(dirs, i), half_angle));
        i = i + 1;
    }
    return beams;
}

# --- coupled.cyr ---

# coupled.cyr -- coupled room acoustics: multi-room energy exchange.
#
# Models sound energy flow between two rooms connected by a portal,
# producing characteristic double-slope reverberant decay. Uses a
# statistical energy analysis (SEA) approach with a portal-derived
# coupling coefficient and two coupled decay eigenvalues.
#
# Ports rust-old/src/coupled.rs. f32 -> f64 throughout (hisab is f64-only).
# Rust's `serde` derive is dropped (no serde in Cyrius); the serde
# round-trip test is omitted.
#
# Requires (from the build/test unit): stdlib math/ganita (f64_*, F64_ONE,
# F64_HALF, F64_LN10), impulse.cyr (sabine_rt60), portal.cyr (portal_area),
# propagation.cyr (speed_of_sound), room.cyr (room_geometry_volume_shoebox,
# room_geometry_total_absorption, AcousticRoom_geometry,
# AcousticRoom_temperature_celsius). alloc_init() must have run.

# +inf bit pattern -- degenerate RT60 sentinel from sabine_rt60 (used to
# reject non-finite reverberation times, matching Rust `rt60.is_finite()`).
var COUPLED_POS_INF = 0x7FF0000000000000;   # +inf

# ================================================================
# Structs
# ================================================================
# A pair of acoustically coupled rooms connected by a portal.
# room_a is the source room, room_b the receiving room.
#derive(accessors)
struct CoupledRooms { room_a; room_b; portal; }

# Result of coupled room energy decay analysis. rt60_early/rt60_late are
# the fast/slow decay components (seconds), early_amplitude the relative
# amplitude of the early component (0..1), coupling_strength the coupling
# ratio (0 = isolated, 1 = fully coupled).
#derive(accessors)
struct CoupledDecay { rt60_early; rt60_late; early_amplitude; coupling_strength; }

# ================================================================
# Helpers
# ================================================================
# Finite test: true (1) iff x is neither +/-inf nor NaN. abs(x) < +inf
# holds for finite x, fails for infinities (inf < inf is false) and NaN
# (any NaN compare is false).
#must_use
fn _coupled_is_finite(x) {
    return f64_lt(f64_abs(x), COUPLED_POS_INF);
}

# ================================================================
# Coupled decay
# ================================================================
# Compute the coupled decay characteristics for two rooms joined by a
# portal. Statistical coupling model (Kuttruff): the coupled system
# produces a double-slope decay where the early slope depends on the more
# absorptive room and the late slope on the less absorptive one.
#must_use
fn coupled_room_decay(coupled) {
    var room_a = CoupledRooms_room_a(coupled);
    var room_b = CoupledRooms_room_b(coupled);
    var portal = CoupledRooms_portal(coupled);

    var geom_a = AcousticRoom_geometry(room_a);
    var geom_b = AcousticRoom_geometry(room_b);
    var vol_a = room_geometry_volume_shoebox(geom_a);
    var vol_b = room_geometry_volume_shoebox(geom_b);
    var abs_a = room_geometry_total_absorption(geom_a);
    var abs_b = room_geometry_total_absorption(geom_b);

    var rt60_a = sabine_rt60(vol_a, abs_a);
    var rt60_b = sabine_rt60(vol_b, abs_b);

    # Portal coupling coefficient: kappa = (c * A_portal) / (4 * V)
    var c = speed_of_sound(AcousticRoom_temperature_celsius(room_a));
    var portal_a = portal_area(portal);
    var kappa_a = 0;
    if (f64_gt(vol_a, 0) == 1) {
        kappa_a = f64_div(f64_mul(c, portal_a), f64_mul(f64_from(4), vol_a));
    }
    var kappa_b = 0;
    if (f64_gt(vol_b, 0) == 1) {
        kappa_b = f64_div(f64_mul(c, portal_a), f64_mul(f64_from(4), vol_b));
    }

    # Coupling strength: ratio of portal coupling to room absorption.
    var coupling = 0;
    if (f64_gt(f64_add(abs_a, abs_b), 0) == 1) {
        coupling = f64_clamp(f64_div(f64_mul(c, portal_a), f64_add(abs_a, abs_b)), 0, F64_ONE);
    }

    # Energy decay rates (1/seconds): gamma = 6*ln(10) / RT60 = 13.8155 / RT60.
    var decay_const = f64_mul(f64_from(6), F64_LN10);
    var gamma_a = 0;
    if (f64_gt(rt60_a, 0) == 1) {
        if (_coupled_is_finite(rt60_a) == 1) {
            gamma_a = f64_div(decay_const, rt60_a);
        }
    }
    var gamma_b = 0;
    if (f64_gt(rt60_b, 0) == 1) {
        if (_coupled_is_finite(rt60_b) == 1) {
            gamma_b = f64_div(decay_const, rt60_b);
        }
    }

    # Coupled decay eigenvalues.
    var ga = f64_add(gamma_a, kappa_a);
    var gb = f64_add(gamma_b, kappa_b);
    var sum = f64_add(ga, gb);
    var product = f64_sub(f64_mul(ga, gb), f64_mul(kappa_a, kappa_b));
    var discriminant = f64_max(f64_sub(f64_mul(sum, sum), f64_mul(f64_from(4), product)), 0);
    var sqrt_disc = f64_sqrt(discriminant);

    var lambda1 = f64_mul(f64_add(sum, sqrt_disc), F64_HALF);   # fast decay
    var lambda2 = f64_mul(f64_sub(sum, sqrt_disc), F64_HALF);   # slow decay

    var rt60_early = 0;
    if (f64_gt(lambda1, 0) == 1) {
        rt60_early = f64_div(decay_const, lambda1);
    }
    var rt60_late = 0;
    if (f64_gt(lambda2, 0) == 1) {
        rt60_late = f64_div(decay_const, lambda2);
    }

    # Early component amplitude (energy partition).
    var early_amp = F64_HALF;
    if (f64_gt(lambda1, lambda2) == 1) {
        early_amp = f64_div(f64_sub(f64_sub(lambda1, gamma_b), kappa_b), f64_sub(lambda1, lambda2));
    }

    var out = alloc(sizeof(CoupledDecay));
    CoupledDecay_set_rt60_early(out, rt60_early);
    CoupledDecay_set_rt60_late(out, rt60_late);
    CoupledDecay_set_early_amplitude(out, f64_clamp(early_amp, 0, F64_ONE));
    CoupledDecay_set_coupling_strength(out, coupling);
    return out;
}

# --- wav.cyr ---

# wav.cyr -- WAV export (16-bit PCM, mono + stereo).
#
# Writes an impulse response (or raw sample buffers) as a minimal 44-byte
# RIFF/WAVE file with 16-bit PCM data. No external dependency; the header
# is emitted byte-for-byte.
#
# Ports rust-old/src/wav.rs. The Rust writer took a `&mut impl Write` and
# streamed bytes into it; Cyrius has no such trait, so each writer builds
# a byte buffer in memory (alloc'd to the exact final size) and returns a
# WavBytes handle (data pointer + byte length). f32 -> f64 throughout:
# each sample is a clamped, scaled, truncated i16 written little-endian.
#
# Requires (from the build/test unit): error.cyr (ERR_COMPUTATION),
# impulse.cyr (ImpulseResponse_samples/_sample_rate), stdlib math (f64_*),
# vec, and a live allocator (alloc_init() must have run).

# ================================================================
# WavBytes -- an in-memory WAV file: byte buffer + its length.
# ================================================================
#derive(accessors)
struct WavBytes { data; len; }

#must_use
fn wav_bytes_new(data, len) {
    var w = alloc(sizeof(WavBytes));
    WavBytes_set_data(w, data);
    WavBytes_set_len(w, len);
    return w;
}

# ================================================================
# Little-endian byte emitters (mutate buf at pos, return next pos).
# ================================================================
# Write a u16 as two little-endian bytes: low then high.
fn _wav_le16(buf, pos, v) {
    store8(buf + pos, v & 0xFF);
    store8(buf + pos + 1, (v >> 8) & 0xFF);
    return pos + 2;
}

# Write a u32 as four little-endian bytes.
fn _wav_le32(buf, pos, v) {
    store8(buf + pos, v & 0xFF);
    store8(buf + pos + 1, (v >> 8) & 0xFF);
    store8(buf + pos + 2, (v >> 16) & 0xFF);
    store8(buf + pos + 3, (v >> 24) & 0xFF);
    return pos + 4;
}

# Write four raw ASCII codes (a four-char chunk tag).
fn _wav_str4(buf, pos, a, b, c, d) {
    store8(buf + pos, a);
    store8(buf + pos + 1, b);
    store8(buf + pos + 2, c);
    store8(buf + pos + 3, d);
    return pos + 4;
}

# Emit the 44-byte RIFF/WAVE header into buf at pos; return next pos.
fn _wav_write_header(buf, pos, file_size, num_channels, sample_rate, byte_rate,
block_align, bits_per_sample, data_size) {
    # RIFF chunk descriptor.
    pos = _wav_str4(buf, pos, 82, 73, 70, 70);   # "RIFF"
    pos = _wav_le32(buf, pos, file_size);
    pos = _wav_str4(buf, pos, 87, 65, 86, 69);   # "WAVE"
    # fmt sub-chunk.
    pos = _wav_str4(buf, pos, 102, 109, 116, 32);   # "fmt "
    pos = _wav_le32(buf, pos, 16);   # PCM fmt chunk size
    pos = _wav_le16(buf, pos, 1);    # audio format 1 = PCM
    pos = _wav_le16(buf, pos, num_channels);
    pos = _wav_le32(buf, pos, sample_rate);
    pos = _wav_le32(buf, pos, byte_rate);
    pos = _wav_le16(buf, pos, block_align);
    pos = _wav_le16(buf, pos, bits_per_sample);
    # data sub-chunk.
    pos = _wav_str4(buf, pos, 100, 97, 116, 97);   # "data"
    pos = _wav_le32(buf, pos, data_size);
    return pos;
}

# Convert one f64 sample to a 16-bit PCM value: clamp to [-1, 1], scale by
# 32767, truncate toward zero. Returns a signed i64 in [-32767, 32767].
#must_use
fn _wav_sample_to_pcm(s) {
    var clamped = f64_clamp(s, f64_neg(F64_ONE), F64_ONE);
    var scaled = f64_mul(clamped, f64_from(32767));
    return f64_to(f64_trunc(scaled));
}

# ================================================================
# Public writers
# ================================================================
# Write a mono 16-bit PCM WAV from a sample vec. Returns a WavBytes on
# success or ERR_COMPUTATION if the data would overflow the 32-bit header.
#must_use
fn write_wav_mono(samples, sample_rate) {
    var num_channels = 1;
    var bits_per_sample = 16;
    var byte_rate = sample_rate * num_channels * bits_per_sample / 8;
    var block_align = num_channels * bits_per_sample / 8;
    var n = vec_len(samples);
    var data_size = n * block_align;
    if (data_size > 0xFFFFFFFF) { return ERR_COMPUTATION; }
    var file_size = 36 + data_size;
    var total = 44 + data_size;
    var buf = alloc(total);
    var pos = _wav_write_header(buf, 0, file_size, num_channels, sample_rate, byte_rate,
    block_align, bits_per_sample, data_size);
    var i = 0;
    while (i < n) {
        var pcm = _wav_sample_to_pcm(vec_get(samples, i));
        pos = _wav_le16(buf, pos, pcm & 0xFFFF);
        i = i + 1;
    }
    return wav_bytes_new(buf, total);
}

# Write a stereo 16-bit PCM WAV from equal-length left/right vecs (samples
# interleaved L,R). Returns ERR_COMPUTATION on mismatched lengths or
# 32-bit-header overflow.
#must_use
fn write_wav_stereo(left, right, sample_rate) {
    var nl = vec_len(left);
    var nr = vec_len(right);
    if (nl != nr) { return ERR_COMPUTATION; }
    var num_channels = 2;
    var bits_per_sample = 16;
    var byte_rate = sample_rate * num_channels * bits_per_sample / 8;
    var block_align = num_channels * bits_per_sample / 8;
    var data_size = nl * block_align;
    if (data_size > 0xFFFFFFFF) { return ERR_COMPUTATION; }
    var file_size = 36 + data_size;
    var total = 44 + data_size;
    var buf = alloc(total);
    var pos = _wav_write_header(buf, 0, file_size, num_channels, sample_rate, byte_rate,
    block_align, bits_per_sample, data_size);
    var i = 0;
    while (i < nl) {
        var l_pcm = _wav_sample_to_pcm(vec_get(left, i));
        var r_pcm = _wav_sample_to_pcm(vec_get(right, i));
        pos = _wav_le16(buf, pos, l_pcm & 0xFFFF);
        pos = _wav_le16(buf, pos, r_pcm & 0xFFFF);
        i = i + 1;
    }
    return wav_bytes_new(buf, total);
}

# Write an ImpulseResponse as a mono WAV (its samples at its sample rate).
#must_use
fn impulse_response_to_wav(ir) {
    return write_wav_mono(ImpulseResponse_samples(ir), ImpulseResponse_sample_rate(ir));
}

# --- binaural.cyr ---

# binaural.cyr -- binaural (stereo) impulse-response generation with HRTF
# spatialization.
#
# Combines room acoustics (image-source early reflections) with user-supplied
# Head-Related Transfer Functions (HRTFs) to produce stereo impulse responses
# for headphone spatialization. Each early reflection is direction-matched to
# the nearest measured HRTF pair, whose broadband amplitude convolves the
# left/right HRIRs into the output buffers.
#
# Ports rust-old/src/binaural.rs. f32 -> f64 throughout (hisab is f64-only).
# Rust's serde derives on HrtfPair/HrtfDataset/BinauralIr are dropped (no serde
# in Cyrius; the oracle has no serde round-trip test to port). Vec<f32> sample
# buffers -> stdlib vec (f64 stored directly). The (f32, f32) tuple returned by
# direction_to_angles -> a small BinauralAngles struct. The wav-feature to_wav
# method -> binaural_ir_to_wav returning a WavBytes handle (see wav.cyr).
#
# Requires (from the build/test unit): error.cyr (GOONJ_EPSILON), material.cyr
# (NUM_BANDS), propagation.cyr (speed_of_sound), room.cyr
# (AcousticRoom_temperature_celsius), image_source.cyr
# (compute_early_reflections, early_reflection_*), impulse.cyr (IrConfig_*),
# wav.cyr (write_wav_stereo), stdlib math/ganita (F64_TAU, f64_*) + vec + hisab
# (hvec3_*, HVec3_*). alloc_init() must have run.

# ================================================================
# HrtfPair -- left/right ear impulse responses for one direction.
# ================================================================
#derive(accessors)
struct HrtfPair { azimuth; elevation; left; right; }

# Allocate an HRTF pair: azimuth/elevation (radians) + left/right HRIR vecs.
#must_use
fn hrtf_pair_new(azimuth, elevation, left, right) {
    var p = alloc(sizeof(HrtfPair));
    HrtfPair_set_azimuth(p, azimuth);
    HrtfPair_set_elevation(p, elevation);
    HrtfPair_set_left(p, left);
    HrtfPair_set_right(p, right);
    return p;
}

# ================================================================
# HrtfDataset -- HRTF pairs indexed by direction.
# ================================================================
#derive(accessors)
struct HrtfDataset { pairs; sample_rate; }

# Create a dataset from a collection of pre-loaded HRTF pairs (a vec of
# HrtfPair pointers) plus the HRIR sample rate.
#must_use
fn hrtf_dataset_from_pairs(pairs, sample_rate) {
    var d = alloc(sizeof(HrtfDataset));
    HrtfDataset_set_pairs(d, pairs);
    HrtfDataset_set_sample_rate(d, sample_rate);
    return d;
}

# Squared angular distance between two directions (nearest-neighbor lookup).
# The azimuth delta wraps around TAU so opposite ends of the circle are close.
#must_use
fn binaural_angular_distance(az1, el1, az2, el2) {
    var daz = f64_abs(f64_sub(az1, az2));
    daz = f64_min(daz, f64_sub(F64_TAU, daz));
    var del = f64_abs(f64_sub(el1, el2));
    return f64_add(f64_mul(daz, daz), f64_mul(del, del));
}

# Find the nearest HRTF pair (pointer) for a direction, or 0 if the dataset is
# empty. Ties keep the first pair (Rust's min_by returns the first minimum).
#must_use
fn hrtf_dataset_nearest(dataset, azimuth, elevation) {
    var pairs = HrtfDataset_pairs(dataset);
    var n = vec_len(pairs);
    if (n == 0) { return 0; }
    var best = vec_get(pairs, 0);
    var best_dist = binaural_angular_distance(
    HrtfPair_azimuth(best), HrtfPair_elevation(best), azimuth, elevation);
    var i = 1;
    while (i < n) {
        var cand = vec_get(pairs, i);
        var d = binaural_angular_distance(
        HrtfPair_azimuth(cand), HrtfPair_elevation(cand), azimuth, elevation);
        if (f64_lt(d, best_dist) == 1) {
            best = cand;
            best_dist = d;
        }
        i = i + 1;
    }
    return best;
}

# ================================================================
# BinauralIr -- a binaural (stereo) impulse response.
# ================================================================
#derive(accessors)
struct BinauralIr { left; right; sample_rate; }

# Allocate a binaural IR from left/right sample vecs and a sample rate.
#must_use
fn binaural_ir_new(left, right, sample_rate) {
    var b = alloc(sizeof(BinauralIr));
    BinauralIr_set_left(b, left);
    BinauralIr_set_right(b, right);
    BinauralIr_set_sample_rate(b, sample_rate);
    return b;
}

# Write the binaural IR as a stereo 16-bit PCM WAV (see wav.cyr). Returns a
# WavBytes handle on success or ERR_COMPUTATION on channel-length mismatch or
# 32-bit-header overflow.
#must_use
fn binaural_ir_to_wav(bir) {
    return write_wav_stereo(
    BinauralIr_left(bir), BinauralIr_right(bir), BinauralIr_sample_rate(bir));
}

# ================================================================
# BinauralAngles -- (azimuth, elevation) tuple return.
# ================================================================
#derive(accessors)
struct BinauralAngles { azimuth; elevation; }

#must_use
fn binaural_angles_new(azimuth, elevation) {
    var a = alloc(sizeof(BinauralAngles));
    BinauralAngles_set_azimuth(a, azimuth);
    BinauralAngles_set_elevation(a, elevation);
    return a;
}

# Convert a direction vector to (azimuth, elevation). Azimuth is the angle in
# the XZ plane from +Z (0 = front, positive = right); elevation is the angle
# from the horizontal plane (positive = up).
#must_use
fn binaural_direction_to_angles(dir) {
    var dx = HVec3_x(dir);
    var dy = HVec3_y(dir);
    var dz = HVec3_z(dir);
    var azimuth = f64_atan2(dx, dz);
    var horizontal = f64_sqrt(f64_add(f64_mul(dx, dx), f64_mul(dz, dz)));
    var elevation = f64_atan2(dy, horizontal);
    return binaural_angles_new(azimuth, elevation);
}

# ================================================================
# generate_binaural_ir
# ================================================================
# Generate a binaural (stereo) impulse response for a room. Computes early
# reflections (image-source method), spatializes each reflection with the
# nearest HRTF pair from the dataset, and sums into left/right channels. An
# empty HRTF dataset yields a silent IR.
#must_use
fn generate_binaural_ir(source, listener, room, hrtf, config) {
    var c = speed_of_sound(AcousticRoom_temperature_celsius(room));
    var rate = IrConfig_sample_rate(config);
    var num_samples = f64_to(f64_mul(IrConfig_max_time_seconds(config), f64_from(rate)));

    var pairs = HrtfDataset_pairs(hrtf);
    var hrir_len = 0;
    if (vec_len(pairs) != 0) { hrir_len = vec_len(HrtfPair_left(vec_get(pairs, 0))); }

    var buf_len = num_samples + hrir_len;
    var out_left = vec_new();
    var out_right = vec_new();
    var z = 0;
    while (z < buf_len) {
        vec_push(out_left, 0);
        vec_push(out_right, 0);
        z = z + 1;
    }

    var reflections = compute_early_reflections(source, listener, room, IrConfig_max_order(config), c);
    var nr = vec_len(reflections);
    var ri = 0;
    while (ri < nr) {
        var refl = vec_get(reflections, ri);
        var sample_idx = f64_to(f64_mul(early_reflection_delay_seconds(refl), f64_from(rate)));
        if (sample_idx < num_samples) {
            # Average amplitude across bands for broadband HRTF application.
            var amp_sum = 0;
            var band = 0;
            while (band < NUM_BANDS) {
                amp_sum = f64_add(amp_sum, early_reflection_amplitude_band(refl, band));
                band = band + 1;
            }
            var amp = f64_div(amp_sum, f64_from(NUM_BANDS));
            if (f64_ge(amp, GOONJ_EPSILON) == 1) {
                var angles = binaural_direction_to_angles(early_reflection_direction(refl));
                var pair = hrtf_dataset_nearest(
                hrtf, BinauralAngles_azimuth(angles), BinauralAngles_elevation(angles));
                if (pair != 0) {
                    # Convolve: add the scaled HRIR at the reflection's arrival.
                    var hl_vec = HrtfPair_left(pair);
                    var hr_vec = HrtfPair_right(pair);
                    var conv_len = vec_len(hl_vec);
                    if (vec_len(hr_vec) < conv_len) { conv_len = vec_len(hr_vec); }
                    var i = 0;
                    while (i < conv_len) {
                        var idx = sample_idx + i;
                        if (idx < buf_len) {
                            var hl = vec_get(hl_vec, i);
                            var hr = vec_get(hr_vec, i);
                            vec_set(out_left, idx, f64_add(vec_get(out_left, idx), f64_mul(amp, hl)));
                            vec_set(out_right, idx, f64_add(vec_get(out_right, idx), f64_mul(amp, hr)));
                        }
                        i = i + 1;
                    }
                }
            }
        }
        ri = ri + 1;
    }

    # Trim to requested length.
    vec_truncate(out_left, num_samples);
    vec_truncate(out_right, num_samples);
    return binaural_ir_new(out_left, out_right, rate);
}

# --- dhvani.cyr ---

# dhvani.cyr -- IR handoff for convolution reverb (dhvani consumer API).
#
# A thin convenience wrapper that exposes goonj's impulse-response data in
# the shape dhvani's convolution-reverb engine wants: a broadband
# ImpulseResponse, the per-band MultibandIr, the room volume, and per-band
# RT60 estimates.
#
# Ports rust-old/src/integration/dhvani.rs. f32 -> f64 throughout (hisab is
# f64-only). Rust's `serde` derive on DhvaniIr is dropped (no serde in
# Cyrius); the serde round-trip test is therefore omitted. The
# `Option<MultibandIr>` field becomes a raw pointer slot (non-zero => Some);
# the `[f32; NUM_BANDS]` rt60 array uses manual inline layout. f32::INFINITY
# on the zero-absorption band becomes the +inf bit pattern (DHVANI_POS_INF).
#
# Requires (from the build/test unit): material.cyr (NUM_BANDS,
# am_absorption_band), room.cyr (AcousticRoom_geometry, RoomGeometry_walls,
# Wall_material, wall_area, room_geometry_volume_shoebox), impulse.cyr
# (generate_ir, multiband_ir_to_broadband, sabine_rt60, ImpulseResponse_*),
# stdlib math/ganita + vec + hisab. alloc_init() must have run.

# +inf bit pattern for the zero-absorption RT60 path (f32::INFINITY).
var DHVANI_POS_INF = 0x7FF0000000000000;   # +inf

# DhvaniIr inline layout: ir ptr | multiband ptr | room_volume | rt60[8].
enum DhvaniLayout {
    DH_IR        = 0,
    DH_MULTIBAND = 8,
    DH_VOLUME    = 16,
    DH_RT60      = 24,   # offsets 24..88 (8 f64)
    DH_SIZE      = 88,
}

# ================================================================
# DhvaniIr accessors
# ================================================================
# The broadband impulse response (ImpulseResponse pointer).
#must_use
fn dhvani_ir_ir(d) { return load64(d + DH_IR); }

# The per-band impulse responses (MultibandIr pointer; 0 => None).
#must_use
fn dhvani_ir_multiband(d) { return load64(d + DH_MULTIBAND); }

# 1 if the multiband IR is present (Option::is_some), else 0.
#must_use
fn dhvani_ir_has_multiband(d) {
    if (load64(d + DH_MULTIBAND) == 0) { return 0; }
    return 1;
}

# Room volume in m^3.
#must_use
fn dhvani_ir_room_volume(d) { return load64(d + DH_VOLUME); }

# Per-band RT60 estimate (seconds) at band index 0..NUM_BANDS-1.
#must_use
fn dhvani_ir_rt60_band(d, band) { return load64(d + DH_RT60 + band * 8); }

# ================================================================
# generate_dhvani_ir
# ================================================================
# Generate an IR ready for dhvani consumption. Runs generate_ir for the
# per-band buffers, collapses to a broadband response, records the room
# volume, and estimates per-band RT60 via Sabine with per-band absorption.
# Bands with non-positive total absorption get +inf (anechoic).
#must_use
fn generate_dhvani_ir(source, listener, room, config) {
    var multiband = generate_ir(source, listener, room, config);
    var broadband = multiband_ir_to_broadband(multiband);
    var geom = AcousticRoom_geometry(room);
    var volume = room_geometry_volume_shoebox(geom);

    var d = alloc(DH_SIZE);
    store64(d + DH_IR, broadband);
    store64(d + DH_MULTIBAND, multiband);
    store64(d + DH_VOLUME, volume);

    # Per-band RT60 using Sabine with per-band absorption.
    var walls = RoomGeometry_walls(geom);
    var nw = vec_len(walls);
    var band = 0;
    while (band < NUM_BANDS) {
        var total_abs = 0;
        var i = 0;
        while (i < nw) {
            var w = vec_get(walls, i);
            total_abs = f64_add(total_abs, f64_mul(wall_area(w), am_absorption_band(Wall_material(w), band)));
            i = i + 1;
        }
        var rt = DHVANI_POS_INF;
        if (f64_gt(total_abs, 0) == 1) {
            rt = sabine_rt60(volume, total_abs);
        }
        store64(d + DH_RT60 + band * 8, rt);
        band = band + 1;
    }
    return d;
}

# --- kiran.cyr ---

# kiran.cyr -- integration API for the kiran consumer (real-time occlusion
# queries for game audio).
#
# Ports rust-old/src/integration/kiran.rs. Wraps diffraction/occlusion +
# room geometry into a small query surface. f32 -> f64 throughout (hisab is
# f64-only). Public entry points are prefixed `kiran_` for the flat
# namespace.
#
# The Rust `OcclusionResult` (bool + f32 + [f32; NUM_BANDS]) is a manual
# inline layout: an occluded flag (integer 0/1), the average attenuation dB
# (f64), and the 8 per-band attenuations (8 f64). `OcclusionEngine` wraps an
# AcceleratedRoom. Rust's serde derive on OcclusionResult is dropped (no
# serde in Cyrius); the serde round-trip test is therefore not ported.
#
# Requires (from the build/test unit): stdlib math/ganita (F64_PI, F64_ONE,
# f64_add/div/lt), hisab (hvec3_*), material.cyr (NUM_BANDS, frequency_band),
# room.cyr (acoustic room / geometry accessors, accelerated_room_new),
# diffraction.cyr (is_occluded, edge_diffraction_loss). alloc_init() must
# have run.

# OcclusionResult inline layout: occluded flag | avg atten dB | 8 band dB.
enum KiranResLayout {
    KOR_OCCLUDED = 0,    # integer 0/1
    KOR_ATTEN    = 8,    # f64 average attenuation (dB)
    KOR_FREQ     = 16,   # offsets 16..80 (8 f64 per-band attenuation, dB)
    KOR_SIZE     = 80,
}

# Pre-built occlusion query engine wrapping a BVH-accelerated room.
#derive(accessors)
struct KiranOcclusionEngine { accel; }

# ================================================================
# OcclusionResult accessors
# ================================================================
# Whether direct line-of-sight is blocked (1 = occluded, 0 = clear).
#must_use
fn kiran_occlusion_result_is_occluded(result) {
    return load64(result + KOR_OCCLUDED);
}

# Overall attenuation in dB (0.0 = no attenuation, negative = attenuated).
#must_use
fn kiran_occlusion_result_attenuation_db(result) {
    return load64(result + KOR_ATTEN);
}

# Per-frequency-band attenuation in dB at band index 0..7.
#must_use
fn kiran_occlusion_result_band(result, band) {
    return load64(result + KOR_FREQ + band * 8);
}

# ================================================================
# OcclusionEngine
# ================================================================
# Build an occlusion engine from a room (wraps it in an AcceleratedRoom).
#must_use
fn kiran_occlusion_engine_new(room) {
    var engine = alloc(sizeof(KiranOcclusionEngine));
    KiranOcclusionEngine_set_accel(engine, accelerated_room_new(room));
    return engine;
}

# Access the underlying room.
#must_use
fn kiran_occlusion_engine_room(engine) {
    return AcceleratedRoom_room(KiranOcclusionEngine_accel(engine));
}

# Query occlusion between a source and listener. Returns an OcclusionResult:
# occlusion status plus per-band attenuation. If the path is occluded,
# estimates edge-diffraction loss at each frequency band using a
# representative edge angle of pi/4 (matching the Rust simplified model).
#must_use
fn kiran_occlusion_query(engine, source, listener) {
    var accel = KiranOcclusionEngine_accel(engine);
    var room = AcceleratedRoom_room(accel);
    var walls = RoomGeometry_walls(AcousticRoom_geometry(room));
    var occluded = is_occluded(source, listener, walls);

    var result = alloc(KOR_SIZE);
    store64(result + KOR_OCCLUDED, occluded);

    if (occluded == 0) {
        store64(result + KOR_ATTEN, 0);
        var b0 = 0;
        while (b0 < NUM_BANDS) {
            store64(result + KOR_FREQ + b0 * 8, 0);
            b0 = b0 + 1;
        }
        return result;
    }

    # Estimate diffraction loss per band with a representative edge angle.
    var edge_angle = f64_div(F64_PI, f64_from(4));
    var temperature = AcousticRoom_temperature_celsius(room);
    var sum = 0;
    var b = 0;
    while (b < NUM_BANDS) {
        var loss = edge_diffraction_loss(frequency_band(b), edge_angle, temperature);
        store64(result + KOR_FREQ + b * 8, loss);
        sum = f64_add(sum, loss);
        b = b + 1;
    }
    store64(result + KOR_ATTEN, f64_div(sum, f64_from(NUM_BANDS)));
    return result;
}

# --- soorat.cyr ---

# soorat.cyr -- integration API for the soorat consumer: visualization data
# structures for acoustic analysis (ray paths, pressure maps, room-mode
# patterns for rendering).
#
# Ports rust-old/src/integration/soorat.rs. f32 -> f64. Rust's `serde`
# derive is dropped (no serde in Cyrius). The three visualization structs
# use manual inline layout (fixed `[usize; N]` / `[u32; 3]` arrays become
# store64/load64 slots). `Vec<f32>`/`Vec<RayPath>` become stdlib `vec`
# handles (a pointer stored in one 8-byte slot). `Vec3` -> hisab `HVec3`
# (also a pointer in one slot).
#
# Requires (build/test unit): resonance.cyr (room_mode), hisab, stdlib
# math/ganita (F64_PI, f64_cos/sqrt) and vec (vec_new/push/len/get).
# alloc_init() must have run.

# ================================================================
# Structs (manual inline layout)
# ================================================================
# RayVisualization: source (HVec3) | paths (vec of RayPath).
enum SrvLayout { SRV_SOURCE = 0, SRV_PATHS = 8, SRV_SIZE = 16 }

# PressureMap: values (vec) | dimensions[3] | origin (HVec3) | spacing | freq.
enum SpmLayout { SPM_VALUES = 0, SPM_DIM = 8, SPM_ORIGIN = 32, SPM_SPACING = 40, SPM_FREQ = 48, SPM_SIZE = 56 }

# ModeVisualization: frequency_hz | mode_indices[3] | pattern (vec) |
# pattern_dimensions[2].
enum SmvLayout { SMV_FREQ = 0, SMV_IDX = 8, SMV_PATTERN = 32, SMV_PDIM = 40, SMV_SIZE = 56 }

# ================================================================
# RayVisualization
# ================================================================
# A collection of ray paths for visualization: a source position and the
# traced ray paths (each a RayPath from ray.cyr) with their bounce points.
#must_use
fn soorat_ray_visualization_new(source, paths) {
    var v = alloc(SRV_SIZE);
    store64(v + SRV_SOURCE, source);
    store64(v + SRV_PATHS, paths);
    return v;
}

fn soorat_ray_visualization_source(v) { return load64(v + SRV_SOURCE); }
fn soorat_ray_visualization_paths(v) { return load64(v + SRV_PATHS); }

# ================================================================
# PressureMap
# ================================================================
# A 3D pressure map on a regular grid. `values` is flattened as
# values[z * ny * nx + y * nx + x]; `dimensions` is (nx, ny, nz);
# `origin` is the world-space min corner; `spacing` is grid step (m).
#must_use
fn soorat_pressure_map_new(values, nx, ny, nz, origin, spacing, frequency_hz) {
    var m = alloc(SPM_SIZE);
    store64(m + SPM_VALUES, values);
    store64(m + SPM_DIM + 0 * 8, nx);
    store64(m + SPM_DIM + 1 * 8, ny);
    store64(m + SPM_DIM + 2 * 8, nz);
    store64(m + SPM_ORIGIN, origin);
    store64(m + SPM_SPACING, spacing);
    store64(m + SPM_FREQ, frequency_hz);
    return m;
}

fn soorat_pressure_map_values(m) { return load64(m + SPM_VALUES); }
fn soorat_pressure_map_dimension(m, i) { return load64(m + SPM_DIM + i * 8); }
fn soorat_pressure_map_origin(m) { return load64(m + SPM_ORIGIN); }
fn soorat_pressure_map_spacing(m) { return load64(m + SPM_SPACING); }
fn soorat_pressure_map_frequency_hz(m) { return load64(m + SPM_FREQ); }

# ================================================================
# ModeVisualization
# ================================================================
# Generate a room-mode pattern for a shoebox on the XZ plane at a given
# height. Computes the standing-wave pattern cos(nx·π·x/Lx)·cos(nz·π·z/Lz)
# over a grid_resolution × grid_resolution grid. `mode_indices` is
# [nx, 0, nz]; `frequency_hz` is the combined axial-mode frequency.
#must_use
fn soorat_mode_visualization_for_shoebox(nx, nz, length, width, speed_of_sound, grid_resolution) {
    var freq_x = 0;
    if (f64_gt(length, 0) == 1) { freq_x = room_mode(length, nx, speed_of_sound); }
    var freq_z = 0;
    if (f64_gt(width, 0) == 1) { freq_z = room_mode(width, nz, speed_of_sound); }
    var frequency_hz = f64_sqrt(f64_add(f64_mul(freq_x, freq_x), f64_mul(freq_z, freq_z)));

    var denom_i = grid_resolution - 1;
    if (denom_i < 1) { denom_i = 1; }
    var denom = f64_from(denom_i);

    var pattern = vec_new();
    var iz = 0;
    while (iz < grid_resolution) {
        var ix = 0;
        while (ix < grid_resolution) {
            var x = f64_mul(f64_div(f64_from(ix), denom), length);
            var z = f64_mul(f64_div(f64_from(iz), denom), width);
            var px = f64_cos(f64_div(f64_mul(f64_mul(f64_from(nx), F64_PI), x), length));
            var pz = f64_cos(f64_div(f64_mul(f64_mul(f64_from(nz), F64_PI), z), width));
            vec_push(pattern, f64_mul(px, pz));
            ix = ix + 1;
        }
        iz = iz + 1;
    }

    var m = alloc(SMV_SIZE);
    store64(m + SMV_FREQ, frequency_hz);
    store64(m + SMV_IDX + 0 * 8, nx);
    store64(m + SMV_IDX + 1 * 8, 0);
    store64(m + SMV_IDX + 2 * 8, nz);
    store64(m + SMV_PATTERN, pattern);
    store64(m + SMV_PDIM + 0 * 8, grid_resolution);
    store64(m + SMV_PDIM + 1 * 8, grid_resolution);
    return m;
}

fn soorat_mode_visualization_frequency_hz(m) { return load64(m + SMV_FREQ); }
fn soorat_mode_visualization_mode_index(m, i) { return load64(m + SMV_IDX + i * 8); }
fn soorat_mode_visualization_pattern(m) { return load64(m + SMV_PATTERN); }
fn soorat_mode_visualization_pattern_dimension(m, i) { return load64(m + SMV_PDIM + i * 8); }
