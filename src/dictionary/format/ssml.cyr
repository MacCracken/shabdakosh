# ssml.cyr — SSML <phoneme> tag parse / emit.
#
# Ports rust-old/src/dictionary/format/ssml.rs. Handles the SSML phoneme element
# `<phoneme alphabet="ipa" ph="IPA">word</phoneme>`. Reuses the XML scan helpers
# from pls.cyr (_shbdk_pls_find / _shbdk_pls_extract_attr / _shbdk_pls_ws) and
# xml_escape/unescape + _shbdk_starts_at / _shbdk_fmt_dup from format/mod.cyr.
# Included after src/dictionary/format/pls.cyr.
#
# NAMING: shbdk_/SHBDK_ prefixes (flat namespace).
#
# ShbdkSsmlResult layout (16 bytes): [0]=word(cstr) [8]=phonemes(vec of ordinals).

# Parse an SSML <phoneme> tag into a (word, phonemes) result, or 0 on error
# (not a <phoneme> tag, unsupported alphabet, missing ph, or empty phonemes).
#must_use
fn shbdk_parse_ssml_phoneme(tag): i64 {
    var len = strlen(tag);
    var s = 0;
    while (s < len) {
        if (_shbdk_pls_ws(load8(tag + s)) == 0) { break; }
        s = s + 1;
    }
    if (_shbdk_starts_at(tag, s, "<phoneme") == 0) { return 0; }

    var alpha = _shbdk_pls_extract_attr(tag, "alphabet");
    if (alpha != 0) {
        if (streq(alpha, "ipa") == 0) { return 0; }
    }
    var ph = _shbdk_pls_extract_attr(tag, "ph");
    if (ph == 0) { return 0; }
    var phon = shbdk_parse_ipa_word(ph);
    if (vec_len(phon) == 0) { return 0; }

    # word = text between the first '>' and '</phoneme>'
    var gt = _shbdk_pls_find(tag, s, len, ">");
    if (gt < 0) { return 0; }
    var cs = gt + 1;
    var ce = _shbdk_pls_find(tag, cs, len, "</phoneme>");
    if (ce < 0) { return 0; }
    while (cs < ce) {
        if (_shbdk_pls_ws(load8(tag + cs)) == 0) { break; }
        cs = cs + 1;
    }
    while (ce > cs) {
        if (_shbdk_pls_ws(load8(tag + ce - 1)) == 0) { break; }
        ce = ce - 1;
    }

    var r = alloc(16);
    store64(r + 0, shbdk_xml_unescape(_shbdk_fmt_dup(tag, cs, ce)));
    store64(r + 8, phon);
    return r;
}

# Word (cstr) from a parse_ssml_phoneme result.
#must_use
fn shbdk_ssml_result_word(r): cstring {
    return load64(r + 0);
}

# Phonemes (vec) from a parse_ssml_phoneme result.
#must_use
fn shbdk_ssml_result_phonemes(r): i64 {
    return load64(r + 8);
}

# Emit an SSML <phoneme> tag (IPA alphabet) for a word + phoneme sequence.
#must_use
fn shbdk_to_ssml_phoneme(word, phonemes): cstring {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "<phoneme alphabet=\"ipa\" ph=\"");
    str_builder_add_cstr(sb, shbdk_phonemes_to_ipa(phonemes));
    str_builder_add_cstr(sb, "\">");
    str_builder_add_cstr(sb, shbdk_xml_escape(word));
    str_builder_add_cstr(sb, "</phoneme>");
    return str_data(str_builder_build(sb));
}
