# lexicon.tcyr — tests for src/dictionary/lexicon.cyr
# (ports rust-old/src/dictionary/mod.rs from_lexicon / spanish / hindi / german / sanskrit).

include "lib/hisab.cyr"
include "lib/goonj.cyr"
include "lib/naad.cyr"
include "lib/svara.cyr"
include "lib/varna.cyr"
include "src/error.cyr"
include "src/arpabet.cyr"
include "src/ipa.cyr"
include "src/dictionary/entry.cyr"
include "src/dictionary/_cmudict_data.cyr"
include "src/dictionary/cmudict.cyr"
include "src/dictionary/mod.cyr"
include "src/dictionary/lexicon.cyr"

alloc_init();

# ================================================================
# spanish(): seeded from varna's Swadesh list — language-tagged, non-empty, and
# every entry carries a frequency (from the Swadesh rank).
test_group("spanish Swadesh seed dict");
var es = shbdk_dict_spanish();
assert_streq(shbdk_dict_language(es), "es", "language es");
assert_gt(shbdk_dict_len(es), 0, "has entries");
# "tú" (IPA "tu") parses to phonemes and lands in the dict, lowercased.
var tu = shbdk_dict_lookup_entry(es, "tú");
assert_neq(tu, 0, "'tú' present");
assert_eq(shbdk_pronunciation_has_frequency(shbdk_dict_entry_primary(tu)), 1, "entry has a Swadesh-rank frequency");

# ================================================================
test_group("hindi / german seed dicts");
assert_streq(shbdk_dict_language(shbdk_dict_hindi()), "hi", "hindi language hi");
assert_gt(shbdk_dict_len(shbdk_dict_hindi()), 0, "hindi has entries");
assert_streq(shbdk_dict_language(shbdk_dict_german()), "de", "german language de");
assert_gt(shbdk_dict_len(shbdk_dict_german()), 0, "german has entries");

# ================================================================
# sanskrit(): language-tagged but empty (no Swadesh data in varna).
test_group("sanskrit (empty, language-tagged)");
var sa = shbdk_dict_sanskrit();
assert_streq(shbdk_dict_language(sa), "sa", "language sa");
assert_eq(shbdk_dict_len(sa), 0, "empty");

# ================================================================
# from_lexicon directly over a varna lexicon == the language wrapper.
test_group("from_lexicon direct");
var direct = shbdk_from_lexicon(swadesh_by_code("es"));
assert_streq(shbdk_dict_language(direct), "es", "from_lexicon sets language");
assert_eq(shbdk_dict_len(direct), shbdk_dict_len(es), "same entry count as spanish()");

var rc = assert_summary();
syscall(60, rc);
