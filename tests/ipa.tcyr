# ipa.tcyr — tests for src/ipa.cyr (ports rust-old/src/ipa.rs #[test]s).
# Needs the svara bundle (SVARA_PH_*) + error.cyr (SHABDA_PH_NONE).

include "lib/hisab.cyr"
include "lib/goonj.cyr"
include "lib/naad.cyr"
include "lib/svara.cyr"
include "src/error.cyr"
include "src/ipa.cyr"

alloc_init();

# ================================================================
test_group("vowel mappings");
assert_eq(shabda_ipa_to_phoneme("a"), SVARA_PH_VOWEL_A, "a");
assert_eq(shabda_ipa_to_phoneme("e"), SVARA_PH_VOWEL_E, "e");
assert_eq(shabda_ipa_to_phoneme("i"), SVARA_PH_VOWEL_I, "i");
assert_eq(shabda_ipa_to_phoneme("o"), SVARA_PH_VOWEL_O, "o");
assert_eq(shabda_ipa_to_phoneme("u"), SVARA_PH_VOWEL_U, "u");
assert_eq(shabda_ipa_to_phoneme("ə"), SVARA_PH_VOWEL_SCHWA, "schwa");
assert_eq(shabda_ipa_to_phoneme("ɔ"), SVARA_PH_VOWEL_OPEN_O, "open-o");
assert_eq(shabda_ipa_to_phoneme("æ"), SVARA_PH_VOWEL_ASH, "ash");
assert_eq(shabda_ipa_to_phoneme("ɪ"), SVARA_PH_VOWEL_NEAR_I, "near-i");
assert_eq(shabda_ipa_to_phoneme("ʊ"), SVARA_PH_VOWEL_NEAR_U, "near-u");
assert_eq(shabda_ipa_to_phoneme("ɑ"), SVARA_PH_VOWEL_OPEN_A, "open-a");
assert_eq(shabda_ipa_to_phoneme("ɛ"), SVARA_PH_VOWEL_OPEN_E, "open-e");
assert_eq(shabda_ipa_to_phoneme("ʌ"), SVARA_PH_VOWEL_CUP_V, "cup-v");
assert_eq(shabda_ipa_to_phoneme("ɜ"), SVARA_PH_VOWEL_BIRD, "bird");
assert_eq(shabda_ipa_to_phoneme("ɝ"), SVARA_PH_VOWEL_BIRD, "bird (r-colored alt)");
assert_eq(shabda_ipa_to_phoneme("iː"), SVARA_PH_VOWEL_LONG_I, "long-i");

# ================================================================
test_group("diphthong mappings");
assert_eq(shabda_ipa_to_phoneme("aɪ"), SVARA_PH_DIPH_AI, "aɪ");
assert_eq(shabda_ipa_to_phoneme("aʊ"), SVARA_PH_DIPH_AU, "aʊ");
assert_eq(shabda_ipa_to_phoneme("ɔɪ"), SVARA_PH_DIPH_OI, "ɔɪ");
assert_eq(shabda_ipa_to_phoneme("eɪ"), SVARA_PH_DIPH_EI, "eɪ");
assert_eq(shabda_ipa_to_phoneme("oʊ"), SVARA_PH_DIPH_OU, "oʊ");

# ================================================================
test_group("consonant mappings");
assert_eq(shabda_ipa_to_phoneme("p"), SVARA_PH_PLOSIVE_P, "p");
assert_eq(shabda_ipa_to_phoneme("b"), SVARA_PH_PLOSIVE_B, "b");
assert_eq(shabda_ipa_to_phoneme("t"), SVARA_PH_PLOSIVE_T, "t");
assert_eq(shabda_ipa_to_phoneme("d"), SVARA_PH_PLOSIVE_D, "d");
assert_eq(shabda_ipa_to_phoneme("k"), SVARA_PH_PLOSIVE_K, "k");
assert_eq(shabda_ipa_to_phoneme("ɡ"), SVARA_PH_PLOSIVE_G, "script-g");
assert_eq(shabda_ipa_to_phoneme("g"), SVARA_PH_PLOSIVE_G, "ascii-g alt");
assert_eq(shabda_ipa_to_phoneme("f"), SVARA_PH_FRIC_F, "f");
assert_eq(shabda_ipa_to_phoneme("v"), SVARA_PH_FRIC_V, "v");
assert_eq(shabda_ipa_to_phoneme("s"), SVARA_PH_FRIC_S, "s");
assert_eq(shabda_ipa_to_phoneme("z"), SVARA_PH_FRIC_Z, "z");
assert_eq(shabda_ipa_to_phoneme("ʃ"), SVARA_PH_FRIC_SH, "sh");
assert_eq(shabda_ipa_to_phoneme("ʒ"), SVARA_PH_FRIC_ZH, "zh");
assert_eq(shabda_ipa_to_phoneme("θ"), SVARA_PH_FRIC_TH, "th");
assert_eq(shabda_ipa_to_phoneme("ð"), SVARA_PH_FRIC_DH, "dh");
assert_eq(shabda_ipa_to_phoneme("h"), SVARA_PH_FRIC_H, "h");
assert_eq(shabda_ipa_to_phoneme("m"), SVARA_PH_NASAL_M, "m");
assert_eq(shabda_ipa_to_phoneme("n"), SVARA_PH_NASAL_N, "n");
assert_eq(shabda_ipa_to_phoneme("ŋ"), SVARA_PH_NASAL_NG, "ng");
assert_eq(shabda_ipa_to_phoneme("tʃ"), SVARA_PH_AFFR_CH, "tʃ");
assert_eq(shabda_ipa_to_phoneme("t͡ʃ"), SVARA_PH_AFFR_CH, "tie-bar tʃ");
assert_eq(shabda_ipa_to_phoneme("dʒ"), SVARA_PH_AFFR_J, "dʒ");
assert_eq(shabda_ipa_to_phoneme("d͡ʒ"), SVARA_PH_AFFR_J, "tie-bar dʒ");
assert_eq(shabda_ipa_to_phoneme("ʔ"), SVARA_PH_GLOTTAL_STOP, "glottal stop");
assert_eq(shabda_ipa_to_phoneme("ɾ"), SVARA_PH_TAP_FLAP, "tap");
assert_eq(shabda_ipa_to_phoneme("l"), SVARA_PH_LATERAL_L, "l");
assert_eq(shabda_ipa_to_phoneme("ɹ"), SVARA_PH_APPROX_R, "approx-r");
assert_eq(shabda_ipa_to_phoneme("r"), SVARA_PH_APPROX_R, "ascii-r alt");
assert_eq(shabda_ipa_to_phoneme("w"), SVARA_PH_APPROX_W, "w");
assert_eq(shabda_ipa_to_phoneme("j"), SVARA_PH_APPROX_J, "j");

# ================================================================
test_group("unknown symbol");
assert_eq(shabda_ipa_to_phoneme("X"), SHABDA_PH_NONE, "X unknown");
assert_eq(shabda_ipa_to_phoneme(""), SHABDA_PH_NONE, "empty unknown");

# ================================================================
test_group("parse hɛˈloʊ (strips stress)");
var hello = shabda_parse_ipa_word("hɛˈloʊ");
assert_eq(vec_len(hello), 4, "hello len 4");
assert_eq(vec_get(hello, 0), SVARA_PH_FRIC_H, "hello[0] h");
assert_eq(vec_get(hello, 1), SVARA_PH_VOWEL_OPEN_E, "hello[1] ɛ");
assert_eq(vec_get(hello, 2), SVARA_PH_LATERAL_L, "hello[2] l");
assert_eq(vec_get(hello, 3), SVARA_PH_DIPH_OU, "hello[3] oʊ");

# ================================================================
test_group("parse strips slashes");
var slashed = shabda_parse_ipa_word("/hɛloʊ/");
assert_eq(vec_len(slashed), 4, "slashed len 4");

# ================================================================
test_group("parse affricate (2-char and tie-bar)");
var chip = shabda_parse_ipa_word("tʃɪp");
assert_eq(vec_len(chip), 3, "chip len 3");
assert_eq(vec_get(chip, 0), SVARA_PH_AFFR_CH, "chip[0] tʃ");
assert_eq(vec_get(chip, 1), SVARA_PH_VOWEL_NEAR_I, "chip[1] ɪ");
assert_eq(vec_get(chip, 2), SVARA_PH_PLOSIVE_P, "chip[2] p");
var chip2 = shabda_parse_ipa_word("t͡ʃɪp");
assert_eq(vec_len(chip2), 3, "tie-bar chip len 3");
assert_eq(vec_get(chip2, 0), SVARA_PH_AFFR_CH, "tie-bar chip[0] t͡ʃ");

# ================================================================
test_group("phonemes_to_ipa + roundtrip");
var seq = vec_new();
vec_push(seq, SVARA_PH_FRIC_H);
vec_push(seq, SVARA_PH_VOWEL_OPEN_E);
vec_push(seq, SVARA_PH_LATERAL_L);
vec_push(seq, SVARA_PH_DIPH_OU);
var rendered = shabda_phonemes_to_ipa(seq);
assert_streq(rendered, "hɛloʊ", "phonemes_to_ipa -> hɛloʊ");
var back = shabda_parse_ipa_word(rendered);
assert_eq(vec_len(back), 4, "roundtrip len 4");
assert_eq(vec_get(back, 0), SVARA_PH_FRIC_H, "roundtrip[0]");
assert_eq(vec_get(back, 3), SVARA_PH_DIPH_OU, "roundtrip[3]");

# ================================================================
test_group("phoneme_to_ipa reverse + no-equivalent");
assert_streq(shabda_phoneme_to_ipa(SVARA_PH_VOWEL_SCHWA), "ə", "schwa -> ə");
assert_streq(shabda_phoneme_to_ipa(SVARA_PH_NASAL_NG), "ŋ", "ng -> ŋ");
assert_streq(shabda_phoneme_to_ipa(SVARA_PH_VOWEL_LONG_I), "iː", "long-i -> iː");
assert_streq(shabda_phoneme_to_ipa(SVARA_PH_AFFR_CH), "tʃ", "ch -> tʃ");
assert_eq(shabda_phoneme_to_ipa(SVARA_PH_SILENCE), 0, "silence has no ipa");

var rc = assert_summary();
syscall(60, rc);
