# json.tcyr — tests for src/dictionary/format/json.cyr (PronunciationDict JSON codec).

include "lib/hisab.cyr"
include "lib/goonj.cyr"
include "lib/naad.cyr"
include "lib/svara.cyr"
include "src/error.cyr"
include "src/arpabet.cyr"
include "src/ipa.cyr"
include "src/dictionary/entry.cyr"
include "src/dictionary/_cmudict_data.cyr"
include "src/dictionary/cmudict.cyr"
include "src/dictionary/mod.cyr"
include "src/dictionary/format/mod.cyr"
include "src/dictionary/format/json.cyr"

alloc_init();

fn _v1(a): i64 { var v = vec_new(); vec_push(v, a); return v; }

# ================================================================
test_group("to_json / from_json roundtrip");
var d = shabda_parse_cmudict(";;; @freq=0.5\ncat  K AE1 T\ndog  D AO1 G\n");
shabda_dict_set_language(d, "en");
shabda_dict_insert_user(d, "custom", _v1(SVARA_PH_VOWEL_A));

var json = shabda_to_json(d);
assert_neq(json, 0, "to_json produced output");

var d2 = shabda_from_json(json);
assert_neq(d2, 0, "from_json parsed");
assert_streq(shabda_dict_language(d2), "en", "language preserved");
assert_eq(shabda_dict_len(d2), 2, "2 base entries");
assert_eq(shabda_dict_user_len(d2), 1, "1 user entry");

var catp = shabda_dict_lookup(d2, "cat");
assert_neq(catp, 0, "cat present");
assert_eq(vec_len(catp), 3, "cat 3 phonemes");
assert_eq(vec_get(catp, 0), SVARA_PH_PLOSIVE_K, "cat[0] K");
assert_eq(vec_get(catp, 2), SVARA_PH_PLOSIVE_T, "cat[2] T");

# frequency survives the roundtrip
var ce = shabda_dict_lookup_entry(d2, "cat");
assert_eq(shabda_pronunciation_has_frequency(shabda_dict_entry_primary(ce)), 1, "freq present");
assert_eq(shabda_pronunciation_frequency(shabda_dict_entry_primary(ce)), 0.5, "freq 0.5 preserved");

# user overlay entry survives + takes precedence
assert_eq(vec_get(shabda_dict_lookup(d2, "custom"), 0), SVARA_PH_VOWEL_A, "user 'custom' preserved");

# ================================================================
test_group("region survives roundtrip");
var dr = shabda_parse_cmudict(";;; @region=GA\npat  P AE1 T\n");
var dr2 = shabda_from_json(shabda_to_json(dr));
assert_neq(dr2, 0, "region dict roundtrip");
var pe = shabda_dict_entry_primary(shabda_dict_lookup_entry(dr2, "pat"));
assert_eq(shabda_pronunciation_has_region(pe), 1, "region present");
assert_eq(shabda_pronunciation_region(pe), SHABDA_REGION_GA, "region GA preserved");

# ================================================================
test_group("empty dict + no language");
var de = shabda_dict_new();
var de2 = shabda_from_json(shabda_to_json(de));
assert_neq(de2, 0, "empty dict roundtrip");
assert_eq(shabda_dict_len(de2), 0, "0 entries");
assert_eq(shabda_dict_language(de2), 0, "no language");

# ================================================================
test_group("from_json error");
assert_eq(shabda_from_json("not valid json {{{"), 0, "invalid JSON -> 0");

var rc = assert_summary();
syscall(60, rc);
